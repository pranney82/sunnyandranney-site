---
import Base from '@/layouts/Base.astro';
---

<Base title="Our Team — Sunny & Ranney" description="Meet Peter & Holly Ranney and the team behind Sunny & Ranney — curating beautiful homes and brighter futures for children with special needs.">

  <!-- ═══ HERO ═══ -->
  <section class="team-hero">
    <div class="team-hero__bg" aria-hidden="true"></div>
    <div class="container team-hero__inner">
      <span class="label animate-fade-up">Our Team</span>
      <h1 class="team-hero__title animate-fade-up delay-1">
        The People Behind<br/>
        <span class="team-hero__accent">Every Brighter Day</span>
      </h1>
      <p class="team-hero__sub animate-fade-up delay-2">
        A small team with a big mission — curating beautiful homes while transforming the lives of children with special needs.
      </p>
      <hr class="divider animate-fade-up delay-3" />
      <a href="#founders" class="team-hero__scroll animate-fade-up delay-4" aria-label="Scroll to meet the team">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
      </a>
    </div>
  </section>

  <!-- ═══ FOUNDERS ═══ -->
  <section class="team-founders section" id="founders">
    <div class="container">
      <!-- Holly -->
      <div class="founder-spread reveal">
        <div class="founder-spread__image">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/holly-ranney/w=600,h=720,fit=cover,gravity=face,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/holly-ranney/w=400,h=480,fit=cover,gravity=face,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/holly-ranney/w=600,h=720,fit=cover,gravity=face,q=80,format=auto 600w"
            sizes="(max-width: 767px) 85vw, 420px"
            alt="Holly Ranney, Co-Founder of Sunny & Ranney"
            width="600"
            height="720"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="founder-spread__content">
          <span class="label">Co-Founder</span>
          <h2 class="founder-spread__name">Holly Ranney</h2>
          <p class="founder-spread__bio">
            The heart and soul behind Sunny & Ranney's curation. With an eye for design and a passion for giving back, Holly transforms every corner of the shop into an inspiring space that tells a story.
          </p>
          <p class="founder-spread__bio">
            Her talent for finding one-of-a-kind pieces and styling them into rooms people fall in love with is what sets Sunny & Ranney apart. For Holly, it was never just about furniture — it's about creating spaces that make life feel a little more beautiful.
          </p>
        </div>
      </div>

      <!-- Peter -->
      <div class="founder-spread founder-spread--reversed reveal">
        <div class="founder-spread__image">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/peter-ranney/w=600,h=720,fit=cover,gravity=face,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/peter-ranney/w=400,h=480,fit=cover,gravity=face,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/peter-ranney/w=600,h=720,fit=cover,gravity=face,q=80,format=auto 600w"
            sizes="(max-width: 767px) 85vw, 420px"
            alt="Peter Ranney, Co-Founder of Sunny & Ranney"
            width="600"
            height="720"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="founder-spread__content">
          <span class="label">Co-Founder</span>
          <h2 class="founder-spread__name">Peter Ranney</h2>
          <p class="founder-spread__bio">
            The driving force behind the mission. Peter's vision for Sunshine on a Ranney Day has impacted over 20,000 children — proving that great design and greater purpose go hand in hand.
          </p>
          <p class="founder-spread__bio">
            What started with one room makeover for an 11-year-old boy named Mathew has grown into a movement. Peter brings the same relentless energy to the shop as he does to the nonprofit — because for him, they've always been one and the same.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MISSION INTERLUDE ═══ -->
  <section class="team-mission">
    <div class="container team-mission__inner">
      <div class="team-mission__content reveal">
        <span class="label">Why We Do This</span>
        <h2>More Than a Store</h2>
        <p>
          Every piece we sell, every customer we serve, every room we style — it all goes toward one thing: transforming the bedrooms and living spaces of children with special needs through <strong>Sunshine on a Ranney Day</strong>.
        </p>
        <div class="team-mission__stats">
          <div class="team-mission__stat">
            <span class="team-mission__number" data-count="269">0</span>
            <span class="team-mission__stat-label">Room Makeovers</span>
          </div>
          <div class="team-mission__stat">
            <span class="team-mission__number" data-count="14">0</span>
            <span class="team-mission__stat-label">Years Giving</span>
          </div>
          <div class="team-mission__stat">
            <span class="team-mission__number" data-count="100" data-suffix="%">0</span>
            <span class="team-mission__stat-label">Profits Donated</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE CREW ═══ -->
  <section class="team-crew section">
    <div class="container">
      <div class="team-crew__header reveal">
        <span class="label">The Crew</span>
        <h2>The People Who Make<br/><em>the Magic Happen</em></h2>
      </div>
      <div class="team-crew__grid">
        {[
          { name: 'Staci', role: 'Store Manager', desc: 'Keeps the showroom running like clockwork and ensures every visitor feels at home from the moment they walk in.', image: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team-staci/public' },
          { name: 'BJ', role: 'Team Member', desc: 'A valued member of the Sunny & Ranney family, helping create beautiful spaces and brighter futures every day.', image: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team-bj/public' },
          { name: 'Staci', role: 'AI Shopping Assistant', desc: 'Our tireless digital team member — always ready to help you find the perfect piece, 24/7.', highlight: true, initials: 'ST' },
        ].map((member, idx) => (
          <div class={`crew-card reveal delay-${idx + 1}`}>
            <div class={`crew-card__avatar${member.highlight ? ' crew-card__avatar--ai' : ''}`}>
              {member.image ? (
                <img src={member.image} alt={member.name} loading="lazy" decoding="async" />
              ) : (
                <div class="crew-card__initials">
                  <span>{member.initials}</span>
                  <div class="crew-card__pulse" aria-hidden="true"></div>
                </div>
              )}
            </div>
            <div class="crew-card__info">
              <h3 class="crew-card__name">{member.name}</h3>
              <span class="crew-card__role">{member.role}</span>
              <p class="crew-card__desc">{member.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ VALUES ═══ -->
  <section class="team-values section">
    <div class="container">
      <div class="team-values__header reveal">
        <span class="label">Our Values</span>
        <h2>What Drives Us</h2>
      </div>
      <div class="team-values__grid">
        <div class="value-card reveal">
          <div class="value-card__accent" aria-hidden="true"></div>
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </div>
          <h3>Purpose First</h3>
          <p>Every dollar of profit goes to children with special needs. We don't just sell furniture — we change lives.</p>
        </div>
        <div class="value-card reveal delay-1">
          <div class="value-card__accent" aria-hidden="true"></div>
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <h3>Joy in the Details</h3>
          <p>From hand-picked inventory to white-glove delivery, we obsess over the little things that make a house a home.</p>
        </div>
        <div class="value-card reveal delay-2">
          <div class="value-card__accent" aria-hidden="true"></div>
          <div class="value-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Community</h3>
          <p>We're deeply rooted in Roswell, GA. Our showroom is a gathering place — come for the furniture, stay for the conversation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CLOSING CTA ═══ -->
  <section class="team-cta">
    <div class="container team-cta__inner">
      <div class="team-cta__content reveal">
        <h2>Come See Us</h2>
        <p>Visit us in Roswell, GA and experience the shop for yourself. We'd love to help you find something beautiful — and do something meaningful.</p>
        <div class="team-cta__actions">
          <a href="/shop" class="btn btn--gold" data-astro-prefetch>Shop Now</a>
          <a href="/mission" class="btn btn--outline team-cta__outline" data-astro-prefetch>Our Mission</a>
        </div>
      </div>
    </div>
  </section>

</Base>

<!-- ═══ COUNT-UP ANIMATION ═══ -->
<script>
  function initCountUp() {
    const counters = document.querySelectorAll('[data-count]');
    if (!counters.length) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.count || '0', 10);
        const suffix = el.dataset.suffix || '+';

        if (prefersReducedMotion) {
          el.textContent = target.toLocaleString() + suffix;
          observer.unobserve(el);
          return;
        }

        const duration = 2000;
        const start = performance.now();

        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(eased * target);
          el.textContent = current.toLocaleString() + (progress >= 1 ? suffix : '');
          if (progress < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach((c) => observer.observe(c));
  }

  initCountUp();
  document.addEventListener('astro:after-swap', initCountUp);
</script>

<style>
  /* ─── Hero ──────────────────────────────── */
  .team-hero {
    position: relative;
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
    overflow: hidden;
  }

  .team-hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(75, 149, 180, 0.10) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(255, 212, 0, 0.07) 0%, transparent 45%),
      radial-gradient(ellipse at 50% 0%, rgba(75, 149, 180, 0.05) 0%, transparent 60%),
      var(--color-cream);
    z-index: 0;
  }

  .team-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .team-hero__title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    margin: var(--space-sm) 0;
    line-height: 1.05;
  }

  .team-hero__accent {
    color: var(--color-gold);
    font-style: italic;
    font-weight: 300;
  }

  .team-hero__sub {
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    max-width: 48ch;
    text-align: center;
    margin-bottom: var(--space-md);
    color: var(--color-slate);
  }

  .team-hero__scroll {
    display: inline-block;
    margin-top: var(--space-lg);
    color: var(--color-stone);
    transition: color 0.3s;
  }

  .team-hero__scroll:hover {
    color: var(--color-gold);
  }

  .team-hero__scroll svg {
    animation: float 3s ease-in-out infinite;
  }

  .team-hero__scroll:hover svg {
    animation: none;
    transform: translateY(4px);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ─── Founder Spreads ───────────────────── */
  .team-founders {
    background: var(--color-warm-white);
  }

  .founder-spread {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
    max-width: 1000px;
    margin: 0 auto;
  }

  .founder-spread + .founder-spread {
    margin-top: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .founder-spread {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-2xl);
    }

    .founder-spread--reversed {
      grid-template-columns: 1.15fr 0.85fr;
    }

    .founder-spread--reversed .founder-spread__image {
      order: 2;
    }

    .founder-spread--reversed .founder-spread__content {
      order: 1;
    }
  }

  .founder-spread__image {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(44, 44, 44, 0.12);
  }

  .founder-spread__image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 5 / 6;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .founder-spread__image:hover img {
    transform: scale(1.03);
  }

  .founder-spread__name {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    margin: var(--space-sm) 0 var(--space-md);
    line-height: 1.05;
  }

  .founder-spread__bio {
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }

  .founder-spread__bio:last-child {
    margin-bottom: 0;
  }

  /* ─── Mission Interlude ────────────────── */
  .team-mission {
    background: linear-gradient(160deg, var(--color-cyan) 0%, #3a7d9a 100%);
    padding: var(--space-2xl) 0;
    overflow: hidden;
    position: relative;
  }

  .team-mission::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 212, 0, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .team-mission__inner {
    position: relative;
    z-index: 1;
  }

  .team-mission__content {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .team-mission__content .label {
    color: rgba(255, 255, 255, 0.7);
  }

  .team-mission__content h2 {
    color: var(--color-gold);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    margin: var(--space-sm) 0;
  }

  .team-mission__content p {
    color: rgba(255, 255, 255, 0.9);
    max-width: 55ch;
    margin: 0 auto;
  }

  .team-mission__content p strong {
    color: white;
  }

  .team-mission__stats {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
    flex-wrap: wrap;
  }

  .team-mission__stat {
    text-align: center;
  }

  .team-mission__number {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 600;
    color: white;
    line-height: 1;
    min-width: 3ch;
  }

  .team-mission__stat-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.4rem;
  }

  /* ─── Crew Section ──────────────────────── */
  .team-crew {
    background: var(--color-cream);
  }

  .team-crew__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .team-crew__header .label {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .team-crew__header h2 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    margin-top: var(--space-sm);
    line-height: 1.1;
  }

  .team-crew__header h2 em {
    color: var(--color-gold);
    font-style: italic;
    font-weight: 300;
  }

  .team-crew__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    max-width: 960px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .team-crew__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .crew-card {
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    border-radius: 16px;
    padding: var(--space-xl) var(--space-md) var(--space-lg);
    text-align: center;
    transition: transform var(--duration) var(--ease-out), box-shadow var(--duration);
  }

  .crew-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(44, 44, 44, 0.08);
  }

  .crew-card__avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto var(--space-md);
    background: var(--color-cream-dark);
    transition: transform 0.5s var(--ease-out);
  }

  .crew-card:hover .crew-card__avatar {
    transform: scale(1.08);
  }

  .crew-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .crew-card__avatar--ai {
    background: linear-gradient(135deg, var(--color-gold) 0%, var(--color-gold-light) 100%);
    position: relative;
  }

  .crew-card__initials {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .crew-card__initials span {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--color-charcoal);
    font-weight: 600;
    position: relative;
    z-index: 1;
  }

  .crew-card__pulse {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--color-gold);
    opacity: 0;
    animation: pulse 3s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0; transform: scale(0.9); }
    50% { opacity: 0.4; transform: scale(1.1); }
  }

  .crew-card__name {
    font-size: 1.2rem;
    margin-bottom: 0.2rem;
  }

  .crew-card__role {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .crew-card__desc {
    font-size: 0.88rem;
    color: var(--color-stone);
    line-height: 1.65;
  }

  /* ─── Values ───────────────────────────── */
  .team-values {
    background: var(--color-warm-white);
  }

  .team-values__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .team-values__header .label {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .team-values__header h2 {
    margin-top: var(--space-sm);
  }

  .team-values__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .team-values__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .value-card {
    position: relative;
    text-align: center;
    padding: var(--space-xl) var(--space-lg);
    background: var(--color-cream);
    border-radius: 16px;
    overflow: hidden;
    transition: transform var(--duration) var(--ease-out), box-shadow var(--duration);
  }

  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(44, 44, 44, 0.06);
  }

  .value-card__accent {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 3px;
    background: var(--color-gold);
    border-radius: 0 0 3px 3px;
    transition: width 0.4s var(--ease-out);
  }

  .value-card:hover .value-card__accent {
    width: 80px;
  }

  .value-card__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-warm-white);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
    color: var(--color-gold);
    transition: transform 0.4s var(--ease-out), background 0.4s, color 0.4s;
  }

  .value-card:hover .value-card__icon {
    transform: scale(1.1);
    background: var(--color-gold);
    color: var(--color-charcoal);
  }

  .value-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .value-card p {
    font-size: 0.9rem;
    color: var(--color-stone);
    max-width: 28ch;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ─── Closing CTA ──────────────────────── */
  .team-cta {
    background: var(--color-charcoal);
    padding: var(--space-2xl) 0;
    position: relative;
    overflow: hidden;
  }

  .team-cta::before {
