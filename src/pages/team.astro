---
import Base from '@/layouts/Base.astro';
---

<Base title="Our Team — Sunny & Ranney" description="Meet the people behind Sunny & Ranney — curating beautiful homes and brighter futures for children with special needs.">

  <!-- ═══ HERO ═══ -->
  <section class="team-hero">
    <div class="container team-hero__inner">
      <span class="label animate-fade-up">Our Team</span>
      <h1 class="team-hero__title animate-fade-up delay-1">
        The People Behind<br/>
        <span class="team-hero__accent">Every Brighter Day</span>
      </h1>
      <p class="team-hero__sub animate-fade-up delay-2">
        We're a small team with a big mission — curating beautiful homes while transforming the lives of children with special needs.
      </p>
      <hr class="divider animate-fade-up delay-3" />
    </div>
  </section>

  <!-- ═══ FOUNDERS ═══ -->
  <section class="team-founders section">
    <div class="container">
      <div class="team-founders__grid">
        <div class="team-card team-card--founder reveal">
          <div class="team-card__portrait">
            <div class="team-card__portrait-inner">
              <div class="team-card__initials">S</div>
            </div>
            <div class="team-card__glow"></div>
          </div>
          <div class="team-card__info">
            <h2 class="team-card__name">Sunny</h2>
            <span class="team-card__role">Co-Founder</span>
            <p class="team-card__bio">
              The heart and soul behind Sunny & Ranney's curation. With an eye for design and a passion for giving back, Sunny transforms every corner of the shop into an inspiring space that tells a story.
            </p>
          </div>
        </div>

        <div class="team-card team-card--founder reveal delay-1">
          <div class="team-card__portrait">
            <div class="team-card__portrait-inner">
              <div class="team-card__initials">R</div>
            </div>
            <div class="team-card__glow"></div>
          </div>
          <div class="team-card__info">
            <h2 class="team-card__name">Ranney</h2>
            <span class="team-card__role">Co-Founder</span>
            <p class="team-card__bio">
              The driving force behind the mission. Ranney's vision for Sunshine on a Ranney Day has impacted over 20,000 children — proving that great design and greater purpose go hand in hand.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MISSION INTERLUDE ═══ -->
  <section class="team-mission">
    <div class="container team-mission__inner">
      <div class="team-mission__content reveal">
        <span class="label">Why We Do This</span>
        <h2>More Than a Store</h2>
        <p>
          Every piece we sell, every customer we serve, every room we style — it all goes toward one thing: transforming the bedrooms and living spaces of children with special needs through <strong>Sunshine on a Ranney Day</strong>.
        </p>
        <div class="team-mission__stats">
          <div class="team-mission__stat">
            <span class="team-mission__number">269+</span>
            <span class="team-mission__label">Room Makeovers</span>
          </div>
          <div class="team-mission__stat">
            <span class="team-mission__number">14</span>
            <span class="team-mission__label">Years Giving</span>
          </div>
          <div class="team-mission__stat">
            <span class="team-mission__number">100%</span>
            <span class="team-mission__label">Profits Donated</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TEAM GRID ═══ -->
  <section class="team-grid-section section">
    <div class="container">
      <div class="team-grid-section__header reveal">
        <h2>The Crew</h2>
        <p>The talented people who make the magic happen every day.</p>
      </div>
      <div class="team-grid">
        {[
          { initials: 'SM', name: 'Store Manager', role: 'Operations', desc: 'Keeps the showroom running like clockwork and ensures every visitor feels at home.' },
          { initials: 'DS', name: 'Design Stylist', role: 'Visual Merchandising', desc: 'Creates the stunning vignettes and room setups that bring our products to life.' },
          { initials: 'CC', name: 'Client Concierge', role: 'Customer Experience', desc: 'Your go-to for design advice, special orders, and making sure you find exactly what you need.' },
          { initials: 'ST', name: 'Staci', role: 'AI Shopping Assistant', desc: 'Our tireless digital team member — always ready to help you find the perfect piece, 24/7.', highlight: true },
        ].map((member, idx) => (
          <div class={`team-mini reveal delay-${idx + 1}`}>
            <div class={`team-mini__avatar${member.highlight ? ' team-mini__avatar--gold' : ''}`}>
              <span>{member.initials}</span>
            </div>
            <h3 class="team-mini__name">{member.name}</h3>
            <span class="team-mini__role">{member.role}</span>
            <p class="team-mini__desc">{member.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ VALUES ═══ -->
  <section class="team-values section">
    <div class="container">
      <div class="team-values__header reveal">
        <h2>What Drives Us</h2>
      </div>
      <div class="team-values__grid">
        <div class="team-value reveal">
          <div class="team-value__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </div>
          <h3>Purpose First</h3>
          <p>Every dollar of profit goes to children with special needs. We don't just sell furniture — we change lives.</p>
        </div>
        <div class="team-value reveal delay-1">
          <div class="team-value__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <h3>Joy in the Details</h3>
          <p>From hand-picked inventory to white-glove delivery, we obsess over the little things that make a house a home.</p>
        </div>
        <div class="team-value reveal delay-2">
          <div class="team-value__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Community</h3>
          <p>We're deeply rooted in Roswell, GA. Our showroom is a gathering place — come for the furniture, stay for the conversation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="team-cta">
    <div class="container team-cta__inner">
      <h2 class="reveal">Come Say Hello</h2>
      <p class="reveal delay-1">
        Visit our Roswell showroom and meet the team in person. We'd love to help you find your next favorite piece.
      </p>
      <div class="team-cta__actions reveal delay-2">
        <a href="/shop" class="btn btn--gold">Shop Now</a>
        <a href="https://maps.google.com/?q=109A+Oak+Street+Roswell+GA+30075" target="_blank" rel="noopener noreferrer" class="btn btn--outline">Get Directions</a>
      </div>
      <div class="team-cta__details reveal delay-3">
        <p>109A Oak Street, Roswell, GA 30075</p>
        <p>Tue–Thu 10am–5pm &middot; Fri–Sat 10am–6pm</p>
        <p><a href="tel:6788885140">678.888.5140</a></p>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ─── Hero ──────────────────────────────── */
  .team-hero {
    background:
      radial-gradient(ellipse at 30% 50%, rgba(75, 149, 180, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 20%, rgba(255, 212, 0, 0.05) 0%, transparent 40%),
      var(--color-cream);
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
  }

  .team-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .team-hero__title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    margin: var(--space-sm) 0;
    line-height: 1.05;
  }

  .team-hero__accent {
    color: var(--color-gold);
    font-style: italic;
    font-weight: 300;
  }

  .team-hero__sub {
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    max-width: 48ch;
    text-align: center;
    margin-bottom: var(--space-md);
    color: var(--color-slate);
  }

  /* ─── Founder Cards ────────────────────── */
  .team-founders {
    background: var(--color-warm-white);
  }

  .team-founders__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .team-founders__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .team-card--founder {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .team-card__portrait {
    position: relative;
    width: 180px;
    height: 180px;
  }

  .team-card__portrait-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-cyan), #3a7d9a);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    transition: transform 0.6s var(--ease-out);
  }

  .team-card--founder:hover .team-card__portrait-inner {
    transform: scale(1.05);
  }

  .team-card__initials {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 400;
    color: white;
    line-height: 1;
    opacity: 0.9;
  }

  .team-card__glow {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 212, 0, 0.25) 0%, transparent 70%);
    z-index: 0;
    opacity: 0;
    transition: opacity 0.6s var(--ease-out);
  }

  .team-card--founder:hover .team-card__glow {
    opacity: 1;
  }

  .team-card__name {
    font-size: clamp(1.8rem, 3vw, 2.2rem);
    margin-bottom: 0.25rem;
  }

  .team-card__role {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .team-card__bio {
    font-size: 0.95rem;
    color: var(--color-slate);
    max-width: 36ch;
    margin-top: var(--space-sm);
  }

  /* ─── Mission Interlude ────────────────── */
  .team-mission {
    background: linear-gradient(160deg, var(--color-cyan) 0%, #3a7d9a 100%);
    padding: var(--space-2xl) 0;
    overflow: hidden;
    position: relative;
  }

  .team-mission::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 212, 0, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .team-mission__inner {
    position: relative;
    z-index: 1;
  }

  .team-mission__content {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .team-mission__content .label {
    color: rgba(255, 255, 255, 0.6);
  }

  .team-mission__content h2 {
    color: var(--color-gold);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    margin: var(--space-sm) 0;
  }

  .team-mission__content p {
    color: rgba(255, 255, 255, 0.85);
    max-width: 55ch;
    margin: 0 auto;
  }

  .team-mission__content p strong {
    color: white;
  }

  .team-mission__stats {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
    flex-wrap: wrap;
  }

  .team-mission__stat {
    text-align: center;
  }

  .team-mission__number {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 600;
    color: white;
    line-height: 1;
  }

  .team-mission__label {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.4rem;
  }

  /* ─── Team Grid ────────────────────────── */
  .team-grid-section {
    background: var(--color-cream);
  }

  .team-grid-section__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .team-grid-section__header h2 {
    margin-bottom: 0.5rem;
  }

  .team-grid-section__header p {
    margin: 0 auto;
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .team-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .team-mini {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    transition: transform var(--duration) var(--ease-out), box-shadow var(--duration);
  }

  .team-mini:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(44, 44, 44, 0.08);
  }

  .team-mini__avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-charcoal);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-sm);
    transition: transform 0.4s var(--ease-out);
  }

  .team-mini:hover .team-mini__avatar {
    transform: scale(1.1);
  }

  .team-mini__avatar span {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-cream);
    font-weight: 400;
  }

  .team-mini__avatar--gold {
    background: var(--color-gold);
  }

  .team-mini__avatar--gold span {
    color: var(--color-charcoal);
  }

  .team-mini__name {
    font-size: 1.1rem;
    margin-bottom: 0.2rem;
  }

  .team-mini__role {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .team-mini__desc {
    font-size: 0.88rem;
    color: var(--color-stone);
    line-height: 1.6;
  }

  /* ─── Values ───────────────────────────── */
  .team-values {
    background: var(--color-warm-white);
  }

  .team-values__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .team-values__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .team-values__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .team-value {
    text-align: center;
    padding: var(--space-lg);
  }

  .team-value__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
    color: var(--color-gold);
    transition: transform 0.4s var(--ease-out), background 0.4s;
  }

  .team-value:hover .team-value__icon {
    transform: scale(1.1);
    background: var(--color-gold);
    color: var(--color-charcoal);
  }

  .team-value h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .team-value p {
    font-size: 0.9rem;
    color: var(--color-stone);
    max-width: 30ch;
    margin: 0 auto;
  }

  /* ─── CTA ──────────────────────────────── */
  .team-cta {
    background: var(--color-gold);
    padding: var(--space-2xl) 0;
    text-align: center;
  }

  .team-cta__inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .team-cta h2 {
    color: var(--color-charcoal);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    margin-bottom: var(--space-sm);
  }

  .team-cta > .container > p,
  .team-cta__inner > p {
    color: var(--color-charcoal);
    max-width: 45ch;
    margin: 0 auto;
  }

  .team-cta__actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  .team-cta__actions .btn--gold {
    background: var(--color-charcoal);
    border-color: var(--color-charcoal);
    color: var(--color-cream);
  }

  .team-cta__actions .btn--gold:hover {
    background: white;
    border-color: white;
    color: var(--color-charcoal);
  }

  .team-cta__actions .btn--outline {
    border-color: var(--color-charcoal);
    color: var(--color-charcoal);
  }

  .team-cta__actions .btn--outline:hover {
    background: var(--color-charcoal);
    color: var(--color-gold);
  }

  .team-cta__details {
    margin-top: var(--space-lg);
  }

  .team-cta__details p {
    color: var(--color-charcoal);
    font-size: 0.9rem;
    margin: 0.2rem auto;
    max-width: none;
  }

  .team-cta__details a {
    font-weight: 600;
    color: var(--color-charcoal);
  }
</style>
