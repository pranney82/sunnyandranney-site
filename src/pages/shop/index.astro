---
import Base from '@/layouts/Base.astro';

// At build time, attempt to fetch products from Shopify
let products: any[] = [];
let hasShopify = false;

try {
  const { getProducts } = await import('@/lib/shopify');
  const result = await getProducts(24);
  products = result.products;
  hasShopify = products.length > 0;
} catch (e) {
  // Shopify not configured — will show placeholder UI
  console.log('Shopify API not configured. Showing placeholder shop.');
}
---

<Base
  title="Shop Our Collection"
  description="Browse curated designer furniture, home decor, lighting, and gifts at Sunny & Ranney. Every purchase supports kids with special needs through Sunshine on a Ranney Day."
>
  <!-- ═══ SHOP HERO ═══ -->
  <section class="shop-hero">
    <div class="container">
      <span class="label animate-fade-up">Shop</span>
      <h1 class="animate-fade-up delay-1">The Collection</h1>
      <p class="shop-hero__subtitle animate-fade-up delay-2">
        Every piece you choose helps transform the life of a child.
      </p>
    </div>
  </section>

  <!-- ═══ TOOLBAR ═══ -->
  <section class="filters-bar">
    <div class="container">
      <div class="toolbar">
        <!-- Categories -->
        <div class="toolbar__categories">
          <button class="filter-btn filter-btn--active" data-filter="all">All</button>
          <button class="filter-btn" data-filter="furniture">Furniture</button>
          <button class="filter-btn" data-filter="decor">Decor</button>
          <button class="filter-btn" data-filter="lighting">Lighting</button>
          <button class="filter-btn" data-filter="gifts">Gifts</button>
          <button class="filter-btn" data-filter="kitchenware">Kitchenware</button>
        </div>
        <!-- Sort + View controls -->
        <div class="toolbar__controls">
          <span class="toolbar__count" id="product-count"></span>
          <select class="toolbar__sort" id="sort-select" aria-label="Sort products">
            <option value="best-selling">Best Selling</option>
            <option value="price-asc">Price: Low → High</option>
            <option value="price-desc">Price: High → Low</option>
            <option value="title-asc">A → Z</option>
            <option value="newest">Newest</option>
          </select>
          <div class="toolbar__views">
            <button class="toolbar__view toolbar__view--active" data-view="grid" aria-label="Grid view">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="0" width="7" height="7" rx="1"/><rect x="9" y="0" width="7" height="7" rx="1"/><rect x="0" y="9" width="7" height="7" rx="1"/><rect x="9" y="9" width="7" height="7" rx="1"/></svg>
            </button>
            <button class="toolbar__view" data-view="list" aria-label="List view">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="0" width="16" height="3" rx="1"/><rect x="0" y="4.5" width="16" height="3" rx="1"/><rect x="0" y="9" width="16" height="3" rx="1"/><rect x="0" y="13" width="16" height="3" rx="1"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PRODUCTS GRID ═══ -->
  <section class="shop-grid-section section">
    <div class="container">
      {hasShopify ? (
        <div class="product-grid" id="shop-grid">
          {products.map((product) => {
            const image = product.images.edges[0]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            const isOnSale = compareAt && parseFloat(compareAt.amount) > parseFloat(price.amount);
            const firstVariant = product.variants.edges[0]?.node;

            return (
              <div class="product-card"
                data-type={product.productType.toLowerCase()}
                data-price={parseFloat(price.amount)}
                data-title={product.title}
                data-handle={product.handle}
              >
                {isOnSale && <span class="product-card__badge">Sale</span>}
                {!isOnSale && !product.availableForSale && <span class="product-card__badge product-card__badge--sold">Sold Out</span>}
                <a href={`/shop/${product.handle}`} class="product-card__image">
                  {image ? (
                    <img
                      src={image.url}
                      alt={image.altText || product.title}
                      width={image.width}
                      height={image.height}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="product-card__image-ph">{product.productType || 'Product'}</div>
                  )}
                  <!-- Quick View overlay -->
                  <div class="product-card__overlay">
                    <button class="product-card__quick-view" data-handle={product.handle}>Quick View</button>
                  </div>
                </a>
                <div class="product-card__info">
                  {product.productType && <span class="product-card__type">{product.productType}</span>}
                  <a href={`/shop/${product.handle}`} class="product-card__title">{product.title}</a>
                  <div class="product-card__pricing">
                    <span class="product-card__price">
                      ${parseFloat(price.amount).toFixed(2)}
                    </span>
                    {isOnSale && (
                      <span class="product-card__price--compare">
                        ${parseFloat(compareAt.amount).toFixed(2)}
                      </span>
                    )}
                  </div>
                  {product.availableForSale && firstVariant && (
                    <button class="product-card__add-btn"
                      data-variant-id={firstVariant.id}
                      data-title={product.title}
                      data-price={parseFloat(price.amount)}
                      data-image={image?.url || ''}
                      data-handle={product.handle}
                      data-variant-title={firstVariant.title}
                    >
                      Add to Cart
                    </button>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <!-- Placeholder: shown when Shopify API is not connected -->
        <div class="shop-placeholder reveal">
          <div class="shop-placeholder__icon">🛍️</div>
          <h3>Connect Your Shopify Store</h3>
          <p>
            Products will appear here once you connect your Shopify Storefront API.
            Add your credentials to the <code>.env</code> file to get started.
          </p>
          <div class="shop-placeholder__steps">
            <div class="shop-placeholder__step">
              <span class="shop-placeholder__step-num">1</span>
              <span>Go to Shopify Admin → Settings → Apps → Develop apps</span>
            </div>
            <div class="shop-placeholder__step">
              <span class="shop-placeholder__step-num">2</span>
              <span>Create an app with Storefront API access</span>
            </div>
            <div class="shop-placeholder__step">
              <span class="shop-placeholder__step-num">3</span>
              <span>Copy the Storefront API token to your <code>.env</code> file</span>
            </div>
          </div>
          <p style="margin-top: 1.5rem;">
            <a href="https://sunnyandranney.myshopify.com" target="_blank" rel="noopener noreferrer" class="btn btn--primary">
              Visit Your Current Shopify Store →
            </a>
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ MISSION REMINDER ═══ -->
  <section class="mission-reminder">
    <div class="container">
      <p class="mission-reminder__text reveal">
        <span class="mission-reminder__sun">☀️</span>
        Every purchase you make here directly supports <strong>Sunshine on a Ranney Day</strong>
        — funding home makeovers for kids with special needs.
        <a href="/charity">Learn more →</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .shop-hero {
    padding: var(--space-2xl) 0 var(--space-lg);
    text-align: center;
    background:
      radial-gradient(ellipse at 50% 80%, var(--color-sage-light) 0%, transparent 50%),
      var(--color-cream);
  }

  .shop-hero h1 { margin: 0.5rem 0; }

  .shop-hero__subtitle {
    font-size: 1.1rem;
    color: var(--color-slate);
    max-width: 40ch;
    margin: 0 auto;
  }

  /* ─── Toolbar ─────────────────────────── */
  .filters-bar {
    border-bottom: 1px solid var(--color-cream-dark);
    padding: 0.75rem 0;
    position: sticky;
    top: var(--nav-height);
    background: rgba(250, 247, 242, 0.95);
    backdrop-filter: blur(8px);
    z-index: 50;
  }

  .toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .toolbar__categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .filter-btn {
    padding: 0.4rem 1rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-slate);
    border: 1.5px solid transparent;
    border-radius: 100px;
    transition: all 0.2s;
    background: transparent;
  }

  .filter-btn:hover { color: var(--color-charcoal); background: var(--color-cream-dark); }
  .filter-btn--active {
    color: var(--color-charcoal);
    background: var(--color-charcoal);
    color: var(--color-cream);
  }

  .toolbar__controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .toolbar__count {
    font-size: 0.78rem;
    color: var(--color-stone);
    white-space: nowrap;
  }

  .toolbar__sort {
    font-family: var(--font-body);
    font-size: 0.78rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-cream-dark);
    border-radius: 6px;
    background: var(--color-warm-white);
    color: var(--color-charcoal);
    cursor: pointer;
    outline: none;
  }
  .toolbar__sort:focus { border-color: var(--color-gold); }

  .toolbar__views {
    display: flex;
    gap: 0.25rem;
  }

  .toolbar__view {
    padding: 0.4rem;
    color: var(--color-stone);
    border-radius: 4px;
    transition: all 0.2s;
  }
  .toolbar__view:hover { color: var(--color-charcoal); }
  .toolbar__view--active { color: var(--color-charcoal); background: var(--color-cream-dark); }

  /* ─── Grid / List views ───────────────── */
  .shop-grid-section { min-height: 400px; }

  #shop-grid.view-list {
    grid-template-columns: 1fr !important;
  }

  #shop-grid.view-list .product-card {
    flex-direction: row;
    max-height: 200px;
  }

  #shop-grid.view-list .product-card__image {
    aspect-ratio: 1;
    max-width: 200px;
    flex-shrink: 0;
  }

  #shop-grid.view-list .product-card__info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-md) var(--space-lg);
  }

  /* ─── Enhanced Product Card ───────────── */
  .product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-warm-white);
    transition: transform var(--duration) var(--ease-out),
                box-shadow var(--duration) var(--ease-out);
    overflow: hidden;
  }

  .product-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 44, 44, 0.0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s;
    pointer-events: none;
  }

  .product-card:hover .product-card__overlay {
    background: rgba(44, 44, 44, 0.25);
    pointer-events: all;
  }

  .product-card__quick-view {
    padding: 0.6rem 1.5rem;
    background: white;
    color: var(--color-charcoal);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 4px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s, transform 0.3s;
    cursor: pointer;
  }

  .product-card:hover .product-card__quick-view {
    opacity: 1;
    transform: translateY(0);
  }

  .product-card__type {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    display: block;
    margin-bottom: 0.2rem;
  }

  .product-card__pricing {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .product-card__badge--sold {
    background: var(--color-stone) !important;
  }

  .product-card__add-btn {
    margin-top: 0.75rem;
    width: 100%;
    padding: 0.6rem 1rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .product-card__add-btn:hover {
    background: var(--color-gold);
    color: var(--color-charcoal);
  }

  /* ─── Placeholder ─────────────────────── */
  .shop-placeholder {
    text-align: center;
    padding: var(--space-2xl) var(--space-md);
    max-width: 600px;
    margin: 0 auto;
  }

  .shop-placeholder__icon { font-size: 3rem; margin-bottom: var(--space-sm); }
  .shop-placeholder h3 { margin-bottom: 0.75rem; }

  .shop-placeholder code {
    background: var(--color-cream-dark);
    padding: 0.15rem 0.5rem;
    font-size: 0.85em;
    border-radius: 3px;
  }

  .shop-placeholder__steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: var(--space-md);
    text-align: left;
    max-width: 450px;
    margin-left: auto;
    margin-right: auto;
  }

  .shop-placeholder__step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  .shop-placeholder__step-num {
    width: 28px;
    height: 28px;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ─── Mission reminder ────────────────── */
  .mission-reminder {
    background: var(--color-gold-soft);
    padding: var(--space-md) 0;
  }

  .mission-reminder__text {
    text-align: center;
    font-size: 0.95rem;
    color: var(--color-charcoal);
    max-width: none;
  }

  .mission-reminder__text a {
    color: var(--color-gold);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .mission-reminder__sun { margin-right: 0.25rem; }

  @media (max-width: 768px) {
    .toolbar { flex-direction: column; align-items: stretch; }
    .toolbar__controls { justify-content: space-between; }
  }
</style>

<script>
  // ─── Enhanced Shop Page Logic ───────────────────────────
  const grid = document.getElementById('shop-grid');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const sortSelect = document.getElementById('sort-select');
  const viewBtns = document.querySelectorAll('.toolbar__view');
  const countEl = document.getElementById('product-count');

  let activeFilter = 'all';

  function getCards() {
    return Array.from(grid?.querySelectorAll('.product-card') || []);
  }

  function getVisibleCards() {
    return getCards().filter(c => c.style.display !== 'none');
  }

  // ─── Category Filter ───────────────────
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeFilter = btn.getAttribute('data-filter') || 'all';
      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      applyFilter();
    });
  });

  function applyFilter() {
    const cards = getCards();
    let visibleCount = 0;
    cards.forEach(card => {
      const type = card.getAttribute('data-type') || '';
      const show = activeFilter === 'all' || type.includes(activeFilter);
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });
    if (countEl) countEl.textContent = `${visibleCount} product${visibleCount !== 1 ? 's' : ''}`;
  }

  // ─── Sort ──────────────────────────────
  sortSelect?.addEventListener('change', () => {
    const cards = getCards();
    const sortBy = sortSelect.value;

    cards.sort((a, b) => {
      const priceA = parseFloat(a.dataset.price) || 0;
      const priceB = parseFloat(b.dataset.price) || 0;
      const titleA = (a.dataset.title || '').toLowerCase();
      const titleB = (b.dataset.title || '').toLowerCase();

      switch (sortBy) {
        case 'price-asc': return priceA - priceB;
        case 'price-desc': return priceB - priceA;
        case 'title-asc': return titleA.localeCompare(titleB);
        case 'newest': return -1; // preserve original (newest first from Shopify)
        default: return 0;
      }
    });

    cards.forEach(card => grid?.appendChild(card));
  });

  // ─── View Toggle ───────────────────────
  viewBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      viewBtns.forEach(b => b.classList.remove('toolbar__view--active'));
      btn.classList.add('toolbar__view--active');
      const view = btn.dataset.view;
      if (view === 'list') {
        grid?.classList.add('view-list');
      } else {
        grid?.classList.remove('view-list');
      }
    });
  });

  // ─── Add to Cart from Grid ─────────────
  grid?.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest('.product-card__add-btn');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const { variantId, title, price, image, handle, variantTitle } = (btn as HTMLElement).dataset;
    if (!variantId || !title || !price) return;

    // Use the global addToCart from CartDrawer
    window.addToCart?.({
      variantId,
      title,
      price: parseFloat(price),
      image: image || '',
      handle: handle || '',
      variantTitle: variantTitle || '',
    });

    // Button feedback
    const orig = btn.textContent;
    btn.textContent = '✓ Added';
    btn.disabled = true;
    setTimeout(() => {
      btn.textContent = orig;
      btn.disabled = false;
    }, 1500);
  });

  // ─── Quick View (opens product page for now) ──
  grid?.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest('.product-card__quick-view');
    if (!btn) return;
    e.preventDefault();
    const handle = (btn as HTMLElement).dataset.handle;
    if (handle) window.location.href = `/shop/${handle}`;
  });

  // ─── URL params ────────────────────────
  const params = new URLSearchParams(window.location.search);
  const category = params.get('category');
  if (category) {
    const btn = document.querySelector(`[data-filter="${category}"]`) as HTMLElement;
    if (btn) btn.click();
  }

  const searchQuery = params.get('q');
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    getCards().forEach(card => {
      const title = (card.dataset.title || '').toLowerCase();
      const type = (card.getAttribute('data-type') || '').toLowerCase();
      const match = title.includes(q) || type.includes(q);
      card.style.display = match ? '' : 'none';
    });
  }

  // Initial count
  applyFilter();
</script>
