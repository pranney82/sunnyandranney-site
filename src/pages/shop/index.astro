---
import Base from '@/layouts/Base.astro';
import { cfImage, cfSrcset, SIZES } from '@/lib/images';
import type { CollectionSetting } from '@/lib/settings';
import { getCollectionsStatic } from '@/lib/settings';

// Fully static — rebuilt via deploy hook when products/settings change
export const prerender = true;

// Fetch ALL products from enabled collections at build time
let products: any[] = [];
let hasShopify = false;

// Track which collections each product belongs to (handle → collection handles)
const productCollections: Record<string, string[]> = {};
// Track collection handle → title for the hero
const collectionTitles: Record<string, string> = {};

try {
  const shopify = await import('@/lib/shopify');
  const collectionSettings = await getCollectionsStatic();
  const enabledHandles = collectionSettings
    ?.filter(c => c.enabled)
    .sort((a, b) => a.order - b.order)
    .map(c => c.handle) ?? [];

  if (enabledHandles.length > 0) {
    const results = await Promise.all(
      enabledHandles.map(handle => shopify.getCollectionByHandle(handle, 100))
    );

    const seen = new Set<string>();
    for (const collection of results) {
      if (!collection) continue;
      collectionTitles[collection.handle] = collection.title;
      for (const product of collection.products) {
        if (!productCollections[product.handle]) {
          productCollections[product.handle] = [];
        }
        productCollections[product.handle].push(collection.handle);
        if (!seen.has(product.id)) {
          seen.add(product.id);
          products.push(product);
        }
      }
    }
  }

  hasShopify = products.length > 0;
} catch (e) {
  console.error('[shop] Shopify fetch failed:', e instanceof Error ? e.message : e);
  console.error('[shop] Token present:', !!import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN);
  console.error('[shop] Domain:', import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN || '(missing, using default)');
}

// Build category pills from actual product types (data-driven, not hardcoded)
const productTypeCounts: Record<string, number> = {};
for (const p of products) {
  const t = (p.productType || '').toLowerCase();
  if (t) productTypeCounts[t] = (productTypeCounts[t] || 0) + 1;
}
// Sort by count descending, take top types
const productTypes = Object.entries(productTypeCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([type, count]) => ({ type, count, label: type.charAt(0).toUpperCase() + type.slice(1) }));

// Preload the first product image as LCP candidate
const lcpUrl = products[0]?.images?.edges[0]?.node?.url;
const lcpImage = lcpUrl ? cfImage(lcpUrl, { width: 600 }) : undefined;
const lcpImageSrcset = lcpUrl ? cfSrcset(lcpUrl, [200, 400, 600]) : undefined;
const lcpImageSizes = SIZES.gridCard;

// Price formatter — drops .00 on whole numbers ($800 not $800.00)
function fmt(amount: number): string {
  return amount % 1 === 0 ? `$${amount.toLocaleString()}` : `$${amount.toFixed(2)}`;
}

// ItemList structured data for SEO (top 1% shops have this)
const itemListSchema = hasShopify ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Shop All Products',
  numberOfItems: products.length,
  itemListElement: products.slice(0, 50).map((p: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.title,
      url: `https://sunnyandranney.com/shop/${p.handle}`,
      image: p.images.edges[0]?.node?.url || '',
      offers: {
        '@type': 'Offer',
        price: parseFloat(p.priceRange.minVariantPrice.amount).toFixed(2),
        priceCurrency: p.priceRange.minVariantPrice.currencyCode,
        availability: p.availableForSale
          ? 'https://schema.org/InStock'
          : 'https://schema.org/OutOfStock',
      },
    },
  })),
} : null;
---

<Base
  title="Shop Our Collection"
  description="Browse curated designer furniture, home decor, lighting, and gifts at Sunny & Ranney. Every purchase supports kids with special needs through Sunshine on a Ranney Day."
  lcpImage={lcpImage}
  lcpImageSrcset={lcpImageSrcset}
  lcpImageSizes={lcpImageSizes}
>
  {/* Collection titles map for client-side filtering */}
  <script is:inline define:vars={{ collectionTitles }}>
    window.__collectionTitles = collectionTitles;
  </script>
  {/* ItemList structured data for rich results */}
  {itemListSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  )}
  <!-- ═══ SHOP HERO ═══ -->
  <section class="shop-hero">
    <div class="container shop-hero__inner">
      <div class="shop-hero__text">
        <h1 class="shop-hero__title animate-fade-up" id="shop-title">The Collection</h1>
        <a href="/shop" class="shop-hero__clear animate-fade-up delay-1" id="shop-clear-collection" style="display:none;">← All Products</a>
      </div>
      <p class="shop-hero__sub animate-fade-up delay-1">Beautiful furniture & decor — 100% of profits fund home makeovers for kids with special needs</p>
    </div>
  </section>

  <!-- ═══ TOOLBAR ═══ -->
  <section class="filters-bar">
    <div class="container">
      <div class="toolbar__row">
        <div class="toolbar__categories">
          <button class="filter-btn filter-btn--active" data-filter="all">All <span class="filter-btn__count" data-count-for="all">{products.length}</span></button>
          {productTypes.map(({ type, count, label }) => (
            <button class="filter-btn" data-filter={type}>{label} <span class="filter-btn__count" data-count-for={type}>{count}</span></button>
          ))}
        </div>
        <div class="toolbar__actions">
          <span class="toolbar__count" id="product-count"></span>
          <button class="toolbar__filter-toggle" id="filter-toggle" aria-expanded="false" aria-controls="filter-panel">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <line x1="1" y1="4" x2="15" y2="4"/><line x1="3" y1="8" x2="13" y2="8"/><line x1="5" y1="12" x2="11" y2="12"/>
            </svg>
            <span class="filter-toggle__text">Filter & Sort</span>
            <span class="filter-toggle__badge" id="filter-badge" style="display:none;">0</span>
          </button>
        </div>
      </div>

      <!-- Panel: top-down dropdown -->
      <div class="toolbar__panel" id="filter-panel" hidden>
        <div class="toolbar__panel-inner">
          <!-- Sort -->
          <div class="toolbar__panel-group">
            <label class="toolbar__panel-label" for="sort-select">Sort by</label>
            <select class="toolbar__sort" id="sort-select" aria-label="Sort products">
              <option value="best-selling">Best Selling</option>
              <option value="price-asc">Price: Low to High</option>
              <option value="price-desc">Price: High to Low</option>
              <option value="title-asc">A to Z</option>
              <option value="newest">Newest</option>
            </select>
          </div>
          <!-- Price -->
          <div class="toolbar__panel-group">
            <label class="toolbar__panel-label">Price range</label>
            <div class="toolbar__price-inputs">
              <input type="number" id="price-min" placeholder="Min" min="0" step="1" aria-label="Minimum price" />
              <span class="toolbar__price-dash">–</span>
              <input type="number" id="price-max" placeholder="Max" min="0" step="1" aria-label="Maximum price" />
              <button class="toolbar__price-go" id="price-go" aria-label="Apply price filter">Go</button>
            </div>
          </div>
          <!-- View -->
          <div class="toolbar__panel-group">
            <label class="toolbar__panel-label">View</label>
            <div class="toolbar__views">
              <button class="toolbar__view toolbar__view--active" data-view="grid" aria-label="Grid view">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="0" width="7" height="7" rx="1"/><rect x="9" y="0" width="7" height="7" rx="1"/><rect x="0" y="9" width="7" height="7" rx="1"/><rect x="9" y="9" width="7" height="7" rx="1"/></svg>
              </button>
              <button class="toolbar__view" data-view="list" aria-label="List view">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="0" width="16" height="3" rx="1"/><rect x="0" y="4.5" width="16" height="3" rx="1"/><rect x="0" y="9" width="16" height="3" rx="1"/><rect x="0" y="13" width="16" height="3" rx="1"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Active filter chips -->
      <div class="filter-chips" id="filter-chips" style="display:none;">
        <div class="filter-chips__list" id="filter-chips-list"></div>
        <button class="filter-chips__clear" id="filter-chips-clear">Clear All</button>
      </div>

      <!-- Active search banner -->
      <div class="search-banner" id="search-banner" style="display:none;">
        <span id="search-banner-text"></span>
        <button class="search-banner__clear" id="search-clear">Clear search</button>
      </div>
    </div>
  </section>

  <!-- ═══ PRODUCTS GRID ═══ -->
  <section class="shop-grid-section section">
    <div class="container">
      {hasShopify ? (
        <>
          <div class="product-grid" id="shop-grid">
            {products.map((product, idx) => {
              const image = product.images.edges[0]?.node;
              const image2 = product.images.edges[1]?.node;
              const price = product.priceRange.minVariantPrice;
              const compareAt = product.compareAtPriceRange?.minVariantPrice;
              const isOnSale = compareAt && parseFloat(compareAt.amount) > parseFloat(price.amount);
              const firstVariant = product.variants.edges[0]?.node;
              const allImages = product.images.edges.map((e: any) => e.node);
              const allVariants = product.variants.edges.map((e: any) => e.node);

              return (
                <>
                {idx === 9 && (
                  <div class="grid-editorial">
                    <div class="grid-editorial__inner">
                      <span class="grid-editorial__label">Our Mission</span>
                      <p class="grid-editorial__text">
                        Every purchase transforms a child's room. 100% of profits fund
                        <strong> Sunshine on a Ranney Day</strong> home makeovers.
                      </p>
                      <a href="/about" class="grid-editorial__link">Learn about our mission</a>
                    </div>
                  </div>
                )}
                <div class="product-card"
                  data-type={product.productType.toLowerCase()}
                  data-price={parseFloat(price.amount)}
                  data-title={product.title}
                  data-handle={product.handle}
                  data-tags={product.tags?.join(',').toLowerCase() || ''}
                  data-collections={(productCollections[product.handle] || []).join(',')}
                  data-description={product.description?.toLowerCase().slice(0, 200) || ''}
                  data-idx={idx}
                  style={idx >= 24 ? 'display:none;' : ''}
                  data-page={Math.floor(idx / 24)}
                >
                  {isOnSale && <span class="product-card__badge">Sale</span>}
                  {!isOnSale && !product.availableForSale && <span class="product-card__badge product-card__badge--sold">Sold Out</span>}

                  {/* Wishlist heart */}
                  <button class="product-card__wishlist" data-handle={product.handle} aria-label="Add to wishlist">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  </button>

                  <div class="product-card__image-container">
                    <a href={`/shop/${product.handle}`} class="product-card__image" aria-hidden="true" tabindex="-1">
                      {image ? (
                        <>
                          <img
                            src={cfImage(image.url, { width: 600 })}
                            srcset={cfSrcset(image.url, [200, 400, 600])}
                            sizes={SIZES.gridCard}
                            alt={image.altText || product.title}
                            width={image.width}
                            height={image.height}
                            loading={idx < 4 ? 'eager' : 'lazy'}
                            fetchpriority={idx === 0 ? 'high' : undefined}
                            decoding={idx === 0 ? 'sync' : 'async'}
                            class="product-card__img-primary"
                          />
                          {image2 && (
                            <img
                              src={cfImage(image2.url, { width: 600 })}
                              srcset={cfSrcset(image2.url, [200, 400, 600])}
                              sizes={SIZES.gridCard}
                              alt={image2.altText || `${product.title} - alternate view`}
                              width={image2.width}
                              height={image2.height}
                              loading="lazy"
                              decoding="async"
                              class="product-card__img-hover"
                            />
                          )}
                        </>
                      ) : (
                        <div class="product-card__image-ph">{product.productType || 'Product'}</div>
                      )}
                    </a>
                    {/* Quick View overlay — outside aria-hidden link for accessibility */}
                    <div class="product-card__overlay">
                      <button
                        class="product-card__quick-view"
                        data-handle={product.handle}
                        data-title={product.title}
                        data-price={price.amount}
                        data-compare-price={isOnSale ? compareAt.amount : ''}
                        data-description={product.description?.slice(0, 300) || ''}
                        data-images={JSON.stringify(allImages.map((img: any) => img.url))}
                        data-variants={JSON.stringify(allVariants.map((v: any) => ({
                          id: v.id,
                          title: v.title,
                          price: v.price.amount,
                          available: v.availableForSale,
                          image: v.image?.url || ''
                        })))}
                        data-type={product.productType}
                        data-available={String(product.availableForSale)}
                      >Quick View</button>
                    </div>
                  </div>
                  <div class="product-card__info">
                    {product.productType && <span class="product-card__type">{product.productType}</span>}
                    <a href={`/shop/${product.handle}`} class="product-card__title">{product.title}</a>
                    <div class="product-card__pricing">
                      <span class={`product-card__price${isOnSale ? ' product-card__price--sale' : ''}`}>
                        {fmt(parseFloat(price.amount))}
                      </span>
                      {isOnSale && (
                        <span class="product-card__price--compare">
                          {fmt(parseFloat(compareAt.amount))}
                        </span>
                      )}
                    </div>
                    {product.availableForSale && firstVariant && (
                      <button class="product-card__add-btn"
                        data-variant-id={firstVariant.id}
                        data-title={product.title}
                        data-price={parseFloat(price.amount)}
                        data-image={image?.url || ''}
                        data-handle={product.handle}
                        data-variant-title={firstVariant.title}
                      >
                        Add to Cart
                      </button>
                    )}
                  </div>
                </div>
                </>
              );
            })}
          </div>

          {/* Load More */}
          <div class="load-more-wrap" id="load-more-wrap">
            <button class="btn btn--outline load-more-btn" id="load-more-btn">
              Load More Products
            </button>
            <p class="load-more-count" id="load-more-count"></p>
          </div>

          {/* No results */}
          <div class="no-results" id="no-results" style="display:none;">
            <div class="no-results__icon"></div>
            <h3>No products found</h3>
            <p>Try adjusting your search or filters</p>
            <button class="btn btn--outline" id="no-results-clear">Clear All Filters</button>
          </div>
        </>
      ) : (
        <!-- Placeholder: shown when Shopify API is not connected -->
        <div class="shop-placeholder reveal">
          <div class="shop-placeholder__icon"></div>
          <h3>Connect Your Shopify Store</h3>
          <p>
            Products will appear here once you connect your Shopify Storefront API.
            Add your credentials to the <code>.env</code> file to get started.
          </p>
          <div class="shop-placeholder__steps">
            <div class="shop-placeholder__step">
              <span class="shop-placeholder__step-num">1</span>
              <span>Go to Shopify Admin, Settings, Apps, Develop apps</span>
            </div>
            <div class="shop-placeholder__step">
              <span class="shop-placeholder__step-num">2</span>
              <span>Create an app with Storefront API access</span>
            </div>
            <div class="shop-placeholder__step">
              <span class="shop-placeholder__step-num">3</span>
              <span>Copy the Storefront API token to your <code>.env</code> file</span>
            </div>
          </div>
          <p style="margin-top: 1.5rem;">
            <a href="https://sunnyandranney.myshopify.com" target="_blank" rel="noopener noreferrer" class="btn btn--primary">
              Visit Your Current Shopify Store
            </a>
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ QUICK VIEW MODAL ═══ -->
  <div class="qv-overlay" id="qv-overlay" aria-hidden="true"></div>
  <div class="qv-modal" id="qv-modal" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Quick view">
    <div class="qv-handle" aria-hidden="true"></div>
    <button class="qv-close" id="qv-close" aria-label="Close quick view">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="qv-body">
      <div class="qv-gallery">
        <img class="qv-image" id="qv-image" src="" alt="" />
        <div class="qv-thumbs" id="qv-thumbs"></div>
      </div>
      <div class="qv-info">
        <span class="qv-type" id="qv-type"></span>
        <h2 class="qv-title" id="qv-title"></h2>
        <div class="qv-pricing">
          <span class="qv-price" id="qv-price"></span>
          <span class="qv-compare" id="qv-compare"></span>
        </div>
        <p class="qv-description" id="qv-description"></p>
        <div class="qv-variants" id="qv-variants"></div>
        <div class="qv-actions">
          <button class="btn btn--gold qv-add" id="qv-add">Add to Cart</button>
          <a class="btn btn--outline qv-view-full" id="qv-view-full" href="#">View Full Details</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ MISSION REMINDER ═══ -->
  <section class="mission-reminder">
    <div class="container">
      <p class="mission-reminder__text reveal">
        <span class="mission-reminder__sun"></span>
        Every purchase you make here directly supports <strong>Sunshine on a Ranney Day</strong>
        — funding home makeovers for kids with special needs.
        <a href="https://sunshineonaranneyday.com" target="_blank" rel="noopener noreferrer">Learn more about Sunshine on a Ranney Day</a>
      </p>
    </div>
  </section>
</Base>

<style>
  /* ─── Editorial Shop Hero ────────────── */
  .shop-hero {
    background: var(--color-cyan);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .shop-hero__inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 2.5rem;
    padding-bottom: 2rem;
  }

  .shop-hero__title {
    font-size: clamp(2.2rem, 7vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: white;
    margin: 0;
  }

  .shop-hero__sub {
    color: #ffffff;
    font-size: 0.88rem;
    margin: 0;
  }

  .shop-hero__clear {
    display: inline-block;
    margin-top: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    transition: color 0.2s;
  }
  .shop-hero__clear:hover { color: white; }

  @media (min-width: 768px) {
    .shop-hero__inner {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      padding-top: var(--space-2xl);
      padding-bottom: var(--space-lg);
    }

    .shop-hero__title {
      font-size: clamp(2.5rem, 5vw, 4.5rem);
    }

    .shop-hero__sub {
      font-size: 0.9rem;
    }
  }

  /* ─── Toolbar ─────────────────────────── */
  .filters-bar {
    border-bottom: 1px solid var(--color-cream-dark);
    padding: 0.6rem 0;
    position: sticky;
    top: var(--nav-height);
    background: var(--color-cream);
    z-index: 50;
  }

  /* ─── Single toolbar row ─────────────── */
  .toolbar__row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    overflow: hidden;
  }

  .toolbar__categories {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.35rem;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    flex: 1;
    min-width: 0;
    -webkit-mask-image: linear-gradient(to right, black calc(100% - 32px), transparent 100%);
    mask-image: linear-gradient(to right, black calc(100% - 32px), transparent 100%);
  }
  .toolbar__categories::-webkit-scrollbar { display: none; }

  .toolbar__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  /* Hide count and text on mobile */
  .toolbar__count { display: none; }
  .filter-toggle__text { display: none; }

  .filter-btn {
    padding: 0.38rem 0.9rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-slate);
    border: 1.5px solid transparent;
    border-radius: 100px;
    transition: background-color 0.18s, color 0.18s, border-color 0.18s;
    background: transparent;
    white-space: nowrap;
    flex-shrink: 0;
    cursor: pointer;
  }

  .filter-btn:hover { color: var(--color-charcoal); background: var(--color-cream-dark); }
  .filter-btn--active {
    background: var(--color-charcoal);
    color: var(--color-cream);
    border-color: var(--color-charcoal);
    font-weight: 600;
  }

  .toolbar__filter-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    width: 36px;
    height: 36px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-charcoal);
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 100px;
    background: transparent;
    cursor: pointer;
    transition: background-color 0.18s, color 0.18s, border-color 0.18s;
    flex-shrink: 0;
  }
  .toolbar__filter-toggle:hover,
  .toolbar__filter-toggle[aria-expanded="true"] {
    border-color: var(--color-gold);
    background: var(--color-gold);
    color: var(--color-charcoal);
  }

  /* ─── Filter panel (top-down dropdown) ─ */
  .toolbar__panel {
    max-height: 0;
    overflow: hidden;
    background: transparent;
    transition: max-height 0.35s ease, opacity 0.2s ease;
    opacity: 0;
  }
  .toolbar__panel[hidden] {
    display: block;
    max-height: 0;
    opacity: 0;
    pointer-events: none;
  }
  .toolbar__panel.is-open {
    max-height: 600px;
    opacity: 1;
    pointer-events: auto;
  }

  .toolbar__panel-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0 0.75rem;
    border-top: 1px solid var(--color-cream-dark);
    margin-top: 0.5rem;
  }

  .toolbar__panel-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .toolbar__panel-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-stone);
  }

  /* ─── Sort select ────────────────────── */
  .toolbar__sort {
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.65rem 0.9rem;
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 10px;
    background: var(--color-warm-white);
    color: var(--color-charcoal);
    cursor: pointer;
    outline: none;
    width: 100%;
  }
  .toolbar__sort:focus { border-color: var(--color-gold); }

  /* ─── Price Range Filter ──────────────── */
  .toolbar__price-inputs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .toolbar__price-inputs input {
    flex: 1;
    padding: 0.65rem 0.75rem;
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    background: var(--color-warm-white);
    color: var(--color-charcoal);
    outline: none;
    -moz-appearance: textfield;
    min-width: 0;
  }

  .toolbar__price-inputs input::-webkit-inner-spin-button,
  .toolbar__price-inputs input::-webkit-outer-spin-button { -webkit-appearance: none; }

  .toolbar__price-inputs input:focus { border-color: var(--color-gold); }

  .toolbar__price-dash {
    color: var(--color-stone);
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .toolbar__price-go {
    padding: 0.65rem 1.1rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.18s;
    flex-shrink: 0;
  }

  .toolbar__price-go:hover { background: var(--color-gold); color: var(--color-charcoal); }

  /* ─── View Toggle ────────────────────── */
  .toolbar__views {
    display: flex;
    gap: 0.5rem;
  }

  .toolbar__view {
    padding: 0.6rem 1.25rem;
    color: var(--color-slate);
    border-radius: 10px;
    transition: all 0.18s;
    border: 1.5px solid var(--color-cream-dark);
    cursor: pointer;
    background: transparent;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .toolbar__view:hover { color: var(--color-charcoal); border-color: var(--color-gold); }
  .toolbar__view--active {
    color: var(--color-charcoal);
    background: var(--color-cream-dark);
    border-color: var(--color-charcoal);
  }

  /* ─── Desktop refinements ────────────── */
  @media (min-width: 768px) {
    /* Show count + text, hide sheet chrome */
    .toolbar__count {
      display: block;
      font-size: 0.72rem;
      color: var(--color-slate);
      white-space: nowrap;
    }
    .filter-toggle__text { display: inline; }
    .toolbar__sheet-header { display: none; }

    .filters-bar {
      border-bottom: 1px solid var(--color-cream-dark);
      padding: 0.75rem 0;
      background: var(--color-cream);
      position: sticky;
      top: var(--nav-height);
    }

    .toolbar__categories {
      gap: 0.25rem;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .filter-btn {
      padding: 0.45rem 1.1rem;
      font-size: 0.72rem;
      border: 1px solid var(--color-cream-dark);
    }
    .filter-btn:hover {
      border-color: var(--color-gold);
      background: transparent;
      color: var(--color-charcoal);
    }
    .filter-btn--active {
      background: var(--color-charcoal);
      color: var(--color-cream);
      border-color: var(--color-charcoal);
    }

    /* Desktop: pill button with text */
    .toolbar__filter-toggle {
      width: auto;
      height: auto;
      padding: 0.45rem 1rem;
    }

    /* Desktop: dropdown panel */
    .toolbar__panel {
      position: static;
      border-radius: 0;
      padding: 0;
      box-shadow: none;
      max-height: 0;
      overflow: hidden;
      background: transparent;
      transition: max-height 0.3s ease, opacity 0.2s ease;
      opacity: 0;
    }
    .toolbar__panel[hidden] {
      display: block;
      max-height: 0;
      opacity: 0;
      pointer-events: none;
    }
    .toolbar__panel.is-open {
      max-height: 300px;
      opacity: 1;
      pointer-events: auto;
    }

    .toolbar__panel-inner {
      flex-direction: row;
      flex-wrap: nowrap;
      gap: 2rem;
      padding: 1rem 0 0.25rem;
      border-top: 1px solid var(--color-cream-dark);
      margin-top: 0.75rem;
    }

    .toolbar__panel-group { gap: 0.35rem; }

    .toolbar__sort {
      font-size: 0.78rem;
      padding: 0.4rem 0.75rem;
      border-radius: 100px;
      border-width: 1px;
      width: auto;
    }

    .toolbar__price-inputs input {
      flex: none;
      width: 72px;
      padding: 0.4rem 0.5rem;
      font-size: 0.78rem;
      border-radius: 6px;
      border-width: 1px;
    }

    .toolbar__price-go {
      padding: 0.4rem 0.75rem;
      font-size: 0.72rem;
      border-radius: 6px;
    }

    .toolbar__views { gap: 0.25rem; }

    .toolbar__view {
      padding: 0.4rem;
      font-size: 0.7rem;
      border-radius: 6px;
      border-width: 1px;
      gap: 0;
    }
  }

  /* ─── Filter button counts ────────────── */
  .filter-btn__count {
    font-size: 0.65em;
    font-weight: 400;
    opacity: 0.6;
    margin-left: 0.15em;
  }
  .filter-btn--active .filter-btn__count {
    opacity: 0.8;
  }

  /* ─── Filter toggle badge ───────────── */
  .filter-toggle__badge {
    width: 18px;
    height: 18px;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-size: 0.6rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    margin-left: -0.1rem;
  }

  /* ─── Active filter chips ──────────── */
  .filter-chips {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0 0;
    flex-wrap: wrap;
  }

  .filter-chips__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.6rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-charcoal);
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    border-radius: 100px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .filter-chip:hover {
    border-color: var(--color-gold);
    background: rgba(255, 212, 0, 0.08);
  }

  .filter-chip__x {
    font-size: 0.85em;
    line-height: 1;
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .filter-chip:hover .filter-chip__x {
    opacity: 1;
  }

  .filter-chips__clear {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-slate);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0.3rem 0;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .filter-chips__clear:hover {
    color: var(--color-charcoal);
  }

  @media (min-width: 768px) {
    .filter-chip {
      padding: 0.35rem 0.75rem;
      font-size: 0.72rem;
    }
  }

  /* ─── Search Banner ────────────────────── */
  .search-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.6rem 0 0;
    font-size: 0.85rem;
    color: var(--color-slate);
  }

  .search-banner__clear {
    color: var(--color-gold);
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ─── Grid / List views ───────────────── */
  .shop-grid-section {
    min-height: 400px;
    content-visibility: auto;
    contain-intrinsic-size: auto 2000px;
    /* Override .section's 6rem top padding — products should start close to the toolbar */
    padding-top: var(--space-md) !important;
  }

  #shop-grid.view-list {
    grid-template-columns: 1fr !important;
  }

  #shop-grid.view-list .product-card {
    flex-direction: row;
    max-height: 220px;
  }

  /* Container wraps the image link + overlay so overlay stays scoped to image area */
  .product-card__image-container {
    position: relative;
    overflow: hidden;
  }

  /* The <a> tag must have a defined height for absolutely-positioned images to fill */
  .product-card__image {
    display: block;
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  #shop-grid.view-list .product-card__image-container {
    max-width: 220px;
    flex-shrink: 0;
  }

  #shop-grid.view-list .product-card__image {
    aspect-ratio: 1;
    max-width: 220px;
    flex-shrink: 0;
  }

  #shop-grid.view-list .product-card__info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-md) var(--space-lg);
  }

  #shop-grid.view-list .product-card__wishlist {
    right: auto;
    left: 190px;
  }

  /* ─── Card entrance animation ────────── */
  .product-card {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s var(--ease-out),
                transform 0.45s var(--ease-out),
                box-shadow var(--duration) var(--ease-out);
  }

  /* First row visible immediately — no blank flash on load */
  .product-card:nth-child(-n+2) {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    .product-card:nth-child(-n+6) {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .product-card.card-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card {
      opacity: 1;
      transform: none;
      transition: box-shadow var(--duration) var(--ease-out);
    }
  }

  /* ─── Skeleton loading shimmer ─────── */
  .skeleton-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .skeleton-grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  }
  @media (min-width: 1200px) {
    .skeleton-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  }

  .skeleton-card {
    background: var(--color-warm-white);
    overflow: hidden;
  }

  .skeleton-card__image {
    aspect-ratio: 1;
    background: linear-gradient(90deg, var(--color-cream-dark) 25%, var(--color-warm-white) 50%, var(--color-cream-dark) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
  }

  .skeleton-card__info {
    padding: 1rem;
  }

  .skeleton-card__line {
    height: 12px;
    border-radius: 6px;
    background: linear-gradient(90deg, var(--color-cream-dark) 25%, var(--color-warm-white) 50%, var(--color-cream-dark) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
    margin-bottom: 0.5rem;
  }

  .skeleton-card__line:nth-child(1) { width: 40%; height: 8px; }
  .skeleton-card__line:nth-child(2) { width: 80%; }
  .skeleton-card__line:nth-child(3) { width: 35%; }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ─── Enhanced Product Card ───────────── */
  .product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-warm-white);
    overflow: hidden;
  }

  /* Wishlist heart */
  .product-card__wishlist {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 3;
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-stone);
    transition: all 0.25s;
    opacity: 0;
    transform: scale(0.8);
  }

  .product-card:hover .product-card__wishlist,
  .product-card__wishlist.is-wished {
    opacity: 1;
    transform: scale(1);
  }

  .product-card__wishlist:hover {
    color: #e74c3c;
    transform: scale(1.15);
  }

  .product-card__wishlist.is-wished {
    color: #e74c3c;
  }

  .product-card__wishlist.is-wished svg {
    fill: #e74c3c;
  }

  /* Image swap on hover */
  .product-card__img-primary,
  .product-card__img-hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.6s var(--ease-out), transform 0.8s var(--ease-out);
  }

  .product-card__img-hover {
    opacity: 0;
  }

  .product-card:hover .product-card__img-primary {
    opacity: 0;
  }

  .product-card:hover .product-card__img-hover {
    opacity: 1;
    transform: scale(1.03);
  }

  .product-card:hover .product-card__img-primary:only-child {
    opacity: 1;
    transform: scale(1.05);
  }

  .product-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 44, 44, 0.0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s;
    pointer-events: none;
    z-index: 2;
  }

  .product-card:hover .product-card__overlay {
    background: rgba(44, 44, 44, 0.25);
    pointer-events: all;
  }

  .product-card__quick-view {
    padding: 0.6rem 1.5rem;
    background: white;
    color: var(--color-charcoal);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 4px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s, transform 0.3s, background 0.2s;
    cursor: pointer;
  }

  .product-card__quick-view:hover {
    background: var(--color-gold);
  }

  .product-card:hover .product-card__quick-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Desktop: Elevated hover — slide-up add-to-cart ─── */
  @media (min-width: 768px) {
    .product-card__overlay {
      inset: auto 0 0 0;
      top: auto;
      background: none;
      align-items: flex-end;
      justify-content: stretch;
      padding: 0;
    }

    .product-card:hover .product-card__overlay {
      background: none;
      pointer-events: all;
    }

    .product-card__quick-view {
      width: 100%;
      border-radius: 0;
      padding: 0.7rem 1.5rem;
      background: rgba(44, 44, 44, 0.92);
      color: white;
      backdrop-filter: blur(8px);
      transform: translateY(100%);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
    }

    .product-card:hover .product-card__quick-view {
      transform: translateY(0);
    }

    .product-card__quick-view:hover {
      background: var(--color-gold);
      color: var(--color-charcoal);
    }

    /* Hide the always-visible add-to-cart on desktop — quick view serves this role */
    .product-card__add-btn {
      opacity: 0;
      max-height: 0;
      padding: 0;
      margin: 0;
      overflow: hidden;
      transition: opacity 0.3s, max-height 0.3s;
    }

    .product-card:hover .product-card__add-btn {
      opacity: 1;
      max-height: 48px;
      padding: 0.55rem 1rem;
      margin-top: 0.5rem;
    }
  }

  .product-card__type {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-slate);
    display: block;
    margin-bottom: 0.2rem;
  }

  .product-card__info {
    padding: 0.9rem 0.85rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  .product-card__title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-charcoal);
    text-decoration: none;
    display: block;
    margin: 0.1rem 0 0.35rem;
    transition: color 0.2s;
  }

  .product-card__title:hover {
    color: var(--color-gold);
  }

  .product-card__pricing {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .product-card__price {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-charcoal);
    letter-spacing: 0.01em;
  }

  .product-card__price--sale {
    color: #8a3a1f;
  }

  .product-card__price--compare {
    font-size: 0.82rem;
    color: #5e5d5b;
    text-decoration: line-through;
  }

  /* No-image placeholder uses cream bg, not white */
  .product-card__image-ph {
    position: absolute;
    inset: 0;
    background: var(--color-cream-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-stone);
  }

  .product-card__badge--sold {
    background: #6b6b68 !important;
    color: #fff !important;
  }

  .product-card__add-btn {
    margin-top: 0.75rem;
    width: 100%;
    padding: 0.6rem 1rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s, color 0.3s;
  }

  .product-card__add-btn:hover {
    background: var(--color-gold);
    color: var(--color-charcoal);
  }

  /* ─── Load More ────────────────────────── */
  .load-more-wrap {
    text-align: center;
    margin-top: var(--space-xl);
  }

  .load-more-btn {
    min-width: 220px;
  }

  .load-more-count {
    font-size: 0.78rem;
    color: var(--color-slate);
    margin-top: 0.75rem;
  }

  /* ─── No Results ───────────────────────── */
  .no-results {
    text-align: center;
    padding: var(--space-2xl) var(--space-md);
  }

  .no-results__icon { font-size: 3rem; margin-bottom: 0.75rem; opacity: 0.5; }
  .no-results h3 { margin-bottom: 0.5rem; }
  .no-results .btn { margin-top: 1rem; }

  /* ─── Quick View Modal ─────────────────── */
  .qv-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 500;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
    backdrop-filter: blur(4px);
  }

  .qv-overlay[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .qv-modal {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 501;
    background: var(--color-cream);
    width: 100%;
    max-height: 90dvh;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    opacity: 0;
    visibility: hidden;
    transform: translateY(100%);
    transition: opacity 0.3s var(--ease-out), visibility 0.3s var(--ease-out), transform 0.35s var(--ease-out);
    box-shadow: 0 -8px 40px rgba(0, 0, 0, 0.12);
    border-radius: 12px 12px 0 0;
  }

  .qv-modal[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    will-change: transform;
  }

  .qv-handle {
    display: block;
    width: 36px;
    height: 4px;
    background: var(--color-stone);
    opacity: 0.3;
    border-radius: 2px;
    margin: 8px auto 0;
  }

  @media (min-width: 640px) {
    .qv-modal {
      top: 50%;
      left: 50%;
      right: auto;
      bottom: auto;
      transform: translate(-50%, -50%) scale(0.95);
      max-width: 900px;
      width: 92vw;
      max-height: 88vh;
      border-radius: 0;
      box-shadow: 0 25px 80px rgba(0, 0, 0, 0.15);
    }

    .qv-modal[aria-hidden="false"] {
      transform: translate(-50%, -50%) scale(1);
    }

    .qv-handle { display: none; }
  }

  .qv-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.9);
    border-radius: 50%;
    color: var(--color-charcoal);
    transition: all 0.2s;
  }
  .qv-close:hover { background: var(--color-gold); }

  .qv-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 640px) {
    .qv-body { grid-template-columns: 1fr 1fr; }
  }

  .qv-gallery {
    background: var(--color-cream-dark);
    aspect-ratio: 3 / 4;
    max-height: 45dvh;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .qv-gallery {
      aspect-ratio: 1;
      max-height: none;
    }
  }

  .qv-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s;
  }

  .qv-thumbs {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
