  /* Image swap on hover */
  .product-card__img-primary,
  .product-card__img-hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.6s var(--ease-out), transform 0.8s var(--ease-out);
