  }
</style>

<script>
  import { wishlist } from '@/lib/cart-store.js';

  // Clean up document-level listeners on re-init (View Transitions)
  let _shopKeyHandler: ((e: KeyboardEvent) => void) | null = null;

  document.addEventListener('astro:page-load', () => {
  if (!document.getElementById('shop-grid')) return;

  // ─── DOM refs ──────────────────────────────────
  const grid = document.getElementById('shop-grid');
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const viewBtns = document.querySelectorAll('.toolbar__view');
  const countEl = document.getElementById('product-count');
  const panelCountEl = document.getElementById('panel-product-count');
  const loadMoreBtn = document.getElementById('load-more-btn');
  const loadMoreWrap = document.getElementById('load-more-wrap');
  const loadMoreCount = document.getElementById('load-more-count');
  const noResults = document.getElementById('no-results');
  const noResultsClear = document.getElementById('no-results-clear');
  const searchBanner = document.getElementById('search-banner');
  const searchBannerText = document.getElementById('search-banner-text');
  const searchClear = document.getElementById('search-clear');
  const filterChips = document.getElementById('filter-chips');
  const filterChipsList = document.getElementById('filter-chips-list');
  const filterChipsClear = document.getElementById('filter-chips-clear');
  const filterBadge = document.getElementById('filter-badge');

  // ─── Debounce helper ────────────────────────────
  let _applyTimer: ReturnType<typeof setTimeout>;
  let _isInitialRender = true;
  function applyAllDebounced() {
    clearTimeout(_applyTimer);
    _applyTimer = setTimeout(applyAll, 60);
  }

  // ─── Filter & Sort panel toggle ───────────────
  const filterToggle = document.getElementById('filter-toggle');
  const filterPanel = document.getElementById('filter-panel');

  function openFilterPanel() {
    filterPanel?.classList.add('is-open');
    filterToggle?.setAttribute('aria-expanded', 'true');
  }

  function closeFilterPanel() {
    filterPanel?.classList.remove('is-open');
    filterToggle?.setAttribute('aria-expanded', 'false');
  }

  filterToggle?.addEventListener('click', () => {
    filterPanel?.classList.contains('is-open') ? closeFilterPanel() : openFilterPanel();
  });


  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && filterPanel?.classList.contains('is-open')) closeFilterPanel();
  });

  let activeSearch = '';
  let activeCollection = '';
  let activeSale = false;
  let priceMin = 0;
  let priceMax = Infinity;
  let activeView = 'grid';
  let visiblePage = 0;
  const PAGE_SIZE = 12;

  // ─── URL sync — encode all filter state ──────
  function syncURL() {
    const params = new URLSearchParams();
    if (activeCollection) params.set('collection', activeCollection);
    if (activeProductType) params.set('type', activeProductType);
    if (activeSearch) params.set('q', activeSearch);
    if (priceMin > 0) params.set('pmin', String(priceMin));
    if (priceMax < Infinity) params.set('pmax', String(priceMax));
    if (sortSelect?.value && sortSelect.value !== 'best-selling') params.set('sort', sortSelect.value);
    if (activeSale) params.set('sale', 'true');
    if (activeView !== 'grid') params.set('view', activeView);
    const qs = params.toString();
    const url = qs ? `/shop/?${qs}` : '/shop/';
    window.history.replaceState({}, '', url);
  }

  // ─── Filter chips — show active filters as removable pills ──
  function renderChips() {
    if (!filterChipsList || !filterChips) return;
    filterChipsList.innerHTML = '';
    const chips: { label: string; action: () => void }[] = [];

    if (activeCollection) {
      const titles = (window as any).__collectionTitles || {};
      const name = activeCollection === 'new-arrivals' ? 'New Arrivals' : (titles[activeCollection] || activeCollection.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '));
      chips.push({ label: name, action: () => {
        activeCollection = '';
        const shopTitle = document.getElementById('shop-title');
        const clearLink = document.getElementById('shop-clear-collection');
        if (shopTitle) shopTitle.textContent = 'The Collection';
        if (clearLink) clearLink.style.display = 'none';
        if (searchBanner) searchBanner.style.display = 'none';
        visiblePage = 0;
        applyAll();
      }});
    }

    if (activeProductType) {
      chips.push({ label: activeProductType, action: () => {
        activeProductType = '';
        syncPillBarState();
        syncPanelCategoryState();
        if (searchBanner && !activeCollection) searchBanner.style.display = 'none';
        visiblePage = 0;
        applyAll();
      }});
    }

    if (priceMin > 0 || priceMax < Infinity) {
      const minStr = priceMin > 0 ? `$${priceMin}` : '$0';
      const maxStr = priceMax < Infinity ? `$${priceMax}` : '+';
      chips.push({ label: `${minStr}–${maxStr}`, action: () => {
        priceMin = 0;
        priceMax = Infinity;
        if (priceMinInput) priceMinInput.value = '';
        if (priceMaxInput) priceMaxInput.value = '';
        visiblePage = 0;
        applyAll();
      }});
    }

    if (sortSelect?.value && sortSelect.value !== 'best-selling') {
      const sortLabels: Record<string, string> = {
        'price-asc': 'Price: Low → High',
        'price-desc': 'Price: High → Low',
        'title-asc': 'A to Z',
        'newest': 'Newest',
      };
      chips.push({ label: sortLabels[sortSelect.value] || sortSelect.value, action: () => {
        sortSelect.value = 'best-selling';
        sortSelect.dispatchEvent(new Event('change'));
      }});
    }

    if (activeSale) {
      chips.push({ label: 'On Sale', action: () => {
        activeSale = false;
        visiblePage = 0;
        applyAll();
      }});
    }

    if (activeSearch) {
      chips.push({ label: `"${activeSearch}"`, action: () => {
        activeSearch = '';
        if (searchBanner) searchBanner.style.display = 'none';
        visiblePage = 0;
        applyAll();
      }});
    }

    for (const chip of chips) {
      const btn = document.createElement('button');
      btn.className = 'filter-chip';
      btn.innerHTML = `${chip.label} <span class="filter-chip__x">&times;</span>`;
      btn.addEventListener('click', chip.action);
      filterChipsList.appendChild(btn);
    }

    filterChips.style.display = chips.length > 0 ? '' : 'none';

    // Update badge count on Filter & Sort toggle
    const activeCount = chips.length;
    if (filterBadge) {
      filterBadge.textContent = String(activeCount);
      filterBadge.style.display = activeCount > 0 ? 'flex' : 'none';
    }
  }

  // ─── Update counts on category pills ─────────

  // ─── Collection + Product Type filter from URL ─────────────
  const urlParams = new URLSearchParams(window.location.search);
  const collectionParam = urlParams.get('collection') || '';
  const productTypeParam = urlParams.get('type') || '';
  let activeProductType = productTypeParam;
  const shopTitle = document.getElementById('shop-title');
  const clearCollectionLink = document.getElementById('shop-clear-collection');
  const titles = (window as any).__collectionTitles || {};

  if (collectionParam) {
    activeCollection = collectionParam;
    const collectionTitle = collectionParam === 'new-arrivals' ? 'New Arrivals' : (titles[collectionParam] || collectionParam.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '));
    if (shopTitle) shopTitle.textContent = collectionTitle;
    if (clearCollectionLink) clearCollectionLink.style.display = '';
    // Show collection context in the toolbar
    if (searchBanner) searchBanner.style.display = '';
    const viewingText = productTypeParam ? `${collectionTitle} > ${productTypeParam}` : collectionTitle;
    if (searchBannerText) searchBannerText.textContent = `Viewing: ${viewingText}`;
    if (searchClear) searchClear.textContent = 'View all products';
  } else if (productTypeParam) {
    // Product type without collection — title-case it
    const typeTitle = productTypeParam.split(' ').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ');
    if (shopTitle) shopTitle.textContent = typeTitle;
    if (clearCollectionLink) clearCollectionLink.style.display = '';
  }

  // ─── Build subcategory pills from taxonomy ─────────────
  const subcatMap: Record<string, string[]> = (window as any).__collectionSubcategories || {};
  const categoryNav = document.getElementById('category-nav');

  function buildSubcategoryPills() {
    if (!categoryNav) return;
    // Clear existing pills except the "All" button
    const allBtn = categoryNav.querySelector('.filter-btn[data-filter="all"]');
    categoryNav.innerHTML = '';
    if (allBtn) categoryNav.appendChild(allBtn);

    // Get subcategories for the active collection — only show if more than 1
    const allSubcats = activeCollection ? (subcatMap[activeCollection] || []) : [];
    if (allSubcats.length <= 1) return;

    // Count products per subcategory to pick the top 5 for pills
    const cards = getCards();
    const subcatCounts: Record<string, number> = {};
    for (const card of cards) {
      const collections = card.dataset.collections || '';
      if (activeCollection && !collections.split(',').includes(activeCollection)) continue;
      const category = card.getAttribute('data-category') || '';
      if (category) subcatCounts[category] = (subcatCounts[category] || 0) + 1;
    }
    const topSubcats = [...allSubcats]
      .sort((a, b) => (subcatCounts[b] || 0) - (subcatCounts[a] || 0))
      .slice(0, 5);

    // Copy Astro scoped attributes from existing button so scoped CSS applies
    const scopeAttrs: string[] = [];
    if (allBtn) {
      for (const attr of Array.from(allBtn.attributes)) {
        if (attr.name.startsWith('data-astro-cid-')) scopeAttrs.push(attr.name);
      }
    }

    for (const subcat of topSubcats) {
      const btn = document.createElement('button');
      btn.className = 'filter-btn';
      btn.dataset.subcat = subcat;
      btn.textContent = subcat;
      // Apply Astro scoped attributes
      for (const attr of scopeAttrs) btn.setAttribute(attr, '');

      btn.addEventListener('click', () => {
        activeProductType = activeProductType === subcat ? '' : subcat;
        visiblePage = 0;
        // Sync active states
        syncPillBarState();
        syncPanelCategoryState();
        applyAll();
        // Scroll so product grid starts just below the sticky nav + toolbar
        const grid = document.getElementById('shop-grid');
        const bar = document.querySelector('.filters-bar');
        if (grid && bar) {
          const offset = grid.getBoundingClientRect().top + window.scrollY - bar.offsetHeight - parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--nav-height') || '0');
          window.scrollTo({ top: offset, behavior: 'smooth' });
        }
      });

      categoryNav.appendChild(btn);
    }

    // Add "+X more" pill if there are more subcats than shown
    const remainingCount = allSubcats.length - topSubcats.length;
    if (remainingCount > 0) {
      const moreBtn = document.createElement('button');
      moreBtn.className = 'filter-btn filter-btn--more';
      moreBtn.textContent = `+${remainingCount} more`;
      for (const attr of scopeAttrs) moreBtn.setAttribute(attr, '');
      moreBtn.addEventListener('click', () => toggleSubcatsExpand());
      categoryNav.appendChild(moreBtn);
    }

    // Update "All" button click
    const newAllBtn = categoryNav.querySelector('.filter-btn[data-filter="all"]');
    newAllBtn?.addEventListener('click', () => {
      activeProductType = '';
      visiblePage = 0;
      syncPillBarState();
      syncPanelCategoryState();
      applyAll();
    });

    // Set active state from URL
    syncPillBarState();
  }

  // ─── Expandable subcategory row ─────────
  const subcatsExpand = document.getElementById('subcats-expand');
  const panelCategoryList = document.getElementById('panel-category-list');

  function toggleSubcatsExpand() {
    if (!subcatsExpand) return;
    subcatsExpand.classList.toggle('is-open');
  }

  function syncPillBarState() {
    if (!categoryNav) return;
    categoryNav.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('filter-btn--active'));
    if (!activeProductType) {
      categoryNav.querySelector('.filter-btn[data-filter="all"]')?.classList.add('filter-btn--active');
      return;
    }
    // Try to highlight matching pill
    const pillMatch = categoryNav.querySelector(`.filter-btn[data-subcat="${CSS.escape(activeProductType)}"]`);
    if (pillMatch) {
      pillMatch.classList.add('filter-btn--active');
    } else {
      // Non-top-5 subcat: highlight the "+X more" pill
      const moreBtn = categoryNav.querySelector('.filter-btn--more');
      if (moreBtn) moreBtn.classList.add('filter-btn--active');
    }
  }

  function syncPanelCategoryState() {
    if (!panelCategoryList) return;
    panelCategoryList.querySelectorAll('.toolbar__category-btn').forEach(b => {
      const isActive = b.textContent === activeProductType;
      b.classList.toggle('toolbar__category-btn--active', isActive);
    });
  }

  function buildPanelCategories() {
    if (!panelCategoryList) return;
    panelCategoryList.innerHTML = '';
    // Close the expand row when rebuilding
    if (subcatsExpand) subcatsExpand.classList.remove('is-open');

    const allSubcats = activeCollection ? (subcatMap[activeCollection] || []) : [];
    if (allSubcats.length <= 1) return;

    // Sort alphabetically for the full list
    const sorted = [...allSubcats].sort((a, b) => a.localeCompare(b));

    for (const subcat of sorted) {
      const btn = document.createElement('button');
      btn.className = 'toolbar__category-btn' + (activeProductType === subcat ? ' toolbar__category-btn--active' : '');
      btn.textContent = subcat;
      btn.addEventListener('click', () => {
        activeProductType = activeProductType === subcat ? '' : subcat;
        visiblePage = 0;
        // Sync pill bar active state
        syncPillBarState();
        // Sync panel button active states
        panelCategoryList.querySelectorAll('.toolbar__category-btn').forEach(b => b.classList.remove('toolbar__category-btn--active'));
        if (activeProductType) btn.classList.add('toolbar__category-btn--active');
        // Close expand row and scroll to products
        if (subcatsExpand) subcatsExpand.classList.remove('is-open');
        applyAll();
        const gridEl = document.getElementById('shop-grid');
        const barEl = document.querySelector('.filters-bar');
        if (gridEl && barEl) {
          const top = gridEl.getBoundingClientRect().top + window.scrollY - barEl.offsetHeight - parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--nav-height') || '0');
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
      panelCategoryList.appendChild(btn);
    }
  }

  buildSubcategoryPills();
  buildPanelCategories();

  const priceMinInput = document.getElementById('price-min') as HTMLInputElement;
  const priceMaxInput = document.getElementById('price-max') as HTMLInputElement;
  const priceGoBtn = document.getElementById('price-go');

  function getCards() {
    return Array.from(grid?.querySelectorAll('.product-card') || []) as HTMLElement[];
  }

  // ─── Filtering + Search + Pagination ────────
  function applyAll() {
    const cards = getCards();
    let matchCount = 0;
    const matchingCards: HTMLElement[] = [];

    cards.forEach(card => {
      const type = card.getAttribute('data-type') || '';
      const category = card.getAttribute('data-category') || '';
      const title = (card.dataset.title || '').toLowerCase();
      const tags = card.dataset.tags || '';
      const handle = card.dataset.handle || '';
      const desc = ((window as any).__productData?.[handle]?.d || '').toLowerCase().slice(0, 200);

      const cardPrice = parseFloat(card.dataset.price || '0');
      const collections = card.dataset.collections || '';
      const matchesCollection = !activeCollection || collections.split(',').includes(activeCollection);
      const matchesProductType = !activeProductType || category === activeProductType || type.toLowerCase() === activeProductType.toLowerCase();
      const matchesSearch = !activeSearch ||
        title.includes(activeSearch) ||
        type.includes(activeSearch) ||
        category.toLowerCase().includes(activeSearch) ||
        tags.includes(activeSearch) ||
        desc.includes(activeSearch);
      const matchesPrice = cardPrice >= priceMin && cardPrice <= priceMax;
      const matchesSale = !activeSale || !!card.querySelector('.product-card__badge')?.textContent?.trim().includes('Sale');

      if (matchesCollection && matchesProductType && matchesSearch && matchesPrice && matchesSale) {
        matchingCards.push(card);
        matchCount++;
      } else {
        card.style.display = 'none';
      }
    });

    // Show cards up to (visiblePage + 1) * PAGE_SIZE
    const showCount = (visiblePage + 1) * PAGE_SIZE;
    matchingCards.forEach((card, i) => {
      card.style.display = i < showCount ? '' : 'none';
    });

    const shownCount = Math.min(showCount, matchCount);

    // Update count
    const countText = `${matchCount} product${matchCount !== 1 ? 's' : ''}`;
    if (countEl) countEl.textContent = countText;
    if (panelCountEl) panelCountEl.textContent = countText;
    // Load more visibility
    if (loadMoreWrap) {
      loadMoreWrap.style.display = matchCount > showCount ? '' : 'none';
    }
    if (loadMoreCount) {
      loadMoreCount.textContent = `Showing ${shownCount} of ${matchCount}`;
    }

    // No results
    if (noResults) noResults.style.display = matchCount === 0 ? '' : 'none';
    if (grid) grid.style.display = matchCount === 0 ? 'none' : '';

    // Position editorial card among visible products
    // Initial render with no filters: build-time HTML is already correct — zero JS cost
    const editorial = document.getElementById('grid-editorial') as HTMLElement;
    if (editorial) {
      const hideEditorial = activeSearch || activeSale;
      const noFilters = !activeCollection && !activeProductType && !activeSearch && !activeSale;
      if (hideEditorial) {
        editorial.style.display = 'none';
      } else if (_isInitialRender && noFilters) {
        // Build-time position is correct — touch nothing
      } else {
        const visibleCards = matchingCards.filter(c => c.style.display !== 'none');
        if (visibleCards.length < 4) {
          editorial.style.display = 'none';
        } else {
          const minPos = 3;
          const maxPos = visibleCards.length;
          const randomIdx = minPos + Math.floor(Math.random() * (maxPos - minPos));
          grid!.insertBefore(editorial, visibleCards[randomIdx]);
          editorial.style.display = '';
        }
      }
    }
    _isInitialRender = false;

    // Update chips, badge, and URL
    renderChips();
    syncURL();

    // Re-observe cards so newly-visible ones get the card-visible animation class
    requestAnimationFrame(() => observeCards());
  }

  // ─── Category Filter (now handled by subcategory pills) ────

  // ─── Price Range Filter ─────────────────────
  function applyPriceFilter() {
    const min = parseFloat(priceMinInput?.value || '0') || 0;
    const max = parseFloat(priceMaxInput?.value || '') || Infinity;
    priceMin = min;
    priceMax = max;
    visiblePage = 0;
    applyAllDebounced();
  }

  priceGoBtn?.addEventListener('click', applyPriceFilter);
  priceMinInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') applyPriceFilter(); });
  priceMaxInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') applyPriceFilter(); });

  // ─── Sort ───────────────────────────────────
  sortSelect?.addEventListener('change', () => {
    const cards = getCards();
    const sortBy = sortSelect.value;

    cards.sort((a, b) => {
      const priceA = parseFloat(a.dataset.price || '0');
      const priceB = parseFloat(b.dataset.price || '0');
      const titleA = (a.dataset.title || '').toLowerCase();
      const titleB = (b.dataset.title || '').toLowerCase();
      const idxA = parseInt(a.dataset.idx || '0');
      const idxB = parseInt(b.dataset.idx || '0');

      switch (sortBy) {
        case 'price-asc': return priceA - priceB;
        case 'price-desc': return priceB - priceA;
        case 'title-asc': return titleA.localeCompare(titleB);
        case 'newest': {
          const dateA = a.dataset.created || '';
          const dateB = b.dataset.created || '';
          // Newest first — reverse chronological
          return dateB.localeCompare(dateA) || idxA - idxB;
        }
        default: return idxA - idxB;
      }
    });

    cards.forEach(card => grid?.appendChild(card));
    applyAll();
  });

  // ─── View Toggle ────────────────────────────
  viewBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      viewBtns.forEach(b => b.classList.remove('toolbar__view--active'));
      btn.classList.add('toolbar__view--active');
      const view = (btn as HTMLElement).dataset.view || 'grid';
      activeView = view;
      if (view === 'list') {
        grid?.classList.add('view-list');
      } else {
        grid?.classList.remove('view-list');
      }
      syncURL();
    });
  });

  // ─── Load More ──────────────────────────────
  loadMoreBtn?.addEventListener('click', () => {
    visiblePage++;
    applyAll();
    // Smooth scroll to new products
    const cards = getCards().filter(c => c.style.display !== 'none');
    const firstNew = cards[visiblePage * PAGE_SIZE];
    if (firstNew) {
      firstNew.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  // ─── Restore all filters from URL ────────────
  const params = new URLSearchParams(window.location.search);

  // Search
  const searchQuery = params.get('q');
  if (searchQuery) {
    activeSearch = searchQuery.toLowerCase();
    if (searchBanner) searchBanner.style.display = '';
    if (searchBannerText) searchBannerText.textContent = `Results for "${searchQuery}"`;
  }


  // Price range
  const pminParam = params.get('pmin');
  const pmaxParam = params.get('pmax');
  if (pminParam) { priceMin = parseFloat(pminParam) || 0; if (priceMinInput) priceMinInput.value = pminParam; }
  if (pmaxParam) { priceMax = parseFloat(pmaxParam) || Infinity; if (priceMaxInput) priceMaxInput.value = pmaxParam; }

  // Sort
  const sortParam = params.get('sort');
  if (sortParam && sortSelect) {
    const validSorts = ['newest', 'price-asc', 'price-desc', 'title-asc'];
    if (validSorts.includes(sortParam)) {
      sortSelect.value = sortParam;
      // Sort cards without triggering change event (we'll call applyAll once at end)
      const cards = getCards();
      cards.sort((a, b) => {
        const priceA = parseFloat(a.dataset.price || '0');
        const priceB = parseFloat(b.dataset.price || '0');
        const titleA = (a.dataset.title || '').toLowerCase();
        const titleB = (b.dataset.title || '').toLowerCase();
        const idxA = parseInt(a.dataset.idx || '0');
        const idxB = parseInt(b.dataset.idx || '0');
        switch (sortParam) {
          case 'price-asc': return priceA - priceB;
          case 'price-desc': return priceB - priceA;
          case 'title-asc': return titleA.localeCompare(titleB);
          case 'newest': {
            const dateA = a.dataset.created || '';
            const dateB = b.dataset.created || '';
            return dateB.localeCompare(dateA) || idxA - idxB;
          }
          default: return idxA - idxB;
        }
      });
      cards.forEach(card => grid?.appendChild(card));
    }
  }

  // Sale
  const saleParam = params.get('sale');
  if (saleParam === 'true') {
    activeSale = true;
    if (shopTitle) shopTitle.textContent = 'Sale';
    if (clearCollectionLink) clearCollectionLink.style.display = '';
  }

  // View
  const viewParam = params.get('view');
  if (viewParam === 'list') {
    activeView = 'list';
    grid?.classList.add('view-list');
    viewBtns.forEach(b => {
      b.classList.toggle('toolbar__view--active', (b as HTMLElement).dataset.view === 'list');
    });
  }

  // ─── Clear handlers ──────────────────────────
  function clearAllFilters() {
    activeSearch = '';
    activeCollection = '';
    activeProductType = '';
    activeSale = false;
    priceMin = 0;
    priceMax = Infinity;
    if (priceMinInput) priceMinInput.value = '';
    if (priceMaxInput) priceMaxInput.value = '';
    if (sortSelect) sortSelect.value = 'best-selling';
    buildSubcategoryPills();
    buildPanelCategories();
    if (searchBanner) searchBanner.style.display = 'none';
    const shopTitle = document.getElementById('shop-title');
    const clearLink = document.getElementById('shop-clear-collection');
    if (shopTitle) shopTitle.textContent = 'The Collection';
    if (clearLink) clearLink.style.display = 'none';
    // Re-sort to default order
    const cards = getCards();
    cards.sort((a, b) => parseInt(a.dataset.idx || '0') - parseInt(b.dataset.idx || '0'));
    cards.forEach(card => grid?.appendChild(card));
    visiblePage = 0;
    applyAll();
  }

  searchClear?.addEventListener('click', clearAllFilters);
  noResultsClear?.addEventListener('click', clearAllFilters);
  filterChipsClear?.addEventListener('click', clearAllFilters);

  // ─── Initial render — apply all URL-restored filters ────
  applyAllDebounced();

  // ─── Add to Cart from Grid ──────────────────
  grid?.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest('.product-card__add-btn');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const { variantId, title, price, image, handle, variantTitle } = (btn as HTMLElement).dataset;
    if (!variantId || !title || !price) return;

    window.addToCart?.({
      variantId,
      title,
      price: parseFloat(price),
      image: image || '',
      handle: handle || '',
      variantTitle: variantTitle || '',
    });

    const orig = btn.textContent;
    btn.textContent = 'Added';
    (btn as HTMLButtonElement).disabled = true;
    setTimeout(() => {
      btn.textContent = orig;
      (btn as HTMLButtonElement).disabled = false;
    }, 1500);
  });

  // ─── Wishlist Hearts ────────────────────────
  function initWishlistHearts() {
    document.querySelectorAll('.product-card__wishlist').forEach(btn => {
      const handle = (btn as HTMLElement).dataset.handle || '';
      if (wishlist.has(handle)) {
        btn.classList.add('is-wished');
      }
    });
  }

  grid?.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest('.product-card__wishlist');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const handle = (btn as HTMLElement).dataset.handle || '';
    wishlist.toggle(handle);
    btn.classList.toggle('is-wished');

    // Pulse animation
    btn.animate([
      { transform: 'scale(1)' },
      { transform: 'scale(1.3)' },
      { transform: 'scale(1)' },
    ], { duration: 300, easing: 'ease-out' });
  });

  initWishlistHearts();

  // ─── Quick View Modal ───────────────────────
  const qvOverlay = document.getElementById('qv-overlay');
  const qvModal = document.getElementById('qv-modal');
  const qvClose = document.getElementById('qv-close');
  const qvImage = document.getElementById('qv-image') as HTMLImageElement;
  const qvThumbs = document.getElementById('qv-thumbs');
  const qvType = document.getElementById('qv-type');
  const qvTitle = document.getElementById('qv-title');
  const qvPrice = document.getElementById('qv-price');
  const qvCompare = document.getElementById('qv-compare');
  const qvDescription = document.getElementById('qv-description');
  const qvVariants = document.getElementById('qv-variants');
  const qvAdd = document.getElementById('qv-add') as HTMLButtonElement;
  const qvViewFull = document.getElementById('qv-view-full') as HTMLAnchorElement;

  let qvSelectedVariant: any = null;
  let qvImages: string[] = [];
  let qvCurrentImage = 0;
  let qvDismissGeneration = 0;

  function fmtPrice(amount: number): string {
    return amount % 1 === 0 ? `$${amount.toLocaleString()}` : `$${amount.toFixed(2)}`;
  }

  function qvOptimize(url: string) {
    if (!url) return url;
    if (url.includes('cdn.shopify.com')) {
      const sep = url.includes('?') ? '&' : '?';
      return `${url}${sep}width=600&crop=center`;
    }
    return url;
  }

  function openQuickView(data: any) {
    qvImages = JSON.parse(data.images || '[]');
    const variants = JSON.parse(data.variants || '[]');

    if (qvImage && qvImages.length) {
      // Optimize: request 600px for QV modal instead of full-size
      qvImage.src = qvOptimize(qvImages[0]);
      qvImage.alt = data.title;
      qvCurrentImage = 0;
    }

    // Thumbs (dots)
    if (qvThumbs) {
      qvThumbs.innerHTML = qvImages.length > 1
        ? qvImages.map((_: string, i: number) =>
            `<button class="qv-thumb ${i === 0 ? 'qv-thumb--active' : ''}" data-idx="${i}"></button>`
          ).join('')
        : '';
    }

    if (qvType) qvType.textContent = data.type || '';
    if (qvTitle) qvTitle.textContent = data.title || '';
    if (qvPrice) qvPrice.textContent = fmtPrice(parseFloat(data.price));
    if (qvCompare) {
      if (data.comparePrice) {
        qvCompare.textContent = fmtPrice(parseFloat(data.comparePrice));
        qvCompare.style.display = '';
      } else {
        qvCompare.style.display = 'none';
      }
    }
    if (qvDescription) qvDescription.textContent = data.description || '';

    // Variants
    if (qvVariants && variants.length > 1) {
      qvVariants.innerHTML = variants.map((v: any, i: number) =>
        `<button class="qv-variant-btn ${i === 0 ? 'qv-variant-btn--active' : ''}"
          data-idx="${i}" data-variant-id="${v.id}" data-price="${v.price}"
          ${!v.available ? 'disabled' : ''}>
          ${v.title}
        </button>`
      ).join('');
      qvVariants.style.display = '';
    } else if (qvVariants) {
      qvVariants.innerHTML = '';
      qvVariants.style.display = 'none';
    }

    qvSelectedVariant = variants[0] || null;
    if (qvViewFull) qvViewFull.href = `/shop/${data.handle}/`;

    // Disable add if not available or coming soon
    const comingSoon = data.comingSoon === 'true';
    if (qvAdd) {
      qvAdd.disabled = data.available === 'false' || comingSoon;
      qvAdd.textContent = comingSoon ? 'Coming Soon' : data.available === 'false' ? 'Sold Out' : 'Add to Cart';
    }

    // Cancel any in-flight swipe-dismiss cleanup
    qvDismissGeneration++;

    // Show
    qvModal?.setAttribute('aria-hidden', 'false');
    qvOverlay?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeQuickView() {
    qvModal?.setAttribute('aria-hidden', 'true');
    qvOverlay?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  qvOverlay?.addEventListener('click', closeQuickView);
  qvClose?.addEventListener('click', closeQuickView);
  if (_shopKeyHandler) document.removeEventListener('keydown', _shopKeyHandler);
  _shopKeyHandler = (e: KeyboardEvent) => {
    if (e.key === 'Escape' && qvModal?.getAttribute('aria-hidden') === 'false') closeQuickView();
  };
  document.addEventListener('keydown', _shopKeyHandler);

  // Swipe-down-to-dismiss on mobile bottom sheet
  if (qvModal && qvOverlay) {
    let sheetStartX = 0;
    let sheetStartY = 0;
    let sheetStartTime = 0;
    let sheetDragging = false;
    let sheetAxis: 'pending' | 'vertical' | 'horizontal' = 'pending';
    // qvDismissGeneration (shared scope) guards against stale cleanup

    function clearSheetInlineStyles() {
      qvModal.style.transform = '';
      qvModal.style.transition = '';
      qvOverlay.style.opacity = '';
      qvOverlay.style.transition = '';
    }

    qvModal.addEventListener('touchstart', (e) => {
      if (qvModal.scrollTop > 0) return;
      sheetStartX = e.touches[0].clientX;
      sheetStartY = e.touches[0].clientY;
      sheetStartTime = Date.now();
      sheetDragging = true;
      sheetAxis = 'pending';
    }, { passive: true });

    qvModal.addEventListener('touchmove', (e) => {
      if (!sheetDragging || sheetAxis === 'horizontal') return;
      const dx = Math.abs(e.touches[0].clientX - sheetStartX);
      const dy = e.touches[0].clientY - sheetStartY;

      // Lock axis after 10px of movement
      if (sheetAxis === 'pending' && (Math.abs(dy) > 10 || dx > 10)) {
        sheetAxis = Math.abs(dy) > dx ? 'vertical' : 'horizontal';
      }
      if (sheetAxis !== 'vertical') return;

      // Clamp: allow pulling down, snap to 0 if user drags back up
      const offset = Math.max(0, dy);
      qvModal.style.transform = `translateY(${offset}px)`;
      qvModal.style.transition = 'none';
      const progress = Math.min(offset / 300, 1);
      qvOverlay.style.opacity = String(1 - progress * 0.6);
    }, { passive: true });

    qvModal.addEventListener('touchend', (e) => {
      if (!sheetDragging || sheetAxis !== 'vertical') {
        sheetDragging = false;
        return;
      }
      sheetDragging = false;
      const dy = e.changedTouches[0].clientY - sheetStartY;
      const velocity = dy / (Date.now() - sheetStartTime);

      if (dy > 100 || velocity > 0.5) {
        const dismissId = ++qvDismissGeneration;

        // Re-enable transitions, animate modal off-screen
        qvModal.style.transition = '';
        qvModal.style.transform = 'translateY(100%)';

        // Fade overlay from current drag opacity to 0
        requestAnimationFrame(() => {
          qvOverlay.style.transition = 'opacity 0.3s var(--ease-out)';
          qvOverlay.style.opacity = '0';
        });

        // Clean up after animation, guarded by generation counter
        const cleanup = () => {
          if (qvDismissGeneration !== dismissId) return;
          clearSheetInlineStyles();
          closeQuickView();
        };
        const fallback = setTimeout(cleanup, 400);
        qvModal.addEventListener('transitionend', function handler(evt) {
          if ((evt as TransitionEvent).propertyName !== 'transform') return;
          qvModal.removeEventListener('transitionend', handler);
          clearTimeout(fallback);
          cleanup();
        });
      } else {
        // Snap back
        qvModal.style.transition = '';
        qvModal.style.transform = '';
        qvOverlay.style.opacity = '';
      }
    }, { passive: true });
  }

  // Quick view image dots
  qvThumbs?.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest('.qv-thumb') as HTMLElement;
    if (!btn) return;
    const idx = parseInt(btn.dataset.idx || '0');
    qvCurrentImage = idx;
    if (qvImage) qvImage.src = qvOptimize(qvImages[idx]);
    qvThumbs.querySelectorAll('.qv-thumb').forEach((t, i) => {
      t.classList.toggle('qv-thumb--active', i === idx);
    });
  });

  // Quick view touch swipe
  if (qvImage) {
    let qvStartX = 0;
    let qvStartY = 0;
    let qvTracking = false;
    qvImage.addEventListener('touchstart', (e) => {
      qvStartX = e.touches[0].clientX;
      qvStartY = e.touches[0].clientY;
      qvTracking = true;
    }, { passive: true });
    qvImage.addEventListener('touchend', (e) => {
      if (!qvTracking || qvImages.length < 2) return;
      qvTracking = false;
      const dx = e.changedTouches[0].clientX - qvStartX;
      const dy = e.changedTouches[0].clientY - qvStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        qvCurrentImage = dx < 0
          ? (qvCurrentImage + 1) % qvImages.length
          : (qvCurrentImage - 1 + qvImages.length) % qvImages.length;
        qvImage.src = qvOptimize(qvImages[qvCurrentImage]);
        qvThumbs?.querySelectorAll('.qv-thumb').forEach((t, i) => {
          t.classList.toggle('qv-thumb--active', i === qvCurrentImage);
        });
      }
    }, { passive: true });
  }

  // Quick view variant selection
  qvVariants?.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest('.qv-variant-btn') as HTMLElement;
    if (!btn || btn.hasAttribute('disabled')) return;
    qvVariants.querySelectorAll('.qv-variant-btn').forEach(b => b.classList.remove('qv-variant-btn--active'));
    btn.classList.add('qv-variant-btn--active');
    const price = btn.dataset.price;
    if (qvPrice && price) qvPrice.textContent = fmtPrice(parseFloat(price));
    qvSelectedVariant = { id: btn.dataset.variantId, price, title: btn.textContent?.trim() || '' };
    // Switch to variant image if available
    const idx = parseInt(btn.dataset.idx || '0');
    if (qvImages[idx] && qvImage) qvImage.src = qvOptimize(qvImages[idx]);
  });

  // Quick view add to cart
  qvAdd?.addEventListener('click', () => {
    if (!qvSelectedVariant) return;
    window.addToCart?.({
      variantId: qvSelectedVariant.id,
      title: qvTitle?.textContent || '',
      price: parseFloat(qvSelectedVariant.price),
      image: qvImage?.src || '',
      handle: qvViewFull?.href?.split('/shop/')[1] || '',
      variantTitle: qvSelectedVariant.title || '',
    });
    qvAdd.textContent = 'Added!';
    qvAdd.disabled = true;
    setTimeout(() => {
      qvAdd.textContent = 'Add to Cart';
      qvAdd.disabled = false;
    }, 1500);
  });

  // Open quick view from card — merge button dataset with pre-built product data
  grid?.addEventListener('click', async (e) => {
    const btn = (e.target as Element)?.closest('.product-card__quick-view') as HTMLElement;
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();
    const handle = btn.dataset.handle || '';
    // Ensure product data JSON has loaded (usually already cached)
    if ((window as any).__productDataReady) await (window as any).__productDataReady();
    const extra = (window as any).__productData?.[handle] || {};
    openQuickView({
      ...btn.dataset,
      images: JSON.stringify(extra.i || []),
      variants: JSON.stringify(extra.v || []),
      description: extra.d || '',
    });
  });

  // ─── Staggered card entrance animation ────────
  function observeCards() {
    if (typeof IntersectionObserver === 'undefined') return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const card = entry.target as HTMLElement;
          // Stagger based on visible position within viewport batch
          const rect = card.getBoundingClientRect();
          const col = Math.floor((rect.left / window.innerWidth) * 4);
          card.style.transitionDelay = `${col * 60}ms`;
          card.classList.add('card-visible');
          observer.unobserve(card);
        }
      });
    }, { threshold: 0.05, rootMargin: '50px' });

    getCards().forEach(card => {
      if (card.style.display !== 'none') {
        observer.observe(card);
      }
    });
  }

  // ─── Back in Stock badges (fetched from D1 at runtime) ───
  fetch('/api/back-in-stock')
    .then(r => r.ok ? r.json() : [])
    .then((handles: string[]) => {
      if (!handles.length) return;
      const set = new Set(handles);
      for (const card of getCards()) {
        const handle = card.dataset.handle;
        if (!handle || !set.has(handle)) continue;
        // Skip if card already has a higher-priority badge (Sold Out, Coming Soon)
        const existing = card.querySelector('.product-card__badge');
        if (existing) {
          const text = existing.textContent?.trim() || '';
          if (text === 'Sold Out' || text === 'Coming Soon') continue;
          // Replace New or Sale badge with Back in Stock
          existing.remove();
        }
        const badge = document.createElement('span');
        badge.className = 'product-card__badge product-card__badge--back-in-stock';
        badge.textContent = 'Back in Stock';
        card.prepend(badge);
      }
    })
    .catch(() => {}); // Non-critical

  }); // end astro:page-load
</script>
