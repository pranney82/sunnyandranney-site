</style>

<script>
  import { recentlyViewed, wishlist } from '@/lib/cart-store.js';

  // Clean up previous keydown listener on re-init (View Transitions)
  let _pdpKeyHandler: ((e: KeyboardEvent) => void) | null = null;

  document.addEventListener('astro:page-load', () => {
  // ─── DOM refs ───────────────────────────────
  const thumbs = document.querySelectorAll('.pdp-thumb');
  if (!thumbs.length && !document.getElementById('main-product-image')) return;
  const mainImg = document.getElementById('main-product-image') as HTMLImageElement;
  const galleryMain = document.getElementById('gallery-main');
  const variantBtns = document.querySelectorAll('.pdp-variant-btn');
  const addToCartBtn = document.getElementById('add-to-cart') as HTMLButtonElement;
  const selectedLabel = document.getElementById('selected-variant-label');
  const currentPriceEl = document.getElementById('pdp-current-price');
  const comparePriceEl = document.getElementById('pdp-compare-price');
  const qtyInput = document.getElementById('qty-input') as HTMLInputElement;
  const qtyMinus = document.getElementById('qty-minus');
  const qtyPlus = document.getElementById('qty-plus');
  const wishlistBtn = document.getElementById('pdp-wishlist');
  const wishlistText = document.getElementById('wishlist-text');
  const stickyBar = document.getElementById('sticky-bar');
  const stickyAdd = document.getElementById('sticky-add');
  const stickyPrice = document.getElementById('sticky-price');

  function cfImg(url: string, width = 900) {
    if (!url || !url.includes('cdn.shopify.com')) return url;
    const sep = url.includes('?') ? '&' : '?';
    return `${url}${sep}width=${width}&crop=center`;
  }

  // ─── Image data ─────────────────────────────
  const imageUrls = Array.from(thumbs).map(t => (t as HTMLElement).dataset.url || '');
  if (mainImg && !imageUrls.length) imageUrls.push(mainImg.src);
  let currentImageIdx = 0;
  const galleryDots = document.querySelectorAll('.pdp-dot');

  function syncDots(idx: number) {
    galleryDots.forEach((d, i) => d.classList.toggle('pdp-dot--active', i === idx));
  }

  // Dot click → change image
  galleryDots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      currentImageIdx = i;
      syncDots(i);
      thumbs.forEach(t => t.classList.remove('pdp-thumb--active'));
      thumbs[i]?.classList.add('pdp-thumb--active');
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = cfImg(imageUrls[i]);
          mainImg.style.opacity = '1';
        }, 150);
      }
    });
  });

  // ─── Mobile swipe on gallery ───────────────
  if (galleryMain && imageUrls.length > 1) {
    let swipeStartX = 0;
    let swipeStartY = 0;
    let swiping = false;

    galleryMain.addEventListener('touchstart', (e: TouchEvent) => {
      swipeStartX = e.touches[0].clientX;
      swipeStartY = e.touches[0].clientY;
      swiping = true;
    }, { passive: true });

    galleryMain.addEventListener('touchend', (e: TouchEvent) => {
      if (!swiping) return;
      swiping = false;
      const dx = e.changedTouches[0].clientX - swipeStartX;
      const dy = e.changedTouches[0].clientY - swipeStartY;
      // Only trigger on horizontal swipe > 50px with horizontal > vertical
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
        const newIdx = dx < 0
          ? Math.min(currentImageIdx + 1, imageUrls.length - 1)
          : Math.max(currentImageIdx - 1, 0);
        if (newIdx !== currentImageIdx) {
          currentImageIdx = newIdx;
          syncDots(currentImageIdx);
          thumbs.forEach(t => t.classList.remove('pdp-thumb--active'));
          thumbs[currentImageIdx]?.classList.add('pdp-thumb--active');
          if (mainImg) {
            mainImg.style.opacity = '0';
            setTimeout(() => {
              mainImg.src = cfImg(imageUrls[currentImageIdx]);
              mainImg.style.opacity = '1';
            }, 150);
          }
        }
      }
    }, { passive: true });
  }

  // ─── Thumbnail gallery ──────────────────────
  thumbs.forEach((thumb, i) => {
    thumb.addEventListener('click', () => {
      thumbs.forEach(t => t.classList.remove('pdp-thumb--active'));
      thumb.classList.add('pdp-thumb--active');
      currentImageIdx = i;
      syncDots(i);
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = cfImg((thumb as HTMLElement).dataset.url || '');
          mainImg.alt = (thumb as HTMLElement).dataset.alt || '';
          mainImg.style.opacity = '1';
        }, 150);
      }
    });
  });

  // ─── Variant selector ──────────────────────
  variantBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      if ((btn as HTMLButtonElement).disabled) return;

      variantBtns.forEach(b => b.classList.remove('pdp-variant-btn--active'));
      btn.classList.add('pdp-variant-btn--active');

      const el = btn as HTMLElement;
      const variantId = el.dataset.variantId || '';
      const variantPrice = el.dataset.variantPrice || '';
      const variantCompare = el.dataset.variantCompare || '';
      const variantAvailable = el.dataset.variantAvailable === 'true';
      const variantImage = el.dataset.variantImage || '';
      const variantTitle = el.dataset.variantTitle || '';

      // Update add to cart button
      if (addToCartBtn) {
        addToCartBtn.dataset.variantId = variantId;
        addToCartBtn.dataset.variantTitle = variantTitle;
        addToCartBtn.dataset.productPrice = variantPrice;
        addToCartBtn.disabled = !variantAvailable;
        addToCartBtn.textContent = variantAvailable ? 'Add to Cart' : 'Sold Out';
      }

      // Update price display
      if (currentPriceEl) currentPriceEl.textContent = `$${parseFloat(variantPrice).toFixed(2)}`;
      if (comparePriceEl) {
        if (variantCompare && parseFloat(variantCompare) > parseFloat(variantPrice)) {
          comparePriceEl.textContent = `$${parseFloat(variantCompare).toFixed(2)}`;
          comparePriceEl.style.display = '';
        } else {
          comparePriceEl.style.display = 'none';
        }
      }

      // Update sticky bar price
      if (stickyPrice) stickyPrice.textContent = `$${parseFloat(variantPrice).toFixed(2)}`;

      // Update selected label
      if (selectedLabel) selectedLabel.textContent = variantTitle;

      // Switch image if variant has one
      if (variantImage && mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = cfImg(variantImage);
          mainImg.style.opacity = '1';
        }, 150);
        // Update thumb active state
        thumbs.forEach((t, i) => {
          const thumbUrl = (t as HTMLElement).dataset.url || '';
          if (thumbUrl === variantImage) {
            thumbs.forEach(tt => tt.classList.remove('pdp-thumb--active'));
            t.classList.add('pdp-thumb--active');
            currentImageIdx = i;
          }
        });
      }
    });
  });

  // ─── Quantity selector ──────────────────────
  qtyMinus?.addEventListener('click', () => {
    const val = parseInt(qtyInput?.value || '1');
    if (val > 1 && qtyInput) qtyInput.value = String(val - 1);
  });

  qtyPlus?.addEventListener('click', () => {
    const val = parseInt(qtyInput?.value || '1');
    if (val < 99 && qtyInput) qtyInput.value = String(val + 1);
  });

  qtyInput?.addEventListener('change', () => {
    let val = parseInt(qtyInput.value || '1');
    if (isNaN(val) || val < 1) val = 1;
    if (val > 99) val = 99;
    qtyInput.value = String(val);
  });

  // ─── Add to cart ────────────────────────────
  function handleAddToCart() {
    const variantId = addToCartBtn?.dataset.variantId;
    if (!variantId) return;

    const title = addToCartBtn.dataset.productTitle || '';
    const price = parseFloat(addToCartBtn.dataset.productPrice || '0');
    const image = addToCartBtn.dataset.productImage || '';
    const handle = addToCartBtn.dataset.productHandle || '';
    const variantTitle = addToCartBtn.dataset.variantTitle || '';
    const qty = parseInt(qtyInput?.value || '1');

    window.addToCart?.({
      variantId,
      title,
      price,
      image,
      handle,
      variantTitle,
    }, qty);

    addToCartBtn.textContent = 'Added to Cart';
    addToCartBtn.disabled = true;
    setTimeout(() => {
      addToCartBtn.textContent = 'Add to Cart';
      addToCartBtn.disabled = false;
    }, 2000);
  }

  addToCartBtn?.addEventListener('click', handleAddToCart);

  // ─── Buy Now ─────────────────────────────────
  const buyNowBtn = document.getElementById('buy-now');
  buyNowBtn?.addEventListener('click', () => {
    const variantId = addToCartBtn?.dataset.variantId;
    if (!variantId) return;
    const qty = parseInt(qtyInput?.value || '1');
    const numericId = variantId.includes('/') ? variantId.split('/').pop() : variantId;
    const domain = (window as any).__SHOPIFY_DOMAIN || 'sunnyandranney.myshopify.com';
    window.location.href = `https://${domain}/cart/${numericId}:${qty}`;
  });

  // Sticky bar add to cart
  stickyAdd?.addEventListener('click', handleAddToCart);

  // ─── Wishlist ───────────────────────────────
  const pdpHandle = addToCartBtn?.dataset.productHandle || '';

  function updateWishlistUI() {
    const isWished = wishlist.has(pdpHandle);
    if (wishlistBtn) wishlistBtn.classList.toggle('is-wished', isWished);
    if (wishlistText) wishlistText.textContent = isWished ? 'Saved' : 'Add to Wishlist';
  }

  wishlistBtn?.addEventListener('click', () => {
    wishlist.toggle(pdpHandle);
    updateWishlistUI();
    wishlistBtn.animate([
      { transform: 'scale(1)' },
      { transform: 'scale(1.1)' },
      { transform: 'scale(1)' },
    ], { duration: 300, easing: 'ease-out' });
  });

  updateWishlistUI();

  // ─── Touch swipe helper ────────────────────
  function addSwipe(el: HTMLElement, onLeft: () => void, onRight: () => void) {
    let startX = 0;
    let startY = 0;
    let tracking = false;
    el.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      tracking = true;
    }, { passive: true });
    el.addEventListener('touchend', (e) => {
      if (!tracking) return;
      tracking = false;
      const dx = e.changedTouches[0].clientX - startX;
      const dy = e.changedTouches[0].clientY - startY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) onLeft();
        else onRight();
      }
    }, { passive: true });
  }

  // ─── Lightbox ───────────────────────────────
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxCounter = document.getElementById('lightbox-counter');
  let lightboxIdx = 0;

  let lightboxPrevFocus: HTMLElement | null = null;

  // Optimize image URL for lightbox via CF Images (AVIF/WebP, 1400px)
  function optimizedUrl(url: string, width = 1400) {
    return cfImg(url, width);
  }

  function openLightbox(idx: number) {
    lightboxPrevFocus = document.activeElement as HTMLElement;
    lightboxIdx = idx;
    updateLightbox();
    lightbox?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => lightboxClose?.focus(), 50);
  }

  function closeLightbox() {
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lightboxPrevFocus?.focus();
    lightboxPrevFocus = null;
  }

  function updateLightbox() {
    if (lightboxImg) lightboxImg.src = optimizedUrl(imageUrls[lightboxIdx] || '');
    if (lightboxCounter && imageUrls.length > 1) {
      lightboxCounter.textContent = `${lightboxIdx + 1} / ${imageUrls.length}`;
    }
    if (lightboxPrev) lightboxPrev.style.display = imageUrls.length > 1 ? '' : 'none';
    if (lightboxNext) lightboxNext.style.display = imageUrls.length > 1 ? '' : 'none';
    // Preload adjacent images
    if (imageUrls.length > 1) {
      const nextIdx = (lightboxIdx + 1) % imageUrls.length;
      const img = new Image();
      img.src = optimizedUrl(imageUrls[nextIdx]);
    }
  }

  function lightboxGoNext() {
    lightboxIdx = (lightboxIdx + 1) % imageUrls.length;
    updateLightbox();
  }

  function lightboxGoPrev() {
    lightboxIdx = (lightboxIdx - 1 + imageUrls.length) % imageUrls.length;
    updateLightbox();
  }

  galleryMain?.addEventListener('click', () => openLightbox(currentImageIdx));
  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  lightboxPrev?.addEventListener('click', (e) => {
    e.stopPropagation();
    lightboxGoPrev();
  });

  lightboxNext?.addEventListener('click', (e) => {
    e.stopPropagation();
    lightboxGoNext();
  });

  // Touch swipe on lightbox
  if (lightbox) addSwipe(lightbox, lightboxGoNext, lightboxGoPrev);

  // Keyboard navigation (clean up previous handler to avoid duplicates)
  if (_pdpKeyHandler) document.removeEventListener('keydown', _pdpKeyHandler);
  _pdpKeyHandler = (e: KeyboardEvent) => {
    if (lightbox?.getAttribute('aria-hidden') === 'false') {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') lightboxGoPrev();
      if (e.key === 'ArrowRight') lightboxGoNext();
    }
  };
  document.addEventListener('keydown', _pdpKeyHandler);

  // ─── Touch swipe on main gallery image ─────
  if (galleryMain && imageUrls.length > 1) {
    function swipeTo(idx: number) {
      currentImageIdx = idx;
      thumbs.forEach(t => t.classList.remove('pdp-thumb--active'));
      thumbs[currentImageIdx]?.classList.add('pdp-thumb--active');
      syncDots(currentImageIdx);
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = cfImg(imageUrls[currentImageIdx]);
          mainImg.style.opacity = '1';
        }, 150);
      }
    }
    addSwipe(galleryMain,
      () => swipeTo((currentImageIdx + 1) % imageUrls.length),
      () => swipeTo((currentImageIdx - 1 + imageUrls.length) % imageUrls.length)
    );
  }

  // ─── Sticky mobile bar ─────────────────────
  if (stickyBar) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        stickyBar.classList.toggle('is-visible', !entry.isIntersecting);
      },
      { threshold: 0 }
    );
    if (addToCartBtn) observer.observe(addToCartBtn);
  }

  // ─── Frequently Bought Together ──────────────
  const fbtAddAll = document.getElementById('fbt-add-all');
  const fbtChecks = document.querySelectorAll('.fbt-check');
  const fbtTotalPrice = document.getElementById('fbt-total-price');

  // Recalculate FBT total when checkboxes change
  function updateFbtTotal() {
    const currentPrice = parseFloat(addToCartBtn?.dataset.productPrice || '0');
    let total = currentPrice;
    fbtChecks.forEach(cb => {
      if ((cb as HTMLInputElement).checked) {
        total += parseFloat((cb as HTMLElement).dataset.price || '0');
      }
    });
    if (fbtTotalPrice) fbtTotalPrice.textContent = `$${total.toFixed(2)}`;
  }

  fbtChecks.forEach(cb => cb.addEventListener('change', updateFbtTotal));

  fbtAddAll?.addEventListener('click', () => {
    // Add current product
    handleAddToCart();
    // Add checked related items
    fbtChecks.forEach(cb => {
      if (!(cb as HTMLInputElement).checked) return;
      const el = cb as HTMLElement;
      window.addToCart?.({
        variantId: el.dataset.variantId || '',
        title: el.dataset.title || '',
        price: parseFloat(el.dataset.price || '0'),
        image: el.dataset.image || '',
        handle: el.dataset.handle || '',
        variantTitle: '',
      });
    });
    fbtAddAll.textContent = 'All Added!';
    (fbtAddAll as HTMLButtonElement).disabled = true;
    setTimeout(() => {
      fbtAddAll.textContent = 'Add All to Cart';
      (fbtAddAll as HTMLButtonElement).disabled = false;
    }, 2000);
  });

  // ─── Inline Image Zoom (hover) ───────────────
  if (galleryMain && mainImg) {
    galleryMain.addEventListener('mousemove', (e) => {
      const rect = galleryMain.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      mainImg.style.transformOrigin = `${x}% ${y}%`;
      mainImg.style.transform = 'scale(2)';
    });
    galleryMain.addEventListener('mouseleave', () => {
      mainImg.style.transformOrigin = 'center';
      mainImg.style.transform = 'scale(1)';
    });
  }

  // ─── Track recently viewed ──────────────────
  const pdpTitle = addToCartBtn?.dataset.productTitle;
  const pdpImage = addToCartBtn?.dataset.productImage;
  const pdpPrice = addToCartBtn?.dataset.productPrice;
  if (pdpHandle && pdpTitle) {
    recentlyViewed.add({ handle: pdpHandle, title: pdpTitle, image: pdpImage, price: pdpPrice });
  }

  // ─── Render recently viewed ─────────────────
  const recentSection = document.getElementById('recently-section');
  const recentScroll = document.getElementById('recently-scroll');

  if (recentSection && recentScroll) {
    const items = recentlyViewed.getItems().filter((i: any) => i.handle !== pdpHandle);
    if (items.length > 0) {
      recentSection.style.display = '';
      const frag = document.createDocumentFragment();
      items.slice(0, 8).forEach((item: any) => {
        const card = document.createElement('a');
        card.href = `/shop/${encodeURIComponent(item.handle)}`;
        card.className = 'recently-card';

        const imgWrap = document.createElement('div');
        imgWrap.className = 'recently-card__image';
        if (item.image) {
          const img = document.createElement('img');
          // Optimize: 320px (2x retina for 160px card)
          img.src = item.image.includes('cdn.shopify.com') ? `${item.image}?width=320&crop=center` : item.image;
          img.alt = item.title || '';
          img.loading = 'lazy';
          imgWrap.appendChild(img);
        }
        card.appendChild(imgWrap);

        const titleEl = document.createElement('span');
        titleEl.className = 'recently-card__title';
        titleEl.textContent = item.title;
        card.appendChild(titleEl);

        if (item.price) {
          const priceEl = document.createElement('span');
          priceEl.className = 'recently-card__price';
          priceEl.textContent = `$${parseFloat(item.price).toFixed(2)}`;
          card.appendChild(priceEl);
        }

        frag.appendChild(card);
      });
      recentScroll.replaceChildren(frag);
    }
  }
  }); // end astro:page-load
</script>
