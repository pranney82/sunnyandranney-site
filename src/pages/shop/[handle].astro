---
export const prerender = true;

import Base from '@/layouts/Base.astro';
import { cfImage, cfSrcset, SIZES } from '@/lib/images';
import { getCollectionByHandle, getProductByHandle, getProducts } from '@/lib/shopify';
import { getCollectionsStatic, getHeroStatic } from '@/lib/settings';

export async function getStaticPaths() {
  // Only build PDPs for products in admin-enabled collections
  const collectionSettings = await getCollectionsStatic();
  const enabledHandles = collectionSettings
    ?.filter(c => c.enabled)
    .sort((a, b) => a.order - b.order)
    .map(c => c.handle) ?? [];

  const allProducts: any[] = [];
  const seen = new Set<string>();

  for (const handle of enabledHandles) {
    const collection = await getCollectionByHandle(handle, 100);
    if (!collection) continue;
    for (const product of collection.products) {
      if (!seen.has(product.id)) {
        seen.add(product.id);
        allProducts.push(product);
      }
    }
  }

  // Also include new-arrivals collection + hero products — they may be from
  // non-enabled collections and would 404 without pages built for them.
  try {
    const [newArrivals, heroSetting] = await Promise.all([
      getCollectionByHandle('new-arrivals', 8),
      getHeroStatic(),
    ]);

    // Add new arrivals products
    if (newArrivals) {
      for (const p of newArrivals.products) {
        if (!seen.has(p.id)) { seen.add(p.id); allProducts.push(p); }
      }
    } else {
      // Homepage falls back to getProducts(8) — ensure those pages are built
      const { products: fallback } = await getProducts(8);
      for (const p of fallback) {
        if (!seen.has(p.id)) { seen.add(p.id); allProducts.push(p); }
      }
    }

    // Add hero product
    const heroHandle = heroSetting?.productHandle;
    if (heroHandle && !new Set(allProducts.map((p: any) => p.handle)).has(heroHandle)) {
      const heroProduct = await getProductByHandle(heroHandle);
      if (heroProduct && !seen.has(heroProduct.id)) {
        seen.add(heroProduct.id);
        allProducts.push(heroProduct);
      }
    }
  } catch { /* Shopify not configured — skip */ }

  // Build related products map — other products from the same collections
  const relatedMap = new Map<string, any[]>();
  for (const product of allProducts) {
    const others = allProducts
      .filter(p => p.handle !== product.handle && p.productType === product.productType)
      .slice(0, 4);
    if (others.length < 4) {
      // Fill with any other products
      const remaining = allProducts
        .filter(p => p.handle !== product.handle && !others.some(o => o.handle === p.handle))
        .slice(0, 4 - others.length);
      others.push(...remaining);
    }
    relatedMap.set(product.handle, others);
  }

  return allProducts.map(product => ({
    params: { handle: product.handle },
    props: { product, relatedProducts: relatedMap.get(product.handle) || [] },
  }));
}

const { handle } = Astro.params;
const { product, relatedProducts } = Astro.props;

if (!product) {
  return Astro.redirect('/shop/');
}

const images = product.images.edges.map((e: any) => e.node);
const variants = product.variants.edges.map((e: any) => e.node);
const mainImage = images[0];
const lcpImage = mainImage ? cfImage(mainImage.url, { width: 900 }) : undefined;
const price = product.priceRange.minVariantPrice;
const compareAt = product.compareAtPriceRange?.minVariantPrice;
const isOnSale = compareAt && parseFloat(compareAt.amount) > parseFloat(price.amount);

// Extract videos from media
const videos = (product.media?.edges || [])
  .filter((e: any) => e.node.mediaContentType === 'VIDEO' || e.node.mediaContentType === 'EXTERNAL_VIDEO')
  .map((e: any) => e.node);

// Low stock threshold - show urgency when <= 5 items left
const firstVariant = variants[0];
const stockQty = firstVariant?.quantityAvailable;
const isLowStock = stockQty !== null && stockQty > 0 && stockQty <= 5;
const isSoldOut = !product.availableForSale;
const isComingSoon = product.tags?.some((t: string) => t.toLowerCase() === 'coming soon');
const isNewArrival = product.createdAt && (Date.now() - new Date(product.createdAt).getTime()) < 30 * 24 * 60 * 60 * 1000;

// Price formatter — drops .00 on whole numbers ($800 not $800.00)
function fmt(amount: number): string {
  return amount % 1 === 0 ? `$${amount.toLocaleString()}` : `$${amount.toFixed(2)}`;
}

const productUrl = `https://sunnyandranney.com/shop/${product.handle}/`;

// Full Product schema — drives Google Shopping rich results
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: product.description || product.seo?.description || '',
  sku: product.handle,
  brand: { '@type': 'Brand', name: product.vendor || 'Sunny & Ranney' },
  url: productUrl,
  image: images.map((img: any) => img.url),
  offers: {
    '@type': 'Offer',
    url: productUrl,
    price: parseFloat(price.amount).toFixed(2),
    priceCurrency: price.currencyCode,
    availability: product.availableForSale
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    itemCondition: 'https://schema.org/NewCondition',
    seller: { '@type': 'Organization', name: 'Sunny & Ranney' },
    availableAtOrFrom: {
      '@type': 'Place',
      name: 'Sunny & Ranney Showroom',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '109A Oak Street',
        addressLocality: 'Roswell',
        addressRegion: 'GA',
        postalCode: '30075',
        addressCountry: 'US',
      },
    },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://sunnyandranney.com' },
    { '@type': 'ListItem', position: 2, name: 'Shop', item: 'https://sunnyandranney.com/shop/' },
    ...(product.productType ? [
      { '@type': 'ListItem', position: 3, name: product.productType.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' '), item: `https://sunnyandranney.com/shop/?type=${encodeURIComponent(product.productType)}` },
      { '@type': 'ListItem', position: 4, name: product.title, item: productUrl },
    ] : [
      { '@type': 'ListItem', position: 3, name: product.title, item: productUrl },
    ]),
  ],
};
---

<Base
  title={product.seo?.title || product.title}
  description={product.seo?.description || product.description?.slice(0, 160)}
  image={mainImage?.url}
  lcpImage={lcpImage}
  type="product"
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="pdp section">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li><a href="/">Home</a></li>
          <li><a href="/shop/">Shop</a></li>
          {product.productType && (
            <li><a href={`/shop/?type=${encodeURIComponent(product.productType)}`}>{product.productType.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ')}</a></li>
          )}
          <li aria-current="page">{product.title}</li>
        </ol>
      </nav>

      <div class="pdp-grid">
        <!-- Image Gallery -->
        <div class="pdp-gallery">
          <div class="pdp-gallery__main" id="gallery-main">
            {mainImage ? (
              <img
                src={cfImage(mainImage.url, { width: 900 })}
                srcset={cfSrcset(mainImage.url, [450, 900, 1400])}
                sizes={SIZES.pdpMain}
                alt={mainImage.altText || product.title}
                width={mainImage.width}
                height={mainImage.height}
                fetchpriority="high"
                decoding="sync"
                id="main-product-image"
              />
            ) : (
              <div class="pdp-gallery__placeholder">No Image</div>
            )}
            <span class="product-card__badge product-card__badge--back-in-stock" id="pdp-back-in-stock-badge" style="display:none">Back in Stock</span>
            {isNewArrival && <span class="product-card__badge product-card__badge--new" id="pdp-new-badge">New</span>}
            {!isNewArrival && isOnSale && <span class="product-card__badge" id="pdp-sale-badge">Sale</span>}

            {/* Zoom hint */}
            <div class="pdp-zoom-hint" id="zoom-hint">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              <span>Hover to zoom</span>
            </div>
          </div>
          {images.length > 1 && (
            <>
              {/* Mobile dot indicators */}
              <div class="pdp-gallery__dots" id="gallery-dots">
                {images.map((_: any, i: number) => (
                  <button
                    class:list={['pdp-dot', { 'pdp-dot--active': i === 0 }]}
                    data-idx={i}
                    aria-label={`Image ${i + 1}`}
                  />
                ))}
              </div>
              {/* Desktop thumbnails */}
              <div class="pdp-gallery__thumbs">
                {images.map((img: any, i: number) => (
                  <button
                    class:list={['pdp-thumb', { 'pdp-thumb--active': i === 0 }]}
                    data-url={img.url}
                    data-alt={img.altText || product.title}
                    data-idx={i}
                    data-type="image"
                  >
                    <img src={cfImage(img.url, { width: 150 })} alt={img.altText || `${product.title} ${i + 1}`} loading="lazy" />
                  </button>
                ))}
                {/* Video thumbnails */}
                {videos.map((video: any, i: number) => (
                  <button
                    class="pdp-thumb pdp-thumb--video"
                    data-type="video"
                    data-video-url={video.sources?.[0]?.url || video.embeddedUrl || ''}
                    data-video-type={video.mediaContentType}
                    data-idx={images.length + i}
                  >
                    <img
                      src={video.previewImage?.url ? cfImage(video.previewImage.url, { width: 150 }) : '/placeholder-video.svg'}
                      alt={`${product.title} video ${i + 1}`}
                      loading="lazy"
                    />
                    <span class="pdp-thumb__play">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </span>
                  </button>
                ))}
              </div>
            </>
          )}
        </div>

        <!-- Product Info -->
        <div class="pdp-info">
          {product.productType && <span class="label">{product.productType}</span>}
          <h1>{product.title}</h1>

          <div class="pdp-price" id="pdp-price-area">
            <span class="pdp-price__current" id="pdp-current-price">
              {fmt(parseFloat(price.amount))}
            </span>
            {isOnSale && (
              <span class="pdp-price__compare" id="pdp-compare-price">
                {fmt(parseFloat(compareAt.amount))}
              </span>
            )}
            {isOnSale && (
              <span class="pdp-price__save">
                Save ${(parseFloat(compareAt.amount) - parseFloat(price.amount)).toFixed(0)}
              </span>
            )}
          </div>

          {/* Low stock urgency indicator */}
          {isLowStock && (
            <div class="pdp-urgency" id="pdp-urgency">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
              <span>Only <strong id="stock-count">{stockQty}</strong> left in stock — order soon</span>
            </div>
          )}

          <hr class="divider" />

          {/* Variant selector with grouped options */}
          {variants.length > 1 && (
            <div class="pdp-variants" id="pdp-variants">
              <label class="pdp-variants__label">
                Options: <span class="pdp-variants__selected" id="selected-variant-label">{variants[0].title}</span>
              </label>
              <div class="pdp-variants__options">
                {variants.map((v: any, i: number) => (
                  <button
                    class:list={['pdp-variant-btn', { 'pdp-variant-btn--active': i === 0 }]}
                    data-variant-id={v.id}
                    data-variant-price={v.price.amount}
                    data-variant-compare={v.compareAtPrice?.amount || ''}
                    data-variant-available={String(v.availableForSale)}
                    data-variant-image={v.image?.url || ''}
                    data-variant-title={v.title}
                    data-variant-qty={v.quantityAvailable ?? ''}
                    disabled={!v.availableForSale}
                  >
                    {v.title}
                    {!v.availableForSale && <span class="pdp-variant-btn__sold">(Sold Out)</span>}
                  </button>
                ))}
              </div>
            </div>
          )}

          {/* Quantity selector */}
          <div class="pdp-qty">
            <label class="pdp-qty__label">Quantity</label>
            <div class="pdp-qty__controls">
              <button class="pdp-qty__btn" id="qty-minus" aria-label="Decrease quantity">−</button>
              <input type="number" class="pdp-qty__input" id="qty-input" value="1" min="1" max="99" aria-label="Quantity" />
              <button class="pdp-qty__btn" id="qty-plus" aria-label="Increase quantity">+</button>
            </div>
          </div>

          <div class="pdp-actions">
            <button
              class="btn btn--gold pdp-add-to-cart"
              id="add-to-cart"
              data-variant-id={variants[0]?.id}
              data-product-title={product.title}
              data-product-price={price.amount}
              data-product-image={mainImage?.url || ''}
              data-product-handle={product.handle}
              data-variant-title={variants[0]?.title || ''}
              data-variant-qty={firstVariant?.quantityAvailable ?? ''}
              disabled={!product.availableForSale || isComingSoon}
            >
              {isComingSoon ? 'Coming Soon' : product.availableForSale ? 'Add to Cart' : 'Sold Out'}
            </button>

            {product.availableForSale && !isComingSoon && (
              <button
                class="btn btn--primary pdp-buy-now"
                id="buy-now"
              >
                Buy Now
              </button>
            )}
          </div>

          {/* Sold out — direct to showroom */}
          {isSoldOut && (
            <div class="pdp-notify" id="pdp-notify">
              <p class="pdp-notify__text">This item is currently sold out. Visit our showroom or call us to ask about availability and upcoming inventory.</p>
              <a href="tel:+16788885140" class="btn btn--outline pdp-notify__btn" style="text-align:center;">Call (678) 888-5140</a>
            </div>
          )}


          <div class="pdp-secondary-actions">
            <button class="pdp-wishlist-btn" id="pdp-wishlist" data-handle={product.handle} aria-label="Add to wishlist">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              <span id="wishlist-text">Save</span>
            </button>
            <button class="pdp-share-btn" id="pdp-share" aria-label="Share product">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              <span>Share</span>
            </button>
          </div>

          {/* Shop Pay Installments for items $50+ */}
          {product.availableForSale && parseFloat(price.amount) >= 50 && (
            <div class="pdp-installments">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              <span>4 interest-free payments of <strong>{fmt(parseFloat(price.amount) / 4)}</strong> with Shop Pay</span>
            </div>
          )}

          {/* Local pickup only */}
          <div class="pdp-delivery">
            <div class="pdp-delivery__item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <div>
                <strong class="pdp-delivery__label">Local Pickup Only</strong>
                <span class="pdp-delivery__date">No shipping — visit our Roswell showroom</span>
              </div>
            </div>
          </div>

          {/* Trust signals */}
          <div class="pdp-trust">
            <div class="pdp-trust__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>Secure checkout via Shopify</span>
            </div>
            <div class="pdp-trust__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
              <span>100% of profits help kids</span>
            </div>
            <div class="pdp-trust__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>In-store pickup available</span>
            </div>
          </div>

          <div class="pdp-charity-note">
            <span class="pdp-charity-note__icon"></span>
            <p>
              This purchase supports <strong>Sunshine on a Ranney Day</strong> —
              100% of profits fund home makeovers for kids with special needs. <a href="/about/" style="color:inherit;text-decoration:underline;text-underline-offset:3px;">Our&nbsp;mission&nbsp;→</a>
            </p>
          </div>

          {/* ─── Product Details Accordion ─── */}
          <div class="pdp-accordion">
            <details class="pdp-accordion__item" open>
              <summary class="pdp-accordion__header">
                <span>Product Details</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pdp-accordion__content">
                <div class="pdp-details-content" set:html={product.descriptionHtml || product.description} />
              </div>
            </details>

            <details class="pdp-accordion__item">
              <summary class="pdp-accordion__header">
                <span>Shipping & Pickup</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pdp-accordion__content">
                <p><strong>Local Pickup Only</strong></p>
                <p>All items are available for pickup at our Roswell, GA showroom:</p>
                <p>109A Oak Street, Roswell, GA 30075</p>
                <p>We do not currently offer shipping. Stop by to see our full collection in person!</p>
              </div>
            </details>

            <details class="pdp-accordion__item">
              <summary class="pdp-accordion__header">
                <span>Returns & Care</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pdp-accordion__content">
                <p>All sales are final. Please inspect items carefully before purchase.</p>
                <p>For care instructions specific to your item, please ask a team member at pickup.</p>
              </div>
            </details>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══ FREQUENTLY BOUGHT TOGETHER ═══ */}
  {relatedProducts.length >= 2 && (
    <section class="fbt-section section">
      <div class="container">
        <h2 class="fbt-title reveal">Frequently Bought Together</h2>
        <div class="fbt-row reveal">
          <div class="fbt-item fbt-item--current">
            <div class="fbt-item__image">
              {mainImage && <img src={cfImage(mainImage.url, { width: 300 })} alt={product.title} loading="lazy" />}
            </div>
            <span class="fbt-item__name">{product.title}</span>
            <span class="fbt-item__price">{fmt(parseFloat(price.amount))}</span>
            <span class="fbt-item__this">This item</span>
          </div>
          <span class="fbt-plus">+</span>
          {relatedProducts.slice(0, 2).map((rp: any, rpIdx: number) => {
            const rpImage = rp.images.edges[0]?.node;
            const rpPrice = rp.priceRange.minVariantPrice;
            const rpVariant = rp.variants?.edges[0]?.node;
            const isLast = rpIdx === Math.min(relatedProducts.length, 2) - 1;
            return (
              <>
                <div class="fbt-item">
                  <input type="checkbox" class="fbt-check" checked
                    data-variant-id={rpVariant?.id || ''}
                    data-title={rp.title}
                    data-price={rpPrice.amount}
                    data-image={rpImage?.url || ''}
                    data-handle={rp.handle}
                  />
                  <a href={`/shop/${rp.handle}/`} class="fbt-item__image">
                    {rpImage && <img src={cfImage(rpImage.url, { width: 300 })} alt={rp.title} loading="lazy" />}
                  </a>
                  <a href={`/shop/${rp.handle}/`} class="fbt-item__name">{rp.title}</a>
                  <span class="fbt-item__price">{fmt(parseFloat(rpPrice.amount))}</span>
                </div>
                {!isLast && <span class="fbt-plus">+</span>}
              </>
            );
          })}
          <div class="fbt-total">
            <span class="fbt-total__label">Bundle Price</span>
            <span class="fbt-total__price" id="fbt-total-price">
              {fmt(parseFloat(price.amount) + relatedProducts.slice(0, 2).reduce((s: number, rp: any) => s + parseFloat(rp.priceRange.minVariantPrice.amount), 0))}
            </span>
            <button class="btn btn--gold fbt-total__btn" id="fbt-add-all">Add All to Cart</button>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* ═══ RELATED PRODUCTS ═══ */}
  {relatedProducts.length > 0 && (
    <section class="related-section section">
      <div class="container">
        <h2 class="related-title reveal">You Might Also Love</h2>
        <div class="related-grid reveal">
          {relatedProducts.map((rp: any) => {
            const rpImage = rp.images.edges[0]?.node;
            const rpPrice = rp.priceRange.minVariantPrice;
            return (
              <a href={`/shop/${rp.handle}/`} class="related-card">
                <div class="related-card__image">
                  {rpImage && (
                    <img
                      src={cfImage(rpImage.url, { width: 400 })}
                      srcset={cfSrcset(rpImage.url, [200, 400, 600])}
                      sizes={SIZES.related}
                      alt={rpImage.altText || rp.title}
                      width={rpImage.width}
                      height={rpImage.height}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <div class="related-card__info">
                  {rp.productType && <span class="related-card__type">{rp.productType}</span>}
                  <span class="related-card__title">{rp.title}</span>
                  <span class="related-card__price">{fmt(parseFloat(rpPrice.amount))}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* ═══ RECENTLY VIEWED ═══ */}
  <section class="recently-section section" id="recently-section" style="display:none;">
    <div class="container">
      <h2 class="recently-title">Recently Viewed</h2>
      <div class="recently-scroll" id="recently-scroll"></div>
    </div>
  </section>

  {/* ═══ LIGHTBOX ═══ */}
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox__close" id="lightbox-close" aria-label="Close zoom">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="lightbox__nav lightbox__prev" id="lightbox-prev" aria-label="Previous image">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="lightbox__nav lightbox__next" id="lightbox-next" aria-label="Next image">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 6 15 12 9 18"/></svg>
    </button>
    <img class="lightbox__img" id="lightbox-img" src="" alt="" decoding="async" />
    <div class="lightbox__counter" id="lightbox-counter"></div>
  </div>

  {/* ═══ STICKY MOBILE BAR ═══ */}
  <div class="sticky-bar" id="sticky-bar">
    <div class="sticky-bar__info">
      <span class="sticky-bar__title">{product.title}</span>
      <span class="sticky-bar__price" id="sticky-price">{fmt(parseFloat(price.amount))}</span>
    </div>
    <button class="btn btn--gold sticky-bar__btn" id="sticky-add" disabled={!product.availableForSale || isComingSoon}>
      {isComingSoon ? 'Coming Soon' : product.availableForSale ? 'Add to Cart' : 'Sold Out'}
    </button>
  </div>

  {/* ═══ STICKY DESKTOP HEADER ═══ */}
  <div class="sticky-header" id="sticky-header" aria-hidden="true">
    <div class="container sticky-header__inner">
      <div class="sticky-header__product">
        {mainImage && (
          <img
            src={cfImage(mainImage.url, { width: 80 })}
            alt={product.title}
            class="sticky-header__img"
          />
        )}
        <div class="sticky-header__details">
          <span class="sticky-header__title">{product.title}</span>
          <span class="sticky-header__price" id="sticky-header-price">{fmt(parseFloat(price.amount))}</span>
        </div>
      </div>
      <div class="sticky-header__actions">
        {isLowStock && (
          <span class="sticky-header__urgency">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
            Only {stockQty} left
          </span>
        )}
        <button
          class="btn btn--gold sticky-header__atc"
          id="sticky-header-add"
          disabled={!product.availableForSale || isComingSoon}
        >
          {isComingSoon ? 'Coming Soon' : product.availableForSale ? 'Add to Cart' : 'Sold Out'}
        </button>
      </div>
    </div>
  </div>
</Base>

<style>
  .breadcrumbs {
    margin-bottom: var(--space-lg);
  }

  .breadcrumbs__list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.78rem;
    color: var(--color-stone);
  }

  .breadcrumbs__list li {
    display: flex;
    align-items: center;
  }

  /* Chevron separator between items */
  .breadcrumbs__list li + li::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    border-right: 1.5px solid var(--color-stone);
    border-top: 1.5px solid var(--color-stone);
    transform: rotate(45deg);
    margin: 0 0.6rem;
    opacity: 0.6;
    flex-shrink: 0;
  }

  .breadcrumbs__list a {
    color: var(--color-stone);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumbs__list a:hover {
    color: var(--color-charcoal);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-cream-dark);
  }

  /* Current page — not a link, darker color */
  .breadcrumbs__list li[aria-current="page"] {
    color: var(--color-charcoal);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 280px;
  }

  @media (min-width: 768px) {
    .breadcrumbs__list li[aria-current="page"] {
      max-width: 400px;
    }
  }

  .pdp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .pdp-grid { grid-template-columns: 1.1fr 1fr; gap: var(--space-2xl); }
  }

  /* ─── Gallery ──────────────────────────── */
  .pdp-gallery__main {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-cream-dark);
    cursor: zoom-in;
  }

  .pdp-gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease, opacity 0.2s ease;
    will-change: transform;
  }

  .pdp-zoom-hint {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
    border-radius: 4px;
    font-size: 0.72rem;
    color: var(--color-slate);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .pdp-gallery__main:hover .pdp-zoom-hint { opacity: 1; }

  .pdp-gallery__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    color: var(--color-stone);
  }

  /* Mobile dot indicators */
  .pdp-gallery__dots {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  @media (min-width: 768px) {
    .pdp-gallery__dots { display: none; }
  }

  .pdp-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-cream-dark);
    border: 1.5px solid var(--color-stone);
    padding: 0;
    cursor: pointer;
    transition: all 0.2s;
  }

  .pdp-dot--active {
    background: var(--color-charcoal);
    border-color: var(--color-charcoal);
    transform: scale(1.2);
  }

  .pdp-gallery__thumbs {
    display: none;
    gap: 0.5rem;
    margin-top: 0.75rem;
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-cream-dark) transparent;
  }

  @media (min-width: 768px) {
    .pdp-gallery__thumbs { display: flex; }
  }

  .pdp-thumb {
    width: 72px;
    height: 72px;
    overflow: hidden;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.3s, opacity 0.3s;
  }

  .pdp-thumb--active,
  .pdp-thumb:hover { border-color: var(--color-charcoal); }

  .pdp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ─── Info ─────────────────────────────── */
  .pdp-info h1 {
    margin: 0.5rem 0 0.75rem;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
  }

  .pdp-price { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: var(--space-md); flex-wrap: wrap; }
  .pdp-price__current { font-family: var(--font-display); font-size: 1.8rem; font-weight: 600; }
  .pdp-price__compare { font-size: 1.1rem; color: var(--color-stone); text-decoration: line-through; }
  .pdp-price__save {
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
    background: #27ae60;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    letter-spacing: 0.02em;
  }

  /* ─── Low Stock Urgency ─────────────────── */
  .pdp-urgency {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.9rem;
    background: #fef3cd;
    border: 1px solid #f0c674;
    border-radius: 4px;
    font-size: 0.82rem;
    color: #856404;
    margin-bottom: var(--space-md);
    animation: pulse-urgency 2s ease-in-out infinite;
  }

  .pdp-urgency svg { color: #e67e22; flex-shrink: 0; }
  .pdp-urgency strong { font-weight: 700; }

  @keyframes pulse-urgency {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.85; }
  }

  /* ─── Back in Stock Notification ─────────── */
  .pdp-notify {
    margin: var(--space-md) 0;
    padding: var(--space-md);
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
  }

  .pdp-notify__text {
    font-size: 0.85rem;
    color: var(--color-slate);
    margin: 0 0 0.75rem;
    line-height: 1.6;
  }

  .pdp-notify__btn {
    padding: 0.75rem 1.25rem;
    font-size: 0.78rem;
    white-space: nowrap;
    display: inline-flex;
    justify-content: center;
  }

  /* ─── Video Thumbnail ───────────────────── */
  .pdp-thumb--video { position: relative; }

  .pdp-thumb__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.35);
    color: white;
    transition: background 0.2s;
  }

  .pdp-thumb--video:hover .pdp-thumb__play { background: rgba(0,0,0,0.5); }

  /* ─── Video Container ───────────────────── */
  .pdp-video-container {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    z-index: 5;
  }

  .pdp-video {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .pdp-variants { margin: var(--space-md) 0; }
  .pdp-variants__label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }
  .pdp-variants__selected {
    font-weight: 400;
    color: var(--color-slate);
    text-transform: none;
    letter-spacing: 0;
  }
  .pdp-variants__options { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .pdp-variant-btn {
    padding: 0.6rem 1.25rem;
    border: 1.5px solid var(--color-cream-dark);
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.3s;
    position: relative;
    background: none;
    font-family: var(--font-body);
    cursor: pointer;
  }

  .pdp-variant-btn:hover:not(:disabled) { border-color: var(--color-charcoal); }
  .pdp-variant-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .pdp-variant-btn--active { border-color: var(--color-charcoal); background: var(--color-charcoal); color: var(--color-cream); }
  .pdp-variant-btn__sold { font-size: 0.7rem; color: var(--color-stone); margin-left: 0.25rem; }
  .pdp-variant-btn--active .pdp-variant-btn__sold { color: var(--color-cream-dark); }

  /* ─── Quantity ─────────────────────────── */
  .pdp-qty { margin: var(--space-md) 0; }
  .pdp-qty__label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }
  .pdp-qty__controls {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 4px;
    overflow: hidden;
  }
  .pdp-qty__btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--color-charcoal);
    transition: background 0.2s;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
  }
  .pdp-qty__btn:hover { background: var(--color-cream-dark); }
  .pdp-qty__input {
    width: 50px;
    height: 44px;
    text-align: center;
    border: none;
    border-left: 1.5px solid var(--color-cream-dark);
    border-right: 1.5px solid var(--color-cream-dark);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    background: none;
    outline: none;
    -moz-appearance: textfield;
  }
  .pdp-qty__input::-webkit-inner-spin-button,
  .pdp-qty__input::-webkit-outer-spin-button { -webkit-appearance: none; }

  /* ─── Actions ──────────────────────────── */
  .pdp-actions {
    display: flex;
    gap: 0.75rem;
    margin: var(--space-lg) 0 0.5rem;
    align-items: stretch;
  }

  .pdp-add-to-cart {
    flex: 1;
    justify-content: center;
    padding: 1.1rem 2rem;
    font-size: 0.9rem;
  }

  .pdp-buy-now {
    flex: 1;
    justify-content: center;
    padding: 1.1rem 2rem;
    font-size: 0.9rem;
  }

  .pdp-secondary-actions {
    display: flex;
    gap: 0.5rem;
    margin-bottom: var(--space-sm);
  }

  .pdp-wishlist-btn,
  .pdp-share-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    border: 1.5px solid var(--color-cream-dark);
    color: var(--color-slate);
    font-size: 0.75rem;
    font-weight: 500;
    transition: all 0.3s;
    background: none;
    cursor: pointer;
    font-family: var(--font-body);
    white-space: nowrap;
  }

  .pdp-wishlist-btn:hover,
  .pdp-share-btn:hover { border-color: var(--color-charcoal); color: var(--color-charcoal); }
  .pdp-wishlist-btn.is-wished { color: #e74c3c; border-color: #e74c3c; }
  .pdp-wishlist-btn.is-wished svg { fill: #e74c3c; }

  /* ─── Shop Pay Installments ───────────── */
  .pdp-installments {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem var(--space-md);
    background: var(--color-gold-soft);
    font-size: 0.82rem;
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
  }

  .pdp-installments svg { color: var(--color-charcoal); flex-shrink: 0; }

  /* ─── Delivery & Shipping ──────────────── */
  .pdp-delivery {
    margin: var(--space-md) 0;
    padding: var(--space-md);
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pdp-delivery__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .pdp-delivery__item svg {
    color: var(--color-charcoal);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pdp-delivery__label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .pdp-delivery__date {
    font-size: 0.78rem;
    color: var(--color-slate);
  }

  .pdp-delivery__free-hint {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--color-gold);
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-cream-dark);
  }

  .pdp-delivery__free-hint svg { color: var(--color-gold); flex-shrink: 0; }

  /* ─── Trust signals ────────────────────── */
  .pdp-trust {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: var(--space-md) 0;
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-cream-dark);
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .pdp-trust__item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--color-slate);
  }

  .pdp-trust__item svg { color: var(--color-gold); flex-shrink: 0; }

  /* ─── Charity note ─────────────────────── */
  .pdp-charity-note {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: var(--space-md);
    background: var(--color-gold-soft);
    margin-top: var(--space-md);
  }

  .pdp-charity-note__icon { font-size: 1.5rem; flex-shrink: 0; }
  .pdp-charity-note p { font-size: 0.85rem; color: var(--color-charcoal); margin: 0; max-width: none; }

  /* ─── Product Details Accordion ─────────── */
  .pdp-accordion {
    margin-top: var(--space-lg);
    border-top: 1px solid var(--color-cream-dark);
  }

  .pdp-accordion__item {
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .pdp-accordion__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-charcoal);
    list-style: none;
    transition: color 0.2s;
  }

  .pdp-accordion__header::-webkit-details-marker { display: none; }
  .pdp-accordion__header:hover { color: var(--color-gold); }

  .pdp-accordion__header svg {
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .pdp-accordion__item[open] .pdp-accordion__header svg {
    transform: rotate(180deg);
  }

  .pdp-accordion__content {
    padding: 0 0 1rem;
    font-size: 0.85rem;
    color: var(--color-slate);
    line-height: 1.7;
  }

  .pdp-accordion__content p {
    margin: 0 0 0.5rem;
  }

  .pdp-details-content {
    font-size: 0.85rem;
    color: var(--color-slate);
    line-height: 1.7;
  }

  .pdp-details-content p { margin: 0 0 0.75rem; }
  .pdp-details-content ul { margin: 0.5rem 0; padding-left: 1.25rem; }
  .pdp-details-content li { margin: 0.25rem 0; }

  /* ─── Frequently Bought Together ─────────── */
  .fbt-section {
    background: var(--color-warm-white);
    border-top: 1px solid var(--color-cream-dark);
  }

  .fbt-title {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .fbt-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .fbt-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    max-width: 160px;
    text-align: center;
    position: relative;
  }

  .fbt-item__image {
    width: 120px;
    height: 120px;
    overflow: hidden;
    background: var(--color-cream-dark);
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .fbt-item--current .fbt-item__image {
    border-color: var(--color-gold);
  }

  .fbt-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fbt-item__name {
    font-family: var(--font-display);
    font-size: 0.82rem;
    line-height: 1.3;
    color: var(--color-charcoal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  a.fbt-item__name:hover { color: var(--color-gold); }

  .fbt-item__price {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .fbt-item__this {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-slate);
  }

  .fbt-check {
    position: absolute;
    top: -4px;
    right: 16px;
    width: 18px;
    height: 18px;
    accent-color: var(--color-gold);
    cursor: pointer;
  }

  .fbt-plus {
    font-size: 1.5rem;
    color: var(--color-stone);
    font-weight: 300;
  }

  .fbt-total {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    min-width: 180px;
  }

  .fbt-total__label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-slate);
  }

  .fbt-total__price {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .fbt-total__btn {
    font-size: 0.72rem;
    padding: 0.7rem 1.5rem;
  }

  @media (max-width: 768px) {
    .fbt-row {
      flex-direction: column;
    }
    .fbt-plus {
      font-size: 1.2rem;
    }
  }

  /* ─── Related Products ─────────────────── */
  .related-section {
    background: var(--color-warm-white);
    border-top: 1px solid var(--color-cream-dark);
  }

  .related-title {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .related-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .related-card {
    background: var(--color-cream);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
    overflow: hidden;
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(44,44,44,0.08);
  }

  .related-card__image {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-cream-dark);
  }

  .related-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .related-card:hover .related-card__image img { transform: scale(1.05); }

  .related-card__info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .related-card__type {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-slate);
  }

  .related-card__title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-charcoal);
  }

  .related-card__price {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-charcoal);
  }

  /* ─── Recently Viewed ──────────────────── */
  .recently-section {
    border-top: 1px solid var(--color-cream-dark);
  }

  .recently-title {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
  }

  .recently-scroll {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-cream-dark) transparent;
  }

  .recently-card {
    flex-shrink: 0;
    width: 160px;
    scroll-snap-align: start;
    transition: transform 0.3s;
  }

  .recently-card:hover { transform: translateY(-3px); }

  .recently-card__image {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-cream-dark);
    margin-bottom: 0.4rem;
  }

  .recently-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .recently-card__title {
    font-family: var(--font-display);
    font-size: 0.82rem;
    line-height: 1.3;
    color: var(--color-charcoal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recently-card__price {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-slate);
    display: block;
    margin-top: 0.1rem;
  }

  /* ─── Lightbox ─────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 600;
    background: rgba(0,0,0,0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
    cursor: zoom-out;
  }

  .lightbox[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .lightbox__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    color: white;
    padding: 0.5rem;
    z-index: 2;
    transition: color 0.2s;
  }
  .lightbox__close:hover { color: var(--color-gold); }

  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: white;
    padding: 1rem;
    z-index: 2;
    transition: color 0.2s;
  }
  .lightbox__nav:hover { color: var(--color-gold); }
  .lightbox__prev { left: 0.5rem; }
  .lightbox__next { right: 0.5rem; }

  .lightbox__img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    cursor: default;
    transition: transform 0.3s;
  }

  .lightbox__counter {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.7);
    font-size: 0.8rem;
  }

  /* ─── Sticky Mobile Bar ────────────────── */
  .sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-cream);
    border-top: 1px solid var(--color-cream-dark);
    padding: 0.75rem 1rem;
    display: none;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    z-index: 90;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
    transform: translateY(100%);
    transition: transform 0.3s var(--ease-out);
  }

  .sticky-bar.is-visible {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .sticky-bar { display: flex; }
  }

  @media (min-width: 769px) {
    .sticky-bar { bottom: 0; }
  }

  .sticky-bar__info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .sticky-bar__title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sticky-bar__price {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .sticky-bar__btn {
    flex-shrink: 0;
    padding: 0.75rem 1.5rem;
    font-size: 0.78rem;
  }

  @media (max-width: 768px) {
    .pdp-actions { flex-direction: column; }
  }

  /* ─── Sticky Desktop Header ─────────────── */
  .sticky-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-cream-dark);
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
    transform: translateY(-100%);
    opacity: 0;
    transition: transform 0.35s var(--ease-out), opacity 0.35s var(--ease-out);
    display: none;
  }

  .sticky-header[aria-hidden="false"] {
    transform: translateY(0);
    opacity: 1;
  }

  @media (min-width: 769px) {
    .sticky-header { display: block; }
  }

  .sticky-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    gap: 1rem;
  }

  .sticky-header__product {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .sticky-header__img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .sticky-header__details {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .sticky-header__title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 300px;
  }

  .sticky-header__price {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .sticky-header__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .sticky-header__urgency {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #e67e22;
    white-space: nowrap;
  }

  .sticky-header__urgency svg { flex-shrink: 0; }

  .sticky-header__atc {
    padding: 0.7rem 1.75rem;
    font-size: 0.78rem;
    white-space: nowrap;
  }

  /* ─── Enhanced Zoom Lens ────────────────── */
  @media (min-width: 769px) {
    .pdp-gallery__main {
      --lens-x: 50%;
      --lens-y: 50%;
    }

    .pdp-gallery__main::after {
      content: '';
      position: absolute;
      width: 140px;
      height: 140px;
      left: var(--lens-x);
      top: var(--lens-y);
      border: 2px solid var(--color-gold);
      border-radius: 50%;
      pointer-events: none;
      opacity: 0;
      transform: translate(-50%, -50%);
      transition: opacity 0.15s;
      box-shadow: 0 4px 20px rgba(0,0,0,0.12), inset 0 0 30px rgba(255,255,255,0.1);
      z-index: 10;
      background: radial-gradient(circle, transparent 30%, rgba(255,255,255,0.05) 100%);
    }

    .pdp-gallery__main.is-zooming::after {
      opacity: 1;
    }

    .pdp-gallery__main.is-zooming {
      cursor: none;
    }
  }

  /* ─── Improved Micro-interactions ─────────── */
  .pdp-add-to-cart,
  .pdp-buy-now {
    position: relative;
    overflow: hidden;
  }

  .pdp-add-to-cart::after,
  .pdp-buy-now::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transform: translateX(-100%);
  }

  .pdp-add-to-cart:not(:disabled):hover::after,
  .pdp-buy-now:not(:disabled):hover::after {
    animation: shimmer 0.6s ease-out;
  }

  @keyframes shimmer {
    to { transform: translateX(100%); }
  }

  /* Added-to-cart confirmation state */
  .btn--added {
    background: #27ae60 !important;
    border-color: #27ae60 !important;
    color: white !important;
    pointer-events: none;
  }

  /* Price update animation */
  .pdp-price__current {
    transition: transform 0.2s ease-out;
  }

  .pdp-price__current.price-changed {
    animation: price-pop 0.3s ease-out;
  }

  @keyframes price-pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
</style>

<script>
  import { cart, recentlyViewed, wishlist } from '@/lib/cart-store.js';

  // Clean up previous keydown listener on re-init (View Transitions)
  let _pdpKeyHandler: ((e: KeyboardEvent) => void) | null = null;

  document.addEventListener('astro:page-load', () => {
  // ─── DOM refs ───────────────────────────────
  const thumbs = document.querySelectorAll('.pdp-thumb');
  if (!thumbs.length && !document.getElementById('main-product-image')) return;
  const mainImg = document.getElementById('main-product-image') as HTMLImageElement;
  const galleryMain = document.getElementById('gallery-main');
  const variantBtns = document.querySelectorAll('.pdp-variant-btn');
  const addToCartBtn = document.getElementById('add-to-cart') as HTMLButtonElement;
  const selectedLabel = document.getElementById('selected-variant-label');
  const currentPriceEl = document.getElementById('pdp-current-price');
  const comparePriceEl = document.getElementById('pdp-compare-price');
  const qtyInput = document.getElementById('qty-input') as HTMLInputElement;
  const qtyMinus = document.getElementById('qty-minus');
  const qtyPlus = document.getElementById('qty-plus');
  const wishlistBtn = document.getElementById('pdp-wishlist');
  const wishlistText = document.getElementById('wishlist-text');
  const stickyBar = document.getElementById('sticky-bar');
  const stickyAdd = document.getElementById('sticky-add');
  const stickyPrice = document.getElementById('sticky-price');
  const stickyHeader = document.getElementById('sticky-header');
  const stickyHeaderAdd = document.getElementById('sticky-header-add');
  const stickyHeaderPrice = document.getElementById('sticky-header-price');
  const urgencyEl = document.getElementById('pdp-urgency');
  const stockCountEl = document.getElementById('stock-count');

  // Smart price formatter — drops .00 on whole numbers ($800 not $800.00)
  function fmtPrice(amount: number): string {
    return amount % 1 === 0 ? `$${amount.toLocaleString()}` : `$${amount.toFixed(2)}`;
  }

  function cfImg(url: string, width = 900) {
    if (!url || !url.includes('cdn.shopify.com')) return url;
    const sep = url.includes('?') ? '&' : '?';
    return `${url}${sep}width=${width}&crop=center`;
  }

  // ─── Image data ─────────────────────────────
  const imageUrls = Array.from(thumbs).map(t => (t as HTMLElement).dataset.url || '');
  if (mainImg && !imageUrls.length) imageUrls.push(mainImg.src);
  let currentImageIdx = 0;
  const galleryDots = document.querySelectorAll('.pdp-dot');

  function syncDots(idx: number) {
    galleryDots.forEach((d, i) => d.classList.toggle('pdp-dot--active', i === idx));
  }

  // Dot click → change image
  galleryDots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      currentImageIdx = i;
      syncDots(i);
      thumbs.forEach(t => t.classList.remove('pdp-thumb--active'));
      thumbs[i]?.classList.add('pdp-thumb--active');
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = cfImg(imageUrls[i]);
          mainImg.style.opacity = '1';
        }, 150);
      }
    });
  });

  // ─── Mobile swipe on gallery ───────────────
  if (galleryMain && imageUrls.length > 1) {
    let swipeStartX = 0;
    let swipeStartY = 0;
    let swiping = false;

    galleryMain.addEventListener('touchstart', (e: TouchEvent) => {
      swipeStartX = e.touches[0].clientX;
      swipeStartY = e.touches[0].clientY;
      swiping = true;
    }, { passive: true });

    galleryMain.addEventListener('touchend', (e: TouchEvent) => {
      if (!swiping) return;
      swiping = false;
      const dx = e.changedTouches[0].clientX - swipeStartX;
      const dy = e.changedTouches[0].clientY - swipeStartY;
      // Only trigger on horizontal swipe > 50px with horizontal > vertical
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
        const newIdx = dx < 0
          ? Math.min(currentImageIdx + 1, imageUrls.length - 1)
          : Math.max(currentImageIdx - 1, 0);
        if (newIdx !== currentImageIdx) {
          currentImageIdx = newIdx;
          syncDots(currentImageIdx);
          thumbs.forEach(t => t.classList.remove('pdp-thumb--active'));
          thumbs[currentImageIdx]?.classList.add('pdp-thumb--active');
          if (mainImg) {
            mainImg.style.opacity = '0';
            setTimeout(() => {
              mainImg.src = cfImg(imageUrls[currentImageIdx]);
              mainImg.style.opacity = '1';
            }, 150);
          }
        }
      }
    }, { passive: true });
  }

  // ─── Thumbnail gallery (images + videos) ──────
  const videoContainer = document.createElement('div');
  videoContainer.className = 'pdp-video-container';
  videoContainer.style.display = 'none';
  galleryMain?.appendChild(videoContainer);

  let isShowingVideo = false;

  thumbs.forEach((thumb, i) => {
    thumb.addEventListener('click', () => {
      const el = thumb as HTMLElement;
      const type = el.dataset.type;

      thumbs.forEach(t => t.classList.remove('pdp-thumb--active'));
      thumb.classList.add('pdp-thumb--active');

      if (type === 'video') {
        // Show video
        const videoUrl = el.dataset.videoUrl || '';
        const videoType = el.dataset.videoType;

        if (mainImg) mainImg.style.display = 'none';
        videoContainer.style.display = 'flex';
        isShowingVideo = true;

        // Clear previous video content safely
        videoContainer.replaceChildren();

        if (videoType === 'VIDEO') {
          const video = document.createElement('video');
          video.controls = true;
          video.autoplay = true;
          video.playsInline = true;
          video.className = 'pdp-video';
          const source = document.createElement('source');
          source.src = videoUrl;
          source.type = 'video/mp4';
          video.appendChild(source);
          videoContainer.appendChild(video);
        } else if (videoType === 'EXTERNAL_VIDEO') {
          const iframe = document.createElement('iframe');
          iframe.className = 'pdp-video';
          iframe.src = videoUrl;
          iframe.setAttribute('frameborder', '0');
          iframe.allowFullscreen = true;
          iframe.allow = 'autoplay';
          videoContainer.appendChild(iframe);
        }
      } else {
        // Show image
        if (isShowingVideo) {
          videoContainer.replaceChildren();
          videoContainer.style.display = 'none';
          if (mainImg) mainImg.style.display = '';
          isShowingVideo = false;
        }

        currentImageIdx = i;
        syncDots(i);
        if (mainImg) {
          mainImg.style.opacity = '0';
          setTimeout(() => {
            mainImg.src = cfImg(el.dataset.url || '');
            mainImg.alt = el.dataset.alt || '';
            mainImg.style.opacity = '1';
          }, 150);
        }
      }
    });
  });

  // ─── Variant selector ──────────────────────
  variantBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      if ((btn as HTMLButtonElement).disabled) return;

      variantBtns.forEach(b => b.classList.remove('pdp-variant-btn--active'));
      btn.classList.add('pdp-variant-btn--active');

      const el = btn as HTMLElement;
      const variantId = el.dataset.variantId || '';
      const variantPrice = el.dataset.variantPrice || '';
      const variantCompare = el.dataset.variantCompare || '';
      const variantAvailable = el.dataset.variantAvailable === 'true';
      const variantImage = el.dataset.variantImage || '';
      const variantTitle = el.dataset.variantTitle || '';

      // Update add to cart button
      if (addToCartBtn) {
        addToCartBtn.dataset.variantId = variantId;
        addToCartBtn.dataset.variantTitle = variantTitle;
        addToCartBtn.dataset.productPrice = variantPrice;
        addToCartBtn.disabled = !variantAvailable;
        addToCartBtn.textContent = variantAvailable ? 'Add to Cart' : 'Sold Out';
      }

      // Update price display
      if (currentPriceEl) currentPriceEl.textContent = fmtPrice(parseFloat(variantPrice));
      if (comparePriceEl) {
        if (variantCompare && parseFloat(variantCompare) > parseFloat(variantPrice)) {
          comparePriceEl.textContent = fmtPrice(parseFloat(variantCompare));
          comparePriceEl.style.display = '';
        } else {
          comparePriceEl.style.display = 'none';
        }
      }

      // Update sticky bar price
      if (stickyPrice) stickyPrice.textContent = fmtPrice(parseFloat(variantPrice));

      // Update sticky header price
      if (stickyHeaderPrice) stickyHeaderPrice.textContent = fmtPrice(parseFloat(variantPrice));

      // Update selected label
      if (selectedLabel) selectedLabel.textContent = variantTitle;

      // Update stock quantity and urgency indicator
      const variantQty = parseInt(el.dataset.variantQty || '');
      if (urgencyEl && stockCountEl) {
        if (!isNaN(variantQty) && variantQty > 0 && variantQty <= 5) {
          stockCountEl.textContent = String(variantQty);
          urgencyEl.style.display = 'flex';
        } else {
          urgencyEl.style.display = 'none';
        }
      }

      // Price change animation
      if (currentPriceEl) {
        currentPriceEl.classList.add('price-changed');
        setTimeout(() => currentPriceEl.classList.remove('price-changed'), 300);
      }

      // Switch image if variant has one
      if (variantImage && mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = cfImg(variantImage);
          mainImg.style.opacity = '1';
        }, 150);
        // Update thumb active state
        thumbs.forEach((t, i) => {
          const thumbUrl = (t as HTMLElement).dataset.url || '';
          if (thumbUrl === variantImage) {
            thumbs.forEach(tt => tt.classList.remove('pdp-thumb--active'));
            t.classList.add('pdp-thumb--active');
            currentImageIdx = i;
          }
        });
      }
    });
  });

  // ─── Quantity selector ──────────────────────
  qtyMinus?.addEventListener('click', () => {
    const val = parseInt(qtyInput?.value || '1');
    if (val > 1 && qtyInput) qtyInput.value = String(val - 1);
  });

  qtyPlus?.addEventListener('click', () => {
    const val = parseInt(qtyInput?.value || '1');
    if (val < 99 && qtyInput) qtyInput.value = String(val + 1);
  });

  qtyInput?.addEventListener('change', () => {
    let val = parseInt(qtyInput.value || '1');
    if (isNaN(val) || val < 1) val = 1;
    if (val > 99) val = 99;
    qtyInput.value = String(val);
  });

  // ─── Add to cart ────────────────────────────
  function handleAddToCart() {
    const variantId = addToCartBtn?.dataset.variantId;
    if (!variantId) return;

    const title = addToCartBtn.dataset.productTitle || '';
    const price = parseFloat(addToCartBtn.dataset.productPrice || '0');
    const image = addToCartBtn.dataset.productImage || '';
    const handle = addToCartBtn.dataset.productHandle || '';
    const variantTitle = addToCartBtn.dataset.variantTitle || '';
    const qty = parseInt(qtyInput?.value || '1');

    window.addToCart?.({
      variantId,
      title,
      price,
      image,
      handle,
      variantTitle,
    }, qty);

    addToCartBtn.textContent = 'Added!';
    addToCartBtn.classList.add('btn--added');
    setTimeout(() => {
      addToCartBtn.textContent = 'Add to Cart';
      addToCartBtn.classList.remove('btn--added');
    }, 1500);
  }

  addToCartBtn?.addEventListener('click', handleAddToCart);

  // ─── Buy Now ─────────────────────────────────
  const buyNowBtn = document.getElementById('buy-now');
  buyNowBtn?.addEventListener('click', async () => {
    const variantId = addToCartBtn?.dataset.variantId;
    if (!variantId) return;
    const qty = parseInt(qtyInput?.value || '1');

    if (buyNowBtn instanceof HTMLButtonElement) {
      buyNowBtn.disabled = true;
      buyNowBtn.textContent = 'Preparing…';
    }

    const url = await cart.createBuyNowCart(variantId, qty);
    if (url) {
      window.location.href = url;
    } else {
      // Variant no longer available
      if (buyNowBtn instanceof HTMLButtonElement) {
        buyNowBtn.textContent = 'Unavailable';
        setTimeout(() => { buyNowBtn.textContent = 'Buy Now'; buyNowBtn.disabled = false; }, 2000);
      }
    }
  });

  // Sticky bar add to cart
  stickyAdd?.addEventListener('click', handleAddToCart);

  // ─── Wishlist ───────────────────────────────
  const pdpHandle = addToCartBtn?.dataset.productHandle || '';

  function updateWishlistUI() {
    const isWished = wishlist.has(pdpHandle);
    if (wishlistBtn) wishlistBtn.classList.toggle('is-wished', isWished);
    if (wishlistText) wishlistText.textContent = isWished ? 'Saved' : 'Save';
  }

  wishlistBtn?.addEventListener('click', () => {
    wishlist.toggle(pdpHandle);
    updateWishlistUI();
    wishlistBtn.animate([
      { transform: 'scale(1)' },
      { transform: 'scale(1.1)' },
      { transform: 'scale(1)' },
    ], { duration: 300, easing: 'ease-out' });
  });

  updateWishlistUI();

  // ─── Share Button ─────────────────────────
  const shareBtn = document.getElementById('pdp-share');
  shareBtn?.addEventListener('click', async () => {
    const url = window.location.href;
    const title = addToCartBtn?.dataset.productTitle || document.title;

    if (navigator.share) {
      try {
        await navigator.share({ title, url });
      } catch { /* User cancelled */ }
    } else {
      // Fallback: copy to clipboard
      try {
        await navigator.clipboard.writeText(url);
        const span = shareBtn.querySelector('span');
        if (span) {
          const orig = span.textContent;
          span.textContent = 'Copied!';
          setTimeout(() => { span.textContent = orig; }, 2000);
        }
      } catch { /* Clipboard failed */ }
    }
  });

  // ─── Touch swipe helper ────────────────────
  function addSwipe(el: HTMLElement, onLeft: () => void, onRight: () => void) {
    let startX = 0;
    let startY = 0;
    let tracking = false;
    el.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      tracking = true;
    }, { passive: true });
    el.addEventListener('touchend', (e) => {
      if (!tracking) return;
      tracking = false;
      const dx = e.changedTouches[0].clientX - startX;
      const dy = e.changedTouches[0].clientY - startY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) onLeft();
        else onRight();
      }
    }, { passive: true });
  }

  // ─── Lightbox ───────────────────────────────
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxCounter = document.getElementById('lightbox-counter');
  let lightboxIdx = 0;

  let lightboxPrevFocus: HTMLElement | null = null;

  // Optimize image URL for lightbox via CF Images (AVIF/WebP, 1400px)
  function optimizedUrl(url: string, width = 1400) {
    return cfImg(url, width);
  }

  function openLightbox(idx: number) {
    lightboxPrevFocus = document.activeElement as HTMLElement;
    lightboxIdx = idx;
    updateLightbox();
    lightbox?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => lightboxClose?.focus(), 50);
  }

  function closeLightbox() {
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lightboxPrevFocus?.focus();
    lightboxPrevFocus = null;
  }

  function updateLightbox() {
    if (lightboxImg) lightboxImg.src = optimizedUrl(imageUrls[lightboxIdx] || '');
    if (lightboxCounter && imageUrls.length > 1) {
      lightboxCounter.textContent = `${lightboxIdx + 1} / ${imageUrls.length}`;
    }
    if (lightboxPrev) lightboxPrev.style.display = imageUrls.length > 1 ? '' : 'none';
    if (lightboxNext) lightboxNext.style.display = imageUrls.length > 1 ? '' : 'none';
    // Preload adjacent images
    if (imageUrls.length > 1) {
      const nextIdx = (lightboxIdx + 1) % imageUrls.length;
      const img = new Image();
      img.src = optimizedUrl(imageUrls[nextIdx]);
    }
  }

  function lightboxGoNext() {
    lightboxIdx = (lightboxIdx + 1) % imageUrls.length;
    updateLightbox();
  }

  function lightboxGoPrev() {
    lightboxIdx = (lightboxIdx - 1 + imageUrls.length) % imageUrls.length;
    updateLightbox();
  }

  galleryMain?.addEventListener('click', () => openLightbox(currentImageIdx));
  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  lightboxPrev?.addEventListener('click', (e) => {
    e.stopPropagation();
    lightboxGoPrev();
  });

  lightboxNext?.addEventListener('click', (e) => {
    e.stopPropagation();
    lightboxGoNext();
  });

  // Touch swipe on lightbox
  if (lightbox) addSwipe(lightbox, lightboxGoNext, lightboxGoPrev);

  // Keyboard navigation (clean up previous handler to avoid duplicates)
  if (_pdpKeyHandler) document.removeEventListener('keydown', _pdpKeyHandler);
  _pdpKeyHandler = (e: KeyboardEvent) => {
    if (lightbox?.getAttribute('aria-hidden') === 'false') {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') lightboxGoPrev();
      if (e.key === 'ArrowRight') lightboxGoNext();
    }
  };
  document.addEventListener('keydown', _pdpKeyHandler);

  // ─── Touch swipe on main gallery image ─────
  if (galleryMain && imageUrls.length > 1) {
    function swipeTo(idx: number) {
      currentImageIdx = idx;
      thumbs.forEach(t => t.classList.remove('pdp-thumb--active'));
      thumbs[currentImageIdx]?.classList.add('pdp-thumb--active');
      syncDots(currentImageIdx);
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = cfImg(imageUrls[currentImageIdx]);
          mainImg.style.opacity = '1';
        }, 150);
      }
    }
    addSwipe(galleryMain,
      () => swipeTo((currentImageIdx + 1) % imageUrls.length),
      () => swipeTo((currentImageIdx - 1 + imageUrls.length) % imageUrls.length)
    );
  }

  // ─── Sticky mobile bar & desktop header ─────
  if (stickyBar || stickyHeader) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        const isHidden = !entry.isIntersecting;
        if (stickyBar) stickyBar.classList.toggle('is-visible', isHidden);
        if (stickyHeader) stickyHeader.setAttribute('aria-hidden', String(!isHidden));
      },
      { threshold: 0 }
    );
    if (addToCartBtn) observer.observe(addToCartBtn);
  }

  // Sticky header add to cart
  stickyHeaderAdd?.addEventListener('click', handleAddToCart);

  // ─── Frequently Bought Together ──────────────
  const fbtAddAll = document.getElementById('fbt-add-all');
  const fbtChecks = document.querySelectorAll('.fbt-check');
  const fbtTotalPrice = document.getElementById('fbt-total-price');

  // Recalculate FBT total when checkboxes change
  function updateFbtTotal() {
    const currentPrice = parseFloat(addToCartBtn?.dataset.productPrice || '0');
    let total = currentPrice;
    fbtChecks.forEach(cb => {
      if ((cb as HTMLInputElement).checked) {
        total += parseFloat((cb as HTMLElement).dataset.price || '0');
      }
    });
    if (fbtTotalPrice) fbtTotalPrice.textContent = fmtPrice(total);
  }

  fbtChecks.forEach(cb => cb.addEventListener('change', updateFbtTotal));

  fbtAddAll?.addEventListener('click', () => {
    // Add current product
    handleAddToCart();
    // Add checked related items
    fbtChecks.forEach(cb => {
      if (!(cb as HTMLInputElement).checked) return;
      const el = cb as HTMLElement;
      window.addToCart?.({
        variantId: el.dataset.variantId || '',
        title: el.dataset.title || '',
        price: parseFloat(el.dataset.price || '0'),
        image: el.dataset.image || '',
        handle: el.dataset.handle || '',
        variantTitle: '',
      });
    });
    fbtAddAll.textContent = 'All Added!';
    (fbtAddAll as HTMLButtonElement).disabled = true;
    setTimeout(() => {
      fbtAddAll.textContent = 'Add All to Cart';
      (fbtAddAll as HTMLButtonElement).disabled = false;
    }, 2000);
  });

  // ─── Enhanced Image Zoom with lens effect ───────
  if (galleryMain && mainImg) {
    const isDesktop = window.matchMedia('(min-width: 769px)').matches;

    if (isDesktop) {
      galleryMain.addEventListener('mouseenter', () => {
        galleryMain.classList.add('is-zooming');
      });

      galleryMain.addEventListener('mousemove', (e) => {
        const rect = galleryMain.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        mainImg.style.transformOrigin = `${x}% ${y}%`;
        mainImg.style.transform = 'scale(2.5)';
        // Move the lens pseudo-element
        (galleryMain as HTMLElement).style.setProperty('--lens-x', `${e.clientX - rect.left}px`);
        (galleryMain as HTMLElement).style.setProperty('--lens-y', `${e.clientY - rect.top}px`);
      });

      galleryMain.addEventListener('mouseleave', () => {
        galleryMain.classList.remove('is-zooming');
        mainImg.style.transformOrigin = 'center';
        mainImg.style.transform = 'scale(1)';
      });
    }
  }

  // ─── Track recently viewed ──────────────────
  const pdpTitle = addToCartBtn?.dataset.productTitle;
  const pdpImage = addToCartBtn?.dataset.productImage;
  const pdpPrice = addToCartBtn?.dataset.productPrice;
  if (pdpHandle && pdpTitle) {
    recentlyViewed.add({ handle: pdpHandle, title: pdpTitle, image: pdpImage, price: pdpPrice });
  }

  // ─── Render recently viewed ─────────────────
  const recentSection = document.getElementById('recently-section');
  const recentScroll = document.getElementById('recently-scroll');

  if (recentSection && recentScroll) {
    const items = recentlyViewed.getItems().filter((i: any) => i.handle !== pdpHandle);
    if (items.length > 0) {
      recentSection.style.display = '';
      const frag = document.createDocumentFragment();
      items.slice(0, 8).forEach((item: any) => {
        const card = document.createElement('a');
        card.href = `/shop/${encodeURIComponent(item.handle)}/`;
        card.className = 'recently-card';

        const imgWrap = document.createElement('div');
        imgWrap.className = 'recently-card__image';
        if (item.image) {
          const img = document.createElement('img');
          // Optimize: 320px (2x retina for 160px card)
          img.src = item.image.includes('cdn.shopify.com') ? `${item.image}?width=320&crop=center` : item.image;
          img.alt = item.title || '';
          img.loading = 'lazy';
          imgWrap.appendChild(img);
        }
        card.appendChild(imgWrap);

        const titleEl = document.createElement('span');
        titleEl.className = 'recently-card__title';
        titleEl.textContent = item.title;
        card.appendChild(titleEl);

        if (item.price) {
          const priceEl = document.createElement('span');
          priceEl.className = 'recently-card__price';
          priceEl.textContent = fmtPrice(parseFloat(item.price));
          card.appendChild(priceEl);
        }

        frag.appendChild(card);
      });
      recentScroll.replaceChildren(frag);
    }
  }
  // ─── Back in Stock badge (runtime check) ───
  const bisHandle = window.location.pathname.split('/shop/')[1]?.replace(/\/$/, '');
  if (bisHandle) {
    fetch('/api/back-in-stock')
      .then(r => r.ok ? r.json() : [])
      .then((handles: string[]) => {
        if (handles.includes(bisHandle)) {
          // Show back-in-stock badge, hide new/sale badges
          const bisEl = document.getElementById('pdp-back-in-stock-badge');
          if (bisEl) bisEl.style.display = '';
          const newEl = document.getElementById('pdp-new-badge');
          if (newEl) newEl.remove();
          const saleEl = document.getElementById('pdp-sale-badge');
          if (saleEl) saleEl.remove();
        }
      })
      .catch(() => {});
  }

  }); // end astro:page-load
</script>
