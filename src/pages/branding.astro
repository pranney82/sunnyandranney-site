<script>
  // Click to copy hex values
  document.querySelectorAll('.brand-color-card').forEach((card) => {
    card.addEventListener('click', () => {
      const hex = card.getAttribute('data-hex');
      if (hex) {
        navigator.clipboard.writeText(hex).then(() => {
          const swatch = card.querySelector('.brand-color-hex');
          if (swatch) {
            const orig = swatch.textContent;
            swatch.textContent = 'Copied!';
            setTimeout(() => { swatch.textContent = orig; }, 1200);
          }
        });
      }
    });
  });
</script>
