---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Our Charity — Sunshine on a Ranney Day"
  description="100% of Sunny & Ranney profits support Sunshine on a Ranney Day, a charity that transforms the homes and lives of children with special needs."
>
  <!-- ═══ HERO ═══ -->
  <section class="charity-hero">
    <div class="charity-hero__bg"></div>
    <div class="container charity-hero__content">
      <img src="/images/logos/gracie.png" alt="Gracie the Pig" class="animate-fade-up" style="width: 56px; margin: 0 auto 1rem; opacity: 0.85;" />
      <span class="label animate-fade-up" style="color: var(--color-gold-light);">Our Mission</span>
      <h1 class="animate-fade-up delay-1">Sunshine on a<br /><span class="hero-accent">Ranney Day</span></h1>
      <p class="charity-hero__subtitle animate-fade-up delay-2">
        Every purchase at Sunny & Ranney directly funds home makeovers
        that transform the lives of children with special needs.
      </p>
      <hr class="divider animate-fade-up delay-3" style="margin: 0 auto; background: var(--color-gold-light);" />
    </div>
  </section>

  <!-- ═══ IMPACT NUMBERS ═══ -->
  <section class="impact-section">
    <div class="container">
      <div class="impact-grid reveal">
        <div class="impact-card">
          <span class="impact-card__number">20,000+</span>
          <span class="impact-card__label">Children's Lives Impacted</span>
        </div>
        <div class="impact-card">
          <span class="impact-card__number">100%</span>
          <span class="impact-card__label">Of Store Profits Donated</span>
        </div>
        <div class="impact-card">
          <span class="impact-card__number">13+</span>
          <span class="impact-card__label">Years of Giving</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE MISSION ═══ -->
  <section class="mission section--large">
    <div class="container">
      <div class="mission-grid">
        <div class="mission-content reveal">
          <span class="label">The Mission</span>
          <h2>Creating Spaces Where Kids Can Thrive</h2>
          <hr class="divider" />
          <p>
            Sunshine on a Ranney Day renovates and transforms the bedrooms and living
            spaces of children with special needs. These aren't just cosmetic changes —
            they're life-changing environments designed around each child's specific needs
            and dreams.
          </p>
          <p>
            A child who's been sleeping on a mattress on the floor gets a proper bed.
            A teenager who's never had a space of their own gets a room that reflects who
            they are. A family that's been struggling gets a reminder that their community
            cares.
          </p>
          <p>
            <strong>That's what happens when you shop at Sunny & Ranney.</strong>
          </p>
        </div>
        <div class="mission-images reveal delay-2">
          <div class="mission-image mission-image--before">
            <div class="image-placeholder">
              <span>Before Photo</span>
              <span class="image-hint">Room before makeover</span>
            </div>
            <span class="image-label">Before</span>
          </div>
          <div class="mission-image mission-image--after">
            <div class="image-placeholder image-placeholder--gold">
              <span>After Photo</span>
              <span class="image-hint">Room after transformation</span>
            </div>
            <span class="image-label image-label--gold">After</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="how-it-works section" style="background: var(--color-warm-white);">
    <div class="container">
      <div class="how-header reveal">
        <span class="label">How It Works</span>
        <h2>Your Purchase, Their Transformation</h2>
      </div>

      <div class="how-steps reveal delay-2">
        <div class="how-step">
          <div class="how-step__number">01</div>
          <h4>You Shop</h4>
          <p>Browse and purchase beautiful furniture, decor, and gifts from our curated collection.</p>
        </div>
        <div class="how-step__arrow">→</div>
        <div class="how-step">
          <div class="how-step__number">02</div>
          <h4>We Give</h4>
          <p>100% of profits go directly to Sunshine on a Ranney Day — no overhead, no middleman.</p>
        </div>
        <div class="how-step__arrow">→</div>
        <div class="how-step">
          <div class="how-step__number">03</div>
          <h4>Lives Change</h4>
          <p>A child receives a fully renovated room designed around their specific needs and dreams.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIAL / QUOTE ═══ -->
  <section class="testimonial section--large">
    <div class="container">
      <div class="testimonial__inner reveal">
        <div class="testimonial__quote-mark">"</div>
        <blockquote class="testimonial__text">
          This work doesn't happen without you. When you shop at Sunny & Ranney,
          you're not just furnishing a home — you're helping change a life.
        </blockquote>
        <div class="testimonial__author">
          <strong>Peter & Holly Ranney</strong>
          <span>Founders, Sunshine on a Ranney Day</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="charity-cta-section section">
    <div class="container">
      <div class="cta-grid reveal">
        <div class="cta-card">
          <h3>Shop With Purpose</h3>
          <p>Every item in our store supports this mission. Browse our collection and find something you love.</p>
          <a href="/shop" class="btn btn--primary">Shop Now</a>
        </div>
        <div class="cta-card cta-card--gold">
          <h3>Learn More</h3>
          <p>Visit the Sunshine on a Ranney Day website to see stories, events, and ways to get involved.</p>
          <a href="https://sunshineonaranneyday.com" target="_blank" rel="noopener noreferrer" class="btn btn--outline" style="color: white; border-color: rgba(255,255,255,0.5);">
            Visit the Charity →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ─── Hero ──────────────────────────── */
  .charity-hero {
    position: relative;
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
    overflow: hidden;
  }

  .charity-hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(255, 212, 0, 0.1) 0%, transparent 60%),
      var(--color-cyan);
  }

  .charity-hero__content {
    position: relative;
    z-index: 1;
  }

  .charity-hero h1 {
    color: white;
    margin: 0.75rem 0 1rem;
  }

  .hero-accent {
    color: var(--color-gold);
    font-style: italic;
    font-weight: 300;
  }

  .charity-hero__subtitle {
    color: rgba(255, 255, 255, 0.7);
    max-width: 45ch;
    margin: 0 auto var(--space-md);
    font-size: 1.1rem;
  }

  /* ─── Impact ────────────────────────── */
  .impact-section {
    padding: var(--space-xl) 0;
    background: var(--color-gold);
  }

  .impact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    text-align: center;
  }

  @media (min-width: 768px) {
    .impact-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .impact-card__number {
    display: block;
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    color: var(--color-charcoal);
    line-height: 1;
  }

  .impact-card__label {
    display: block;
    color: rgba(44, 44, 44, 0.75);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-top: 0.5rem;
  }

  /* ─── Mission ───────────────────────── */
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 768px) {
    .mission-grid { grid-template-columns: 1fr 1fr; gap: var(--space-2xl); }
  }

  .mission-content h2 { margin: 0.5rem 0 1rem; }
  .mission-content p { margin-top: var(--space-sm); }

  .mission-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .mission-image { position: relative; }

  .image-placeholder {
    width: 100%;
    min-height: 280px;
    background: var(--color-cream-dark);
    border: 2px dashed var(--color-stone);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-stone);
  }

  .image-placeholder--gold {
    background: var(--color-gold-soft);
    border-color: var(--color-gold);
  }

  .image-hint {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--color-stone);
  }

  .image-label {
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-charcoal);
    color: white;
    padding: 0.25rem 0.75rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .image-label--gold {
    background: var(--color-gold);
  }

  /* ─── How It Works ──────────────────── */
  .how-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .how-header h2 { margin-top: 0.5rem; }

  .how-steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .how-steps {
      flex-direction: row;
      align-items: flex-start;
      justify-content: center;
    }
  }

  .how-step {
    text-align: center;
    max-width: 280px;
    flex: 1;
  }

  .how-step__number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--color-gold);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .how-step h4 { margin-bottom: 0.5rem; }
  .how-step p { font-size: 0.9rem; margin: 0 auto; }

  .how-step__arrow {
    font-size: 1.5rem;
    color: var(--color-gold);
    padding-top: 1rem;
    display: none;
  }

  @media (min-width: 768px) {
    .how-step__arrow { display: block; }
  }

  /* ─── Testimonial ───────────────────── */
  .testimonial {
    background: var(--color-cream);
  }

  .testimonial__inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .testimonial__quote-mark {
    font-family: var(--font-display);
    font-size: 6rem;
    color: var(--color-gold);
    line-height: 0.5;
    margin-bottom: 1rem;
  }

  .testimonial__text {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    color: var(--color-charcoal);
    margin-bottom: var(--space-md);
  }

  .testimonial__author {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .testimonial__author strong {
    font-size: 0.95rem;
    color: var(--color-charcoal);
  }

  .testimonial__author span {
    font-size: 0.8rem;
    color: var(--color-stone);
  }

  /* ─── CTA ───────────────────────────── */
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .cta-grid { grid-template-columns: 1fr 1fr; }
  }

  .cta-card {
    padding: var(--space-xl);
    background: var(--color-warm-white);
    text-align: center;
  }

  .cta-card h3 { margin-bottom: 0.75rem; }
  .cta-card p { margin: 0 auto var(--space-md); max-width: 35ch; }

  .cta-card--gold {
    background: var(--color-cyan);
    color: white;
  }

  .cta-card--gold h3 { color: var(--color-gold); }
  .cta-card--gold p { color: rgba(255, 255, 255, 0.8); }
</style>
