---
import Base from '@/layouts/Base.astro';
import GoogleReviews from '@/components/GoogleReviews.astro';
import EmailCapture from '@/components/EmailCapture.astro';
import { getProducts, getCollections, shopifyImageUrl, shopifyImageSrcset } from '@/lib/shopify';

let products: any[] = [];
let collections: any[] = [];
let hasShopify = false;

// The 12 collections featured on the Shopify homepage, in order
const FEATURED_HANDLES = [
  'accent-chairs',
  'accent-end-tables',
  'bedroom-furniture',
  'coffee-tables',
  'consoles-sideboards-sofa-tables',
  'desks',
  'dining-tables',
  'dining-chairs',
  'ottoman-benches',
  'sofas',
  'sectionals',
  'gift-cards',
];

try {
  const result = await getProducts(24);
  products = result.products;
  hasShopify = products.length > 0;

  // Fetch collections and filter/sort to match Shopify homepage order
  const allCollections = await getCollections(20);
  const handleOrder = new Map(FEATURED_HANDLES.map((h, i) => [h, i]));
  collections = allCollections
    .filter((c: any) => handleOrder.has(c.handle))
    .sort((a: any, b: any) => (handleOrder.get(a.handle) ?? 99) - (handleOrder.get(b.handle) ?? 99));
} catch (e) {
  console.log('Shopify API not configured.');
}

// Split products by type for homepage sections
const onSaleProducts = products.filter(p => {
  const compare = p.compareAtPriceRange?.minVariantPrice;
  const price = p.priceRange.minVariantPrice;
  return compare && parseFloat(compare.amount) > parseFloat(price.amount);
});
const featuredProducts = products.slice(0, 8);

---

<Base lcpImage="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=480,h=600,fit=cover,q=80,format=auto">
  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__kicker animate-fade-up">Furniture with Heart</p>
        <h1 class="hero__title animate-fade-up delay-1">Shop with<br/>a Purpose</h1>
        <p class="hero__sub animate-fade-up delay-2">Curated furniture & home decor where every purchase transforms a child's room through <strong>Sunshine on a Ranney Day</strong>.</p>
        <div class="hero__actions animate-fade-up delay-3">
          <a href="/shop" class="btn btn--gold btn--hero" data-astro-prefetch="viewport">Shop &amp; Give Back</a>
        </div>
        <div class="hero__trust animate-fade-up delay-3">
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure Checkout
          </span>
          <span class="hero__trust-sep"></span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            4.9 on Google
          </span>
          <span class="hero__trust-sep"></span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Roswell Pickup
          </span>
        </div>
      </div>
      <div class="hero__media animate-fade-up delay-2">
        <div class="hero__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=480,h=600,fit=cover,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=320,h=400,fit=cover,q=75,format=auto 320w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=480,h=600,fit=cover,q=80,format=auto 480w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=640,h=800,fit=cover,q=80,format=auto 640w"
            sizes="(max-width: 767px) 260px, (max-width: 1023px) 340px, 420px"
            alt="Sunshine on a Ranney Day room makeover"
            width="480"
            height="600"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <div class="hero__accent" aria-hidden="true"></div>
      </div>
    </div>
    <div class="hero__ribbon">
      <div class="container hero__ribbon-inner">
        <span class="hero__ribbon-stat" data-count="269" data-suffix="+">0</span><span> rooms transformed</span>
        <span class="hero__ribbon-sep" aria-hidden="true"></span>
        <span class="hero__ribbon-stat" data-count="14" data-suffix="">0</span><span> years of giving</span>
        <span class="hero__ribbon-sep" aria-hidden="true"></span>
        <span><strong>100%</strong> of profits donated</span>
      </div>
    </div>
  </section>

  <!-- ═══ SHOP BY COLLECTION ═══ -->
  {collections.length > 0 && (
    <section class="collections-grid section">
      <div class="container">
        <div class="collections-grid__header reveal">
          <h2 class="section-title">Shop by Collection</h2>
          <a href="/shop" class="collections-grid__link" data-astro-prefetch>View all &rarr;</a>
        </div>
        <div class="collections-grid__items">
          {collections.map((col: any, idx: number) => {
            const colImage = col.image;
            const previewProduct = col.products?.edges?.[0]?.node;
            const imgUrl = colImage?.url || previewProduct?.images?.edges?.[0]?.node?.url;
            return (
              <a href={`/shop?collection=${col.handle}`} data-astro-prefetch class={`collection-tile reveal${idx > 0 ? ` delay-${Math.min(idx, 3)}` : ''}`}>
                <div class="collection-tile__image">
                  {imgUrl ? (
                    <img
                      src={shopifyImageUrl(imgUrl, 500, 500)}
                      srcset={shopifyImageSrcset(imgUrl, [250, 500])}
                      sizes="(max-width: 480px) 45vw, (max-width: 768px) 30vw, 200px"
                      alt={colImage?.altText || col.title}
                      width="500"
                      height="500"
                      loading={idx < 4 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  ) : (
                    <div class="collection-tile__placeholder">
                      <span>{col.title.charAt(0)}</span>
                    </div>
                  )}
                  <div class="collection-tile__overlay">
                    <span>{col.title}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ FEATURED / TRENDING ═══ -->
  {hasShopify && featuredProducts.length > 0 && (
    <section class="home-products section">
      <div class="container">
        <div class="home-products__header reveal">
          <h2 class="section-title">Trending Now</h2>
          <a href="/shop" class="home-products__see-all" data-astro-prefetch>See all &rarr;</a>
        </div>
        <div class="product-grid reveal" id="home-grid">
          {featuredProducts.map((product: any, idx: number) => {
            const image = product.images.edges[0]?.node;
            const image2 = product.images.edges[1]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            const isOnSale = compareAt && parseFloat(compareAt.amount) > parseFloat(price.amount);
            const firstVariant = product.variants.edges[0]?.node;

            return (
              <div class="product-card" data-type={product.productType.toLowerCase()}>
                {isOnSale && <span class="product-card__badge">Sale</span>}
                {!isOnSale && !product.availableForSale && <span class="product-card__badge product-card__badge--sold">Sold Out</span>}
                <a href={`/shop/${product.handle}`} data-astro-prefetch class="product-card__image">
                  {image ? (
                    <>
                      <img
                        src={shopifyImageUrl(image.url, 600)}
                        srcset={shopifyImageSrcset(image.url, [300, 600, 900])}
                        sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
                        alt={image.altText || product.title}
                        width={image.width}
                        height={image.height}
                        loading={idx < 4 ? 'eager' : 'lazy'}
                        fetchpriority={idx === 0 ? 'high' : undefined}
                        decoding={idx === 0 ? 'sync' : 'async'}
                        class="product-card__img-primary"
                      />
                      {image2 && (
                        <img
                          src={shopifyImageUrl(image2.url, 600)}
                          srcset={shopifyImageSrcset(image2.url, [300, 600, 900])}
                          sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
                          alt={image2.altText || product.title}
                          width={image2.width}
                          height={image2.height}
                          loading="lazy"
                          decoding="async"
                          class="product-card__img-hover"
                        />
                      )}
                    </>
                  ) : (
                    <div class="product-card__image-ph">{product.productType || 'Product'}</div>
                  )}
                </a>
                <div class="product-card__info">
                  {product.productType && <span class="product-card__type">{product.productType}</span>}
                  <a href={`/shop/${product.handle}`} data-astro-prefetch class="product-card__title">{product.title}</a>
                  <div class="product-card__pricing">
                    <span class="product-card__price">${parseFloat(price.amount).toFixed(2)}</span>
                    {isOnSale && (
                      <span class="product-card__price--compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                    )}
                  </div>
                  {product.availableForSale && firstVariant && (
                    <button class="product-card__add-btn"
                      data-variant-id={firstVariant.id}
                      data-title={product.title}
                      data-price={parseFloat(price.amount)}
                      data-image={image?.url || ''}
                      data-handle={product.handle}
                      data-variant-title={firstVariant.title}
                    >
                      Add to Cart
                    </button>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ MISSION ═══ -->
  <section class="mission" id="mission">
    <div class="container mission__inner">
      <div class="mission__media reveal">
        <div class="mission__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=600,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=600,q=80,format=auto 600w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=900,q=80,format=auto 900w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=1200,q=80,format=auto 1200w"
            sizes="(max-width: 767px) 90vw, (max-width: 1024px) 45vw, 540px"
            alt="Sunshine on a Ranney Day founders"
            width="600"
            height="400"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="mission__content reveal delay-1">
        <p class="mission__kicker">Our Why</p>
        <h2 class="mission__title">Every Purchase Changes a Child's World</h2>
        <p class="mission__body">
          When you shop at Sunny and Ranney, you're not just buying furniture.
          Through <strong>Sunshine on a Ranney Day</strong>, 100% of store profits
          fund bedroom and living space makeovers for children with special needs.
          269 rooms transformed. 14 years and counting.
        </p>
        <a href="/mission" class="btn btn--outline mission__cta" data-astro-prefetch>Read Our Full Story</a>
      </div>
    </div>
  </section>

  <!-- ═══ GOOGLE REVIEWS ═══ -->
  <GoogleReviews variant="full" />

  <!-- ═══ ON SALE (if any) ═══ -->
  {onSaleProducts.length > 0 && (
    <section class="home-products home-products--deals section">
      <div class="container">
        <div class="home-products__header reveal">
          <h2 class="section-title">On Sale</h2>
          <a href="/shop" class="home-products__see-all" data-astro-prefetch>Shop all deals &rarr;</a>
        </div>
        <div class="home-scroll reveal">
          {onSaleProducts.slice(0, 8).map((product: any) => {
            const image = product.images.edges[0]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            return (
              <a href={`/shop/${product.handle}`} data-astro-prefetch class="home-scroll__card">
                <div class="home-scroll__image">
                  <span class="product-card__badge">Sale</span>
                  {image && (
                    <img
                      src={shopifyImageUrl(image.url, 400)}
                      srcset={shopifyImageSrcset(image.url, [220, 400])}
                      sizes="220px"
                      alt={image.altText || product.title}
                      width={image.width}
                      height={image.height}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <div class="home-scroll__info">
                  <span class="home-scroll__title">{product.title}</span>
                  <div class="home-scroll__pricing">
                    <span class="home-scroll__price">${parseFloat(price.amount).toFixed(2)}</span>
                    <span class="home-scroll__compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ VISIT STRIP ═══ -->
  <section class="visit-strip section">
    <div class="container visit-strip__inner">
      <div class="visit-strip__info">
        <h3>Visit Our Roswell Showroom</h3>
        <p>109A Oak Street, Roswell, GA 30075</p>
        <p>Tue–Thu 10am–5pm &middot; Fri–Sat 10am–6pm</p>
        <p><a href="tel:6788885140">678.888.5140</a> &middot; <a href="mailto:info@sunnyandranney.com">info@sunnyandranney.com</a></p>
      </div>
      <a href="https://maps.google.com/?q=109A+Oak+Street+Roswell+GA+30075" target="_blank" rel="noopener noreferrer" class="btn btn--outline">
        Get Directions
      </a>
    </div>
  </section>

  <!-- ═══ RECENTLY VIEWED ═══ -->
  <section class="home-recent section" id="home-recent-section" style="display:none;">
    <div class="container">
      <div class="home-products__header">
        <h2 class="section-title">Pick Up Where You Left Off</h2>
        <a href="/shop" class="home-products__see-all" data-astro-prefetch>Continue shopping &rarr;</a>
      </div>
      <div class="home-recent__scroll" id="home-recent-scroll"></div>
    </div>
  </section>

  <!-- ═══ EMAIL CAPTURE ═══ -->
  <EmailCapture />
</Base>

<style>
  /* ─── Hero ─────────────────────────────── */
  .hero {
    background: linear-gradient(165deg, var(--color-cyan) 0%, #3d8aaa 60%, #357a98 100%);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding-top: clamp(2rem, 5vh, 3.5rem);
    padding-bottom: 0;
    align-items: center;
  }

  .hero__text {
    padding-bottom: var(--space-lg);
  }

  .hero__kicker {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 var(--space-sm);
  }

  .hero__title {
    font-size: clamp(2.6rem, 8vw, 5.2rem);
    line-height: 0.92;
    letter-spacing: -0.025em;
    color: white;
    margin: 0 0 var(--space-md);
  }

  .hero__sub {
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(0.92rem, 1.1vw, 1.05rem);
    max-width: 38ch;
    margin: 0 0 var(--space-lg);
    line-height: 1.65;
  }

  .hero__sub strong {
    color: var(--color-gold);
    font-weight: 600;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .hero__mission-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .hero__mission-link:hover {
    color: var(--color-gold);
  }

  /* Trust signals — inline in hero */
  .hero__trust {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.02em;
  }

  .hero__trust-item svg {
    opacity: 0.8;
  }

  .hero__trust-sep {
    width: 1px;
    height: 12px;
    background: rgba(255,255,255,0.2);
  }

  /* Hero image — contained, rounded, with accent */
  .hero__media {
    position: relative;
    display: flex;
    justify-content: center;
    padding-bottom: var(--space-md);
  }

  .hero__img-wrap {
    position: relative;
    z-index: 1;
    width: 85%;
    max-width: 300px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2), 0 8px 20px rgba(0,0,0,0.12);
  }

  .hero__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .hero__img-wrap:hover img {
    transform: scale(1.03);
  }

  .hero__accent {
    position: absolute;
    bottom: -8px;
    right: -8px;
    width: 55%;
    height: 50%;
    background: var(--color-gold);
    border-radius: 20px;
    opacity: 0.2;
    z-index: 0;
  }

  /* Gold ribbon with inline stats */
  .hero__ribbon {
    background: var(--color-gold);
    padding: 0.6rem 0;
  }

  .hero__ribbon-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-charcoal);
  }

  .hero__ribbon-stat {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .hero__ribbon-sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-charcoal);
    opacity: 0.3;
    margin: 0 0.3rem;
  }

  /* Mobile: tighter hero so products appear faster */
  @media (max-width: 767px) {
    .hero__inner {
      gap: var(--space-md);
      padding-top: var(--space-md);
    }

    .hero__text {
      padding-bottom: var(--space-sm);
    }

    .hero__title {
      margin-bottom: var(--space-sm);
    }

    .hero__sub {
      margin-bottom: var(--space-md);
    }

    .hero__actions {
      margin-bottom: var(--space-sm);
    }

    .hero__media {
      padding-bottom: var(--space-sm);
    }

    .hero__img-wrap {
      max-width: 240px;
    }
  }

  @media (min-width: 768px) {
    .hero__inner {
      grid-template-columns: 1.2fr 0.8fr;
      padding-top: clamp(2.5rem, 6vh, 4.5rem);
      gap: var(--space-xl);
    }

    .hero__text {
      padding-bottom: var(--space-xl);
    }

    .hero__media {
      justify-content: flex-end;
      padding-bottom: var(--space-lg);
    }

    .hero__img-wrap {
      width: 100%;
      max-width: 340px;
    }

    .hero__ribbon-inner {
      font-size: 0.78rem;
    }

    .hero__ribbon-stat {
      font-size: 0.92rem;
    }
  }

  @media (min-width: 1024px) {
    .hero__img-wrap {
      max-width: 380px;
    }
  }

  /* ─── Section Title ────────────────────── */
  .section-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: var(--space-lg);
  }

  /* ─── Collections Grid ────────────────── */
  .collections-grid__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .collections-grid__header .section-title { margin-bottom: 0; }

  .collections-grid__link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-cyan);
    letter-spacing: 0.03em;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .collections-grid__link:hover { color: var(--color-charcoal); }

  .collections-grid__items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-top: var(--space-lg);
  }

  @media (min-width: 640px) {
    .collections-grid__items {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .collections-grid__items {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
  }

  .collection-tile {
    display: block;
    text-decoration: none;
    color: var(--color-charcoal);
    transition: transform 0.4s var(--ease-out);
  }

  .collection-tile:hover {
    transform: translateY(-4px);
  }

  .collection-tile__image {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 12px;
    background: var(--color-cream-dark);
  }

  .collection-tile__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .collection-tile:hover .collection-tile__image img {
    transform: scale(1.06);
  }

  .collection-tile__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 60%);
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
    transition: background 0.3s;
  }

  .collection-tile:hover .collection-tile__overlay {
    background: linear-gradient(0deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.05) 70%);
  }

  .collection-tile__overlay span {
    font-family: var(--font-display);
    font-size: clamp(0.82rem, 1.2vw, 0.95rem);
    font-weight: 600;
    color: white;
    line-height: 1.2;
    text-shadow: 0 1px 3px rgba(0,0,0,0.3);
  }

  .collection-tile__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-charcoal);
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
  }

  /* ─── Home Products Header ─────────────── */
  .home-products { background: var(--color-warm-white); }

