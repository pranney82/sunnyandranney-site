---
import Base from '@/layouts/Base.astro';
import GoogleReviews from '@/components/GoogleReviews.astro';
import { getProducts, getCollections, shopifyImageUrl, shopifyImageSrcset } from '@/lib/shopify';

let products: any[] = [];
let collections: any[] = [];
let hasShopify = false;

// The 12 collections featured on the Shopify homepage, in order
const FEATURED_HANDLES = [
  'accent-chairs',
  'accent-end-tables',
  'bedroom-furniture',
  'coffee-tables',
  'consoles-sideboards-sofa-tables',
  'dining-tables',
  'sofas',
  'sectionals',
];

try {
  const result = await getProducts(8);
  products = result.products;
  hasShopify = products.length > 0;

  // Fetch collections and filter/sort to match Shopify homepage order
  const allCollections = await getCollections(10);
  const handleOrder = new Map(FEATURED_HANDLES.map((h, i) => [h, i]));
  collections = allCollections
    .filter((c: any) => handleOrder.has(c.handle))
    .sort((a: any, b: any) => (handleOrder.get(a.handle) ?? 99) - (handleOrder.get(b.handle) ?? 99));
} catch (e) {
  console.log('Shopify API not configured.');
}

// Split products by type for homepage sections
const onSaleProducts = products.filter(p => {
  const compare = p.compareAtPriceRange?.minVariantPrice;
  const price = p.priceRange.minVariantPrice;
  return compare && parseFloat(compare.amount) > parseFloat(price.amount);
});
const featuredProducts = products.slice(0, 8);

---

<Base lcpImage="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=480,h=600,fit=cover,q=80,format=auto">
  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__kicker animate-fade-up">Furniture with Heart</p>
        <h1 class="hero__title animate-fade-up delay-1">Shop with<br/>a Purpose</h1>
        <p class="hero__sub animate-fade-up delay-2">Curated furniture & home decor where every purchase transforms a child's room through <strong>Sunshine on a Ranney Day</strong>.</p>
        <div class="hero__actions animate-fade-up delay-3">
          <a href="/shop" class="btn btn--gold btn--hero" data-astro-prefetch="viewport">Shop &amp; Give Back</a>
        </div>
        <div class="hero__trust animate-fade-up delay-3">
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure Checkout
          </span>
          <span class="hero__trust-sep"></span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            4.9 on Google
          </span>
          <span class="hero__trust-sep"></span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Roswell Pickup
          </span>
        </div>
      </div>
      <div class="hero__media animate-fade-up delay-2">
        <div class="hero__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=480,h=600,fit=cover,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=320,h=400,fit=cover,q=75,format=auto 320w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=480,h=600,fit=cover,q=80,format=auto 480w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=640,h=800,fit=cover,q=80,format=auto 640w"
            sizes="(max-width: 767px) 280px, (max-width: 1023px) 400px, 440px"
            alt="Adrian's room makeover by Sunshine on a Ranney Day"
            width="480"
            height="600"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <div class="hero__accent" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ═══ IMPACT STATS ═══ -->
  <section class="impact">
    <div class="container impact__inner">
      <div class="impact__stat reveal">
        <span class="impact__number" data-count="269" data-suffix="+">0</span>
        <span class="impact__label">Rooms Transformed</span>
      </div>
      <div class="impact__divider" aria-hidden="true"></div>
      <div class="impact__stat reveal delay-1">
        <span class="impact__number" data-count="14" data-suffix="">0</span>
        <span class="impact__label">Years of Giving</span>
      </div>
      <div class="impact__divider" aria-hidden="true"></div>
      <div class="impact__stat reveal delay-2">
        <span class="impact__number">100%</span>
        <span class="impact__label">Of Profits Donated</span>
      </div>
    </div>
  </section>

  <!-- ═══ SHOP BY COLLECTION ═══ -->
  {collections.length > 0 && (
    <section class="collections-grid section">
      <div class="container">
        <div class="collections-grid__header reveal">
          <h2 class="section-title">Shop by Collection</h2>
          <a href="/shop" class="collections-grid__link" data-astro-prefetch>View all &rarr;</a>
        </div>
        <div class="collections-grid__items">
          {collections.map((col: any, idx: number) => {
            const colImage = col.image;
            const previewProduct = col.products?.edges?.[0]?.node;
            const imgUrl = colImage?.url || previewProduct?.images?.edges?.[0]?.node?.url;
            return (
              <a href={`/shop?collection=${col.handle}`} data-astro-prefetch class={`collection-tile reveal${idx > 0 ? ` delay-${Math.min(idx, 3)}` : ''}`}>
                <div class="collection-tile__image">
                  {imgUrl ? (
                    <img
                      src={shopifyImageUrl(imgUrl, 500, 500)}
                      srcset={shopifyImageSrcset(imgUrl, [250, 500])}
                      sizes="(max-width: 480px) 45vw, (max-width: 768px) 30vw, 200px"
                      alt={colImage?.altText || col.title}
                      width="500"
                      height="500"
                      loading={idx < 4 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  ) : (
                    <div class="collection-tile__placeholder">
                      <span>{col.title.charAt(0)}</span>
                    </div>
                  )}
                  <div class="collection-tile__overlay">
                    <span>{col.title}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ FEATURED / TRENDING ═══ -->
  {hasShopify && featuredProducts.length > 0 && (
    <section class="home-products section">
      <div class="container">
        <div class="home-products__header reveal">
          <h2 class="section-title">Trending Now</h2>
          <a href="/shop" class="home-products__see-all" data-astro-prefetch>See all &rarr;</a>
        </div>
        <div class="product-grid reveal" id="home-grid">
          {featuredProducts.map((product: any, idx: number) => {
            const image = product.images.edges[0]?.node;
            const image2 = product.images.edges[1]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            const isOnSale = compareAt && parseFloat(compareAt.amount) > parseFloat(price.amount);
            const firstVariant = product.variants.edges[0]?.node;

            return (
              <div class="product-card" data-type={product.productType.toLowerCase()}>
                {isOnSale && <span class="product-card__badge">Sale</span>}
                {!isOnSale && !product.availableForSale && <span class="product-card__badge product-card__badge--sold">Sold Out</span>}
                <a href={`/shop/${product.handle}`} data-astro-prefetch class="product-card__image" aria-hidden="true" tabindex="-1">
                  {image ? (
                    <>
                      <img
                        src={shopifyImageUrl(image.url, 600)}
                        srcset={shopifyImageSrcset(image.url, [300, 600, 900])}
                        sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
                        alt=""
                        width={image.width}
                        height={image.height}
                        loading={idx < 4 ? 'eager' : 'lazy'}
                        fetchpriority={idx === 0 ? 'high' : undefined}
                        decoding={idx === 0 ? 'sync' : 'async'}
                        class="product-card__img-primary"
                      />
                      {image2 && (
                        <img
                          src={shopifyImageUrl(image2.url, 600)}
                          srcset={shopifyImageSrcset(image2.url, [300, 600, 900])}
                          sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
                          alt=""
                          width={image2.width}
                          height={image2.height}
                          loading="lazy"
                          decoding="async"
                          class="product-card__img-hover"
                        />
                      )}
                    </>
                  ) : (
                    <div class="product-card__image-ph">{product.productType || 'Product'}</div>
                  )}
                </a>
                <div class="product-card__info">
                  {product.productType && <span class="product-card__type">{product.productType}</span>}
                  <a href={`/shop/${product.handle}`} data-astro-prefetch class="product-card__title">{product.title}</a>
                  <div class="product-card__pricing">
                    <span class="product-card__price">${parseFloat(price.amount).toFixed(2)}</span>
                    {isOnSale && (
                      <span class="product-card__price--compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                    )}
                  </div>
                  {product.availableForSale && firstVariant && (
                    <button class="product-card__add-btn"
                      data-variant-id={firstVariant.id}
                      data-title={product.title}
                      data-price={parseFloat(price.amount)}
                      data-image={image?.url || ''}
                      data-handle={product.handle}
                      data-variant-title={firstVariant.title}
                    >
                      Add to Cart
                    </button>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ DESIGN SERVICES ═══ -->
  <section class="services">
    <div class="container">
      <div class="services__top reveal">
        <p class="services__kicker">Beyond the Showroom</p>
        <h2 class="services__heading">We don't just sell furniture.<br/>We help you build a home.</h2>
      </div>

      <div class="services__grid">
        <div class="services__card services__card--1 reveal">
          <div class="services__card-inner">
            <div class="services__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 7.586 7.586"/><circle cx="11" cy="11" r="2"/>
              </svg>
            </div>
            <h3 class="services__title">Design<br/>Assistance</h3>
            <p class="services__desc">Tell us about your space and we'll help you fill it. Our in-house designers work with you from concept to final pillow — no project too big or small.</p>
            <span class="services__tag">Complimentary</span>
          </div>
        </div>

        <div class="services__card services__card--2 reveal delay-1">
          <div class="services__card-inner">
            <div class="services__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
              </svg>
            </div>
            <h3 class="services__title">Custom<br/>Sourcing</h3>
            <p class="services__desc">Have something specific in mind? We tap into a global network of makers to find exactly what you're looking for — beyond what's on our floor.</p>
            <span class="services__tag">Worldwide</span>
          </div>
        </div>

        <div class="services__card services__card--3 reveal delay-2">
          <div class="services__card-inner">
            <div class="services__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 9V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v3"/><path d="M3 16a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v1.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V11a2 2 0 0 0-4 0z"/><path d="M5 18v2"/><path d="M19 18v2"/>
              </svg>
            </div>
            <h3 class="services__title">Custom<br/>Upholstery</h3>
            <p class="services__desc">Choose your own fabrics, finishes, and silhouettes. We craft one-of-a-kind pieces built around your vision — made just for you.</p>
            <span class="services__tag">Made to Order</span>
          </div>
        </div>
      </div>

      <div class="services__bottom reveal delay-3">
        <p class="services__bottom-text">Have a project in mind?</p>
        <a href="mailto:info@sunnyandranney.com" class="services__cta-btn">
          Let's Talk
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ MISSION ═══ -->
  <section class="mission" id="mission">
    <div class="container mission__inner">
      <div class="mission__media reveal">
        <div class="mission__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=600,h=400,fit=cover,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=600,h=400,fit=cover,q=80,format=auto 600w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=900,h=600,fit=cover,q=80,format=auto 900w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=1200,h=800,fit=cover,q=80,format=auto 1200w"
            sizes="(max-width: 767px) 90vw, (max-width: 1024px) 45vw, 540px"
            alt="Adrian — a Sunshine on a Ranney Day room makeover recipient"
            width="600"
            height="400"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="mission__content reveal delay-1">
        <p class="mission__kicker">Our Why</p>
        <h2 class="mission__title">Every Purchase Changes a Child's World</h2>
        <p class="mission__body">
          When you shop at Sunny and Ranney, you're not just buying furniture.
          Through <strong>Sunshine on a Ranney Day</strong>, 100% of store profits
          fund bedroom and living space makeovers for children with special needs.
          269 rooms transformed. 14 years and counting.
        </p>
        <a href="/mission" class="btn btn--outline mission__cta" data-astro-prefetch>Read Our Full Story</a>
      </div>
    </div>
  </section>

  <!-- ═══ GOOGLE REVIEWS ═══ -->
  <GoogleReviews variant="full" />

  <!-- ═══ ON SALE (if any) ═══ -->
  {onSaleProducts.length > 0 && (
    <section class="home-products home-products--deals section">
      <div class="container">
        <div class="home-products__header reveal">
          <h2 class="section-title">On Sale</h2>
          <a href="/shop" class="home-products__see-all" data-astro-prefetch>Shop all deals &rarr;</a>
        </div>
        <div class="home-scroll reveal">
          {onSaleProducts.slice(0, 8).map((product: any) => {
            const image = product.images.edges[0]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            return (
              <a href={`/shop/${product.handle}`} data-astro-prefetch class="home-scroll__card" aria-label={product.title}>
                <div class="home-scroll__image">
                  <span class="product-card__badge">Sale</span>
                  {image && (
                    <img
                      src={shopifyImageUrl(image.url, 400)}
                      srcset={shopifyImageSrcset(image.url, [220, 400])}
                      sizes="220px"
                      alt=""
                      width={image.width}
                      height={image.height}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <div class="home-scroll__info">
                  <span class="home-scroll__title">{product.title}</span>
                  <div class="home-scroll__pricing">
                    <span class="home-scroll__price">${parseFloat(price.amount).toFixed(2)}</span>
                    <span class="home-scroll__compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ RECENTLY VIEWED ═══ -->
  <section class="home-recent section" id="home-recent-section" style="display:none;">
    <div class="container">
      <div class="home-products__header">
        <h2 class="section-title">Pick Up Where You Left Off</h2>
        <a href="/shop" class="home-products__see-all" data-astro-prefetch>Continue shopping &rarr;</a>
      </div>
      <div class="home-recent__scroll" id="home-recent-scroll"></div>
    </div>
  </section>

</Base>

<style>
  /* ─── Hero ─────────────────────────────── */
  .hero {
    background: linear-gradient(165deg, var(--color-cyan) 0%, #3d8aaa 60%, #357a98 100%);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding-top: clamp(2rem, 5vh, 3.5rem);
    padding-bottom: 0;
    align-items: center;
  }

  .hero__text {
    padding-bottom: var(--space-lg);
  }

  .hero__kicker {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 var(--space-sm);
  }

  .hero__title {
    font-size: clamp(2.6rem, 8vw, 5.2rem);
    line-height: 0.92;
    letter-spacing: -0.025em;
    color: white;
    margin: 0 0 var(--space-md);
  }

  .hero__sub {
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(0.92rem, 1.1vw, 1.05rem);
    max-width: 38ch;
    margin: 0 0 var(--space-lg);
    line-height: 1.65;
  }

  .hero__sub strong {
    color: var(--color-gold);
    font-weight: 600;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .hero__mission-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .hero__mission-link:hover {
    color: var(--color-gold);
  }

  /* Trust signals — inline in hero */
  .hero__trust {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.02em;
  }

  .hero__trust-item svg {
    opacity: 0.8;
  }

  .hero__trust-sep {
    width: 1px;
    height: 12px;
    background: rgba(255,255,255,0.2);
  }

  /* Hero image — contained, rounded, with accent */
  .hero__media {
    position: relative;
    display: flex;
    justify-content: center;
    padding-bottom: var(--space-md);
  }

  .hero__img-wrap {
    position: relative;
    z-index: 1;
    width: 90%;
    max-width: 320px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2), 0 8px 20px rgba(0,0,0,0.12);
  }

  .hero__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .hero__img-wrap:hover img {
    transform: scale(1.03);
  }

  .hero__accent {
    position: absolute;
    bottom: -8px;
    right: -8px;
    width: 55%;
    height: 50%;
    background: var(--color-gold);
    border-radius: 20px;
    opacity: 0.2;
    z-index: 0;
  }

  /* ─── Impact Stats ───────────────────── */
  .impact {
    background: var(--color-charcoal);
    padding: clamp(2.5rem, 5vh, 4rem) 0;
  }

  .impact__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    flex-wrap: wrap;
  }

  .impact__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.35rem;
    flex: 0 0 auto;
  }

  .impact__number {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-gold);
    letter-spacing: -0.02em;
  }

  .impact__label {
    font-size: clamp(0.72rem, 1vw, 0.85rem);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .impact__divider {
    width: 1px;
    height: 3rem;
    background: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }

  @media (max-width: 479px) {
    .impact__divider { height: 2rem; }
    .impact__inner { gap: 1.2rem; }
  }

  /* Mobile: tighter hero so products appear faster */
  @media (max-width: 767px) {
    .hero__inner {
      gap: var(--space-md);
      padding-top: var(--space-md);
    }

    .hero__text {
      padding-bottom: var(--space-sm);
    }

    .hero__title {
      margin-bottom: var(--space-sm);
    }

    .hero__sub {
      margin-bottom: var(--space-md);
    }

    .hero__actions {
      margin-bottom: var(--space-sm);
    }

    .hero__media {
      padding-bottom: var(--space-sm);
    }

    .hero__img-wrap {
      max-width: 280px;
    }
  }

  @media (min-width: 768px) {
    .hero__inner {
      grid-template-columns: 1.1fr 0.9fr;
      padding-top: clamp(3rem, 7vh, 5rem);
      gap: var(--space-xl);
    }

    .hero__text {
      padding-bottom: var(--space-xl);
    }

    .hero__media {
      justify-content: flex-end;
      padding-bottom: var(--space-lg);
    }

    .hero__img-wrap {
      width: 100%;
      max-width: 400px;
    }

  }

  @media (min-width: 1024px) {
