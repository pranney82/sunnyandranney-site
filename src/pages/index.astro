  }

  /* ─ CTA link ─ */
  .services__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-xl);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
