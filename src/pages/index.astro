    color: var(--color-charcoal);
  }

  @media (min-width: 768px) {
    .home-products .product-card {
      border-radius: 4px;
    }
    .home-products .product-card__info {
      padding: 1rem 0.25rem 0.25rem;
    }
    .home-products .product-card__type {
      display: none;
    }
