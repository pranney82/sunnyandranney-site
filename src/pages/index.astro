---
import Base from '@/layouts/Base.astro';
import GoogleReviews from '@/components/GoogleReviews.astro';
import EmailCapture from '@/components/EmailCapture.astro';

let products: any[] = [];
let hasShopify = false;
let shopifyImageUrl: (url: string, w?: number, h?: number) => string = (url) => url;
let shopifyImageSrcset: (url: string, widths?: number[]) => string = () => '';

try {
  const { getProducts, shopifyImageUrl: siu, shopifyImageSrcset: sis } = await import('@/lib/shopify');
  shopifyImageUrl = siu;
  shopifyImageSrcset = sis;
  const result = await getProducts(24);
  products = result.products;
  hasShopify = products.length > 0;
} catch (e) {
  console.log('Shopify API not configured.');
}

// Split products by type for homepage sections
const onSaleProducts = products.filter(p => {
  const compare = p.compareAtPriceRange?.minVariantPrice;
  const price = p.priceRange.minVariantPrice;
  return compare && parseFloat(compare.amount) > parseFloat(price.amount);
});
const featuredProducts = products.slice(0, 8);
const newArrivals = products.slice(0, 4);

// Hero images — use first 3 products with images for a dynamic collage
const heroImages = products
  .filter(p => p.images.edges.length > 0)
  .slice(0, 3)
  .map(p => p.images.edges[0].node);

// Category images — pick a representative product image per category
const categoryMap: Record<string, { href: string; label: string; sub: string; color: string; image?: string }> = {
  furniture: { href: '/shop?category=furniture', label: 'Furniture', sub: 'Sofas, chairs, tables & more', color: '' },
  decor:     { href: '/shop?category=decor', label: 'Home Decor', sub: 'Accessories, art & accents', color: 'sage' },
  lighting:  { href: '/shop?category=lighting', label: 'Lighting', sub: 'Lamps, pendants & fixtures', color: 'blush' },
  gifts:     { href: '/shop?category=gifts', label: 'Gifts', sub: 'Candles, books & unique finds', color: 'gold' },
  kitchenware: { href: '/shop?category=kitchenware', label: 'Kitchenware', sub: 'Serveware, tools & essentials', color: 'terracotta' },
};
for (const p of products) {
  const type = (p.productType || '').toLowerCase();
  if (categoryMap[type] && !categoryMap[type].image && p.images.edges.length > 0) {
    categoryMap[type].image = p.images.edges[0].node.url;
  }
}
const categoryTiles = Object.values(categoryMap);
---

<Base>
  <!-- ═══ HERO BANNER ═══ -->
  <section class="hero-banner">
    <div class="hero-banner__inner container">
      <div class="hero-banner__text">
        <h1 class="hero-banner__title animate-fade-up">
          Designer Furniture<br/>
          <span class="hero-banner__accent">& Home Decor</span>
        </h1>
        <p class="hero-banner__sub animate-fade-up delay-1">
          Curated pieces for every room. Every purchase supports children with special needs.
        </p>
        <div class="hero-banner__actions animate-fade-up delay-2">
          <a href="/shop" class="btn btn--gold" data-astro-prefetch="viewport">Shop All Products</a>
        </div>
      </div>
      <div class="hero-banner__visual animate-fade-up delay-1">
        {heroImages.length > 0 ? (
          <div class="hero-collage">
            <div class="hero-collage__main">
              <img
                src={shopifyImageUrl(heroImages[0].url, 800)}
                srcset={shopifyImageSrcset(heroImages[0].url, [400, 800, 1200])}
                sizes="(max-width: 768px) 90vw, 45vw"
                alt={heroImages[0].altText || 'Featured product'}
                width={heroImages[0].width}
                height={heroImages[0].height}
                fetchpriority="high"
                decoding="sync"
              />
            </div>
            {heroImages.length > 1 && (
              <div class="hero-collage__side">
                {heroImages.slice(1, 3).map((img: any) => (
                  <div class="hero-collage__thumb">
                    <img
                      src={shopifyImageUrl(img.url, 400)}
                      alt={img.altText || 'Featured product'}
                      width={img.width}
                      height={img.height}
                      loading="eager"
                      decoding="async"
                    />
                  </div>
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="hero-banner__image-placeholder">
            <span>Hero Image</span>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ═══ CATEGORY TILES ═══ -->
  <section class="cat-tiles section">
    <div class="container">
      <h2 class="section-title reveal">Shop by Category</h2>
      <div class="cat-tiles__grid">
        {categoryTiles.map((cat, idx) => (
          <a href={cat.href} class={`cat-tile reveal${idx > 0 ? ` delay-${idx}` : ''}`}>
            <div class={`cat-tile__bg${cat.color ? ` cat-tile__bg--${cat.color}` : ''}`}>
              {cat.image && (
                <img
                  src={shopifyImageUrl(cat.image, 500)}
                  srcset={shopifyImageSrcset(cat.image, [250, 500])}
                  sizes="(max-width: 768px) 50vw, 20vw"
                  alt={cat.label}
                  loading={idx < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="cat-tile__img"
                />
              )}
            </div>
            <div class="cat-tile__content">
              <h3>{cat.label}</h3>
              <span>{cat.sub}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED / TRENDING ═══ -->
  {hasShopify && featuredProducts.length > 0 && (
    <section class="home-products section">
      <div class="container">
        <div class="home-products__header reveal">
          <h2 class="section-title">Trending Now</h2>
          <a href="/shop" class="home-products__see-all">See all products →</a>
        </div>
        <div class="product-grid reveal" id="home-grid">
          {featuredProducts.map((product: any, idx: number) => {
            const image = product.images.edges[0]?.node;
            const image2 = product.images.edges[1]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            const isOnSale = compareAt && parseFloat(compareAt.amount) > parseFloat(price.amount);
            const firstVariant = product.variants.edges[0]?.node;

            return (
              <div class="product-card" data-type={product.productType.toLowerCase()}>
                {isOnSale && <span class="product-card__badge">Sale</span>}
                {!isOnSale && !product.availableForSale && <span class="product-card__badge product-card__badge--sold">Sold Out</span>}
                <a href={`/shop/${product.handle}`} class="product-card__image">
                  {image ? (
                    <>
                      <img
                        src={shopifyImageUrl(image.url, 600)}
                        srcset={shopifyImageSrcset(image.url, [300, 600, 900])}
                        sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
                        alt={image.altText || product.title}
                        width={image.width}
                        height={image.height}
                        loading={idx < 4 ? 'eager' : 'lazy'}
                        fetchpriority={idx === 0 ? 'high' : undefined}
                        decoding={idx === 0 ? 'sync' : 'async'}
                        class="product-card__img-primary"
                      />
                      {image2 && (
                        <img
                          src={shopifyImageUrl(image2.url, 600)}
                          srcset={shopifyImageSrcset(image2.url, [300, 600, 900])}
                          sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
                          alt={image2.altText || product.title}
                          width={image2.width}
                          height={image2.height}
                          loading="lazy"
                          decoding="async"
                          class="product-card__img-hover"
                        />
                      )}
                    </>
                  ) : (
                    <div class="product-card__image-ph">{product.productType || 'Product'}</div>
                  )}
                </a>
                <div class="product-card__info">
                  {product.productType && <span class="product-card__type">{product.productType}</span>}
                  <a href={`/shop/${product.handle}`} class="product-card__title">{product.title}</a>
                  <div class="product-card__pricing">
                    <span class="product-card__price">${parseFloat(price.amount).toFixed(2)}</span>
                    {isOnSale && (
                      <span class="product-card__price--compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                    )}
                  </div>
                  {product.availableForSale && firstVariant && (
                    <button class="product-card__add-btn"
                      data-variant-id={firstVariant.id}
                      data-title={product.title}
                      data-price={parseFloat(price.amount)}
                      data-image={image?.url || ''}
                      data-handle={product.handle}
                      data-variant-title={firstVariant.title}
                    >
                      Add to Cart
                    </button>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ VALUE PROPS BAR ═══ -->
  <section class="value-bar">
    <div class="container value-bar__inner">
      <div class="value-bar__item reveal">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <div>
          <strong>Free Shipping</strong>
          <span>On orders over $200</span>
        </div>
      </div>
      <div class="value-bar__item reveal delay-1">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div>
          <strong>Secure Checkout</strong>
          <span>Powered by Shopify</span>
        </div>
      </div>
      <div class="value-bar__item reveal delay-2">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
        <div>
          <strong>100% to Charity</strong>
          <span>Every dollar helps kids</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GOOGLE REVIEWS ═══ -->
  <GoogleReviews variant="full" />

  <!-- ═══ ON SALE (if any) ═══ -->
  {onSaleProducts.length > 0 && (
    <section class="home-products section">
      <div class="container">
        <div class="home-products__header reveal">
          <h2 class="section-title">On Sale</h2>
          <a href="/shop" class="home-products__see-all">Shop all deals →</a>
        </div>
        <div class="home-scroll reveal">
          {onSaleProducts.slice(0, 8).map((product: any) => {
            const image = product.images.edges[0]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            return (
              <a href={`/shop/${product.handle}`} class="home-scroll__card">
                <div class="home-scroll__image">
                  <span class="product-card__badge">Sale</span>
                  {image && (
                    <img
                      src={shopifyImageUrl(image.url, 400)}
                      srcset={shopifyImageSrcset(image.url, [220, 400])}
                      sizes="220px"
                      alt={image.altText || product.title}
                      width={image.width}
                      height={image.height}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <div class="home-scroll__info">
                  <span class="home-scroll__title">{product.title}</span>
                  <div class="home-scroll__pricing">
                    <span class="home-scroll__price">${parseFloat(price.amount).toFixed(2)}</span>
                    <span class="home-scroll__compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ MISSION STRIP ═══ -->
  <section class="mission-strip" id="mission">
    <div class="container mission-strip__inner">
      <div class="mission-strip__text">
        <h2>When You Shop Here, You Change a Life</h2>
        <p>
          Sunshine on a Ranney Day transforms the bedrooms and living spaces of children
          with special needs. 100% of store profits fund these makeovers.
        </p>
      </div>
      <div class="mission-strip__stats">
        <div class="mission-strip__stat">
          <span class="mission-strip__number">20,000+</span>
          <span class="mission-strip__label">Kids Impacted</span>
        </div>
        <div class="mission-strip__stat">
          <span class="mission-strip__number">13+</span>
          <span class="mission-strip__label">Years Giving</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VISIT STRIP ═══ -->
  <section class="visit-strip section">
    <div class="container visit-strip__inner">
      <div class="visit-strip__info">
        <h3>Visit Our Roswell Showroom</h3>
        <p>109A Oak Street, Roswell, GA 30075</p>
        <p>Tue–Thu 10am–5pm &middot; Fri–Sat 10am–6pm</p>
        <p><a href="tel:6788885140">678.888.5140</a> &middot; <a href="mailto:info@sunnyandranney.com">info@sunnyandranney.com</a></p>
      </div>
      <a href="https://maps.google.com/?q=109A+Oak+Street+Roswell+GA+30075" target="_blank" rel="noopener noreferrer" class="btn btn--outline">
        Get Directions
      </a>
    </div>
  </section>

  <!-- ═══ RECENTLY VIEWED ═══ -->
  <section class="home-recent section" id="home-recent-section" style="display:none;">
    <div class="container">
      <div class="home-products__header">
        <h2 class="section-title">Pick Up Where You Left Off</h2>
        <a href="/shop" class="home-products__see-all">Continue shopping →</a>
      </div>
      <div class="home-recent__scroll" id="home-recent-scroll"></div>
    </div>
  </section>

  <!-- ═══ EMAIL CAPTURE ═══ -->
  <EmailCapture />
</Base>

<style>
  /* ─── Hero Banner ──────────────────────── */
  .hero-banner {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(75, 149, 180, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(255, 212, 0, 0.06) 0%, transparent 40%),
      var(--color-cyan);
    overflow: hidden;
  }

  .hero-banner__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  @media (min-width: 768px) {
    .hero-banner__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
      min-height: 420px;
    }
  }

  .hero-banner__title {
    color: white;
    font-size: clamp(2.4rem, 5vw, 4rem);
    margin: 0 0 1rem;
    line-height: 1.05;
  }

  .hero-banner__accent {
    color: var(--color-gold);
    font-style: italic;
    font-weight: 300;
  }

  .hero-banner__sub {
    color: rgba(255,255,255,0.85);
    font-size: 1rem;
    margin-bottom: 0;
  }

  .hero-banner__actions { margin-top: var(--space-md); }
  .hero-banner__actions .btn--gold:hover { background: white; border-color: white; }

  .hero-banner__image-placeholder {
    aspect-ratio: 3/2;
    background: rgba(255,255,255,0.1);
    border: 2px dashed rgba(255,255,255,0.3);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: rgba(255,255,255,0.4);
  }

  /* ─── Hero Collage ──────────────────────── */
  .hero-collage {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    border-radius: 8px;
    overflow: hidden;
  }

  @media (min-width: 480px) {
    .hero-collage {
      grid-template-columns: 2fr 1fr;
    }
  }

  .hero-collage__main {
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 8px;
  }

  @media (min-width: 480px) {
    .hero-collage__main { aspect-ratio: 3/4; }
  }

  .hero-collage__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .hero-collage:hover .hero-collage__main img {
    transform: scale(1.03);
  }

  .hero-collage__side {
    display: none;
    flex-direction: column;
    gap: 0.5rem;
  }

  @media (min-width: 480px) {
    .hero-collage__side { display: flex; }
  }

  .hero-collage__thumb {
    flex: 1;
    overflow: hidden;
    border-radius: 8px;
  }

  .hero-collage__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .hero-collage__thumb:hover img {
    transform: scale(1.05);
  }

  /* ─── Section Title ────────────────────── */
  .section-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: var(--space-lg);
  }

  /* ─── Category Tiles ───────────────────── */
  .cat-tiles__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .cat-tiles__grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
    }
  }

  .cat-tile {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    border-radius: 4px;
  }

  .cat-tile__bg {
    position: absolute;
    inset: 0;
    background: var(--color-charcoal);
    transition: transform 0.6s var(--ease-out);
    overflow: hidden;
  }

  .cat-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.7;
    transition: opacity 0.4s, transform 0.6s var(--ease-out);
  }

  .cat-tile:hover .cat-tile__img {
    opacity: 0.5;
    transform: scale(1.08);
  }

  .cat-tile__bg--sage { background: var(--color-sage); }
  .cat-tile__bg--blush { background: var(--color-blush); }
  .cat-tile__bg--gold { background: linear-gradient(135deg, var(--color-gold), #e6bf00); }
  .cat-tile__bg--terracotta { background: var(--color-terracotta); }

  .cat-tile:hover .cat-tile__bg { transform: scale(1.08); }

  .cat-tile__content {
    position: relative;
    z-index: 1;
    padding: 1rem;
    color: white;
  }

  .cat-tile__content h3 {
    font-size: 1.2rem;
    margin-bottom: 0.15rem;
    line-height: 1.2;
  }

  .cat-tile__content span {
    font-size: 0.72rem;
    opacity: 0.75;
  }

  .cat-tile__bg--gold + .cat-tile__content { color: var(--color-charcoal); }
  .cat-tile__bg--gold + .cat-tile__content span { opacity: 0.6; }

  /* ─── Home Products Header ─────────────── */
  .home-products { background: var(--color-warm-white); }

  .home-products__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .home-products__header .section-title { margin-bottom: 0; }

  .home-products__see-all {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-gold);
    letter-spacing: 0.04em;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .home-products__see-all:hover { color: var(--color-charcoal); }

  .home-products .product-grid {
    margin-top: var(--space-lg);
  }

  /* ─── Image hover swap (homepage cards) ── */
  .product-card__img-primary,
  .product-card__img-hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.6s var(--ease-out), transform 0.8s var(--ease-out);
  }

  .product-card__img-hover { opacity: 0; }
  .product-card:hover .product-card__img-primary { opacity: 0; }
  .product-card:hover .product-card__img-hover { opacity: 1; transform: scale(1.03); }
  .product-card:hover .product-card__img-primary:only-child { opacity: 1; transform: scale(1.05); }

  /* ─── Horizontal Scroll (deals) ────────── */
  .home-scroll {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.5rem;
    margin-top: var(--space-lg);
    scrollbar-width: thin;
    scrollbar-color: var(--color-cream-dark) transparent;
  }

  .home-scroll__card {
    flex-shrink: 0;
    width: 220px;
    scroll-snap-align: start;
    background: var(--color-cream);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    overflow: hidden;
  }

  .home-scroll__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(44,44,44,0.08);
  }

  .home-scroll__image {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-cream-dark);
    position: relative;
  }

  .home-scroll__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .home-scroll__card:hover .home-scroll__image img { transform: scale(1.05); }

  .home-scroll__info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .home-scroll__title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-charcoal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-scroll__pricing { display: flex; align-items: baseline; gap: 0.5rem; }
  .home-scroll__price { font-weight: 600; font-size: 0.9rem; color: var(--color-charcoal); }
  .home-scroll__compare { font-size: 0.8rem; color: var(--color-stone); text-decoration: line-through; }

  /* ─── Value Props Bar ──────────────────── */
  .value-bar {
    background: var(--color-cream);
    border-top: 1px solid var(--color-cream-dark);
    border-bottom: 1px solid var(--color-cream-dark);
    padding: var(--space-lg) 0;
  }

  .value-bar__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .value-bar__inner { grid-template-columns: repeat(3, 1fr); }
  }

  .value-bar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .value-bar__item svg { color: var(--color-gold); flex-shrink: 0; }
  .value-bar__item strong { display: block; font-size: 0.85rem; color: var(--color-charcoal); }
  .value-bar__item span { font-size: 0.78rem; color: var(--color-stone); }
  .value-bar__item div { text-align: left; }

  /* ─── Mission Strip ────────────────────── */
  .mission-strip {
    background: linear-gradient(160deg, var(--color-cyan) 0%, #3a7d9a 100%);
    padding: var(--space-xl) 0;
  }

  .mission-strip__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (min-width: 768px) {
    .mission-strip__inner { grid-template-columns: 1.5fr 1fr; }
  }

  .mission-strip__text h2 {
    color: var(--color-gold);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin-bottom: 0.75rem;
  }

  .mission-strip__text p {
    color: rgba(255,255,255,0.8);
    max-width: 50ch;
  }

  .mission-strip__stats {
    display: flex;
    gap: var(--space-xl);
    justify-content: center;
  }

  .mission-strip__stat { text-align: center; }
  .mission-strip__number {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 600;
    color: white;
    line-height: 1;
  }
  .mission-strip__label {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-top: 0.3rem;
  }

  /* ─── Visit Strip ──────────────────────── */
  .visit-strip {
    background: var(--color-gold);
  }

  .visit-strip__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .visit-strip__info h3 {
    font-size: 1.3rem;
    margin-bottom: 0.3rem;
    color: var(--color-charcoal);
  }

  .visit-strip__info p {
    font-size: 0.88rem;
    color: var(--color-charcoal);
    margin: 0.15rem 0;
    max-width: none;
  }

  .visit-strip__info a { color: var(--color-charcoal); font-weight: 600; }

  .visit-strip .btn--outline {
    border-color: var(--color-charcoal);
    color: var(--color-charcoal);
    flex-shrink: 0;
  }

  .visit-strip .btn--outline:hover {
    background: var(--color-charcoal);
    color: var(--color-gold);
  }

  /* ─── Product card add to cart (homepage) ── */
  .product-card__add-btn {
    margin-top: 0.75rem;
    width: 100%;
    padding: 0.6rem 1rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .product-card__add-btn:hover {
    background: var(--color-gold);
    color: var(--color-charcoal);
  }

  /* ─── Recently Viewed (homepage) ────────── */
  .home-recent { background: var(--color-cream); }

  .home-recent__scroll {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.5rem;
    margin-top: var(--space-lg);
    scrollbar-width: thin;
    scrollbar-color: var(--color-cream-dark) transparent;
  }

  .home-recent__card {
    flex-shrink: 0;
    width: 200px;
    scroll-snap-align: start;
    background: var(--color-warm-white);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    overflow: hidden;
  }

  .home-recent__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(44,44,44,0.08);
  }

  .home-recent__image {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-cream-dark);
  }

  .home-recent__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .home-recent__card:hover .home-recent__image img { transform: scale(1.05); }

  .home-recent__info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .home-recent__title {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-charcoal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-recent__price {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }
</style>

<script>
  // ─── Recently viewed on homepage ───────────
  const recentSection = document.getElementById('home-recent-section');
  const recentScroll = document.getElementById('home-recent-scroll');
  if (recentSection && recentScroll) {
    try {
      const items = JSON.parse(localStorage.getItem('sr_recent') || '[]');
      if (items.length > 0) {
        recentSection.style.display = '';
        const frag = document.createDocumentFragment();
        items.slice(0, 8).forEach((item: any) => {
          const card = document.createElement('a');
          card.href = `/shop/${encodeURIComponent(item.handle)}`;
          card.className = 'home-recent__card';

          const imgWrap = document.createElement('div');
          imgWrap.className = 'home-recent__image';
          if (item.image) {
            const img = document.createElement('img');
            img.src = item.image.includes('cdn.shopify.com') ? `${item.image}?width=400&crop=center` : item.image;
            img.alt = item.title || '';
            img.loading = 'lazy';
            imgWrap.appendChild(img);
          }
          card.appendChild(imgWrap);

          const info = document.createElement('div');
          info.className = 'home-recent__info';
          const title = document.createElement('span');
          title.className = 'home-recent__title';
          title.textContent = item.title;
          info.appendChild(title);
          if (item.price) {
            const price = document.createElement('span');
            price.className = 'home-recent__price';
            price.textContent = `$${parseFloat(item.price).toFixed(2)}`;
            info.appendChild(price);
          }
          card.appendChild(info);
          frag.appendChild(card);
        });
        recentScroll.replaceChildren(frag);
      }
    } catch {}
  }

  // Add to cart from homepage product cards
  const homeGrid = document.getElementById('home-grid');

  homeGrid?.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest('.product-card__add-btn');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const { variantId, title, price, image, handle, variantTitle } = (btn as HTMLElement).dataset;
    if (!variantId || !title || !price) return;

    window.addToCart?.({
      variantId,
      title,
      price: parseFloat(price),
      image: image || '',
      handle: handle || '',
      variantTitle: variantTitle || '',
    });

    const orig = btn.textContent;
    btn.textContent = '✓ Added';
    (btn as HTMLButtonElement).disabled = true;
    setTimeout(() => {
      btn.textContent = orig;
      (btn as HTMLButtonElement).disabled = false;
    }, 1500);
  });
</script>
