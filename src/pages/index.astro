---
import Base from '@/layouts/Base.astro';
import GoogleReviews from '@/components/GoogleReviews.astro';
import { getProducts, getCollectionByHandle, getProductByHandle, formatPriceShort as fmt } from '@/lib/shopify';
import { cfImage, cfSrcset } from '@/lib/images';
import { getHeroStatic, getReviewsStatic } from '@/lib/settings';
import { fetchGooglePlaceData } from '@/lib/google-places';

// Fetch live stats from SOARD at build time
let soardStats: { roomMakeovers: number; yearsGiving: number } | null = null;
try {
  const res = await fetch('https://soard-site.pages.dev/api/stats.json', { signal: AbortSignal.timeout(3000) });
  if (res.ok) soardStats = await res.json();
} catch { /* use fallbacks */ }
const statRooms = soardStats?.roomMakeovers ?? 269;
const statYears = soardStats?.yearsGiving ?? 14;

// Google rating (live API → saved fallback)
const livePlace = await fetchGooglePlaceData();
const savedReviews = await getReviewsStatic();
const googleRating = livePlace?.rating ?? savedReviews?.googleRating ?? 5.0;

let products: any[] = [];
let staffPickProducts: any[] = [];
let hasShopify = false;

// Load hero setting (fallback image + product handle)
const heroSetting = await getHeroStatic();
const HERO_DEFAULT_IMAGE = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/sunny-ranney-storefront';
const HERO_QUALITY = 75;
const HERO_SIZES = '(max-width: 767px) 280px, (max-width: 1023px) 400px, 440px';

let heroProduct: any = null;
let heroImageBase = heroSetting?.imageUrl?.trim().replace(/\/$/, '') || HERO_DEFAULT_IMAGE;

try {
  // Load newest products sorted by creation date (no Shopify collection needed)
  const result = await getProducts(8, undefined, 'CREATED_AT');
  products = result.products;
  hasShopify = products.length > 0;

  // Load hero product — smart collection "homepage-hero" (tag: hero) → hero.json → first product
  const heroCollection = await getCollectionByHandle('homepage-hero', 1);
  if (heroCollection && heroCollection.products.length > 0) {
    heroProduct = heroCollection.products[0];
    // Use the product's first image as the hero image
    const heroImg = heroProduct.images?.edges?.[0]?.node?.url || heroProduct.images?.[0]?.url;
    if (heroImg) {
      heroImageBase = heroImg;
    }
  }
  if (!heroProduct && heroSetting?.productHandle) {
    heroProduct = await getProductByHandle(heroSetting.productHandle);
  }
  if (!heroProduct && products.length > 0) {
    heroProduct = products[0];
  }

  // Load staff picks from Shopify "staff-picks" manual collection
  const staffPicksCollection = await getCollectionByHandle('staff-picks', 8);
  if (staffPicksCollection && staffPicksCollection.products.length > 0) {
    staffPickProducts = staffPicksCollection.products;
  }
} catch (e) {
  console.log('Shopify API not configured.');
}

const heroSrc = cfImage(heroImageBase, { width: 480, height: 480, quality: HERO_QUALITY });
const heroSrcset = cfSrcset(heroImageBase, [280, 480, 880], HERO_QUALITY);


---

<Base lcpImage={heroSrc} lcpImageSrcset={heroSrcset} lcpImageSizes={HERO_SIZES}>
  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__kicker">Furniture with Heart</p>
        <h1 class="hero__title">Shop with<br/>a Purpose</h1>
        <p class="hero__sub">Curated furniture & home decor where every purchase transforms a child's room through <strong>Sunshine on a Ranney Day</strong>.</p>
        <div class="hero__actions">
          <a href="/shop/" class="btn btn--gold btn--hero" data-astro-prefetch>Shop &amp; Give Back</a>
        </div>
        <div class="hero__trust">
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure Checkout
          </span>
          <span class="hero__trust-sep"></span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {googleRating} on Google
          </span>
          <span class="hero__trust-sep"></span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Roswell Pickup
          </span>
        </div>
      </div>
      <div class="hero__media">
        <div class="hero__img-wrap">
          <a href={hasShopify && heroProduct ? `/shop/${heroProduct.handle}/` : '/shop/'} data-astro-prefetch>
            <img
              src={heroSrc}
              srcset={heroSrcset}
              sizes={HERO_SIZES}
              alt="The Sunny & Ranney storefront in historic Roswell, Georgia"
              width="480"
              height="480"
              fetchpriority="high"
            />
          </a>
        </div>
        <div class="hero__accent" aria-hidden="true"></div>
        {hasShopify && heroProduct && (() => {
          const fp = heroProduct;
          const fpImg = fp.images.edges[0]?.node;
          const fpPrice = fp.priceRange.minVariantPrice;
          return (
            <a href={`/shop/${fp.handle}/`} class="hero__product-card" data-astro-prefetch>
              {fpImg && (
                <img
                  src={cfImage(fpImg.url, { width: 200 })}
                  alt=""
                  width="80"
                  height="80"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="hero__product-info">
                <span class="hero__product-label">Bestseller</span>
                <span class="hero__product-name">{fp.title}</span>
                <span class="hero__product-price">${parseFloat(fpPrice.amount).toFixed(0)}</span>
              </div>
            </a>
          );
        })()}
      </div>
    </div>
  </section>

  <!-- ═══ PROMISE STRIP ═══ -->
  <section class="promise" aria-label="Why shop with us">
    <div class="container promise__inner">
      <div class="promise__item reveal">
        <span class="promise__rule" aria-hidden="true"></span>
        <span class="promise__title">100% of Profits Donated</span>
        <span class="promise__desc">Every order transforms a child's room</span>
      </div>
      <div class="promise__item reveal delay-1">
        <span class="promise__rule" aria-hidden="true"></span>
        <span class="promise__title">Brand New Furniture</span>
        <span class="promise__desc">Quality pieces, not a thrift store</span>
      </div>
      <div class="promise__item reveal delay-2">
        <span class="promise__rule" aria-hidden="true"></span>
        <span class="promise__title">Complimentary Design</span>
        <span class="promise__desc">Our designers work with you at no cost</span>
      </div>
    </div>
  </section>

  <!-- ═══ STAFF PICKS ═══ -->
  {staffPickProducts.length > 0 && (
    <section class="staff-picks section">
      <div class="container">
        <div class="staff-picks__header reveal">
          <p class="staff-picks__kicker"><span class="staff-picks__kicker-line"></span>Staff Picks<span class="staff-picks__kicker-line"></span></p>
          <h2 class="staff-picks__title">What We're Loving</h2>
        </div>
        <div class={`staff-picks__grid staff-picks__grid--${Math.min(staffPickProducts.length, 6)}`}>
          {staffPickProducts.map((p: any, idx: number) => {
            const img = p.images.edges[0]?.node;
            const img2 = p.images.edges[1]?.node;
            const price = parseFloat(p.priceRange.minVariantPrice.amount);
            const comparePrice = p.compareAtPriceRange?.maxVariantPrice
              ? parseFloat(p.compareAtPriceRange.maxVariantPrice.amount)
              : 0;
            const hasDiscount = comparePrice > price;
            const allImages = p.images.edges.map((e: any) => e.node.url);
            const variants = p.variants.edges.map((e: any) => ({
              id: e.node.id,
              title: e.node.title,
              price: e.node.price.amount,
              available: e.node.availableForSale,
            }));
            return (
              <div class={`staff-pick-card reveal${idx > 0 ? ` delay-${Math.min(idx, 3)}` : ''}`}>
                <div class="staff-pick-card__img">
                  <a href={`/shop/${p.handle}/`} data-astro-prefetch aria-label={p.title}>
                    {img && (
                      <img
                        src={cfImage(img.url, { width: 800, quality: 80 })}
                        srcset={cfSrcset(img.url, [400, 600, 800], 80)}
                        sizes="(max-width: 480px) 45vw, (max-width: 768px) 30vw, 260px"
                        alt={p.title}
                        width="600"
                        height="600"
                        loading="lazy"
                        decoding="async"
                        class="staff-pick-card__img-primary"
                      />
                    )}
                  </a>
                  {hasDiscount && <span class="staff-pick-card__sale">Sale</span>}
                </div>
                <a href={`/shop/${p.handle}/`} class="staff-pick-card__info" data-astro-prefetch>
                  <h3 class="staff-pick-card__name">{p.title}</h3>
                  <div class="staff-pick-card__pricing">
                    <span class="staff-pick-card__price">{fmt(price)}</span>
                    {hasDiscount && <span class="staff-pick-card__compare">{fmt(comparePrice)}</span>}
                  </div>
                </a>
              </div>
            );
          })}
        </div>
        <div class="staff-picks__footer reveal">
          <a href="/shop/" class="staff-picks__cta" data-astro-prefetch>
            <span class="staff-picks__cta-text">Shop the Collection</span>
            <span class="staff-picks__cta-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9h10m0 0-3.5-3.5M14 9l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ GOOGLE REVIEWS ═══ -->
  <GoogleReviews variant="full" />

  <!-- ═══ SHOWROOM EXPERIENCE ═══ -->
  <section class="services">
    <div class="container services__inner">
      <div class="services__media reveal">
        <div class="shop-look__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/showroom-editorial/w=800,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/showroom-editorial/w=500,q=75,format=auto 500w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/showroom-editorial/w=800,q=80,format=auto 800w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/showroom-editorial/w=1100,q=80,format=auto 1100w"
            sizes="(max-width: 767px) 90vw, 45vw"
            alt="Elegant living room with cream boucle sofa and cognac leather accent chair"
            width="800"
            height="1000"
            loading="lazy"
            decoding="async"
          />
          <a href="/shop/?collection=art-mirrors" class="shop-look__tag" style="top: 20%; left: 50%;" data-astro-prefetch>
            <span class="shop-look__dot"></span>
            <span class="shop-look__label">Art & Mirrors</span>
          </a>
          <a href="/shop/?collection=living&type=Sofas" class="shop-look__tag" style="top: 45%; left: 10%;" data-astro-prefetch>
            <span class="shop-look__dot"></span>
            <span class="shop-look__label">Sofas</span>
          </a>
          <a href="/shop/?collection=living&type=Armchairs" class="shop-look__tag" style="top: 58%; left: 82%;" data-astro-prefetch>
            <span class="shop-look__dot"></span>
            <span class="shop-look__label">Accent Chairs</span>
          </a>
          <a href="/shop/?collection=living&type=Coffee+Tables" class="shop-look__tag" style="top: 65%; left: 28%;" data-astro-prefetch>
            <span class="shop-look__dot"></span>
            <span class="shop-look__label">Coffee Tables</span>
          </a>
          <a href="/shop/?collection=rugs-collection" class="shop-look__tag" style="top: 88%; left: 72%;" data-astro-prefetch>
            <span class="shop-look__dot"></span>
            <span class="shop-look__label">Rugs</span>
          </a>
        </div>
      </div>
      <div class="services__content reveal delay-1">
        <p class="services__kicker">The Showroom Experience</p>
        <h2 class="services__heading">We help you build<br/>the room you've<br/>been imagining.</h2>

        <div class="services__list">
          <div class="services__offering">
            <span class="services__number">01</span>
            <div>
              <h3 class="services__title">Design Assistance</h3>
              <p class="services__desc">Tell us about your space. Our in-house designers work with you from layout to finishing touches — complimentary, no project too small.</p>
            </div>
          </div>
          <div class="services__offering">
            <span class="services__number">02</span>
            <div>
              <h3 class="services__title">Custom Sourcing</h3>
              <p class="services__desc">Looking for something specific? We tap into a global network of makers to find pieces beyond what's on our floor.</p>
            </div>
          </div>
          <div class="services__offering">
            <span class="services__number">03</span>
            <div>
              <h3 class="services__title">Custom Upholstery</h3>
              <p class="services__desc">Choose your fabrics, finishes, and silhouettes. We'll craft a one-of-a-kind piece made to order, just for you.</p>
            </div>
          </div>
        </div>

        <a href="mailto:info@sunnyandranney.com" class="services__link">
          Start a project
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>



  <!-- ═══ MISSION ═══ -->
  <section class="mission" id="mission">
    <div class="container mission__inner">
      <div class="mission__media reveal">
        <div class="mission__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/desmond/photo-11/w=900,h=600,fit=cover,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/desmond/photo-11/w=600,h=400,fit=cover,q=80,format=auto 600w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/desmond/photo-11/w=900,h=600,fit=cover,q=80,format=auto 900w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/desmond/photo-11/w=1200,h=800,fit=cover,q=80,format=auto 1200w"
            sizes="(max-width: 767px) 90vw, (max-width: 1024px) 45vw, 540px"
            alt="Desmond seeing his new room for the first time during a Sunshine on a Ranney Day reveal"
            width="900"
            height="600"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <!-- Content -->
      <div class="mission__content reveal delay-1">
        <div class="mission__badge">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/brand-logo-nav-circle/w=120,h=120,fit=scale-down,q=85,format=auto"
            alt="Sunshine on a Ranney Day"
            width="48"
            height="48"
            loading="lazy"
            decoding="async"
          />
          <span class="mission__badge-text">Sunshine on a Ranney Day</span>
        </div>
        <h2 class="mission__title">Every Purchase Changes a Child's World</h2>
        <p class="mission__body">
          When you shop at Sunny and Ranney, you're not just buying furniture.
          100% of store profits fund bedroom and living space makeovers
          for children with special needs.
        </p>

        <!-- Stats -->
        <div class="mission__stats">
          <div class="mission__stat">
            <span class="mission__stat-num" data-count={statRooms}>{statRooms}+</span>
            <span class="mission__stat-label">Rooms Transformed</span>
          </div>
          <div class="mission__stat-divider" aria-hidden="true"></div>
          <div class="mission__stat">
            <span class="mission__stat-num" data-count={statYears}>{statYears}</span>
            <span class="mission__stat-label">Years &amp; Counting</span>
          </div>
          <div class="mission__stat-divider" aria-hidden="true"></div>
          <div class="mission__stat">
            <span class="mission__stat-num">100%</span>
            <span class="mission__stat-label">Profits Donated</span>
          </div>
        </div>

        <div class="mission__actions">
          <a href="/shop/" class="btn btn--gold mission__cta-primary" data-astro-prefetch>Shop &amp; Give Back</a>
          <a href="/about/" class="mission__cta-link" data-astro-prefetch>Read Our Full Story <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>


</Base>

<style>
  /* ─── Hero ─────────────────────────────── */
  .hero {
    background: #2B7A96;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding-top: clamp(2rem, 5vh, 3.5rem);
    padding-bottom: 0;
    align-items: center;
  }

  .hero__text {
    padding-bottom: var(--space-lg);
  }

  .hero__kicker {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 var(--space-sm);
  }

  .hero__title {
    font-size: clamp(2.6rem, 8vw, 5.2rem);
    line-height: 0.92;
    letter-spacing: -0.025em;
    color: white;
    margin: 0 0 var(--space-md);
  }

  .hero__sub {
    color: #fff;
    font-size: clamp(0.92rem, 1.1vw, 1.05rem);
    max-width: 38ch;
    margin: 0 0 var(--space-lg);
    line-height: 1.65;
  }

  .hero__sub strong {
    color: #fff;
    font-weight: 700;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .hero__mission-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .hero__mission-link:hover {
    color: var(--color-gold);
  }

  /* Trust signals — inline in hero */
  .hero__trust {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: 0.02em;
  }

  .hero__trust-item svg {
    opacity: 1;
  }

  .hero__trust-sep {
    width: 1px;
    height: 12px;
    background: rgba(255,255,255,0.2);
  }

  /* Hero image — contained, rounded, with accent */
  .hero__media {
    position: relative;
    display: flex;
    justify-content: center;
    padding-bottom: var(--space-md);
  }

  .hero__img-wrap {
    position: relative;
    z-index: 1;
    width: 90%;
    max-width: 320px;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2), 0 8px 20px rgba(0,0,0,0.12);
    background: #f0ede8;
  }

  .hero__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1;
    object-fit: cover;
    transition: transform 1.2s var(--ease-out);
  }

  .hero__img-wrap:hover img {
    transform: scale(1.03);
  }

  .hero__accent {
    position: absolute;
    bottom: -8px;
    right: -8px;
    width: 55%;
    height: 50%;
    background: var(--color-gold);
    border-radius: 12px;
    opacity: 0.2;
    z-index: 0;
  }

  /* Hero floating product card */
  .hero__product-card {
    position: absolute;
    bottom: 2rem;
    left: -1rem;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: white;
    border-radius: 8px;
    padding: 0.5rem 0.75rem 0.5rem 0.5rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.15), 0 2px 8px rgba(0,0,0,0.08);
    text-decoration: none;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    max-width: 200px;
  }

  .hero__product-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.2), 0 4px 12px rgba(0,0,0,0.1);
  }

  .hero__product-card img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .hero__product-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .hero__product-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #175870;
  }

  .hero__product-name {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-charcoal);
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero__product-price {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-slate);
  }

  @media (max-width: 767px) {
    .hero__product-card {
      bottom: 1.5rem;
      left: -0.5rem;
      max-width: 180px;
      padding: 0.4rem 0.6rem 0.4rem 0.4rem;
    }
    .hero__product-card img {
      width: 44px;
      height: 44px;
    }
  }


  /* Mobile: tighter hero so products appear faster */
  @media (max-width: 767px) {
    .hero__inner {
      gap: var(--space-md);
      padding-top: var(--space-md);
    }

    .hero__text {
      padding-bottom: var(--space-sm);
    }

    .hero__title {
      margin-bottom: var(--space-sm);
    }

    .hero__sub {
      margin-bottom: var(--space-md);
    }

    .hero__actions {
      margin-bottom: var(--space-sm);
    }

    .hero__media {
      padding-bottom: var(--space-sm);
    }

    .hero__img-wrap {
      max-width: 280px;
    }
  }

  @media (min-width: 768px) {
    .hero__inner {
      grid-template-columns: 1.1fr 0.9fr;
      padding-top: clamp(3rem, 7vh, 5rem);
      gap: var(--space-xl);
    }

    .hero__text {
      padding-bottom: var(--space-xl);
    }

    .hero__media {
      justify-content: flex-end;
      padding-bottom: var(--space-lg);
    }

    .hero__img-wrap {
      width: 100%;
      max-width: 400px;
    }

  }

  @media (min-width: 1024px) {
    .hero__img-wrap {
      max-width: 440px;
    }
  }

  /* ─── Promise Strip ──────────────────── */
  .promise {
    background: transparent;
    padding: clamp(3rem, 6vh, 5rem) 0;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .promise__inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .promise__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 clamp(1.5rem, 3vw, 3rem);
    position: relative;
  }

  .promise__item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 10%;
    height: 80%;
    width: 1px;
    background: var(--color-cream-dark);
  }

  .promise__rule {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--color-charcoal);
    margin-bottom: 1.25rem;
  }

  .promise__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    font-weight: 400;
    color: var(--color-charcoal);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }

  .promise__desc {
    font-size: clamp(0.82rem, 0.95vw, 0.9rem);
    color: var(--color-slate);
    line-height: 1.6;
    max-width: 28ch;
  }

  @media (max-width: 679px) {
    .promise__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .promise__item:not(:last-child)::after {
      display: none;
    }

    .promise__item:not(:last-child) {
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--color-cream-dark);
    }

    .promise__item {
      padding-left: 0;
      padding-right: 0;
    }
  }

  /* ─── Section Title ────────────────────── */
  .section-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: var(--space-lg);
  }

  /* ─── Staff Picks ────────────────────── */
  .staff-picks {
    padding-top: clamp(4rem, 8vh, 6rem);
    padding-bottom: clamp(4rem, 8vh, 6rem);
    background: #fff;
  }

  .staff-picks__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vh, 3.5rem);
  }

  .staff-picks__kicker {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-charcoal);
    margin: 0 0 1.2rem;
  }

  .staff-picks__kicker-line {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--color-cyan);
    opacity: 0.5;
  }

  .staff-picks__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* ── Grid ── */
  .staff-picks__grid {
    display: grid;
    gap: clamp(2rem, 3vw, 2.5rem);
    grid-template-columns: repeat(3, 1fr);
  }

  .staff-picks__grid--4 {
    grid-template-columns: repeat(2, 1fr);
    max-width: 52rem;
    margin-inline: auto;
  }

  .staff-picks__grid--5 {
    grid-template-columns: repeat(6, 1fr);
  }

  .staff-picks__grid--5 > :nth-child(-n+3) {
    grid-column: span 2;
  }

  .staff-picks__grid--5 > :nth-child(4) {
    grid-column: 2 / span 2;
  }

  .staff-picks__grid--5 > :nth-child(5) {
    grid-column: 4 / span 2;
  }

  .staff-picks__grid--6 {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 767px) {
    .staff-picks__grid,
    .staff-picks__grid--5 {
      grid-template-columns: repeat(2, 1fr);
    }
    .staff-picks__grid--5 > * {
      grid-column: span 1 !important;
    }
    .staff-picks__grid--4 {
      max-width: none;
    }
  }

  @media (min-width: 1024px) {
    .staff-picks__grid--4 {
      grid-template-columns: repeat(4, 1fr);
      max-width: none;
    }
  }

  /* ── Card ── */
  .staff-pick-card {
    text-decoration: none;
    color: var(--color-charcoal);
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
  }

  .staff-pick-card__img {
    position: relative;
    overflow: hidden;
    background: #f8f7f5;
    aspect-ratio: 1 / 1;
  }

  .staff-pick-card__img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(0, 0, 0, 0.03) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .staff-pick-card__img a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .staff-pick-card__img-primary,
  .staff-pick-card__img-hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transition: transform 1.2s var(--ease-out);
  }

  .staff-pick-card:hover .staff-pick-card__img-primary {
    transform: scale(1.04);
  }

  .staff-pick-card__img-hover {
    display: none;
  }


  .staff-pick-card__sale {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-charcoal);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.55rem;
    border-radius: 4px;
    z-index: 2;
  }

  .staff-pick-card__info {
    padding: 0.9rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    color: var(--color-charcoal);
  }

  .staff-pick-card__name {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-charcoal);
    margin: 0 0 0.3rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .staff-pick-card__pricing {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: auto;
  }

  .staff-pick-card__price {
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .staff-pick-card__compare {
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--color-stone);
    text-decoration: line-through;
  }

  /* ── CTA ── */
  .staff-picks__footer {
    text-align: center;
    margin-top: clamp(2.5rem, 5vh, 3.5rem);
  }

  .staff-picks__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    text-decoration: none;
    border: 2px solid var(--color-charcoal);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.35s var(--ease-out);
  }

  .staff-picks__cta:hover {
    background: var(--color-gold);
    border-color: var(--color-gold);
    color: var(--color-charcoal);
    transform: translateY(-2px);
  }

  .staff-picks__cta:active {
    transform: translateY(0);
    transition-duration: 0.08s;
  }

  .staff-picks__cta-text {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.9rem 1.6rem;
  }

  .staff-picks__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding-right: 1.4rem;
    transition: transform 0.3s var(--ease-out);
  }

  .staff-picks__cta:hover .staff-picks__cta-icon {
    transform: translateX(3px);
  }

  /* ─── Shop the Look (hotspots) ──────────── */
  .shop-look__img-wrap {
    position: relative;
    overflow: hidden;
    background: #f0ede8;
  }

  .shop-look__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  /* Hotspot tags */
  .shop-look__tag {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    z-index: 1;
    transform: translate(-50%, -50%);
    min-width: 48px;
    min-height: 48px;
    padding: 10px;
  }

  .shop-look__dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: white;
    border: 2px solid var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .shop-look__dot::after {
    content: '+';
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-charcoal);
    line-height: 1;
  }

  .shop-look__label {
    background: white;
    color: var(--color-charcoal);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    white-space: nowrap;
  }

  .shop-look__tag:hover .shop-look__dot {
    transform: scale(1.15);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }

  /* Pulse animation on dots */
  .shop-look__dot::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--color-gold);
    opacity: 0;
    animation: shop-look-pulse 2.5s ease-out infinite;
  }

  @keyframes shop-look-pulse {
    0% { opacity: 0.6; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.6); }
  }

  @media (max-width: 639px) {
    .shop-look__dot {
      width: 24px;
      height: 24px;
    }
    .shop-look__dot::after {
      font-size: 0.75rem;
    }
    .shop-look__label {
      font-size: 0.7rem;
      padding: 0.25rem 0.5rem;
    }
  }

  /* ─── Trending Hero Row ──────────────────── */
  .trending-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: var(--space-lg);
  }

  @media (min-width: 640px) {
    .trending-hero {
      grid-template-columns: 1fr 1fr;
    }
  }

  .product-card--hero .product-card__image {
    aspect-ratio: 3/4;
  }

  .product-card--hero .product-card__info {
    padding: 1rem 0.25rem 0.25rem;
  }

  .product-card--hero .product-card__title {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
  }

  .product-card--hero .product-card__price {
    font-size: 1rem;
  }

  .product-card--hero .product-card__type {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-cyan);
    font-weight: 600;
  }

  /* Standard grid below hero row */
  .home-products .product-grid {
    margin-top: 1.25rem;
  }

  /* ─── Home Products Header ─────────────── */
  .home-products { background: var(--color-warm-white); }

  .home-products__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .home-products__header .section-title { margin-bottom: 0; }

  .home-products__see-all {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-cyan);
    letter-spacing: 0.03em;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .home-products__subtitle {
    font-size: 0.85rem;
    color: var(--color-stone);
    margin: 0.25rem 0 0;
    line-height: 1.4;
  }

  .home-products__see-all:hover { color: var(--color-charcoal); }

  .home-products .product-grid {
    margin-top: var(--space-lg);
  }

  /* ─── Product card structure ────────────── */
  .home-products .product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .product-card__image-container {
    position: relative;
    overflow: hidden;
  }

  .product-card__img-primary,
  .product-card__img-hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card__img-hover {
    display: none;
  }





  /* ─── Sale price styling ─────────────────── */
  .product-card__price--sale {
    color: #c0392b;
  }


  /* ─── Staggered card entrance ────────────── */
  :global(.js-reveal) .home-products .product-card {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s var(--ease-out),
                transform 0.45s var(--ease-out);
  }

  /* Fallback: if observer hasn't run after 1s, show all cards */
  @keyframes card-fallback {
    to { opacity: 1; transform: translateY(0); }
  }
  :global(.js-reveal) .home-products .product-card {
    animation: card-fallback 0s 1s forwards;
  }

  .home-products .product-card.card-visible {
    opacity: 1;
    transform: translateY(0);
    animation: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-products .product-card {
      opacity: 1;
      transform: none;
      transition: none;
      animation: none;
    }
  }

  /* First two cards visible immediately — no blank flash */
  .trending-hero .product-card:nth-child(-n+2) {
    opacity: 1;
    transform: translateY(0);
    animation: none;
  }


  /* ─── Horizontal Scroll (deals) ────────── */
  .home-scroll {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.5rem;
    margin-top: var(--space-lg);
    scrollbar-width: thin;
    scrollbar-color: var(--color-cream-dark) transparent;
  }

  .home-scroll__card {
    flex-shrink: 0;
    width: 220px;
    scroll-snap-align: start;
    background: var(--color-cream);
    border-radius: 12px;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    overflow: hidden;
  }

  .home-scroll__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(44,44,44,0.08);
  }

  .home-scroll__image {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-cream-dark);
    position: relative;
  }

  .home-scroll__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .home-scroll__card:hover .home-scroll__image img { transform: scale(1.05); }

  .home-scroll__info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .home-scroll__title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-charcoal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-scroll__pricing { display: flex; align-items: baseline; gap: 0.5rem; }
  .home-scroll__price { font-weight: 600; font-size: 0.9rem; color: var(--color-charcoal); }
  .home-scroll__compare { font-size: 0.8rem; color: var(--color-stone); text-decoration: line-through; }

  /* ─── Design Services ─────────────────── */
  .services {
    background: var(--color-cream);
    padding: clamp(5rem, 12vh, 10rem) 0;
  }

  .services__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 768px) {
    .services__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  @media (min-width: 1024px) {
    .services__inner {
      gap: clamp(5rem, 8vw, 8rem);
    }
  }

  /* ─ Image ─ */
  .services__media {
    order: -1;
  }

  /* ─ Content ─ */
  .services__content {
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .services__content {
      padding-top: 1rem;
    }
  }

  .services__kicker {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-stone);
    margin: 0 0 var(--space-lg);
    display: block;
  }

  .services__heading {
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 0 0 clamp(2.5rem, 6vh, 4.5rem);
    color: var(--color-charcoal);
  }

  /* ─ Service offerings ─ */
  .services__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .services__offering {
    display: flex;
    align-items: flex-start;
    gap: clamp(1rem, 2vw, 1.75rem);
    padding: clamp(1.5rem, 3vh, 2.25rem) 0;
    border-top: 1px solid var(--color-cream-dark);
  }

  .services__offering:last-child {
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .services__number {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--color-stone);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  .services__title {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.8vw, 1.4rem);
    font-weight: 400;
    margin: 0 0 0.6rem;
    color: var(--color-charcoal);
    letter-spacing: -0.01em;
    line-height: 1.25;
  }

  .services__desc {
    font-size: clamp(0.88rem, 1vw, 0.95rem);
    color: var(--color-stone);
    line-height: 1.75;
    max-width: 44ch;
    margin: 0;
  }

  /* ─ CTA link ─ */
  .services__link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: clamp(2rem, 4vh, 3rem);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-charcoal);
    transition: gap 0.4s var(--ease-out), color 0.3s;
    min-height: 48px;
  }

  .services__link svg {
    transition: transform 0.4s var(--ease-out);
  }

  .services__link:hover {
    color: var(--color-charcoal);
    gap: 1rem;
  }

  .services__link:hover svg {
    transform: translateX(4px);
  }

  .services__link:focus-visible {
    outline: 2px solid var(--color-charcoal);
    outline-offset: 4px;
  }

  /* ─── Mission Section ──────────────────── */
  .mission {
    background: var(--color-cream);
    padding: clamp(4rem, 10vh, 7rem) 0;
    position: relative;
  }

  .mission__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (max-width: 767px) {
    .mission {
      padding: var(--space-xl) 0;
    }
    .mission__inner {
      gap: var(--space-lg);
    }
  }

  @media (min-width: 768px) {
    .mission__inner {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .mission__media {
    order: -1;
  }

  /* ─ Mission image ─ */
  .mission__img-wrap {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.14);
    background: #f0ede8;
  }

  .mission__img-wrap img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3/2;
    object-fit: cover;
    transition: transform 1.2s var(--ease-out);
  }

  .mission__img-wrap:hover img {
    transform: scale(1.03);
  }

  /* ─ Badge (logo + name) ─ */
  .mission__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    background: white;
    border-radius: 8px;
    padding: 0.35rem 1rem 0.35rem 0.35rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    margin-bottom: var(--space-md);
  }

  .mission__badge img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
  }

  .mission__badge-text {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-charcoal);
  }

  .mission__title {
    color: var(--color-charcoal);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.08;
    margin-bottom: var(--space-md);
  }

  .mission__body {
    color: var(--color-stone);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 48ch;
    margin: 0 0 var(--space-lg);
  }

  /* ─ Stats row ─ */
  .mission__stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: var(--space-xl);
  }

  .mission__stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .mission__stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1;
    color: var(--color-cyan);
  }

  .mission__stat-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-stone);
  }

  .mission__stat-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--color-cream-dark);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .mission__stats {
      gap: 1rem;
    }
    .mission__stat-num {
      font-size: 1.5rem;
    }
  }

  /* ─ CTAs ─ */
  .mission__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .mission__cta-primary {
    color: var(--color-charcoal);
  }

  .mission__cta-primary:hover {
    color: var(--color-cream);
  }

  .mission__cta-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-charcoal);
    letter-spacing: 0.02em;
    transition: color 0.2s;
    min-height: 48px;
    display: inline-flex;
    align-items: center;
  }

  .mission__cta-link span {
    display: inline-block;
    transition: transform 0.3s var(--ease-out);
  }

  .mission__cta-link:hover {
    color: var(--color-cyan);
  }

  .mission__cta-link:hover span {
    transform: translateX(4px);
  }


  @media (min-width: 768px) {
    .home-products .product-card {
      border-radius: 12px;
    }
    .home-products .product-card__info {
      padding: 1rem 0.25rem 0.25rem;
    }
  }

</style>

<script>

  document.addEventListener('astro:page-load', () => {

  const homeProducts = document.querySelector('.home-products');
  const staffPicks = document.querySelector('.staff-picks');
  if (!homeProducts && !staffPicks) return;



  // ─── Staggered card entrance animation ────
  function getCards(): HTMLElement[] {
    return Array.from(homeProducts?.querySelectorAll('.product-card') || []) as HTMLElement[];
  }

  function observeCards() {
    if (typeof IntersectionObserver === 'undefined') return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const card = entry.target as HTMLElement;
          const rect = card.getBoundingClientRect();
          const col = Math.floor((rect.left / window.innerWidth) * 4);
          card.style.transitionDelay = `${col * 60}ms`;
          card.classList.add('card-visible');
          observer.unobserve(card);
        }
      });
    }, { threshold: 0.05, rootMargin: '50px' });

    getCards().forEach(card => {
      observer.observe(card);
    });
  }

  observeCards();

  }); // end astro:page-load
</script>
