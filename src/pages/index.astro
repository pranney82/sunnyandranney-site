  }

  .services__link:focus-visible {
    outline: 2px solid var(--color-charcoal);
    outline-offset: 4px;
  }

  /* ─── Mission Section ──────────────────── */
  .mission {
    background: var(--color-charcoal);
    padding: clamp(3rem, 8vh, 5rem) 0;
  }

  .mission__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (max-width: 767px) {
    .mission {
      padding: var(--space-xl) 0;
    }
    .mission__inner {
      gap: var(--space-lg);
    }
  }

  @media (min-width: 768px) {
    .mission__inner {
      grid-template-columns: 0.9fr 1.1fr;
      gap: var(--space-2xl);
    }
  }

  .mission__media {
    order: -1;
  }

  .mission__img-wrap {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0,0,0,0.3);
  }

  .mission__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3/2;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .mission__img-wrap:hover img {
    transform: scale(1.03);
  }

  .mission__kicker {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-cyan-light);
    margin: 0 0 var(--space-sm);
  }

  .mission__title {
    color: white;
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .mission__body {
    color: rgba(255,255,255,0.75);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 52ch;
    margin: 0 0 var(--space-lg);
  }

  .mission__body strong {
    color: var(--color-gold);
    font-weight: 600;
  }

  .mission__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .mission__cta {
    border-color: rgba(255,255,255,0.3);
    color: white;
  }

  .mission__cta.btn--gold {
    color: var(--color-charcoal);
  }

  .mission__cta:hover {
    background: var(--color-gold);
    border-color: var(--color-gold);
    color: var(--color-charcoal);
  }

  /* ─── Product card add to cart (homepage) ── */
  .product-card__add-btn {
    margin-top: 0.75rem;
    width: 100%;
    padding: 0.6rem 1rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s, color 0.3s;
  }

  .product-card__add-btn:hover {
    background: var(--color-gold);
    color: var(--color-charcoal);
  }

  @media (min-width: 768px) {
    .home-products .product-card {
      border-radius: 4px;
    }
    .home-products .product-card__info {
      padding: 1rem 0.25rem 0.25rem;
    }
    .home-products .product-card__type {
      display: none;
    }
  }

  /* ─── Recently Viewed (homepage) ────────── */
  .home-recent { background: var(--color-cream); }

  .home-recent__scroll {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.5rem;
    margin-top: var(--space-lg);
    scrollbar-width: thin;
    scrollbar-color: var(--color-cream-dark) transparent;
  }

  .home-recent__card {
    flex-shrink: 0;
    width: 200px;
    scroll-snap-align: start;
    background: var(--color-warm-white);
    border-radius: 8px;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    overflow: hidden;
  }

  .home-recent__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(44,44,44,0.08);
  }

  .home-recent__image {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-cream-dark);
  }

  .home-recent__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .home-recent__card:hover .home-recent__image img { transform: scale(1.05); }

  .home-recent__info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .home-recent__title {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-charcoal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-recent__price {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }
</style>

<script>
  // ─── Animated counters ───────────────────
  const counterEls = document.querySelectorAll('[data-count]');
  if (counterEls.length > 0) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const animateCounter = (el: Element) => {
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      const suffix = el.getAttribute('data-suffix') || '';

      // Respect reduced motion — show final value immediately
      if (prefersReducedMotion) {
        el.textContent = target.toString() + suffix;
        return;
      }

      const duration = 1600;
      const start = performance.now();
      const step = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target).toString() + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target);
          counterObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });
    counterEls.forEach(el => counterObserver.observe(el));
  }

  // ─── Recently viewed on homepage ───────────
  const recentSection = document.getElementById('home-recent-section');
  const recentScroll = document.getElementById('home-recent-scroll');
  if (recentSection && recentScroll) {
    try {
      const items = JSON.parse(localStorage.getItem('sr_recent') || '[]');
      if (items.length > 0) {
        recentSection.style.display = '';
        const frag = document.createDocumentFragment();
        items.slice(0, 8).forEach((item: any) => {
          const card = document.createElement('a');
          card.href = `/shop/${encodeURIComponent(item.handle)}`;
          card.className = 'home-recent__card';

          const imgWrap = document.createElement('div');
          imgWrap.className = 'home-recent__image';
          if (item.image) {
            const img = document.createElement('img');
            img.src = item.image.includes('cdn.shopify.com') ? `${item.image}?width=400&crop=center` : item.image;
            img.alt = item.title || '';
            img.loading = 'lazy';
            imgWrap.appendChild(img);
          }
          card.appendChild(imgWrap);

          const info = document.createElement('div');
          info.className = 'home-recent__info';
          const title = document.createElement('span');
          title.className = 'home-recent__title';
          title.textContent = item.title;
          info.appendChild(title);
          if (item.price) {
            const price = document.createElement('span');
            price.className = 'home-recent__price';
            price.textContent = `$${parseFloat(item.price).toFixed(2)}`;
            info.appendChild(price);
          }
          card.appendChild(info);
          frag.appendChild(card);
        });
        recentScroll.replaceChildren(frag);
      }
    } catch (e) {
      console.warn('Recently viewed failed to load:', e);
    }
  }

  // Add to cart from homepage product cards (covers both hero + standard grids)
  const homeProducts = document.querySelector('.home-products');

  homeProducts?.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest('.product-card__add-btn');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const { variantId, title, price, image, handle, variantTitle } = (btn as HTMLElement).dataset;
    if (!variantId || !title || !price) return;

    window.addToCart?.({
      variantId,
      title,
      price: parseFloat(price),
      image: image || '',
      handle: handle || '',
      variantTitle: variantTitle || '',
    });

    const orig = btn.textContent;
    btn.textContent = 'Added';
    (btn as HTMLButtonElement).disabled = true;
    setTimeout(() => {
      btn.textContent = orig;
      (btn as HTMLButtonElement).disabled = false;
    }, 1500);
  });

</script>
