---
import Base from '@/layouts/Base.astro';
import GoogleReviews from '@/components/GoogleReviews.astro';
import { getProducts, getCollectionByHandle, getProductByHandle } from '@/lib/shopify';
import { cfImage, cfSrcset } from '@/lib/images';
import { getCollectionsStatic, getTrendingStatic, getHeroStatic, type CollectionSetting } from '@/lib/settings';

// Fetch live stats from SOARD at build time
let soardStats: { roomMakeovers: number; yearsGiving: number } | null = null;
try {
  const res = await fetch('https://soard-site.pages.dev/api/stats.json');
  if (res.ok) soardStats = await res.json();
} catch { /* use fallbacks */ }
const statRooms = soardStats?.roomMakeovers ?? 269;
const statYears = soardStats?.yearsGiving ?? 14;

let products: any[] = [];
let collections: any[] = [];
let hasShopify = false;

// Fallback handles if admin hasn't configured collections yet
const DEFAULT_HANDLES = [
  'accent-chairs', 'accent-end-tables', 'bedroom-furniture', 'coffee-tables',
  'consoles-sideboards-sofa-tables', 'dining-tables', 'sofas', 'sectionals',
];

// Load hero setting (image URL + featured product handle)
const heroSetting = await getHeroStatic();
const HERO_DEFAULT_IMAGE = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/sunny-ranney-storefront';
const heroImageBase = heroSetting?.imageUrl?.trim().replace(/\/$/, '') || HERO_DEFAULT_IMAGE;
const HERO_QUALITY = 70;
const heroSrc = cfImage(heroImageBase, { width: 480, height: 600, quality: HERO_QUALITY });
const heroSrcset = cfSrcset(heroImageBase, [280, 480, 640], HERO_QUALITY);
const HERO_SIZES = '(max-width: 767px) 280px, (max-width: 1023px) 400px, 440px';

let heroProduct: any = null;

try {
  // Load trending product handles from admin setting
  const trendingSetting = await getTrendingStatic();
  if (trendingSetting && trendingSetting.handles.length > 0) {
    products = (await Promise.all(
      trendingSetting.handles.map(h => getProductByHandle(h))
    )).filter(Boolean);
  } else {
    const result = await getProducts(8);
    products = result.products;
  }
  hasShopify = products.length > 0;

  // Load hero product — use admin-configured handle or fall back to first product
  if (heroSetting?.productHandle) {
    heroProduct = await getProductByHandle(heroSetting.productHandle);
  }
  if (!heroProduct && products.length > 0) {
    heroProduct = products[0];
  }

  // Load admin collection settings (committed JSON) or fall back to defaults
  const saved = await getCollectionsStatic();
  const enabledHandles: string[] = saved
    ? saved.filter(c => c.enabled).sort((a, b) => a.order - b.order).map(c => c.handle)
    : DEFAULT_HANDLES;

  // Fetch only enabled collections by handle — no wasted API calls
  const collectionResults = await Promise.all(
    enabledHandles.map(handle => getCollectionByHandle(handle, 4))
  );
  collections = collectionResults.filter(Boolean);
} catch (e) {
  console.log('Shopify API not configured.');
}

// Split products by type for homepage sections
const onSaleProducts = products.filter(p => {
  const compare = p.compareAtPriceRange?.minVariantPrice;
  const price = p.priceRange.minVariantPrice;
  return compare && parseFloat(compare.amount) > parseFloat(price.amount);
});
const featuredProducts = products.slice(0, 8);

---

<Base lcpImage={heroSrc} lcpImageSrcset={heroSrcset} lcpImageSizes={HERO_SIZES}>
  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__kicker animate-fade-up">Furniture with Heart</p>
        <h1 class="hero__title animate-fade-up delay-1">Shop with<br/>a Purpose</h1>
        <p class="hero__sub animate-fade-up delay-2">Curated furniture & home decor where every purchase transforms a child's room through <strong>Sunshine on a Ranney Day</strong>.</p>
        <div class="hero__actions animate-fade-up delay-3">
          <a href="/shop" class="btn btn--gold btn--hero" data-astro-prefetch="viewport">Shop &amp; Give Back</a>
        </div>
        <div class="hero__trust animate-fade-up delay-3">
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure Checkout
          </span>
          <span class="hero__trust-sep"></span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            4.9 on Google
          </span>
          <span class="hero__trust-sep"></span>
          <span class="hero__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Roswell Pickup
          </span>
        </div>
      </div>
      <div class="hero__media animate-fade-up delay-2">
        <div class="hero__img-wrap">
          <img
            src={heroSrc}
            srcset={heroSrcset}
            sizes={HERO_SIZES}
            alt="The Sunny & Ranney storefront in historic Roswell, Georgia"
            width="480"
            height="600"
            fetchpriority="high"
          />
        </div>
        <div class="hero__accent" aria-hidden="true"></div>
        {hasShopify && heroProduct && (() => {
          const fp = heroProduct;
          const fpImg = fp.images.edges[0]?.node;
          const fpPrice = fp.priceRange.minVariantPrice;
          return (
            <a href={`/shop/${fp.handle}`} class="hero__product-card" data-astro-prefetch>
              {fpImg && (
                <img
                  src={cfImage(fpImg.url, { width: 200 })}
                  alt=""
                  width="80"
                  height="80"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="hero__product-info">
                <span class="hero__product-label">Bestseller</span>
                <span class="hero__product-name">{fp.title}</span>
                <span class="hero__product-price">${parseFloat(fpPrice.amount).toFixed(0)}</span>
              </div>
            </a>
          );
        })()}
      </div>
    </div>
  </section>

  <!-- ═══ IMPACT STATS ═══ -->
  <section class="impact">
    <div class="container impact__inner">
      <div class="impact__stat reveal">
        <span class="impact__number" data-count={statRooms} data-suffix="+">0</span>
        <span class="impact__label">Rooms Transformed</span>
      </div>
      <div class="impact__divider" aria-hidden="true"></div>
      <div class="impact__stat reveal delay-1">
        <span class="impact__number" data-count={statYears} data-suffix="">0</span>
        <span class="impact__label">Years of Giving</span>
      </div>
      <div class="impact__divider" aria-hidden="true"></div>
      <div class="impact__stat reveal delay-2">
        <span class="impact__number">100%</span>
        <span class="impact__label">Of Profits Donated</span>
      </div>
    </div>
  </section>

  <!-- ═══ PROMISE STRIP ═══ -->
  <section class="promise" aria-label="Why shop with us">
    <div class="container promise__inner">
      <div class="promise__item">
        <div class="promise__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 3 20 16 16 16"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="promise__text">
          <span class="promise__title">Local Delivery</span>
          <span class="promise__desc">Metro Atlanta white-glove service</span>
        </div>
      </div>
      <div class="promise__sep" aria-hidden="true"></div>
      <div class="promise__item">
        <div class="promise__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        </div>
        <div class="promise__text">
          <span class="promise__title">Roswell Pickup</span>
          <span class="promise__desc">Ready same or next day</span>
        </div>
      </div>
      <div class="promise__sep" aria-hidden="true"></div>
      <div class="promise__item">
        <div class="promise__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="promise__text">
          <span class="promise__title">Complimentary Design Help</span>
          <span class="promise__desc">Our team helps you get it right</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SHOP BY COLLECTION ═══ -->
  {collections.length > 0 && (
    <section class="collections-grid section">
      <div class="container">
        <div class="collections-grid__header reveal">
          <h2 class="section-title">Shop by Collection</h2>
          <a href="/shop" class="collections-grid__link" data-astro-prefetch>View all &rarr;</a>
        </div>
        <div class="collections-grid__items">
          {collections.map((col: any, idx: number) => {
            const colImage = col.image;
            const previewProduct = col.products?.[0];
            const imgUrl = colImage?.url || previewProduct?.images?.edges?.[0]?.node?.url;
            return (
              <a href={`/shop?collection=${col.handle}`} data-astro-prefetch class={`collection-tile reveal${idx > 0 ? ` delay-${Math.min(idx, 3)}` : ''}`}>
                <div class="collection-tile__image">
                  {imgUrl ? (
                    <img
                      src={cfImage(imgUrl, { width: 500, height: 500 })}
                      srcset={cfSrcset(imgUrl, [250, 500])}
                      sizes="(max-width: 480px) 45vw, (max-width: 768px) 30vw, 200px"
                      alt=""
                      width="500"
                      height="500"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="collection-tile__placeholder">
                      <span>{col.title.charAt(0)}</span>
                    </div>
                  )}
                  <div class="collection-tile__overlay">
                    <span>{col.title}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ SHOWROOM EXPERIENCE ═══ -->
  <section class="services">
    <div class="container services__inner">
      <div class="services__media reveal">
        <div class="shop-look__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=800,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=500,q=75,format=auto 500w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=800,q=80,format=auto 800w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=1100,q=80,format=auto 1100w"
            sizes="(max-width: 767px) 90vw, 45vw"
            alt="Inside the Sunny & Ranney showroom — curated furniture and decor"
            width="800"
            height="1000"
            loading="lazy"
            decoding="async"
          />
          <a href="/shop?collection=sofas" class="shop-look__tag" style="top: 40%; left: 25%;" data-astro-prefetch>
            <span class="shop-look__dot"></span>
            <span class="shop-look__label">Sofas</span>
          </a>
          <a href="/shop?collection=accent-chairs" class="shop-look__tag" style="top: 30%; left: 70%;" data-astro-prefetch>
            <span class="shop-look__dot"></span>
            <span class="shop-look__label">Accent Chairs</span>
          </a>
          <a href="/shop?collection=coffee-tables" class="shop-look__tag" style="top: 65%; left: 50%;" data-astro-prefetch>
            <span class="shop-look__dot"></span>
            <span class="shop-look__label">Coffee Tables</span>
          </a>
        </div>
      </div>
      <div class="services__content reveal delay-1">
        <p class="services__kicker">The Showroom Experience</p>
        <h2 class="services__heading">We help you build<br/>the room you've<br/>been imagining.</h2>

        <div class="services__list">
          <div class="services__offering">
            <h3 class="services__title">Design Assistance</h3>
            <p class="services__desc">Tell us about your space. Our in-house designers work with you from layout to finishing touches — complimentary, no project too small.</p>
          </div>
          <div class="services__offering">
            <h3 class="services__title">Custom Sourcing</h3>
            <p class="services__desc">Looking for something specific? We tap into a global network of makers to find pieces beyond what's on our floor.</p>
          </div>
          <div class="services__offering">
            <h3 class="services__title">Custom Upholstery</h3>
            <p class="services__desc">Choose your fabrics, finishes, and silhouettes. We'll craft a one-of-a-kind piece made to order, just for you.</p>
          </div>
        </div>

        <a href="mailto:info@sunnyandranney.com" class="services__link">
          Start a project
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED / TRENDING ═══ -->
  {hasShopify && featuredProducts.length > 0 && (
    <section class="home-products section">
      <div class="container">
        <div class="home-products__header reveal">
          <div>
            <h2 class="section-title">Trending Now</h2>
            <p class="home-products__subtitle">Hand-picked from our showroom floor</p>
          </div>
          <a href="/shop" class="home-products__see-all" data-astro-prefetch>See all &rarr;</a>
        </div>

        {/* ── Hero row: first 2 products, editorial size ── */}
        <div class="trending-hero reveal" id="home-grid">
          {featuredProducts.slice(0, 2).map((product: any, idx: number) => {
            const image = product.images.edges[0]?.node;
            const image2 = product.images.edges[1]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            const isOnSale = compareAt && parseFloat(compareAt.amount) > parseFloat(price.amount);
            const firstVariant = product.variants.edges[0]?.node;

            return (
              <div class="product-card product-card--hero" data-type={product.productType.toLowerCase()}>
                {isOnSale && <span class="product-card__badge">Sale</span>}
                {!isOnSale && !product.availableForSale && <span class="product-card__badge product-card__badge--sold">Sold Out</span>}
                <a href={`/shop/${product.handle}`} data-astro-prefetch class="product-card__image" aria-hidden="true" tabindex="-1">
                  {image ? (
                    <>
                      <img
                        src={cfImage(image.url, { width: 900 })}
                        srcset={cfSrcset(image.url, [450, 900])}
                        sizes="(max-width: 768px) 90vw, 45vw"
                        alt=""
                        width={image.width}
                        height={image.height}
                        loading="lazy"
                        decoding="async"
                        class="product-card__img-primary"
                      />
                      {image2 && (
                        <img
                          src={cfImage(image2.url, { width: 900 })}
                          srcset={cfSrcset(image2.url, [450, 900])}
                          sizes="(max-width: 768px) 90vw, 45vw"
                          alt=""
                          width={image2.width}
                          height={image2.height}
                          loading="lazy"
                          decoding="async"
                          class="product-card__img-hover"
                        />
                      )}
                    </>
                  ) : (
                    <div class="product-card__image-ph">{product.productType || 'Product'}</div>
                  )}
                </a>
                <div class="product-card__info">
                  {product.productType && <span class="product-card__type">{product.productType}</span>}
                  <a href={`/shop/${product.handle}`} data-astro-prefetch class="product-card__title">{product.title}</a>
                  <div class="product-card__pricing">
                    <span class="product-card__price">${parseFloat(price.amount).toFixed(2)}</span>
                    {isOnSale && (
                      <span class="product-card__price--compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                    )}
                  </div>
                  {product.availableForSale && firstVariant && (
                    <button class="product-card__add-btn"
                      data-variant-id={firstVariant.id}
                      data-title={product.title}
                      data-price={parseFloat(price.amount)}
                      data-image={image?.url || ''}
                      data-handle={product.handle}
                      data-variant-title={firstVariant.title}
                    >
                      Add to Cart
                    </button>
                  )}
                </div>
              </div>
            );
          })}
        </div>

        {/* ── Standard row: remaining products ── */}
        {featuredProducts.length > 2 && (
          <div class="product-grid reveal delay-1">
            {featuredProducts.slice(2, 6).map((product: any, idx: number) => {
              const image = product.images.edges[0]?.node;
              const image2 = product.images.edges[1]?.node;
              const price = product.priceRange.minVariantPrice;
              const compareAt = product.compareAtPriceRange?.minVariantPrice;
              const isOnSale = compareAt && parseFloat(compareAt.amount) > parseFloat(price.amount);
              const firstVariant = product.variants.edges[0]?.node;

              return (
                <div class="product-card" data-type={product.productType.toLowerCase()}>
                  {isOnSale && <span class="product-card__badge">Sale</span>}
                  {!isOnSale && !product.availableForSale && <span class="product-card__badge product-card__badge--sold">Sold Out</span>}
                  <a href={`/shop/${product.handle}`} data-astro-prefetch class="product-card__image" aria-hidden="true" tabindex="-1">
                    {image ? (
                      <>
                        <img
                          src={cfImage(image.url, { width: 600 })}
                          srcset={cfSrcset(image.url, [300, 600])}
                          sizes="(max-width: 768px) 50vw, 25vw"
                          alt=""
                          width={image.width}
                          height={image.height}
                          loading="lazy"
                          decoding="async"
                          class="product-card__img-primary"
                        />
                        {image2 && (
                          <img
                            src={cfImage(image2.url, { width: 600 })}
                            srcset={cfSrcset(image2.url, [300, 600])}
                            sizes="(max-width: 768px) 50vw, 25vw"
                            alt=""
                            width={image2.width}
                            height={image2.height}
                            loading="lazy"
                            decoding="async"
                            class="product-card__img-hover"
                          />
                        )}
                      </>
                    ) : (
                      <div class="product-card__image-ph">{product.productType || 'Product'}</div>
                    )}
                  </a>
                  <div class="product-card__info">
                    {product.productType && <span class="product-card__type">{product.productType}</span>}
                    <a href={`/shop/${product.handle}`} data-astro-prefetch class="product-card__title">{product.title}</a>
                    <div class="product-card__pricing">
                      <span class="product-card__price">${parseFloat(price.amount).toFixed(2)}</span>
                      {isOnSale && (
                        <span class="product-card__price--compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                      )}
                    </div>
                    {product.availableForSale && firstVariant && (
                      <button class="product-card__add-btn"
                        data-variant-id={firstVariant.id}
                        data-title={product.title}
                        data-price={parseFloat(price.amount)}
                        data-image={image?.url || ''}
                        data-handle={product.handle}
                        data-variant-title={firstVariant.title}
                      >
                        Add to Cart
                      </button>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ═══ MISSION ═══ -->
  <section class="mission" id="mission">
    <div class="container mission__inner">
      <div class="mission__media reveal">
        <div class="mission__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=600,h=400,fit=cover,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=600,h=400,fit=cover,q=80,format=auto 600w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=900,h=600,fit=cover,q=80,format=auto 900w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=1200,h=800,fit=cover,q=80,format=auto 1200w"
            sizes="(max-width: 767px) 90vw, (max-width: 1024px) 45vw, 540px"
            alt="Adrian — a Sunshine on a Ranney Day room makeover recipient"
            width="600"
            height="400"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="mission__content reveal delay-1">
        <p class="mission__kicker">Our Why</p>
        <h2 class="mission__title">Every Purchase Changes a Child's World</h2>
        <p class="mission__body">
          When you shop at Sunny and Ranney, you're not just buying furniture.
          Through <strong>Sunshine on a Ranney Day</strong>, 100% of store profits
          fund bedroom and living space makeovers for children with special needs.
          {statRooms} rooms transformed. {statYears} years and counting.
        </p>
        <div class="mission__actions">
          <a href="/shop" class="btn btn--gold mission__cta" data-astro-prefetch>Shop &amp; Give Back</a>
          <a href="/about" class="btn btn--outline mission__cta" data-astro-prefetch>Read Our Full Story</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GOOGLE REVIEWS ═══ -->
  <GoogleReviews variant="full" />

  <!-- ═══ ON SALE (if any) ═══ -->
  {onSaleProducts.length > 0 && (
    <section class="home-products home-products--deals section">
      <div class="container">
        <div class="home-products__header reveal">
          <h2 class="section-title">On Sale</h2>
          <a href="/shop" class="home-products__see-all" data-astro-prefetch>Shop all deals &rarr;</a>
        </div>
        <div class="home-scroll reveal">
          {onSaleProducts.slice(0, 8).map((product: any) => {
            const image = product.images.edges[0]?.node;
            const price = product.priceRange.minVariantPrice;
            const compareAt = product.compareAtPriceRange?.minVariantPrice;
            return (
              <a href={`/shop/${product.handle}`} data-astro-prefetch class="home-scroll__card" aria-label={product.title}>
                <div class="home-scroll__image">
                  <span class="product-card__badge">Sale</span>
                  {image && (
                    <img
                      src={cfImage(image.url, { width: 400 })}
                      srcset={cfSrcset(image.url, [220, 400])}
                      sizes="220px"
                      alt=""
                      width={image.width}
                      height={image.height}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <div class="home-scroll__info">
                  <span class="home-scroll__title">{product.title}</span>
                  <div class="home-scroll__pricing">
                    <span class="home-scroll__price">${parseFloat(price.amount).toFixed(2)}</span>
                    <span class="home-scroll__compare">${parseFloat(compareAt.amount).toFixed(2)}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

