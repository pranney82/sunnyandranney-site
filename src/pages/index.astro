  /* ─── Product card add to cart (homepage) ── */
  .product-card__add-btn {
    margin-top: 0.75rem;
    width: 100%;
    padding: 0.6rem 1rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
