---
import Base from '@/layouts/Base.astro';

// Fetch live impact stats from SOARD site — falls back to hardcoded values
const fallbackStats = { roomMakeovers: 269, childrenServed: 203, livesImpacted: 17000, yearsGiving: 14 };
let stats = fallbackStats;
try {
  const statsUrl = import.meta.env.SOARD_STATS_URL;
  if (statsUrl) {
    const res = await fetch(statsUrl);
    if (res.ok) stats = { ...fallbackStats, ...await res.json() };
  }
} catch (e) {
  console.log('SOARD stats fetch failed, using fallback values.');
}

const kids = [
  { name: 'Adrian', slug: 'adrian', blurb: 'Adrian dreamed of a space-themed bedroom where he could imagine exploring the stars. His new room gave him a launchpad for his biggest adventures.' },
  { name: 'Mathew', slug: 'mathew', blurb: 'Our very first makeover — 11-year-old Mathew wanted a military-themed bunker bedroom, and bringing it to life changed everything for us and for him.' },
  { name: 'Tripp', slug: 'tripp', blurb: 'Tripp\'s whole-home makeover drew 1.6 million viewers on WSB-TV and showed the world what a little sunshine can do.' },
  { name: 'Ellie', slug: 'ellie', blurb: 'Ellie needed a wheelchair-accessible bathroom that was as beautiful as it was functional. Now she has both — and the independence she deserves.' },
  { name: 'Jackson', slug: 'jackson', blurb: 'Jackson\'s in-home therapy space was designed around his daily needs, giving him a safe and joyful place to grow stronger every day.' },
  { name: 'Sophia', slug: 'sophia', blurb: 'Sophia\'s dream bedroom is filled with the colors and characters she loves — a space that finally feels like her own.' },
];
---

<Base title="Our Mission — Sunny & Ranney" description="100% of Sunny & Ranney profits fund Sunshine on a Ranney Day — life-changing home makeovers for children with special needs in the greater Atlanta area.">

  <!-- ═══ HERO ═══ -->
  <section class="mission-hero">
    <div class="mission-hero__bg" aria-hidden="true"></div>
    <div class="container mission-hero__inner">
      <span class="label animate-fade-up">Our Mission</span>
      <h1 class="mission-hero__title animate-fade-up delay-1">
        Shop with a <span class="mission-hero__accent">Purpose</span>
      </h1>
      <p class="mission-hero__sub animate-fade-up delay-2">
        100% of profits fund life-changing home makeovers for children with special needs.
      </p>
      <hr class="divider animate-fade-up delay-3" />
      <a href="#mission-story" class="mission-hero__scroll animate-fade-up delay-4" aria-label="Scroll to learn more">
        <svg class="mission-hero__scroll-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
      </a>
    </div>
  </section>

  <!-- ═══ IMPACT STATS ═══ -->
  <section class="mission-stats" aria-label="Impact statistics">
    <div class="container mission-stats__inner">
      <div class="mission-stats__stat reveal" role="group" aria-label="Room makeovers completed">
        <span class="mission-stats__number">{stats.roomMakeovers.toLocaleString()}+</span>
        <span class="mission-stats__label">Room Makeovers</span>
      </div>
      <div class="mission-stats__stat reveal delay-1" role="group" aria-label="Children served">
        <span class="mission-stats__number">{stats.childrenServed.toLocaleString()}+</span>
        <span class="mission-stats__label">Children Served</span>
      </div>
      <div class="mission-stats__stat reveal delay-2" role="group" aria-label="Lives impacted">
        <span class="mission-stats__number">{stats.livesImpacted.toLocaleString()}+</span>
        <span class="mission-stats__label">Lives Impacted</span>
      </div>
      <div class="mission-stats__stat reveal delay-3" role="group" aria-label="Years of giving">
        <span class="mission-stats__number">{stats.yearsGiving}</span>
        <span class="mission-stats__label">Years Giving</span>
      </div>
    </div>
  </section>

  <!-- ═══ THE STORY ═══ -->
  <section class="mission-story section" id="mission-story">
    <div class="container mission-story__grid">
      <div class="mission-story__image reveal">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=600,h=600,fit=cover,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=320,h=320,fit=cover,q=75,format=auto 320w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=480,h=480,fit=cover,q=80,format=auto 480w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=600,h=600,fit=cover,q=80,format=auto 600w"
          sizes="(max-width: 767px) 90vw, 420px"
          alt="Peter and Holly Ranney, founders of Sunshine on a Ranney Day"
          width="600"
          height="600"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="mission-story__content reveal delay-1">
        <span class="label">The Story</span>
        <h2>Sunshine on a Ranney Day</h2>
        <p>
          In 2012, Peter and Holly Ranney were inspired by a church sermon to do something simple but powerful — give a child with special needs a bedroom they could truly call their own. That first project was for 11-year-old Mathew, who dreamed of a military-themed bunker bedroom. Seeing how a thoughtfully designed space transformed Mathew's life changed everything.
        </p>
        <p>
          What started as one room has grown into a 501(c)(3) nonprofit creating <strong>wheelchair-accessible bathrooms, dream bedrooms, and in-home therapy spaces</strong> for children with special needs in the greater Atlanta area — completely free to families. Every makeover is designed around the child's unique needs, personality, and dreams.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ WHY THE PIG ═══ -->
  <section class="mission-mascot section">
    <div class="container mission-mascot__grid">
      <div class="mission-mascot__content reveal">
        <span class="label">Our Mascot</span>
        <h2>Why the Pig?</h2>
        <p>
          Gracie was inspired by an unforgettable wedding gift — when Peter surprised Holly with a baby pot-bellied pig named Gracie. What started as a unique and heartfelt gesture has since grown into something magical.
        </p>
        <p>
          Over the years, Gracie has transformed into our golden, high-flying mascot, soaring above the clouds in her signature cape, always on the lookout for children and families in need of a little extra sunshine.
        </p>
        <p>
          With her trusty handsaw and a heart full of hope, Gracie leads her team of Sunshiners to build wheelchair-accessible bathrooms, dream bedrooms, and in-home therapy spaces — spaces that bring comfort, independence, and joy to children facing daily challenges.
        </p>
        <p>
          She's a reminder that with creativity, compassion, and a whole lot of heart, <strong>anything is possible with a little bit of Sunshine.</strong>
        </p>
      </div>
      <div class="mission-mascot__image reveal delay-1">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=600,h=600,fit=cover,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=320,h=320,fit=cover,q=75,format=auto 320w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=480,h=480,fit=cover,q=80,format=auto 480w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=600,h=600,fit=cover,q=80,format=auto 600w"
          sizes="(max-width: 767px) 90vw, 420px"
          alt="Gracie the Pig — the real pot-bellied pig that inspired SOARD's mascot"
          width="600"
          height="600"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- ═══ KIDS STORIES — Editorial Magazine ═══ -->
  <section class="ed section">
    <div class="container">

      <!-- ── Section Opener ── -->
      <div class="ed__opener reveal">
        <div class="ed__opener-rule" aria-hidden="true"></div>
        <span class="ed__eyebrow">Their Stories</span>
        <h2 class="ed__headline">The Kids Who<br/><em>Inspire</em> Us</h2>
        <p class="ed__deck">Every room starts with a dream. These are the children who remind us why we do what we do.</p>
      </div>

      <!-- ── Cover Story: Kid 0 — cinematic hero with floating glass caption ── -->
      <div class="ed__cover reveal">
        <div class="ed__cover-frame">
          <img
            src={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[0].slug}/hero/w=1200,h=700,fit=cover,q=80,format=auto`}
            srcset={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[0].slug}/hero/w=600,h=350,fit=cover,q=75,format=auto 600w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[0].slug}/hero/w=900,h=525,fit=cover,q=80,format=auto 900w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[0].slug}/hero/w=1200,h=700,fit=cover,q=80,format=auto 1200w`}
            sizes="(max-width: 767px) 92vw, (max-width: 1024px) 88vw, 1040px"
            alt={`${kids[0].name} in their transformed room`}
            width="1200" height="700" loading="lazy" decoding="async"
          />
          <span class="ed__num" aria-hidden="true">01</span>
        </div>
        <div class="ed__cover-glass">
          <span class="ed__tag">Cover Story</span>
          <h3 class="ed__cover-name">{kids[0].name}</h3>
          <div class="ed__cover-rule" aria-hidden="true"></div>
          <p>{kids[0].blurb}</p>
        </div>
      </div>

      <!-- ── Editorial Spread: Kids 1 & 2 — asymmetric with text columns ── -->
      <div class="ed__spread reveal">
        <div class="ed__spread-left">
          <div class="ed__spread-img">
            <img
              src={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[1].slug}/hero/w=600,h=800,fit=cover,q=80,format=auto`}
              srcset={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[1].slug}/hero/w=400,h=533,fit=cover,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[1].slug}/hero/w=600,h=800,fit=cover,q=80,format=auto 600w`}
              sizes="(max-width: 767px) 92vw, 55vw"
              alt={`${kids[1].name} in their transformed room`}
              width="600" height="800" loading="lazy" decoding="async"
            />
            <span class="ed__num" aria-hidden="true">02</span>
          </div>
        </div>
        <div class="ed__spread-right">
          <div class="ed__spread-text">
            <span class="ed__tag">{kids[1].name}'s Story</span>
            <h3>{kids[1].name}</h3>
            <p>{kids[1].blurb}</p>
          </div>
          <div class="ed__spread-img ed__spread-img--inset">
            <img
              src={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[2].slug}/hero/w=500,h=500,fit=cover,q=80,format=auto`}
              srcset={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[2].slug}/hero/w=340,h=340,fit=cover,q=75,format=auto 340w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kids[2].slug}/hero/w=500,h=500,fit=cover,q=80,format=auto 500w`}
              sizes="(max-width: 767px) 92vw, 38vw"
              alt={`${kids[2].name} in their transformed room`}
              width="500" height="500" loading="lazy" decoding="async"
            />
            <span class="ed__num ed__num--dark" aria-hidden="true">03</span>
          </div>
          <div class="ed__spread-text ed__spread-text--bottom">
            <h3>{kids[2].name}</h3>
            <p>{kids[2].blurb}</p>
          </div>
        </div>
      </div>

      <!-- ── Pull Quote ── -->
      <div class="ed__quote reveal">
        <div class="ed__quote-inner">
          <svg class="ed__quote-mark" width="64" height="52" viewBox="0 0 64 52" fill="none" aria-hidden="true"><path d="M0 33c0-5.7 1.3-10.7 4-15C7 13.7 10.4 10 14.7 7.1 19 4.2 23.7 2.2 29 1.2L30.5 8c-5 1.3-9.3 3.6-12.5 6.9-3.3 3.4-5 7-5 11 0 1 .2 2 .6 2.8 1-.7 2.3-1 4-1 2.7 0 5 1 7 3 2 2 3 4.5 3 7.6 0 3.2-1.2 5.8-3.4 8-2.2 2-4.8 3-8 3-3.7 0-6.8-1.5-9.3-4.4C4 42 2.6 38 2.6 33H0zm32 0c0-5.7 1.3-10.7 4-15C39 13.7 42.4 10 46.7 7.1 51 4.2 55.7 2.2 61 1.2L62.5 8c-5 1.3-9.3 3.6-12.5 6.9-3.3 3.4-5 7-5 11 0 1 .2 2 .6 2.8 1-.7 2.3-1 4-1 2.7 0 5 1 7 3 2 2 3 4.5 3 7.6 0 3.2-1.2 5.8-3.4 8-2.2 2-4.8 3-8 3-3.7 0-6.8-1.5-9.3-4.4C34.6 42 34.6 38 34.6 33H32z" fill="currentColor"/></svg>
          <blockquote>
            A room is more than four walls.<br/>
            It's where a child starts to believe<br/>
            <em>anything is possible.</em>
          </blockquote>
          <div class="ed__quote-attr">
            <span class="ed__quote-rule" aria-hidden="true"></span>
            <span>Peter & Holly Ranney</span>
          </div>
        </div>
      </div>

      <!-- ── Gallery Row: Kids 3, 4, 5 — staggered masonry with hover reveals ── -->
      <div class="ed__gallery reveal">
        {kids.slice(3).map((kid, i) => (
          <article class={`ed__card ed__card--${i}`}>
            <div class="ed__card-img">
              <img
                src={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kid.slug}/hero/w=500,h=650,fit=cover,q=80,format=auto`}
                srcset={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kid.slug}/hero/w=340,h=442,fit=cover,q=75,format=auto 340w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kid.slug}/hero/w=500,h=650,fit=cover,q=80,format=auto 500w`}
                sizes="(max-width: 567px) 85vw, (max-width: 1024px) 30vw, 310px"
                alt={`${kid.name} in their transformed room`}
                width="500" height="650" loading="lazy" decoding="async"
              />
              <span class="ed__num ed__num--card" aria-hidden="true">{String(i + 4).padStart(2, '0')}</span>
              <div class="ed__card-reveal">
                <p>{kid.blurb}</p>
              </div>
            </div>
            <h3 class="ed__card-name">{kid.name}</h3>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══ EVERY PURCHASE ═══ -->
  <section class="mission-impact">
    <div class="container mission-impact__inner">
      <div class="mission-impact__media reveal">
        <div class="mission-impact__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=600,h=400,fit=cover,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=600,h=400,fit=cover,q=80,format=auto 600w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=900,h=600,fit=cover,q=80,format=auto 900w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero/w=1200,h=800,fit=cover,q=80,format=auto 1200w"
            sizes="(max-width: 767px) 90vw, (max-width: 1024px) 45vw, 540px"
            alt="Adrian in his newly transformed room"
            width="600"
            height="400"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="mission-impact__content reveal delay-1">
        <span class="label mission-impact__kicker">The Impact</span>
        <h2 class="mission-impact__title">Every Purchase Changes a Child's World</h2>
        <p class="mission-impact__body">
          When you shop at Sunny and Ranney, you're not just buying furniture.
          Through <strong>Sunshine on a Ranney Day</strong>, 100% of store profits
          fund bedroom and living space makeovers for children with special needs.
          {stats.roomMakeovers}+ rooms transformed. {stats.yearsGiving} years and counting.
        </p>
        <a href="/shop" class="btn mission-impact__cta" data-astro-prefetch>Shop & Give Back</a>
      </div>
    </div>
  </section>

  <!-- ═══ QUOTE / HIGHLIGHT ═══ -->
  <section class="mission-highlight">
    <div class="container mission-highlight__inner">
      <div class="mission-highlight__decoration" aria-hidden="true">
        <svg width="48" height="40" viewBox="0 0 48 40" fill="currentColor" opacity="0.15"><path d="M0 24.7c0-4.3 1-8 3-11.2 2-3.3 4.8-6 8.3-8.2 3.6-2.3 7.5-3.8 11.7-4.5L24.3 6c-3.8 1-7 2.7-9.4 5.2-2.5 2.5-3.7 5.2-3.7 8.2 0 .8.1 1.5.4 2.1.7-.5 1.7-.7 3-.7 2 0 3.8.7 5.2 2.2 1.4 1.5 2.2 3.4 2.2 5.7 0 2.4-.8 4.4-2.5 6-1.6 1.5-3.6 2.3-6 2.3-2.8 0-5.1-1.1-7-3.3C4.6 31.5 3.6 28.5 3.6 24.7H0zm24 0c0-4.3 1-8 3-11.2 2-3.3 4.8-6 8.3-8.2 3.6-2.3 7.5-3.8 11.7-4.5L48.3 6c-3.8 1-7 2.7-9.4 5.2-2.5 2.5-3.7 5.2-3.7 8.2 0 .8.1 1.5.4 2.1.7-.5 1.7-.7 3-.7 2 0 3.8.7 5.2 2.2 1.4 1.5 2.2 3.4 2.2 5.7 0 2.4-.8 4.4-2.5 6-1.6 1.5-3.6 2.3-6 2.3-2.8 0-5.1-1.1-7-3.3-1.9-2.2-2.9-5.2-2.9-9H24z"/></svg>
      </div>
      <blockquote class="mission-highlight__quote reveal">
        <p>"Every child deserves a space that reflects their personality, brings them joy, and supports their unique needs."</p>
        <footer class="mission-highlight__attribution">
          <span class="mission-highlight__name">Peter & Holly Ranney</span>
          <span class="mission-highlight__title">Founders, Sunshine on a Ranney Day</span>
        </footer>
      </blockquote>
    </div>
  </section>


</Base>

<!-- ═══ NONPROFIT STRUCTURED DATA ═══ -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Sunshine on a Ranney Day",
  "alternateName": "SOARD",
  "url": "https://www.sunshineonarranneyday.org",
  "nonprofitStatus": "Nonprofit501c3",
  "description": "501(c)(3) nonprofit creating wheelchair-accessible bathrooms, dream bedrooms, and in-home therapy spaces for children with special needs in the greater Atlanta area.",
  "founder": [
    { "@type": "Person", "name": "Peter Ranney" },
    { "@type": "Person", "name": "Holly Ranney" }
  ],
  "foundingDate": "2012",
  "areaServed": {
    "@type": "State",
    "name": "Georgia"
  },
  "funder": {
    "@type": "FurnitureStore",
    "name": "Sunny & Ranney",
    "url": "https://www.sunnyandranney.com"
  }
})} />

<style>
  /* ─── Hero ──────────────────────────────── */
  .mission-hero {
    position: relative;
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
    overflow: hidden;
  }

  .mission-hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(75, 149, 180, 0.10) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(255, 212, 0, 0.07) 0%, transparent 45%),
      radial-gradient(ellipse at 50% 0%, rgba(75, 149, 180, 0.05) 0%, transparent 60%),
      var(--color-cream);
    z-index: 0;
  }

  .mission-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mission-hero__title {
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    margin: var(--space-sm) 0 var(--space-xs);
    line-height: 1.05;
  }

  .mission-hero__accent {
    color: var(--color-gold);
    font-style: italic;
    font-weight: 300;
  }

  .mission-hero__sub {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    max-width: 48ch;
    text-align: center;
    margin: 0 0 var(--space-md);
    color: var(--color-slate);
  }

  .mission-hero__scroll {
    display: inline-block;
    margin-top: var(--space-lg);
    color: var(--color-stone);
    transition: color 0.3s;
  }

  .mission-hero__scroll:hover {
    color: var(--color-gold);
  }

  .mission-hero__scroll-icon {
    animation: float 3s ease-in-out infinite;
  }

  .mission-hero__scroll:hover .mission-hero__scroll-icon {
    animation: none;
    transform: translateY(4px);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ─── Impact Stats ──────────────────────── */
  .mission-stats {
    background: linear-gradient(160deg, var(--color-cyan) 0%, #3a7d9a 100%);
    padding: var(--space-xl) 0;
    position: relative;
    overflow: hidden;
  }

  .mission-stats::before {
    content: '';
    position: absolute;
    top: -40%;
    left: -15%;
    width: 50%;
    height: 180%;
    background: radial-gradient(circle, rgba(255, 212, 0, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .mission-stats__inner {
    display: flex;
    justify-content: center;
    gap: var(--space-2xl);
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }

  .mission-stats__stat {
    text-align: center;
    min-width: 120px;
  }

  .mission-stats__number {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 600;
    color: white;
    line-height: 1;
    min-width: 3ch;
  }

  .mission-stats__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.5rem;
  }

  /* ─── Story ─────────────────────────────── */
  .mission-story {
    background: var(--color-warm-white);
  }

  .mission-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
    max-width: 1040px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .mission-story__grid {
