<script>
  function initAbout() {
    // Click-to-play video
    document.querySelectorAll('.ab-video__poster[data-video-src]').forEach((poster) => {
      poster.addEventListener('click', () => {
        const wrap = poster.closest('.ab-video__player');
        if (!wrap) return;
        const iframe = document.createElement('iframe');
        iframe.src = poster.dataset.videoSrc;
        iframe.allow = 'accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.title = 'Peter and Holly share why they started Sunny & Ranney';
        wrap.appendChild(iframe);
        poster.remove();
      });
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', (e) => {
        const target = document.querySelector(link.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }
  initAbout();
  document.addEventListener('astro:after-swap', initAbout);
</script>
