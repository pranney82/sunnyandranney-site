    height: 3px;
    border-radius: 50%;
    background: var(--color-gold);
  }
</style>

<script>
  function initAboutPage() {
    // ── Counter animation on stats ──
    const counters = document.querySelectorAll('.about-stats__number[data-count]');
    if (counters.length) {
      const animateCounter = (el) => {
        const target = parseInt(el.dataset.count, 10);
        const duration = 1800;
        const start = performance.now();
        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target).toLocaleString();
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };

      const statsObserver = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            statsObserver.unobserve(entry.target);
          }
        }
      }, { threshold: 0.5 });

      counters.forEach((c) => statsObserver.observe(c));
    }

    // ── Sticky-scroll: crossfade images + highlight active story ──
    const isMobile = window.matchMedia('(max-width: 767px)').matches;

    const stories = document.querySelectorAll('.ed__story[data-story]');
    const photos = document.querySelectorAll('.ed__cover-photo[data-index]');
    const numEl = document.querySelector('.ed__num-dynamic');
    const dots = document.querySelectorAll('.ed__dot[data-dot]');

    if (!isMobile) {
      // Desktop: sticky-scroll crossfade
      if (stories.length && photos.length) {
        const activate = (idx) => {
          photos.forEach((p) => p.classList.toggle('is-active', p.dataset.index === idx));
          stories.forEach((s) => s.classList.toggle('is-active', s.dataset.story === idx));
          if (numEl) numEl.textContent = String(Number(idx) + 1).padStart(2, '0');
        };

        const storyObserver = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) activate(entry.target.dataset.story);
          }
        }, {
          rootMargin: '-35% 0px -35% 0px',
          threshold: 0,
        });

        stories.forEach((s) => storyObserver.observe(s));

        document.addEventListener('astro:before-swap', () => {
          storyObserver.disconnect();
        }, { once: true });
      }
    } else {
      // Mobile: horizontal scroll carousel sync
      const frame = document.querySelector('.ed__cover-frame');
      if (frame && photos.length) {
        let ticking = false;
        frame.addEventListener('scroll', () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const scrollLeft = frame.scrollLeft;
            const childWidth = photos[0].offsetWidth;
            const gap = parseInt(getComputedStyle(frame).gap) || 0;
            const idx = Math.round(scrollLeft / (childWidth + gap));
            const clamped = Math.max(0, Math.min(idx, photos.length - 1));
            const idxStr = String(clamped);
            stories.forEach((s) => s.classList.toggle('is-active', s.dataset.story === idxStr));
            dots.forEach((d) => d.classList.toggle('is-active', d.dataset.dot === idxStr));
            ticking = false;
          });
        }, { passive: true });
      }
    }

    // ── Before/After sliders ──
    document.querySelectorAll('[data-ba-slider]').forEach((slider) => {
      const beforeEl = slider.querySelector('.ba-card__before');
      const handle = slider.querySelector('.ba-card__handle');
      if (!beforeEl || !handle) return;

      const update = (x) => {
        const rect = slider.getBoundingClientRect();
        const pct = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
        beforeEl.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
        handle.style.left = `${pct}%`;
      };

      // Swipe hint: animate on first viewport entry
      let hinted = false;
      const hintObserver = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !hinted) {
            hinted = true;
            beforeEl.classList.add('ba-hint');
            handle.classList.add('ba-hint');
            handle.addEventListener('animationend', () => {
              beforeEl.classList.remove('ba-hint');
              handle.classList.remove('ba-hint');
            }, { once: true });
            hintObserver.unobserve(slider);
          }
        }
      }, { threshold: 0.4 });
      hintObserver.observe(slider);

      let active = false;

      slider.addEventListener('pointerdown', (e) => {
        active = true;
        hinted = true; // cancel any pending hint
        beforeEl.classList.remove('ba-hint');
        handle.classList.remove('ba-hint');
        slider.setPointerCapture(e.pointerId);
        update(e.clientX);
      });

      slider.addEventListener('pointermove', (e) => {
        if (active) update(e.clientX);
      });

      slider.addEventListener('pointerup', () => { active = false; });
      slider.addEventListener('pointercancel', () => { active = false; });
    });

    // ── Video modal (kept for future use) ──
    const modal = document.getElementById('video-modal');
    if (modal) {
      const closeVideo = () => {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        const content = document.getElementById('video-modal-content');
        if (content) content.innerHTML = '';
        document.body.style.overflow = '';
      };

      modal.querySelector('.video-modal__close')?.addEventListener('click', closeVideo);
      modal.addEventListener('click', (e) => { if (e.target === modal) closeVideo(); });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) closeVideo();
      });
    }

    // ── Smooth scroll for anchor links ──
    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', (e) => {
        const target = document.querySelector(link.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }

  // Init on load and on Astro view transition
  initAboutPage();
  document.addEventListener('astro:after-swap', initAboutPage);
</script>
