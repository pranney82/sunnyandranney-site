  .ed__kb.is-active { animation-play-state: running; }
  .ed__kb { animation-play-state: paused; }

  .ed__kb--0 { animation: kb-0 12s ease-in-out infinite alternate; }
  .ed__kb--1 { animation: kb-1 14s ease-in-out infinite alternate; }
