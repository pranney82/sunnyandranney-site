  .ed__tag {
    display: inline-block;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-gold);
    border: 1px solid rgba(255, 212, 0, 0.3);
    padding: 0.3rem 0.9rem;
    margin-bottom: var(--space-sm);
