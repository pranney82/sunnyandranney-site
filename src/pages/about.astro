<script>
  function initAbout() {
    const openBtn = document.getElementById('ab-video-open');
    const player = document.getElementById('cf-player') as HTMLIFrameElement | null;
    const VIDEO_SRC = 'https://customer-cuav5h47lgfe96ql.cloudflarestream.com/7d7459064cd569cd7a3d806914f7aec7/iframe?autoplay=true&muted=false';

    openBtn?.addEventListener('click', () => {
      if (!player || !openBtn) return;
      player.src = VIDEO_SRC;
      player.hidden = false;
      openBtn.hidden = true;
    });

    if (player) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          const msg = entry.isIntersecting ? '{"method":"play"}' : '{"method":"pause"}';
          player.contentWindow?.postMessage(msg, 'https://customer-cuav5h47lgfe96ql.cloudflarestream.com');
        },
        { threshold: 0.25 }
      );
      observer.observe(player);
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', (e) => {
        const target = document.querySelector((link as HTMLAnchorElement).getAttribute('href')!);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }
  initAbout();
  document.addEventListener('astro:after-swap', initAbout);
</script>
