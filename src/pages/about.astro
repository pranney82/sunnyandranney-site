      scroll-snap-align: center;
      border-radius: var(--ed-r);
    }
    .ed__num {
      display: none;
    }
    .ed__cover-frame::after {
      display: none;
    }
    /* Scroll dots */
    .ed__sticky-img::after {
      content: '';
      display: flex;
      justify-content: center;
      margin-top: var(--space-sm);
    }
    .ed__story {
