---
import Base from '@/layouts/Base.astro';
import { getKidsStatic } from '@/lib/settings';

const stats = [
  { value: '269+', label: 'Room Makeovers' },
  { value: '203+', label: 'Children Served' },
  { value: '17,000+', label: 'Lives Impacted' },
  { value: '100%', label: 'Of Profits Donated' },
];

const DEFAULT_KIDS_HEADING = 'The Kids Who Inspire Us';
const DEFAULT_KIDS_SUBHEADING = 'Every room starts with a dream. These are the children who remind us why we do what we do.';
const DEFAULT_KIDS = [
  { name: 'Mathew', tag: 'Where It All Began', blurb: 'Our very first makeover — 11-year-old Mathew wanted a military-themed bunker bedroom, and bringing it to life changed everything for us and for him.', imageUrl: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/mathew/hero' },
  { name: 'Adrian', tag: 'Room #247', blurb: 'Adrian dreamed of a space-themed bedroom where he could imagine exploring the stars. His new room gave him a launchpad for his biggest adventures.', imageUrl: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero' },
  { name: 'Tripp', tag: '1.6 Million Watched', blurb: "Tripp's whole-home makeover drew 1.6 million viewers on WSB-TV and showed the world what a little sunshine can do.", imageUrl: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/tripp/hero' },
];

const kidsSetting = await getKidsStatic();
const kidsHeading = kidsSetting?.heading ?? DEFAULT_KIDS_HEADING;
const kidsSubheading = kidsSetting?.subheading ?? DEFAULT_KIDS_SUBHEADING;
const kids = kidsSetting?.kids ?? DEFAULT_KIDS;
---

<Base title="About Us — Sunny & Ranney" description="Meet the team behind Sunny & Ranney — a furniture store where 100% of profits fund life-changing room makeovers for children with special needs." lcpImage="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=700,q=80,format=auto">

  <!-- ═══ HERO ═══ -->
  <section class="ab-hero">
    <div class="container ab-hero__inner">
      <div class="ab-hero__text">
        <span class="label animate-fade-up">About Us</span>
        <h1 class="ab-hero__title animate-fade-up delay-1">
          Come In.<br/><span class="accent">Stay Awhile.</span>
        </h1>
        <p class="ab-hero__sub animate-fade-up delay-2">
          We're a small team in Roswell, GA with one big belief: beautiful furniture should do more than fill a room — it should change a life.
        </p>
        <div class="ab-hero__actions animate-fade-up delay-3">
          <a href="/shop" class="btn btn--gold" data-astro-prefetch>Shop & Give Back</a>
          <a href="#our-story" class="text-link">
            Our Story
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
          </a>
        </div>
      </div>
      <div class="ab-hero__media animate-fade-up delay-2">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=700,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=400,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=700,q=80,format=auto 700w"
          sizes="(max-width: 767px) 90vw, 50vw"
          alt="Inside the Sunny & Ranney showroom in Roswell, Georgia"
          width="700" height="467"
          loading="eager" fetchpriority="high" decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="ab-stats" aria-label="Impact statistics">
    <div class="container ab-stats__inner">
      {stats.map((s) => (
        <div class="ab-stats__item" role="group">
          <span class="ab-stats__number">{s.value}</span>
          <span class="ab-stats__label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="ab-how">
    <div class="container">
      <span class="label ab-how__eyebrow">How It Works</span>
      <h2>From Your Home to Theirs</h2>
      <div class="ab-how__steps">
        <div class="ab-how__step reveal">
          <span class="ab-how__num" aria-hidden="true">01</span>
          <h3>You Shop</h3>
          <p>You find a piece you love at Sunny & Ranney — furniture, decor, or a gift.</p>
        </div>
        <div class="ab-how__step reveal delay-1">
          <span class="ab-how__num" aria-hidden="true">02</span>
          <h3>100% of Profit</h3>
          <p>Every dollar of profit goes directly to Sunshine on a Ranney Day. Not a percentage — all of it.</p>
        </div>
        <div class="ab-how__step reveal delay-2">
          <span class="ab-how__num" aria-hidden="true">03</span>
          <h3>A Child Gets a Room</h3>
          <p>Volunteers build wheelchair-accessible bathrooms, dream bedrooms, and therapy spaces — free to families.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VIDEO ═══ -->
  <section class="ab-video" id="our-story">
    <div class="container ab-video__inner">
      <div class="ab-video__text reveal">
        <span class="label">Our Story</span>
        <h2>See why we do<br/><em>what we do</em></h2>
        <p>In 60 seconds, Peter and Holly share the moment that changed everything — and why every piece of furniture in our showroom carries a deeper purpose.</p>
      </div>
      <div class="ab-video__player reveal delay-1">
        <button
          class="ab-video__poster"
          aria-label="Play video: Peter and Holly share why they started Sunny & Ranney"
          data-video-src="https://customer-cuav5h47lgfe96ql.cloudflarestream.com/7d7459064cd569cd7a3d806914f7aec7/iframe?autoplay=true"
        >
          <img
            src="https://customer-cuav5h47lgfe96ql.cloudflarestream.com/7d7459064cd569cd7a3d806914f7aec7/thumbnails/thumbnail.jpg?height=600"
            alt="" width="338" height="600" loading="lazy" decoding="async"
          />
          <span class="ab-video__play" aria-hidden="true">
            <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><circle cx="28" cy="28" r="28" fill="rgba(0,0,0,0.45)"/><polygon points="22,16 22,40 40,28" fill="white"/></svg>
          </span>
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ FOUNDERS ═══ -->
  <section class="ab-story">
    <div class="container ab-story__inner">
      <div class="ab-story__image reveal">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=600,h=750,fit=cover,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=400,h=500,fit=cover,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/founders-reunion-2026/w=600,h=750,fit=cover,q=80,format=auto 600w"
          sizes="(max-width: 767px) 85vw, 440px"
          alt="Peter and Holly Ranney with family"
          width="600" height="750" loading="lazy" decoding="async"
        />
      </div>
      <div class="ab-story__content reveal delay-1">
        <span class="label">The Founders</span>
        <h2>It started with<br/><em>one room.</em></h2>
        <blockquote>
          "It started with one room for an 11-year-old boy named Mathew. That room changed everything."
        </blockquote>
        <p>
          In 2012, Peter and Holly were inspired by a church sermon to do something simple but powerful — give a child with special needs a bedroom they could truly call their own. That first project for 11-year-old Mathew, who dreamed of a military-themed bunker bedroom, changed everything.
        </p>
        <p>
          What started as one room has grown into <strong>Sunshine on a Ranney Day</strong>, a 501(c)(3) nonprofit creating wheelchair-accessible bathrooms, dream bedrooms, and in-home therapy spaces — completely free to families. In 2020, they opened <strong>Sunny & Ranney</strong> with one goal: fund the mission. Every dollar of profit goes directly to SOARD — not a percentage, <strong>all of it</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ THE KIDS ═══ -->
  <section class="ab-kids">
    <div class="container">
      <div class="ab-kids__header">
        <span class="label">Their Stories</span>
        <h2 set:html={kidsHeading.replace('Inspire', '<em>Inspire</em>')}></h2>
        <p>{kidsSubheading}</p>
      </div>
      <div class="ab-kids__grid">
        {kids.map((kid, i) => {
          const base = kid.imageUrl.trim().replace(/\/$/, '');
          return (
            <article class={`ab-kids__card reveal delay-${i + 1}`}>
              <div class="ab-kids__img">
                <img
                  src={`${base}/w=600,h=450,fit=cover,q=80,format=auto`}
                  srcset={`${base}/w=400,h=300,fit=cover,q=75,format=auto 400w, ${base}/w=600,h=450,fit=cover,q=80,format=auto 600w`}
                  sizes="(max-width: 767px) 90vw, 340px"
                  alt={`${kid.name} — a Sunshine on a Ranney Day room makeover recipient`}
                  width="600" height="450" loading="lazy" decoding="async"
                />
              </div>
              <div class="ab-kids__content">
                <span class="ab-kids__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span class="ab-kids__tag">{kid.tag}</span>
                <h3>{kid.name}</h3>
                <p>{kid.blurb}</p>
              </div>
            </article>
          );
        })}
      </div>

      <blockquote class="ab-pullquote reveal">
        A room is more than four walls. It's where a child starts to believe <em>anything is possible.</em>
        <cite>— Peter & Holly Ranney</cite>
      </blockquote>
    </div>
  </section>

  <!-- ═══ CREW ═══ -->
  <section class="ab-crew">
    <div class="container">
      <div class="ab-crew__header">
        <span class="label">The Crew</span>
        <h2>The faces you'll see<br/>when you <em>walk in</em></h2>
      </div>
      <div class="ab-crew__grid">
        {[
          { name: 'Staci', role: 'Store Manager', desc: 'Keeps the showroom running like clockwork and ensures every visitor feels at home from the moment they walk in.', image: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team-staci' },
          { name: 'BJ', role: 'Team Member', desc: 'A valued member of the Sunny & Ranney family, helping create beautiful spaces and brighter futures every day.', image: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team-bj' },
          { name: 'Staci', role: 'AI Shopping Assistant', desc: 'Our tireless digital team member — always ready to help you find the perfect piece, 24/7.', initials: 'ST' },
        ].map((member, idx) => (
          <article class={`ab-crew__card reveal delay-${idx + 1}`}>
            <div class={`ab-crew__photo${member.initials ? ' ab-crew__photo--ai' : ''}`}>
              {member.image ? (
                <img
                  src={`${member.image}/w=200,h=250,fit=cover,gravity=face,q=80,format=auto`}
                  srcset={`${member.image}/w=160,h=200,fit=cover,gravity=face,q=75,format=auto 160w, ${member.image}/w=320,h=400,fit=cover,gravity=face,q=80,format=auto 320w`}
                  sizes="160px" alt={member.name} width="160" height="200" loading="lazy" decoding="async"
                />
              ) : (
                <div class="ab-crew__initials"><span>{member.initials}</span></div>
              )}
            </div>
            <h3>{member.name}</h3>
            <span class="ab-crew__role">{member.role}</span>
            <p>{member.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ MASCOT ═══ -->
  <section class="ab-mascot">
    <div class="container ab-mascot__inner">
      <div class="ab-mascot__image reveal">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=400,h=400,fit=cover,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=240,h=240,fit=cover,q=75,format=auto 240w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=400,h=400,fit=cover,q=80,format=auto 400w"
          sizes="(max-width: 767px) 160px, 200px"
          alt="Gracie the Pig — the real pot-bellied pig that inspired SOARD's mascot"
          width="400" height="400" loading="lazy" decoding="async"
        />
      </div>
      <div class="ab-mascot__content reveal delay-1">
        <span class="label">Our Mascot</span>
        <h3>Why the Pig?</h3>
        <p>It started as a wedding gift — Peter surprised Holly with a baby pot-bellied pig named Gracie. She's been our golden, cape-wearing, high-flying mascot ever since — leading her team of Sunshiners to build rooms that bring comfort, independence, and joy.</p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="ab-cta">
    <div class="container ab-cta__inner reveal">
      <h2>Find Something Beautiful.<br/><em>Do Something Meaningful.</em></h2>
      <p>Every purchase at Sunny & Ranney funds bedroom makeovers for children with special needs. You're not just shopping — you're building a room that changes a child's life.</p>
      <a href="/shop" class="btn btn--gold" data-astro-prefetch>Shop Now</a>
      <div class="ab-cta__trust">
        <span>100% of profits donated</span>
        <span class="dot" aria-hidden="true"></span>
        <span>269+ rooms built</span>
        <span class="dot" aria-hidden="true"></span>
        <span>4.9 stars on Google</span>
      </div>
    </div>
  </section>

</Base>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Sunshine on a Ranney Day",
  "alternateName": "SOARD",
  "url": "https://www.sunshineonarranneyday.org",
  "nonprofitStatus": "Nonprofit501c3",
  "description": "501(c)(3) nonprofit creating wheelchair-accessible bathrooms, dream bedrooms, and in-home therapy spaces for children with special needs in the greater Atlanta area.",
  "founder": [
    { "@type": "Person", "name": "Peter Ranney" },
    { "@type": "Person", "name": "Holly Ranney" }
  ],
  "foundingDate": "2012",
  "areaServed": { "@type": "State", "name": "Georgia" },
  "funder": {
    "@type": "FurnitureStore",
    "name": "Sunny & Ranney",
    "url": "https://www.sunnyandranney.com",
    "foundingDate": "2020"
  }
})} />

<style>
  /* ─── Hero ─── */
  .ab-hero { background: var(--color-cream); padding: clamp(2rem, 5vh, 4rem) 0 0; }
  .ab-hero__inner { display: grid; gap: var(--space-xl); align-items: center; }
  @media (min-width: 768px) { .ab-hero__inner { grid-template-columns: 1fr 1.1fr; gap: var(--space-2xl); } }
  .ab-hero__text { padding: var(--space-lg) 0; }
  .ab-hero__text .label { color: var(--color-cyan); }
  .ab-hero__title { font-size: clamp(2.8rem, 6vw, 4.5rem); margin: var(--space-sm) 0 var(--space-md); line-height: 0.95; letter-spacing: -0.03em; }
  .accent { color: var(--color-gold); font-style: italic; font-weight: 300; }
  .ab-hero__sub { font-size: clamp(0.95rem, 1.2vw, 1.1rem); max-width: 38ch; color: var(--color-slate); line-height: 1.7; }
  .ab-hero__actions { display: flex; align-items: center; gap: 1.5rem; margin-top: var(--space-lg); flex-wrap: wrap; }
  .text-link { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; font-weight: 600; color: var(--color-charcoal); letter-spacing: 0.03em; transition: color 0.3s; }
  .text-link:hover { color: var(--color-cyan); }
  .ab-hero__media { border-radius: 4px; overflow: hidden; }
  .ab-hero__media img { width: 100%; height: auto; display: block; aspect-ratio: 3 / 2; object-fit: cover; }
  @media (max-width: 767px) {
    .ab-hero__text { padding-bottom: 0; text-align: center; }
    .ab-hero__sub { margin: 0 auto; }
    .ab-hero__actions { justify-content: center; }
    .ab-hero__media { max-width: 480px; margin: 0 auto; }
  }

  /* ─── Stats ─── */
  .ab-stats { background: linear-gradient(160deg, var(--color-cyan) 0%, #3a7d9a 100%); padding: var(--space-lg) 0; }
  .ab-stats__inner { display: flex; justify-content: center; gap: var(--space-xl); flex-wrap: wrap; }
  .ab-stats__item { text-align: center; min-width: 110px; }
  .ab-stats__number { font-family: var(--font-display); font-size: clamp(2.2rem, 4.5vw, 3rem); font-weight: 600; color: white; line-height: 1; }
  .ab-stats__label { display: block; font-size: 0.7rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-top: 0.4rem; }

  /* ─── How It Works ─── */
  .ab-how { background: var(--color-cream); padding: clamp(3rem, 8vh, 5rem) 0; text-align: center; }
  .ab-how__eyebrow { color: var(--color-gold); }
  .ab-how h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); margin: var(--space-sm) 0 clamp(2.5rem, 6vh, 4rem); }
  .ab-how__steps { display: flex; align-items: flex-start; justify-content: center; max-width: 900px; margin: 0 auto; }
  .ab-how__step { flex: 1; max-width: 260px; padding: 0 var(--space-md); }
  .ab-how__num { display: block; font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 700; color: var(--color-cyan); opacity: 0.15; line-height: 1; margin-bottom: var(--space-sm); }
  .ab-how__step h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .ab-how__step p { font-size: 0.88rem; color: var(--color-slate); line-height: 1.7; }
  @media (max-width: 767px) {
    .ab-how { text-align: left; }
    .ab-how__steps { flex-direction: column; max-width: 400px; position: relative; padding-left: 56px; }
    .ab-how__steps::before { content: ''; position: absolute; left: 23px; top: 8px; bottom: 8px; width: 1.5px; background: var(--color-gold); opacity: 0.25; }
    .ab-how__step { padding: 0 0 var(--space-xl) 0; max-width: 100%; position: relative; }
    .ab-how__step:last-child { padding-bottom: 0; }
    .ab-how__num { position: absolute; left: -56px; top: -4px; width: 48px; height: 48px; border-radius: 50%; background: var(--color-cream); border: 1.5px solid rgba(255,212,0,0.35); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; opacity: 1; margin-bottom: 0; z-index: 1; }
  }

  /* ─── Video ─── */
  .ab-video { background: var(--color-warm-white); padding: clamp(4rem, 10vh, 7rem) 0; }
  .ab-video__inner { display: grid; grid-template-columns: 1.2fr minmax(280px, 400px); gap: clamp(3rem, 6vw, 5rem); align-items: center; }
  .ab-video__text .label { color: var(--color-gold); }
  .ab-video__text h2 { font-size: clamp(2rem, 4vw, 3rem); line-height: 1; margin: var(--space-xs) 0 var(--space-md); letter-spacing: -0.02em; }
  .ab-video__text h2 em { font-style: italic; font-weight: 300; color: var(--color-cyan); }
  .ab-video__text p { font-size: clamp(0.9rem, 1.1vw, 1rem); color: var(--color-slate); line-height: 1.7; max-width: 48ch; }
  .ab-video__player { position: relative; aspect-ratio: 9 / 16; border-radius: 12px; overflow: hidden; box-shadow: 0 24px 64px rgba(44,44,44,0.18); }
  .ab-video__player iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }
  .ab-video__poster { position: absolute; inset: 0; width: 100%; height: 100%; border: none; padding: 0; cursor: pointer; background: var(--color-charcoal); }
  .ab-video__poster img { width: 100%; height: 100%; object-fit: cover; }
  .ab-video__play { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); filter: drop-shadow(0 4px 16px rgba(0,0,0,0.35)); }
  @media (max-width: 767px) {
    .ab-video__inner { grid-template-columns: 1fr; text-align: center; }
    .ab-video__text { margin: 0 auto; }
    .ab-video__text p { margin: 0 auto; }
    .ab-video__player { max-width: 300px; margin: 0 auto; }
  }

  /* ─── Our Story ─── */
  .ab-story { background: var(--color-warm-white); padding: clamp(4rem, 10vh, 7rem) 0; }
  .ab-story__inner { display: grid; gap: var(--space-xl); align-items: center; max-width: 1040px; margin: 0 auto; }
  @media (min-width: 768px) { .ab-story__inner { grid-template-columns: 0.9fr 1.1fr; gap: var(--space-2xl); } }
  .ab-story__image { border-radius: 4px; overflow: hidden; box-shadow: 0 20px 60px rgba(44,44,44,0.12); }
  .ab-story__image img { width: 100%; height: auto; display: block; aspect-ratio: 4 / 5; object-fit: cover; }
  @media (max-width: 767px) { .ab-story__image { max-width: 400px; margin: 0 auto; } }
  .ab-story__content .label { color: var(--color-gold); }
  .ab-story__content h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); margin: var(--space-xs) 0 var(--space-md); line-height: 1; letter-spacing: -0.02em; }
  .ab-story__content h2 em { font-style: italic; font-weight: 300; color: var(--color-cyan); }
  .ab-story__content blockquote { font-family: var(--font-display); font-style: italic; font-size: clamp(1rem, 1.3vw, 1.15rem); color: var(--color-cyan); line-height: 1.5; margin-bottom: var(--space-md); padding-left: var(--space-md); border-left: 2px solid var(--color-gold); }
  .ab-story__content p { font-size: 0.95rem; line-height: 1.8; color: var(--color-slate); margin-bottom: var(--space-sm); }
  .ab-story__content p strong { color: var(--color-charcoal); }

  /* ─── Kids ─── */
  .ab-kids { background: var(--color-cream); padding: clamp(4rem, 10vh, 7rem) 0; }
  .ab-kids__header { text-align: center; max-width: 560px; margin: 0 auto clamp(2.5rem, 6vh, 4rem); }
  .ab-kids__header .label { color: var(--color-gold); }
  .ab-kids__header h2 { font-size: clamp(2rem, 4vw, 3rem); line-height: 1; margin: var(--space-xs) 0 var(--space-md); letter-spacing: -0.02em; }
  .ab-kids__header h2 em { font-style: italic; font-weight: 300; color: var(--color-gold); }
  .ab-kids__header p { font-size: clamp(0.9rem, 1.1vw, 1rem); color: var(--color-slate); line-height: 1.7; }
  .ab-kids__grid { display: grid; gap: 1.75rem; max-width: 1040px; margin: 0 auto; }
  @media (min-width: 768px) { .ab-kids__grid { grid-template-columns: repeat(3, 1fr); align-items: start; } }

  /* Card */
  .ab-kids__card {
    background: #fff;
    border-radius: 10px;
