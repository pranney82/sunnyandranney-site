<script>
  function initAbout() {
    const openBtn = document.getElementById('ab-video-open') as HTMLButtonElement | null;
    const player = document.getElementById('cf-player') as HTMLIFrameElement | null;
    const VIDEO_SRC = 'https://customer-cuav5h47lgfe96ql.cloudflarestream.com/7d7459064cd569cd7a3d806914f7aec7/iframe?autoplay=true&muted=false';

    // Reset video state on re-visit (View Transitions)
    if (player) { player.src = ''; player.hidden = true; }
    if (openBtn) { openBtn.hidden = false; }

    openBtn?.addEventListener('click', () => {
      if (!player || !openBtn) return;
      player.src = VIDEO_SRC;
      player.hidden = false;
      openBtn.hidden = true;
    });

    if (player) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (!player.src) return;
          const msg = entry.isIntersecting ? '{"method":"play"}' : '{"method":"pause"}';
          player.contentWindow?.postMessage(msg, 'https://customer-cuav5h47lgfe96ql.cloudflarestream.com');
        },
        { threshold: 0.25 }
      );
      observer.observe(player);
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', (e) => {
        const target = document.querySelector((link as HTMLAnchorElement).getAttribute('href')!);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Mosaic stagger entrance on scroll
    const mosaic = document.querySelector('.ab-kids__mosaic');
    if (mosaic) {
      // Reset for View Transitions
      mosaic.classList.remove('in-view');
      const mo = new IntersectionObserver(([e]) => {
        if (e.isIntersecting) { mosaic.classList.add('in-view'); mo.disconnect(); }
      }, { threshold: 0.15 });
      mo.observe(mosaic);
    }

    // Animate counter on scroll
    document.querySelectorAll('.ab-kids__counter-num, .ab-proof__number').forEach((el) => {
      const raw = el.textContent?.trim() ?? '';
      const match = raw.match(/^([\d,]+)/);
      if (!match) return;
      const target = parseInt(match[1].replace(/,/g, ''), 10);
      const suffix = raw.slice(match[1].length); // e.g. "+"
      const htmlEl = el as HTMLElement;
      let animated = false;

      const co = new IntersectionObserver(([e]) => {
        if (!e.isIntersecting || animated) return;
        animated = true;
        co.disconnect();
        const dur = 1200;
        const start = performance.now();
        function tick(now: number) {
          const t = Math.min((now - start) / dur, 1);
          const ease = 1 - Math.pow(1 - t, 3); // ease-out cubic
          const val = Math.round(ease * target);
          htmlEl.textContent = val.toLocaleString('en-US') + suffix;
          if (t < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }, { threshold: 0.5 });
      co.observe(htmlEl);
    });

  }
  initAbout();
  document.addEventListener('astro:after-swap', initAbout);
</script>
