---
import Base from '@/layouts/Base.astro';

// ── Live SOARD stats (falls back gracefully) ──
const fallbackStats = { roomMakeovers: 269, childrenServed: 203, livesImpacted: 17000, yearsGiving: 14 };
let stats = fallbackStats;
try {
  const statsUrl = import.meta.env.SOARD_STATS_URL;
  if (statsUrl) {
    const res = await fetch(statsUrl);
    if (res.ok) stats = { ...fallbackStats, ...await res.json() };
  }
} catch (e) {
  console.log('SOARD stats fetch failed, using fallback values.');
}

const pressLogos = [
  { name: 'WSB-TV', placeholder: true },
  { name: 'Atlanta Journal-Constitution', placeholder: true },
  { name: 'Roswell Patch', placeholder: true },
  { name: 'Good Day Atlanta', placeholder: true },
];

const kids = [
  { name: 'Adrian', slug: 'adrian', blurb: 'Adrian dreamed of a space-themed bedroom where he could imagine exploring the stars. His new room gave him a launchpad for his biggest adventures.' },
  { name: 'Mathew', slug: 'mathew', blurb: 'Our very first makeover — 11-year-old Mathew wanted a military-themed bunker bedroom, and bringing it to life changed everything for us and for him.' },
  { name: 'Tripp', slug: 'tripp', blurb: 'Tripp\'s whole-home makeover drew 1.6 million viewers on WSB-TV and showed the world what a little sunshine can do.' },
];

const beforeAfter = [
  { kid: 'Mathew', slug: 'mathew', label: 'Room #1 — Where It All Began' },
  { kid: 'Ellie', slug: 'ellie', label: 'Wheelchair-Accessible Bathroom' },
  { kid: 'Tripp', slug: 'tripp', label: '1.6 Million Watched on WSB-TV' },
];
---

<Base title="About Us — Sunny & Ranney" description="Meet the team behind Sunny & Ranney — a furniture store where 100% of profits fund life-changing room makeovers for children with special needs." lcpImage="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=700,q=80,format=auto">

  <!-- ═══ 1. HERO ═══ -->
  <section class="about-hero">
    <div class="container about-hero__inner">
      <div class="about-hero__text">
        <span class="label animate-fade-up">About Us</span>
        <h1 class="about-hero__title animate-fade-up delay-1">
          Come In.<br/>
          <span class="about-hero__accent">Stay Awhile.</span>
        </h1>
        <p class="about-hero__sub animate-fade-up delay-2">
          We're a small team in Roswell, GA with one big belief: beautiful furniture should do more than fill a room — it should change a life.
        </p>
        <div class="about-hero__actions animate-fade-up delay-3">
          <a href="/shop" class="btn btn--gold" data-astro-prefetch>Shop & Give Back</a>
          <a href="#our-story" class="about-hero__scroll-link">
            Our Story
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
          </a>
        </div>
      </div>
      <div class="about-hero__media animate-fade-up delay-2">
        <div class="about-hero__img-wrap">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=700,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=400,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=700,q=80,format=auto 700w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=1000,q=80,format=auto 1000w"
            sizes="(max-width: 767px) 90vw, 50vw"
            alt="Inside the Sunny & Ranney showroom in Roswell, Georgia"
            width="700"
            height="875"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 2. PRESS BAR ═══ -->
  <section class="press" aria-label="Featured in">
    <div class="container press__inner">
      <span class="press__label">As Seen In</span>
      <div class="press__logos">
        {pressLogos.map((logo) => (
          <div class="press__logo" aria-label={logo.name}>
            <!-- PLACEHOLDER: Replace with actual logo images -->
            <span class="press__logo-text">{logo.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 3. IMPACT STATS ═══ -->
  <section class="about-stats" aria-label="Impact statistics">
    <div class="container about-stats__inner">
      <div class="about-stats__stat" role="group" aria-label="Room makeovers completed">
        <span class="about-stats__number" data-count={stats.roomMakeovers}>0</span>
        <span class="about-stats__plus" aria-hidden="true">+</span>
        <span class="about-stats__label">Room Makeovers</span>
      </div>
      <div class="about-stats__stat" role="group" aria-label="Children served">
        <span class="about-stats__number" data-count={stats.childrenServed}>0</span>
        <span class="about-stats__plus" aria-hidden="true">+</span>
        <span class="about-stats__label">Children Served</span>
      </div>
      <div class="about-stats__stat" role="group" aria-label="Lives impacted">
        <span class="about-stats__number" data-count={stats.livesImpacted}>0</span>
        <span class="about-stats__plus" aria-hidden="true">+</span>
        <span class="about-stats__label">Lives Impacted</span>
      </div>
      <div class="about-stats__stat" role="group" aria-label="Of profits donated">
        <span class="about-stats__number">100</span>
        <span class="about-stats__plus" aria-hidden="true">%</span>
        <span class="about-stats__label">Of Profits Donated</span>
      </div>
    </div>
  </section>

  <!-- ═══ 4. HOW IT WORKS ═══ -->
  <section class="how-it-works">
    <div class="container how-it-works__inner">
      <span class="label how-it-works__eyebrow">How It Works</span>
      <h2 class="how-it-works__title">From Your Home to Theirs</h2>
      <div class="how-it-works__steps">
        <div class="how-it-works__step reveal">
          <span class="how-it-works__num" aria-hidden="true">01</span>
          <h3>You Shop</h3>
          <p>You find a piece you love at Sunny & Ranney — furniture, decor, or a gift.</p>
        </div>
        <div class="how-it-works__connector" aria-hidden="true">
          <svg width="48" height="24" viewBox="0 0 48 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h44m-8-8 8 8-8 8"/></svg>
        </div>
        <div class="how-it-works__step reveal delay-1">
          <span class="how-it-works__num" aria-hidden="true">02</span>
          <h3>100% of Profit</h3>
          <p>Every dollar of profit goes directly to Sunshine on a Ranney Day. Not a percentage — all of it.</p>
        </div>
        <div class="how-it-works__connector" aria-hidden="true">
          <svg width="48" height="24" viewBox="0 0 48 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h44m-8-8 8 8-8 8"/></svg>
        </div>
        <div class="how-it-works__step reveal delay-2">
          <span class="how-it-works__num" aria-hidden="true">03</span>
          <h3>A Child Gets a Room</h3>
          <p>Volunteers build wheelchair-accessible bathrooms, dream bedrooms, and therapy spaces — free to families.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 5. FOUNDER VIDEO ═══ -->
  <section class="video-section" id="our-story">
    <div class="container video__split">
      <div class="video__header reveal">
        <div class="video__rule" aria-hidden="true"></div>
        <span class="video__eyebrow">Our Story</span>
        <h2>See why we do<br/><em>what we do</em></h2>
        <p class="video__deck">In 60 seconds, Peter and Holly share the moment that changed everything — and why every piece of furniture in our showroom carries a deeper purpose.</p>
      </div>
      <div class="video__stream-wrap reveal delay-1">
        <iframe
          src="https://customer-cuav5h47lgfe96ql.cloudflarestream.com/7d7459064cd569cd7a3d806914f7aec7/iframe"
          allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
          title="Peter and Holly share why they started Sunny & Ranney"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ═══ 6. FOUNDERS + ORIGIN STORY ═══ -->
  <section class="founders" id="founders">
    <div class="container">

      <!-- Holly -->
      <div class="founder reveal">
        <div class="founder__image">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/holly-ranney/w=600,h=750,fit=cover,gravity=face,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/holly-ranney/w=400,h=500,fit=cover,gravity=face,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/holly-ranney/w=600,h=750,fit=cover,gravity=face,q=80,format=auto 600w"
            sizes="(max-width: 767px) 85vw, 440px"
            alt="Holly Ranney, Co-Founder of Sunny & Ranney"
            width="600"
            height="750"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="founder__content">
          <span class="label">Co-Founder</span>
          <h2 class="founder__name">Holly Ranney</h2>
          <blockquote class="founder__quote">
            "It was never just about furniture — it's about creating spaces that make life feel a little more beautiful."
          </blockquote>
          <p class="founder__bio">
            The heart and soul behind Sunny & Ranney's curation. With an eye for design and a passion for giving back, Holly transforms every corner of the shop into an inspiring space that tells a story.
          </p>
          <p class="founder__bio">
            Her talent for finding one-of-a-kind pieces and styling them into rooms people fall in love with is what sets Sunny & Ranney apart.
          </p>
          <a href="/shop" class="founder__link" data-astro-prefetch>
            See Holly's picks
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <!-- Peter + Origin Story -->
      <div class="founder founder--reversed reveal">
        <div class="founder__image">
          <img
            src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/peter-ranney/w=600,h=750,fit=cover,gravity=face,q=80,format=auto"
            srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/peter-ranney/w=400,h=500,fit=cover,gravity=face,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team/peter-ranney/w=600,h=750,fit=cover,gravity=face,q=80,format=auto 600w"
            sizes="(max-width: 767px) 85vw, 440px"
            alt="Peter Ranney, Co-Founder of Sunny & Ranney"
            width="600"
            height="750"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="founder__content">
          <span class="label">Co-Founder</span>
          <h2 class="founder__name">Peter Ranney</h2>
          <blockquote class="founder__quote">
            "It started with one room for an 11-year-old boy named Mathew. That room changed everything."
          </blockquote>
          <p class="founder__bio">
            In 2012, Peter and Holly were inspired by a church sermon to do something simple but powerful — give a child with special needs a bedroom they could truly call their own. That first project for 11-year-old Mathew, who dreamed of a military-themed bunker bedroom, changed everything.
          </p>
          <p class="founder__bio">
            What started as one room has grown into <strong>Sunshine on a Ranney Day</strong>, a 501(c)(3) nonprofit creating wheelchair-accessible bathrooms, dream bedrooms, and in-home therapy spaces — completely free to families. In 2020, they opened <strong>Sunny & Ranney</strong> with one goal: fund the mission. Every dollar of profit goes directly to SOARD — not a percentage, <strong>all of it</strong>.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ 7. KIDS STORIES — editorial sticky-scroll ═══ -->
  <section class="ed" aria-labelledby="ed-heading">
    <div class="container">

      <div class="ed__opener">
        <div class="ed__opener-rule" aria-hidden="true"></div>
        <span class="ed__eyebrow">Their Stories</span>
        <h2 class="ed__headline" id="ed-heading">The Kids Who<br/><em>Inspire</em> Us</h2>
        <p class="ed__deck">Every room starts with a dream. These are the children who remind us why we do what we do.</p>
      </div>

      <div class="ed__sticky-wrap">
        <div class="ed__sticky-img">
          <div class="ed__cover-frame">
            {kids.map((kid, i) => (
              <img
                class={`ed__cover-photo ed__kb ed__kb--${i} ${i === 0 ? 'is-active' : ''}`}
                data-index={i}
                src={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kid.slug}/hero/w=1200,h=800,fit=cover,q=80,format=auto`}
                srcset={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kid.slug}/hero/w=600,h=400,fit=cover,q=75,format=auto 600w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kid.slug}/hero/w=900,h=600,fit=cover,q=80,format=auto 900w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${kid.slug}/hero/w=1200,h=800,fit=cover,q=80,format=auto 1200w`}
                sizes="(max-width: 767px) 92vw, 58vw"
                alt={`${kid.name} in their transformed room`}
                width="1200" height="800"
                loading="lazy"
                decoding="async"
              />
            ))}
            <span class="ed__num ed__num-dynamic" aria-hidden="true">01</span>
          </div>
          <div class="ed__dots" aria-hidden="true">
            {kids.map((_, i) => (
              <span class={`ed__dot ${i === 0 ? 'is-active' : ''}`} data-dot={i}></span>
            ))}
          </div>
        </div>
        <div class="ed__sticky-stories">
          <div class="ed__story is-active" data-story="0">
            <span class="ed__tag">Room #{stats.roomMakeovers - 22}</span>
            <h3 class="ed__story-name">{kids[0].name}</h3>
            <div class="ed__story-rule" aria-hidden="true"></div>
            <p>{kids[0].blurb}</p>
          </div>
          <div class="ed__story" data-story="1">
            <span class="ed__tag">Where It All Began</span>
            <h3 class="ed__story-name">{kids[1].name}</h3>
            <div class="ed__story-rule" aria-hidden="true"></div>
            <p>{kids[1].blurb}</p>
          </div>
          <div class="ed__story" data-story="2">
            <span class="ed__tag">1.6 Million Watched</span>
            <h3 class="ed__story-name">{kids[2].name}</h3>
            <div class="ed__story-rule" aria-hidden="true"></div>
            <p>{kids[2].blurb}</p>
          </div>
        </div>
      </div>

      <!-- Pull Quote -->
      <div class="ed__quote">
        <div class="ed__quote-inner">
          <svg class="ed__quote-mark" width="64" height="52" viewBox="0 0 64 52" fill="none" aria-hidden="true"><path d="M0 33c0-5.7 1.3-10.7 4-15C7 13.7 10.4 10 14.7 7.1 19 4.2 23.7 2.2 29 1.2L30.5 8c-5 1.3-9.3 3.6-12.5 6.9-3.3 3.4-5 7-5 11 0 1 .2 2 .6 2.8 1-.7 2.3-1 4-1 2.7 0 5 1 7 3 2 2 3 4.5 3 7.6 0 3.2-1.2 5.8-3.4 8-2.2 2-4.8 3-8 3-3.7 0-6.8-1.5-9.3-4.4C4 42 2.6 38 2.6 33H0zm32 0c0-5.7 1.3-10.7 4-15C39 13.7 42.4 10 46.7 7.1 51 4.2 55.7 2.2 61 1.2L62.5 8c-5 1.3-9.3 3.6-12.5 6.9-3.3 3.4-5 7-5 11 0 1 .2 2 .6 2.8 1-.7 2.3-1 4-1 2.7 0 5 1 7 3 2 2 3 4.5 3 7.6 0 3.2-1.2 5.8-3.4 8-2.2 2-4.8 3-8 3-3.7 0-6.8-1.5-9.3-4.4C34.6 42 34.6 38 34.6 33H32z" fill="currentColor"/></svg>
          <blockquote>
            A room is more than four walls.<br/>
            It's where a child starts to believe<br/>
            <em>anything is possible.</em>
          </blockquote>
          <div class="ed__quote-attr">
            <span class="ed__quote-rule" aria-hidden="true"></span>
            <span>Peter & Holly Ranney</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ 8. BEFORE / AFTER REVEALS ═══ -->
  <section class="reveals-section">
    <div class="container">
      <div class="reveals__header reveal">
        <div class="reveals__rule" aria-hidden="true"></div>
        <span class="reveals__eyebrow">Room Reveals</span>
        <h2>See the <em>transformation</em></h2>
        <p class="reveals__deck">Swipe to see what your support makes possible. Real rooms. Real kids. Real impact.</p>
      </div>
      <div class="reveals__grid">
        {beforeAfter.map((room, idx) => (
          <article class={`ba-card reveal delay-${idx + 1}`}>
            <div class="ba-card__slider" data-ba-slider>
              <div class="ba-card__before">
                <!-- PLACEHOLDER: Replace with actual before image -->
                <img
                  src={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${room.slug}/before/w=600,h=400,fit=cover,q=80,format=auto`}
                  alt={`${room.kid}'s room before makeover`}
                  width="600" height="400" loading="lazy" decoding="async"
                />
                <span class="ba-card__badge ba-card__badge--before">Before</span>
              </div>
              <div class="ba-card__after">
                <img
                  src={`https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/${room.slug}/hero/w=600,h=400,fit=cover,q=80,format=auto`}
                  alt={`${room.kid}'s room after makeover`}
                  width="600" height="400" loading="lazy" decoding="async"
                />
                <span class="ba-card__badge ba-card__badge--after">After</span>
              </div>
              <div class="ba-card__handle" aria-hidden="true">
                <div class="ba-card__handle-line"></div>
                <div class="ba-card__handle-grip">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
                </div>
                <div class="ba-card__handle-line"></div>
              </div>
            </div>
            <div class="ba-card__info">
              <h3 class="ba-card__name">{room.kid}</h3>
              <span class="ba-card__label">{room.label}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 9. THE CREW ═══ -->
  <section class="crew">
    <div class="container">
      <div class="crew__header reveal">
        <div class="crew__rule" aria-hidden="true"></div>
        <span class="crew__eyebrow">The Crew</span>
        <h2>The faces you'll see<br/>when you <em>walk in</em></h2>
      </div>
      <div class="crew__grid">
        {[
          { name: 'Staci', role: 'Store Manager', desc: 'Keeps the showroom running like clockwork and ensures every visitor feels at home from the moment they walk in.', image: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team-staci' },
          { name: 'BJ', role: 'Team Member', desc: 'A valued member of the Sunny & Ranney family, helping create beautiful spaces and brighter futures every day.', image: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team-bj' },
          { name: 'Staci', role: 'AI Shopping Assistant', desc: 'Our tireless digital team member — always ready to help you find the perfect piece, 24/7.', highlight: true, initials: 'ST' },
        ].map((member, idx) => (
          <article class={`crew__card reveal delay-${idx + 1}`}>
            <div class={`crew__photo${member.highlight ? ' crew__photo--ai' : ''}`}>
              {member.image ? (
                <img
                  src={`${member.image}/w=200,h=250,fit=cover,gravity=face,q=80,format=auto`}
                  srcset={`${member.image}/w=160,h=200,fit=cover,gravity=face,q=75,format=auto 160w, ${member.image}/w=320,h=400,fit=cover,gravity=face,q=80,format=auto 320w`}
                  sizes="160px"
                  alt={member.name}
                  width="160"
                  height="200"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="crew__initials">
                  <span>{member.initials}</span>
                </div>
              )}
            </div>
            <h3 class="crew__name">{member.name}</h3>
            <span class="crew__role">{member.role}</span>
            <p class="crew__desc">{member.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 10. MASCOT ═══ -->
  <section class="mascot">
    <div class="container mascot__inner">
      <div class="mascot__image reveal">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=400,h=400,fit=cover,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=240,h=240,fit=cover,q=75,format=auto 240w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/gracie/w=400,h=400,fit=cover,q=80,format=auto 400w"
          sizes="(max-width: 767px) 160px, 200px"
          alt="Gracie the Pig — the real pot-bellied pig that inspired SOARD's mascot"
          width="400"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="mascot__content reveal delay-1">
        <span class="label">Our Mascot</span>
        <h3>Why the Pig?</h3>
        <p>
          It started as a wedding gift — Peter surprised Holly with a baby pot-bellied pig named Gracie. She's been our golden, cape-wearing, high-flying mascot ever since — leading her team of Sunshiners to build rooms that bring comfort, independence, and joy.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ 11. CLOSING CTA ═══ -->
  <section class="about-cta">
    <div class="container about-cta__inner">
      <div class="about-cta__content reveal">
        <h2>Find Something Beautiful.<br/><em>Do Something Meaningful.</em></h2>
        <p>Every purchase at Sunny & Ranney funds bedroom makeovers for children with special needs. You're not just shopping — you're building a room that changes a child's life.</p>
        <div class="about-cta__actions">
          <a href="/shop" class="btn btn--gold" data-astro-prefetch>Shop Now</a>
        </div>
        <div class="about-cta__trust">
          <span>100% of profits donated</span>
          <span class="about-cta__dot" aria-hidden="true"></span>
          <span>{stats.roomMakeovers}+ rooms built</span>
