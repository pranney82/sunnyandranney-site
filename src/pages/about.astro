    position: sticky;
    top: 10vh;
    align-self: start;
  }

  @media (max-width: 767px) {
    .ed__sticky-img {
      position: relative;
      top: auto;
    }
    .ed__cover-frame {
      display: flex;
      aspect-ratio: auto;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: var(--space-md);
      scroll-padding: 0 8%;
    }
    .ed__cover-frame::-webkit-scrollbar {
      display: none;
    }
    .ed__cover-photo {
      position: static;
      width: 85vw;
      max-width: 400px;
      min-width: 85vw;
      height: auto;
