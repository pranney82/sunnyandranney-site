---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Sunshine on a Ranney Fairway 2026 — Charity Golf | Sunny & Ranney"
  description="Join us for Sunshine on a Ranney Fairway 2026 — a charity golf tournament where every swing supports life-changing room makeovers for children with special needs."
  image="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-light/og"
  lcpImage="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-dark/w=400,q=85,format=auto"
  lcpImageSrcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-dark/w=280,q=80,format=auto 280w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-dark/w=400,q=85,format=auto 400w"
  lcpImageSizes="(max-width: 767px) 200px, 320px"
>

  <!-- ═══ HERO ═══ -->
  <section class="ev-hero">
    <div class="ev-hero__bg" aria-hidden="true">
      <div class="ev-hero__gradient"></div>
    </div>
    <div class="container ev-hero__inner">
      <div class="ev-hero__content">
        <span class="label ev-hero__eyebrow reveal">Charity Golf Tournament</span>
        <h1 class="ev-hero__title reveal">
          Sunshine on a<br/>Ranney <span class="ev-hero__accent">Fairway</span>
        </h1>
        <p class="ev-hero__subtitle reveal">
          Tee up for a cause. Every swing supports life-changing room makeovers for children with special needs through <a href="https://sunshineonaranneyday.com" target="_blank" rel="noopener" class="ev-hero__link">Sunshine on a Ranney Day</a>.
        </p>
        <div class="ev-hero__actions reveal">
          <a href="#tickets" class="btn btn--gold btn--hero">Register</a>
          <a href="#details" class="ev-hero__scroll-link">
            Learn More
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
          </a>
        </div>
      </div>
      <div class="ev-hero__visual reveal">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-dark/w=400,q=85,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-dark/w=280,q=80,format=auto 280w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-dark/w=400,q=85,format=auto 400w"
          sizes="(max-width: 767px) 200px, 320px"
          alt="Sunshine on a Ranney Fairway Golf Tournament logo"
          class="ev-hero__logo"
          width="400"
          height="400"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>
    <div class="ev-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" fill="var(--color-cream)"><path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z"/></svg>
    </div>
  </section>

  <!-- ═══ EVENT DETAILS ═══ -->
  <section class="ev-details" id="details">
    <div class="container ev-details__inner">
      <div class="ev-details__grid">
        <div class="ev-details__card reveal">
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="ev-details__card-title">When</h3>
          <p class="ev-details__card-date">Monday, May 18th, 2026</p>
          <p class="ev-details__card-text">
            <strong>7:00 AM</strong> &mdash; Registration<br/>
            <strong>10:00 AM</strong> &mdash; Tee Off<br/>
            <strong>TBA</strong> &mdash; Banquet
          </p>
        </div>
        <div class="ev-details__card reveal">
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="ev-details__card-title">Where</h3>
          <p class="ev-details__card-text">
            <strong>Indian Hills Country Club</strong><br/>
            <a href="https://maps.google.com/?q=4001+Clubland+Dr+Marietta+GA+30068" target="_blank" rel="noopener" class="ev-details__map-link">
              4001 Clubland Dr.<br/>
              Marietta, GA 30068
            </a>
          </p>
        </div>
        <div class="ev-details__card reveal">
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </div>
          <h3 class="ev-details__card-title">The Cause</h3>
          <p class="ev-details__card-text">100% of proceeds fund dream room makeovers for children with special needs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DEDICATED TO ═══ -->
  <section class="ev-chair">
    <div class="container ev-chair__inner reveal">
      <div class="ev-chair__photo-wrap">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-brent-aronson/w=500,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-brent-aronson/w=340,q=75,format=auto 340w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-brent-aronson/w=500,q=80,format=auto 500w"
          sizes="(max-width: 639px) 220px, 260px"
          alt="Brent Aronson"
          class="ev-chair__photo"
          width="500"
          height="500"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="ev-chair__text">
        <span class="label">Dedicated To</span>
        <h2>Brent Aronson</h2>
        <p>This year's tournament is dedicated to Brent Aronson, whose vision and commitment helped build SOARD. Join us as we celebrate his legacy and see the impact firsthand. Many of the kids you support will be out on the course!</p>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT HELPS ═══ -->
  <section class="ev-impact">
    <div class="container ev-impact__inner">
      <span class="label reveal">Your Impact</span>
      <h2 class="reveal">Every Ticket Changes a Life</h2>
      <div class="ev-impact__steps">
        <div class="ev-impact__step reveal">
          <div class="ev-impact__num" aria-hidden="true">1</div>
          <h4>You Play</h4>
          <p>Grab your clubs and enjoy a day on the course with friends, food, and fun.</p>
        </div>
        <div class="ev-impact__connector" aria-hidden="true">
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><path d="M4 12h32M28 5l8 7-8 7" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ev-impact__step reveal">
          <div class="ev-impact__num" aria-hidden="true">2</div>
          <h4>We Give</h4>
          <p>Every dollar goes directly to Sunshine on a Ranney Day to fund room makeovers.</p>
        </div>
        <div class="ev-impact__connector" aria-hidden="true">
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><path d="M4 12h32M28 5l8 7-8 7" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ev-impact__step reveal">
          <div class="ev-impact__num" aria-hidden="true">3</div>
          <h4>Kids Dream</h4>
          <p>A child with special needs gets the room they've always dreamed of.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TICKETS ═══ -->
  <section class="ev-tickets" id="tickets">
    <div class="container ev-tickets__inner">
      <span class="label reveal">Reserve Your Spot</span>
      <h2 class="reveal">Sponsorships & Tickets</h2>
      <p class="ev-tickets__sub reveal">Browse sponsorship packages and foursomes, then register on Zeffy to complete your purchase.</p>

      <!-- Sponsor tiers -->
      <div class="ev-tiers reveal">
        <div class="ev-tier ev-tier--featured">
          <span class="ev-tier__badge">Top Sponsor</span>
          <h3 class="ev-tier__name">Presenting Sponsor</h3>
          <span class="ev-tier__price">$20,000</span>
          <span class="ev-tier__detail">2 Foursomes (8 Golfers)</span>
          <span class="ev-tier__perk">Oakley sunglasses + Footjoy shoes per player, video interview, logo on all signage & social media</span>
        </div>
        <div class="ev-tier">
          <h3 class="ev-tier__name">Titanium Sponsor</h3>
          <span class="ev-tier__price">$15,000</span>
          <span class="ev-tier__detail">2 Foursomes (8 Golfers)</span>
          <span class="ev-tier__perk">Oakley sunglasses or Footjoy shoes, video interview, logo placement</span>
        </div>
        <div class="ev-tier">
          <h3 class="ev-tier__name">Diamond Sponsor</h3>
          <span class="ev-tier__price">$10,000</span>
          <span class="ev-tier__detail">1 Foursome (4 Golfers)</span>
          <span class="ev-tier__perk">Video interview, logo on social media & signage</span>
        </div>
        <div class="ev-tier">
          <h3 class="ev-tier__name">Platinum Sponsor</h3>
          <span class="ev-tier__price">$7,500</span>
          <span class="ev-tier__detail">1 Foursome (4 Golfers)</span>
          <span class="ev-tier__perk">Signage, multiple social media posts</span>
        </div>
        <div class="ev-tier">
          <h3 class="ev-tier__name">Gold Sponsor</h3>
          <span class="ev-tier__price">$5,000</span>
          <span class="ev-tier__detail">1 Foursome (4 Golfers)</span>
          <span class="ev-tier__perk">Signage, social media posts</span>
        </div>
        <div class="ev-tier ev-tier--popular">
          <span class="ev-tier__badge">Most Popular</span>
          <h3 class="ev-tier__name">Foursome</h3>
          <span class="ev-tier__price">$1,500</span>
          <span class="ev-tier__detail">4 Golfers</span>
          <span class="ev-tier__perk">Lunch & beverages included</span>
        </div>
      </div>

      <!-- Additional sponsorships -->
      <details class="ev-more reveal">
        <summary class="ev-more__toggle">
          <span>Additional Sponsorships</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="ev-more__grid">
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Lunch Sponsor</h3>
            <span class="ev-tier__price">$2,500</span>
          </div>
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Putting Contest</h3>
            <span class="ev-tier__price">$2,500</span>
          </div>
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Beverage Cart</h3>
            <span class="ev-tier__price">$2,000</span>
          </div>
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Bloody Mary Bar</h3>
            <span class="ev-tier__price">$2,000</span>
          </div>
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Banquet Bar</h3>
            <span class="ev-tier__price">$2,000</span>
          </div>
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Raffle Sponsor</h3>
            <span class="ev-tier__price">$2,000</span>
          </div>
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Banquet Sponsor</h3>
            <span class="ev-tier__price">$1,500</span>
          </div>
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Closest to the Pin</h3>
            <span class="ev-tier__price">$1,500</span>
          </div>
          <div class="ev-tier ev-tier--sm">
            <h3 class="ev-tier__name">Hole Sponsor</h3>
            <span class="ev-tier__price">$1,000</span>
          </div>
        </div>
      </details>

      <!-- Single CTA -->
      <div class="ev-tickets__cta reveal">
        <a href="https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026" target="_blank" rel="noopener" class="btn btn--gold btn--hero">
          Register & Select Your Package
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        <p class="ev-tickets__secure-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          Secure checkout powered by Zeffy · Zero platform fees
        </p>
      </div>
    </div>
  </section>


  <!-- ═══ CTA ═══ -->
  <section class="ev-cta">
    <div class="container ev-cta__inner">
      <div class="ev-cta__card reveal">
        <h2>Can't Make It?<br/>You Can Still Help.</h2>
        <p>Shop Sunny & Ranney — 100% of our profits are donated to fund room makeovers for children with special needs.</p>
        <div class="ev-cta__actions">
          <a href="/shop/" class="btn btn--primary" data-astro-prefetch>Shop & Give Back</a>
          <a href="/about/" class="btn btn--outline" data-astro-prefetch>Our Mission</a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ═══════════════════════════════════════════════════════════════
     EVENTS PAGE — Sunshine on a Ranney Fairway 2026
     Matches Sunny & Ranney design system: warm, elevated, charity-forward
     ═══════════════════════════════════════════════════════════════ */

  /* ─── Scroll offset for fixed nav on all anchor targets ───── */
  [id] {
    scroll-margin-top: calc(var(--nav-height, 123px) + 1.5rem);
  }

  /* ─── Hero ──────────────────────────────────────────────────── */
  .ev-hero {
    position: relative;
    overflow: hidden;
    padding: var(--space-3xl) 0 calc(var(--space-3xl) + 40px);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .ev-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(135deg, #1a472a 0%, #2e7d32 40%, #388e3c 70%, #43a047 100%);
  }

  .ev-hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(255, 212, 0, 0.12) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 20%, rgba(255, 255, 255, 0.06) 0%, transparent 60%);
  }

  .ev-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (min-width: 768px) {
    .ev-hero {
      min-height: 600px;
      padding: var(--space-3xl) 0 calc(var(--space-3xl) + 60px);
    }
    .ev-hero__inner {
      grid-template-columns: 1fr auto;
      gap: var(--space-xl);
    }
  }

  .ev-hero__eyebrow {
    color: var(--color-gold-light);
    margin-bottom: var(--space-xs);
    display: block;
  }

  .ev-hero__title {
    color: #fff;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 1.08;
    margin-bottom: var(--space-sm);
  }

  .ev-hero__accent {
    color: var(--color-gold);
    font-style: italic;
  }

  .ev-hero__subtitle {
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(0.95rem, 1.2vw, 1.15rem);
    max-width: 52ch;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .ev-hero__link {
    color: var(--color-gold-light);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .ev-hero__link:hover { color: var(--color-gold); }

  .ev-hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .ev-hero__scroll-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.88rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .ev-hero__scroll-link:hover { color: #fff; }

  /* Hero logo */
  .ev-hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ev-hero__logo {
    width: 200px;
    height: auto;
    filter: drop-shadow(0 4px 24px rgba(0, 0, 0, 0.2));
  }

  @media (min-width: 768px) {
    .ev-hero__logo {
      width: 320px;
    }
  }

  /* Wave divider */
  .ev-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    line-height: 0;
    z-index: 2;
  }
  .ev-hero__wave svg {
    width: 100%;
    height: 60px;
  }
  @media (min-width: 768px) {
    .ev-hero__wave svg { height: 80px; }
  }

  /* ─── Event Details ─────────────────────────────────────────── */
  .ev-details {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .ev-details__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .ev-details__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }

  .ev-details__card {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    border-radius: 12px;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .ev-details__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(44, 44, 44, 0.08);
  }

  .ev-details__icon {
    width: 56px;
    height: 56px;
    margin: 0 auto var(--space-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8f5e9;
    color: #2e7d32;
    border-radius: 50%;
  }

  .ev-details__card-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-charcoal);
    margin-bottom: 0.4rem;
  }

  .ev-details__card-date {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--color-charcoal);
    margin-bottom: 0.5rem;
  }

  .ev-details__card-text {
    font-size: 0.92rem;
    color: var(--color-slate);
    line-height: 1.7;
  }

  .ev-details__map-link {
    color: #2e7d32;
    text-decoration: underline;
    text-decoration-color: rgba(46, 125, 50, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s;
  }
  .ev-details__map-link:hover {
    text-decoration-color: #2e7d32;
  }

  /* ─── Dedicated To ──────────────────────────────────────────── */
  .ev-chair {
    padding: var(--space-2xl) 0;
    background: var(--color-warm-white);
    border-top: 1px solid var(--color-cream-dark);
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .ev-chair__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .ev-chair__inner {
      grid-template-columns: auto 1fr;
      gap: var(--space-xl);
    }
  }

  .ev-chair__photo-wrap {
    display: flex;
    justify-content: center;
  }

  .ev-chair__photo {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-cream-dark);
    box-shadow: 0 8px 32px rgba(44, 44, 44, 0.1);
  }

  @media (min-width: 640px) {
    .ev-chair__photo {
      width: 260px;
      height: 260px;
    }
  }

  .ev-chair__text {
    text-align: center;
  }

  @media (min-width: 640px) {
    .ev-chair__text {
      text-align: left;
    }
  }

  .ev-chair__text h2 {
    margin: 0.3rem 0 var(--space-sm);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  .ev-chair__text p {
    margin-bottom: 0;
  }

  /* ─── Impact / How It Helps ─────────────────────────────────── */
  .ev-impact {
    padding: var(--space-2xl) 0;
  }

  .ev-impact__inner {
    text-align: center;
  }

  .ev-impact__inner h2 {
    margin: 0.4rem 0 var(--space-xl);
  }

  .ev-impact__steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  @media (min-width: 768px) {
    .ev-impact__steps {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-md);
    }
  }

  .ev-impact__step {
    flex: 0 1 260px;
    text-align: center;
    padding: var(--space-md);
  }



  .ev-impact__step h4 {
    font-family: var(--font-display);
    font-size: 1.2rem;
