---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';

export const prerender = false;

const hours: any = await getSetting('settings:hours');

const DAYS = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

const defaults = {
  days: DAYS.map(day => ({
    day,
    open: '10:00',
    close: '18:00',
    closed: false,
  })),
  holidays: [] as Array<{ date: string; label: string; closed: boolean; open: string; close: string }>,
  note: '',
};

const data = hours || defaults;
---

<Admin title="Store Hours">
  <div class="admin-header">
    <div>
      <h2>Store Hours</h2>
      <p>Set your regular hours and holiday closures</p>
    </div>
    <div class="admin-unsaved-badge" aria-live="polite">
      <span class="admin-unsaved-dot"></span>
      Unsaved changes
    </div>
  </div>

  <form id="hours-form">
    <div class="admin-card">
      <h3>Regular Hours</h3>
      <div class="hours-grid">
        {data.days.map((d: any, i: number) => (
          <div class:list={['hours-row', { 'is-closed': d.closed }]}>
            <span class="hours-day">{d.day}</span>
            <label class="admin-toggle">
              <input type="checkbox" name={`closed-${i}`} checked={!d.closed} />
              <span class="admin-toggle-slider"></span>
            </label>
            <span class:list={['hours-status', d.closed ? 'closed' : 'open']}>{d.closed ? 'Closed' : 'Open'}</span>
            <div class:list={['hours-times', { disabled: d.closed }]} data-index={i}>
              <input type="time" class="admin-input hours-time" name={`open-${i}`} value={d.open} disabled={d.closed} />
              <span class="hours-sep">to</span>
              <input type="time" class="admin-input hours-time" name={`close-${i}`} value={d.close} disabled={d.closed} />
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="admin-card">
      <h3>Holiday Hours</h3>
      <p style="font-size: 0.85rem; color: var(--admin-text-light); margin-bottom: 1rem;">
        Set modified hours or closures for specific dates. These override regular hours.
      </p>
      <div id="holidays-container">
        {data.holidays.map((h: any, i: number) => (
          <div class="holiday-row" data-holiday-index={i}>
            <div class="holiday-row-top">
              <div class="admin-field" style="flex:1; margin-bottom:0">
                <label class="admin-label">Date</label>
                <input type="date" class="admin-input holiday-date" value={h.date} />
              </div>
              <div class="admin-field" style="flex:2; margin-bottom:0">
                <label class="admin-label">Label</label>
                <input type="text" class="admin-input holiday-label" value={h.label} placeholder="e.g. Thanksgiving" />
              </div>
              <button type="button" class="admin-btn admin-btn--danger remove-holiday" style="align-self:flex-end; margin-bottom: 0.05rem;">Remove</button>
            </div>
            <div class="holiday-row-bottom">
              <label class="admin-toggle">
                <input type="checkbox" class="holiday-closed" checked={h.closed} />
                <span class="admin-toggle-slider"></span>
              </label>
              <span class="holiday-closed-label">{h.closed ? 'Closed all day' : 'Modified hours'}</span>
              <div class="holiday-times" style={h.closed ? 'opacity:0.3;pointer-events:none;' : ''}>
                <input type="time" class="admin-input hours-time holiday-open" value={h.open || '10:00'} />
                <span class="hours-sep">to</span>
                <input type="time" class="admin-input hours-time holiday-close" value={h.close || '14:00'} />
              </div>
            </div>
          </div>
        ))}
      </div>
      <button type="button" class="admin-btn admin-btn--outline" id="add-holiday" style="margin-top: 0.75rem">+ Add Holiday</button>
    </div>

    <div class="admin-card">
      <h3>Additional Note</h3>
      <p style="font-size: 0.85rem; color: var(--admin-text-light); margin-bottom: 0.75rem;">
        Shown on the site and available to the chatbot (e.g. "Curbside pickup available")
      </p>
      <textarea class="admin-input admin-textarea" name="note" placeholder="Optional note about store hours...">{data.note}</textarea>
    </div>

    <div class="admin-save-bar">
      <button type="submit" class="admin-btn admin-btn--primary" id="save-btn">
        <span class="btn-spinner"></span>
        <span class="btn-label">Save Hours</span>
      </button>
      <span class="admin-save-hint">
        <kbd class="admin-kbd">⌘S</kbd> to save
      </span>
    </div>
  </form>
</Admin>

<style>
  .hours-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hours-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    transition: background 0.15s;
  }

  .hours-row.is-closed {
    background: rgba(0,0,0,0.025);
  }

  .hours-row.is-closed .hours-day {
    color: var(--admin-text-light);
  }

  .hours-day {
    width: 100px;
    font-weight: 600;
    font-size: 0.9rem;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .hours-status {
    font-size: 0.8rem;
    font-weight: 600;
    width: 48px;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .hours-status.open { color: var(--admin-success); }
  .hours-status.closed { color: var(--admin-text-light); }

  .hours-times {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    transition: opacity 0.2s;
  }

  .hours-time {
    max-width: 130px;
  }

  .hours-sep {
    font-size: 0.85rem;
    color: var(--admin-text-light);
    flex-shrink: 0;
  }

  .hours-times.disabled {
    opacity: 0.25;
    pointer-events: none;
  }

  .holiday-row {
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 0.75rem;
  }

  .holiday-row-top {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
    margin-bottom: 0.75rem;
  }

  .holiday-row-bottom {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .holiday-closed-label {
    font-size: 0.82rem;
    color: var(--admin-text-light);
    width: 110px;
    flex-shrink: 0;
  }

  .holiday-times {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: opacity 0.2s;
  }

  .holiday-times .hours-time {
    max-width: none;
    flex: 1;
  }

  @media (max-width: 768px) {
    .hours-row {
      flex-wrap: wrap;
      padding: 0.6rem 0.5rem;
    }

    .hours-day {
      width: auto;
      flex: 1;
    }

    .hours-times {
      width: 100%;
      margin-top: 0.25rem;
    }

    .hours-times .hours-time {
      flex: 1;
      max-width: none;
    }

    .holiday-row-top {
      flex-wrap: wrap;
    }

    .holiday-row-bottom {
      flex-wrap: wrap;
    }

    .holiday-times {
      width: 100%;
    }

    .holiday-times .hours-time {
      flex: 1;
    }
  }
</style>

<script>
  const DAYS = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
  const form = document.getElementById('hours-form') as HTMLFormElement;

  // Toggle open/closed state
  form.querySelectorAll('.hours-row .admin-toggle input').forEach((toggle) => {
    toggle.addEventListener('change', (e) => {
      const input = e.target as HTMLInputElement;
      const row = input.closest('.hours-row') as HTMLElement;
      if (!row) return;
      const timesDiv = row.querySelector('.hours-times') as HTMLElement;
      const status = row.querySelector('.hours-status') as HTMLElement;
      const isOpen = input.checked;

      timesDiv.querySelectorAll('input').forEach((i) => {
        (i as HTMLInputElement).disabled = !isOpen;
      });
      timesDiv.classList.toggle('disabled', !isOpen);
      row.classList.toggle('is-closed', !isOpen);
      status.textContent = isOpen ? 'Open' : 'Closed';
      status.className = `hours-status ${isOpen ? 'open' : 'closed'}`;
    });
  });

  // Holiday closed toggle
  function initHolidayToggles() {
    document.querySelectorAll('.holiday-closed').forEach((cb) => {
      cb.addEventListener('change', (e) => {
        const input = e.target as HTMLInputElement;
        const row = input.closest('.holiday-row');
        if (!row) return;
        const times = row.querySelector('.holiday-times') as HTMLElement;
        const label = row.querySelector('.holiday-closed-label') as HTMLElement;
        if (input.checked) {
          times.style.opacity = '0.3';
          times.style.pointerEvents = 'none';
          label.textContent = 'Closed all day';
        } else {
          times.style.opacity = '1';
          times.style.pointerEvents = 'auto';
          label.textContent = 'Modified hours';
        }
      });
    });
  }
  initHolidayToggles();

  // Add holiday
  let holidayCount = form.querySelectorAll('.holiday-row').length;
  document.getElementById('add-holiday')?.addEventListener('click', () => {
    const container = document.getElementById('holidays-container')!;
    const row = document.createElement('div');
    row.className = 'holiday-row';
    row.dataset.holidayIndex = String(holidayCount);
    row.innerHTML = `
      <div class="holiday-row-top">
        <div class="admin-field" style="flex:1; margin-bottom:0">
          <label class="admin-label">Date</label>
          <input type="date" class="admin-input holiday-date" />
        </div>
        <div class="admin-field" style="flex:2; margin-bottom:0">
          <label class="admin-label">Label</label>
          <input type="text" class="admin-input holiday-label" placeholder="e.g. Thanksgiving" />
        </div>
        <button type="button" class="admin-btn admin-btn--danger remove-holiday" style="align-self:flex-end; margin-bottom: 0.05rem;">Remove</button>
      </div>
      <div class="holiday-row-bottom">
        <label class="admin-toggle">
          <input type="checkbox" class="holiday-closed" />
          <span class="admin-toggle-slider"></span>
        </label>
        <span class="holiday-closed-label">Modified hours</span>
        <div class="holiday-times">
          <input type="time" class="admin-input hours-time holiday-open" value="10:00" />
          <span class="hours-sep">to</span>
          <input type="time" class="admin-input hours-time holiday-close" value="14:00" />
        </div>
      </div>
    `;
    container.appendChild(row);
    holidayCount++;
    initHolidayToggles();
  });

  // Remove holiday
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.remove-holiday');
    if (btn) btn.closest('.holiday-row')?.remove();
  });

  // Save
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    (window as any).setButtonLoading(btn, true);

    // Snapshot for undo
    const snapshot = new FormData(form);

    const days = DAYS.map((day, i) => {
      const isOpen = (form.querySelector(`[name="closed-${i}"]`) as HTMLInputElement).checked;
      return {
        day,
        open: (form.querySelector(`[name="open-${i}"]`) as HTMLInputElement).value,
        close: (form.querySelector(`[name="close-${i}"]`) as HTMLInputElement).value,
        closed: !isOpen,
      };
    });

    const holidays: Array<{ date: string; label: string; closed: boolean; open: string; close: string }> = [];
    form.querySelectorAll('.holiday-row').forEach((row) => {
      const dateInput = row.querySelector('.holiday-date') as HTMLInputElement;
      const labelInput = row.querySelector('.holiday-label') as HTMLInputElement;
      const closedInput = row.querySelector('.holiday-closed') as HTMLInputElement;
      const openInput = row.querySelector('.holiday-open') as HTMLInputElement;
      const closeInput = row.querySelector('.holiday-close') as HTMLInputElement;
      if (dateInput.value) {
        holidays.push({
          date: dateInput.value,
          label: labelInput.value,
          closed: closedInput.checked,
          open: openInput.value || '10:00',
          close: closeInput.value || '14:00',
        });
      }
    });

    const note = (form.querySelector('[name="note"]') as HTMLTextAreaElement).value;

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'settings:hours', value: { days, holidays, note } }),
      });

      if (!res.ok) throw new Error('Save failed');
      const data = await res.json();
      if (data.warning) {
        (window as any).showToast(`Saved, but site won't update: ${data.warning}`, true);
      } else {
        (window as any).showToast('Store hours saved — site will rebuild shortly', false, () => {
          // Restore snapshot values
          for (const [key, val] of snapshot.entries()) {
            const el = form.querySelector(`[name="${key}"]`) as HTMLInputElement | null;
            if (!el) continue;
            if (el.type === 'checkbox') el.checked = val === 'on';
            else el.value = val as string;
          }
        });
      }
    } catch {
      (window as any).showToast('Failed to save', true);
    } finally {
      (window as any).setButtonLoading(btn, false);
    }
  });
</script>
