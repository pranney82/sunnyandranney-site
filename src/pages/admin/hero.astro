---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';
import { getCollectionByHandle } from '@/lib/shopify';
import { getCollectionsStatic } from '@/lib/settings';
import type { HeroSetting } from '@/lib/settings';

export const prerender = false;

// Load enabled collection handles from admin settings
const collectionSettings = await getCollectionsStatic();
const enabledHandles = collectionSettings
  ?.filter(c => c.enabled)
  .sort((a, b) => a.order - b.order)
  .map(c => c.handle) ?? [];

// Fetch products for each enabled collection
type CollectionData = { handle: string; title: string; products: any[] };
let collectionData: CollectionData[] = [];
try {
  const results = await Promise.all(
    enabledHandles.map(h => getCollectionByHandle(h, 100))
  );
  collectionData = results
    .filter(Boolean)
    .map(c => ({ handle: c!.handle, title: c!.title, products: c!.products }));
} catch (e) {
  console.error('Failed to fetch collections:', e);
}

// Load current hero setting
const saved = await getSetting<HeroSetting>('settings:hero');
const savedImageUrl = saved?.imageUrl ?? '';
const savedProductHandle = saved?.productHandle ?? '';
const savedCollectionHandle = saved?.collectionHandle ?? '';

// Determine which collection tab to show initially
const initialCollection =
  collectionData.find(c => c.handle === savedCollectionHandle)?.handle ??
  collectionData.find(c => c.products.some((p: any) => p.handle === savedProductHandle))?.handle ??
  collectionData[0]?.handle ??
  '';
---

<Admin title="Hero Section">
  <div class="admin-header">
    <div>
      <h2>Hero Section</h2>
      <p>Pick a product from a collection — its image becomes the hero background and it appears as the featured card.</p>
    </div>
    <div class="admin-unsaved-badge" aria-live="polite">
      <span class="admin-unsaved-dot"></span>
      Unsaved changes
    </div>
  </div>

  {collectionData.length === 0 ? (
    <div class="admin-card">
      <p style="color: var(--admin-text-light);">
        No enabled collections found. Go to <a href="/admin/collections">Collections</a> to enable some first.
      </p>
    </div>
  ) : (
    <form id="hero-form">
      <!-- Hidden fields updated by JS when a product is selected -->
      <input type="hidden" id="hero-image-url" name="imageUrl" value={savedImageUrl} />
      <input type="hidden" id="hero-collection-handle" name="collectionHandle" value={initialCollection} />

      <!-- ─── Collection Tabs ─────────────────────────────── -->
      <div class="admin-card collection-tab-card">
        <div class="collection-tab-top">
          <div class="field-label">Collection</div>
          <input
            type="search"
            id="product-search"
            class="product-search"
            placeholder="Search products…"
            autocomplete="off"
          />
        </div>
        <div class="collection-tabs" role="tablist">
          {collectionData.map(c => (
            <button
              type="button"
              role="tab"
              class:list={['collection-tab', { active: c.handle === initialCollection }]}
              data-collection={c.handle}
              aria-selected={c.handle === initialCollection ? 'true' : 'false'}
            >
              {c.title}
            </button>
          ))}
        </div>
      </div>

      <!-- ─── Product Grid per Collection ─────────────────── -->
      {collectionData.map(c => (
        <div
          class:list={['collection-products', { 'collection-products--hidden': c.handle !== initialCollection }]}
          data-collection={c.handle}
          role="tabpanel"
        >
          <div class="admin-card">
            <div class="field-label">{c.title}</div>
            <p class="field-hint">Select a product — its image becomes the hero background and it appears as the featured product card.</p>

            {c.products.length === 0 ? (
              <p style="color: var(--admin-text-light); font-size: 0.85rem; margin-top: 0.5rem;">No products in this collection.</p>
            ) : (
              <div class="hero-product-grid">
                {c.products.map((p: any) => {
                  const img = p.images.edges[0]?.node;
                  const price = p.priceRange.minVariantPrice;
                  const isSelected = p.handle === savedProductHandle;
                  return (
                    <label
                      class:list={['product-pick', { selected: isSelected }]}
                      data-handle={p.handle}
                      data-image-url={img?.url ?? ''}
                      data-collection={c.handle}
                    >
                      <input
                        type="radio"
                        name="productHandle"
                        value={p.handle}
                        checked={isSelected}
                        class="product-pick-radio"
                      />
                      {isSelected && <span class="product-pick-badge">✓</span>}
                      <div class="product-pick-img">
                        {img
                          ? <img src={`${img.url}&width=200`} alt={p.title} width="200" height="160" />
                          : <div class="product-pick-ph">{p.title.charAt(0)}</div>
                        }
                      </div>
                      <div class="product-pick-info">
                        <strong>{p.title}</strong>
                        <span>${parseFloat(price.amount).toFixed(2)}</span>
                      </div>
                    </label>
                  );
                })}
              </div>
            )}
          </div>
        </div>
      ))}

      <div class="admin-save-bar">
        <button type="submit" class="admin-btn admin-btn--primary" id="save-btn">
          <span class="btn-spinner"></span>
          <span class="btn-label">Save Hero Settings</span>
        </button>
        <span class="admin-save-hint">
          <kbd class="admin-kbd">⌘S</kbd> to save
        </span>
      </div>
    </form>
  )}
</Admin>

<style>
  .collection-tab-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .collection-tab-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .product-search {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    font-size: 0.85rem;
    color: var(--admin-text);
    background: var(--admin-bg);
    width: 220px;
    transition: border-color 0.15s;
  }

  .product-search:focus {
    outline: none;
    border-color: var(--admin-accent);
  }

  .collection-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .collection-tab {
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--admin-border);
    border-radius: 2rem;
    background: var(--admin-bg);
    color: var(--admin-text);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .collection-tab:hover {
    border-color: #bbb;
  }

  .collection-tab.active {
    background: var(--admin-accent, #f59e0b);
    border-color: var(--admin-accent, #f59e0b);
    color: #000;
    font-weight: 600;
  }

  .collection-products--hidden {
    display: none;
  }

  .field-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--admin-text);
  }

  .field-hint {
    font-size: 0.8rem;
    color: var(--admin-text-light);
    margin: 0;
    line-height: 1.5;
  }

  /* ─── Product grid ─── */
  .hero-product-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  @media (max-width: 1200px) {
    .hero-product-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 900px) {
    .hero-product-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .hero-product-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .product-pick {
    position: relative;
    background: var(--admin-card);
    border: 2px solid var(--admin-border);
    border-radius: var(--admin-radius);
    cursor: pointer;
    transition: box-shadow 0.2s, border-color 0.2s;
    overflow: hidden;
    display: block;
    user-select: none;
  }

  .product-pick:hover {
    border-color: #ccc;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .product-pick.selected {
    border-color: var(--admin-accent, #f59e0b);
    box-shadow: 0 2px 10px rgba(255, 212, 0, 0.25);
  }

  .product-pick-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .product-pick-badge {
    position: absolute;
    top: 0.4rem;
    right: 0.4rem;
    background: var(--admin-accent, #f59e0b);
    color: #000;
    font-size: 0.72rem;
    font-weight: 700;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .product-pick-img {
    width: 100%;
    height: 120px;
    overflow: hidden;
    background: #f0f0f0;
  }

  .product-pick-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s;
  }

  .product-pick:hover .product-pick-img img {
    transform: scale(1.03);
  }

  .product-pick-ph {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 600;
    color: var(--admin-text-light);
  }

  .product-pick-info {
    padding: 0.6rem 0.75rem;
  }

  .product-pick-info strong {
    display: block;
    font-size: 0.88rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-pick-info span {
    font-size: 0.78rem;
    color: var(--admin-text-light);
    display: block;
    margin-top: 0.1rem;
  }
</style>

<script>
  const form = document.getElementById('hero-form')!;
  const imageInput = document.getElementById('hero-image-url') as HTMLInputElement;
  const collectionInput = document.getElementById('hero-collection-handle') as HTMLInputElement;

  // ─── Product search ─────────────────────────────────────────
  document.getElementById('product-search')?.addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.trim().toLowerCase();
    document.querySelectorAll<HTMLElement>('.product-pick').forEach(card => {
      const title = card.querySelector<HTMLElement>('.product-pick-info strong')?.textContent?.toLowerCase() ?? '';
      card.style.display = !q || title.includes(q) ? '' : 'none';
    });
  });

  // ─── Collection tab switching ───────────────────────────────
  document.querySelectorAll<HTMLElement>('.collection-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const handle = tab.dataset.collection!;

      document.querySelectorAll<HTMLElement>('.collection-tab').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      document.querySelectorAll<HTMLElement>('.collection-products').forEach(g => {
        g.classList.toggle('collection-products--hidden', g.dataset.collection !== handle);
      });

      collectionInput.value = handle;
    });
  });

  // ─── Product selection ──────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.hero-product-grid').forEach(grid => {
    grid.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest<HTMLElement>('.product-pick');
      if (!card) return;

      // Deselect all products across all grids
      document.querySelectorAll<HTMLElement>('.product-pick').forEach(c => {
        c.classList.remove('selected');
        c.querySelector<HTMLInputElement>('input[type="radio"]')!.checked = false;
        c.querySelector('.product-pick-badge')?.remove();
      });

      // Select clicked
      card.classList.add('selected');
      card.querySelector<HTMLInputElement>('input[type="radio"]')!.checked = true;
      let badge = card.querySelector<HTMLElement>('.product-pick-badge');
      if (!badge) {
        badge = document.createElement('span');
        badge.className = 'product-pick-badge';
        badge.textContent = '✓';
        card.insertBefore(badge, card.firstChild);
      }

      // Update hidden fields
      imageInput.value = card.dataset.imageUrl ?? '';
      collectionInput.value = card.dataset.collection ?? '';
    });
  });

  // ─── Save ───────────────────────────────────────────────────
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    (window as any).setButtonLoading(btn, true);

    const selectedCard = document.querySelector<HTMLElement>('.product-pick.selected');
    const productHandle = selectedCard?.querySelector<HTMLInputElement>('input[type="radio"]')?.value ?? '';
    const imageUrl = imageInput.value;
    const collectionHandle = collectionInput.value;

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'settings:hero', value: { imageUrl, productHandle, collectionHandle } }),
      });
      if (!res.ok) throw new Error('Save failed');
      const data = await res.json();
      if (data.warning) {
        (window as any).showToast(`Saved, but site won't update: ${data.warning}`, true);
      } else {
        (window as any).showToast('Hero settings saved — site will rebuild shortly');
      }
    } catch {
      (window as any).showToast('Failed to save', true);
    } finally {
      (window as any).setButtonLoading(btn, false);
    }
  });

</script>
