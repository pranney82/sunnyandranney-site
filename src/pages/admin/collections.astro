---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';
import { getCollections } from '@/lib/shopify';

export const prerender = false;

// Fetch all collections from Shopify
let shopifyCollections: Array<{ id: string; title: string; handle: string; description: string; image: any; products: any }> = [];
try {
  shopifyCollections = await getCollections(50);
} catch (e) {
  console.error('Failed to fetch Shopify collections:', e);
}

// Get saved collection settings from D1
let savedSettings: Array<{ handle: string; enabled: boolean; order: number }> = [];
const data = await getSetting<typeof savedSettings>('settings:collections');
if (data) savedSettings = data;

// Merge: Shopify collections with saved enabled/order state
const collections = shopifyCollections.map((c, i) => {
  const saved = savedSettings.find((s) => s.handle === c.handle);
  return {
    id: c.id,
    title: c.title,
    handle: c.handle,
    description: c.description,
    productCount: c.products?.edges?.length || 0,
    imageUrl: c.image?.url || '',
    enabled: saved ? saved.enabled : false,
    order: saved ? saved.order : i,
    showInNav: saved ? (saved.showInNav ?? false) : false,
    navLabel: saved ? (saved.navLabel ?? '') : '',
  };
}).sort((a, b) => {
  // Selected (enabled) collections first, then by order
  if (a.enabled !== b.enabled) return a.enabled ? -1 : 1;
  return a.order - b.order;
});
---

<Admin title="Collections">
  <div class="admin-header">
    <div>
      <h2>Collections</h2>
      <p>Choose which Shopify collections appear on your shop page</p>
    </div>
    <div class="admin-unsaved-badge" aria-live="polite">
      <span class="admin-unsaved-dot"></span>
      Unsaved changes
    </div>
  </div>

  {shopifyCollections.length === 0 ? (
    <div class="admin-card">
      <p style="color: var(--admin-text-light);">Could not load collections from Shopify. Check your Storefront API token.</p>
    </div>
  ) : (
    <form id="collections-form">
      <div class="collections-toolbar">
        <span class="collections-count" id="collections-count">
          {collections.filter(c => c.enabled).length} of {collections.length} enabled
        </span>
        <div class="collections-bulk">
          <button type="button" class="admin-btn admin-btn--outline" id="enable-all-btn">Enable All</button>
          <button type="button" class="admin-btn admin-btn--outline" id="disable-all-btn">Disable All</button>
        </div>
      </div>

      <div class="collections-grid" id="collections-list">
        {collections.map((c) => (
          <div class="collection-card" data-handle={c.handle} draggable="true">
            <div class="collection-card-header">
              <div class="collection-drag">&#9776;</div>
              <label class="admin-toggle">
                <input type="checkbox" name={`enabled-${c.handle}`} checked={c.enabled} />
                <span class="admin-toggle-slider"></span>
              </label>
            </div>
            <div class="collection-nav-row">
              <label class="collection-nav-label">
                <input type="checkbox" name={`nav-${c.handle}`} checked={c.showInNav} class="collection-nav-check" />
                <span>Show in nav</span>
              </label>
              <input
                type="text"
                name={`navlabel-${c.handle}`}
                value={c.navLabel}
                placeholder={c.title}
                class="collection-nav-input"
                aria-label={`Nav label for ${c.title}`}
              />
            </div>
            <div class="collection-thumb">
              {c.imageUrl
                ? <img src={`${c.imageUrl}&width=200`} alt={c.title} width="200" height="140" />
                : <div class="collection-thumb-ph">{c.title.charAt(0)}</div>
              }
            </div>
            <div class="collection-info">
              <strong>{c.title}</strong>
              <span>{c.productCount} products</span>
            </div>
          </div>
        ))}
      </div>

      <div class="admin-save-bar">
        <button type="submit" class="admin-btn admin-btn--primary" id="save-btn">
          <span class="btn-spinner"></span>
          <span class="btn-label">Save Collections</span>
        </button>
        <span class="admin-save-hint">
          <kbd class="admin-kbd">⌘S</kbd> to save
        </span>
        <span style="font-size: 0.8rem; color: var(--admin-text-light);">Drag to reorder</span>
      </div>
    </form>
  )}
</Admin>

<style>
  .collections-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .collections-count {
    font-size: 0.82rem;
    color: var(--admin-text-light);
    font-weight: 500;
  }

  .collections-bulk {
    display: flex;
    gap: 0.5rem;
  }

  .collections-bulk .admin-btn {
    font-size: 0.78rem;
    padding: 0.4rem 0.85rem;
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 1200px) {
    .collections-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 900px) {
    .collections-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .collection-card {
    background: var(--admin-card);
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    cursor: grab;
    transition: box-shadow 0.2s, border-color 0.2s;
    overflow: hidden;
  }

  .collection-card:active {
    cursor: grabbing;
  }

  .collection-card.dragging {
    opacity: 0.5;
    border-color: var(--admin-accent);
  }

  .collection-card.drag-over {
    border-color: var(--admin-accent);
    box-shadow: 0 2px 8px rgba(255, 212, 0, 0.2);
  }

  .collection-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
  }

  .collection-drag {
    color: var(--admin-text-light);
    font-size: 1rem;
    flex-shrink: 0;
    cursor: grab;
  }

  .collection-thumb {
    width: 100%;
    height: 120px;
    overflow: hidden;
    background: #f0f0f0;
  }

  .collection-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-thumb-ph {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 600;
    color: var(--admin-text-light);
  }

  .collection-nav-row {
    padding: 0.4rem 0.75rem;
    border-top: 1px solid var(--admin-border);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .collection-nav-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--admin-text-light);
    cursor: pointer;
    user-select: none;
  }

  .collection-nav-check {
    width: 13px;
    height: 13px;
    accent-color: var(--admin-accent);
    cursor: pointer;
    flex-shrink: 0;
  }

  .collection-nav-input {
    width: 100%;
    font-size: 0.75rem;
    padding: 0.25rem 0.4rem;
    border: 1px solid var(--admin-border);
    border-radius: 4px;
    background: var(--admin-bg);
    color: var(--admin-text);
    font-family: inherit;
    display: none;
  }

  .collection-nav-input:focus {
    outline: none;
    border-color: var(--admin-accent);
  }

  .collection-card:has(.collection-nav-check:checked) .collection-nav-input {
    display: block;
  }

  .collection-info {
    padding: 0.6rem 0.75rem;
  }

  .collection-info strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .collection-info span {
    font-size: 0.78rem;
    color: var(--admin-text-light);
    display: block;
  }
</style>

<script>
  const list = document.getElementById('collections-list')!;
  let dragItem: HTMLElement | null = null;

  // ─── Count badge ────────────────────────
  function updateCount() {
    const total = list.querySelectorAll('.collection-card').length;
    const enabled = list.querySelectorAll('input[type="checkbox"]:checked').length;
    const el = document.getElementById('collections-count');
    if (el) el.textContent = `${enabled} of ${total} enabled`;
  }

  list.addEventListener('change', updateCount);

  // ─── Bulk actions ────────────────────────
  document.getElementById('enable-all-btn')?.addEventListener('click', () => {
    list.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach(cb => cb.checked = true);
    updateCount();
  });

  document.getElementById('disable-all-btn')?.addEventListener('click', () => {
    list.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach(cb => cb.checked = false);
    updateCount();
  });

  // Drag & drop reordering
  list.addEventListener('dragstart', (e) => {
    dragItem = (e.target as HTMLElement).closest('.collection-card');
    dragItem?.classList.add('dragging');
  });

  list.addEventListener('dragend', () => {
    dragItem?.classList.remove('dragging');
    list.querySelectorAll('.collection-card').forEach((el) => el.classList.remove('drag-over'));
    dragItem = null;
  });

  list.addEventListener('dragover', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('.collection-card');
    if (target && target !== dragItem) {
      list.querySelectorAll('.collection-card').forEach((el) => el.classList.remove('drag-over'));
      target.classList.add('drag-over');
    }
  });

  list.addEventListener('drop', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('.collection-card');
    if (target && target !== dragItem && dragItem) {
      const items = [...list.querySelectorAll('.collection-card')];
      const dragIdx = items.indexOf(dragItem);
      const targetIdx = items.indexOf(target);
      if (dragIdx < targetIdx) {
        target.after(dragItem);
      } else {
        target.before(dragItem);
      }
    }
    list.querySelectorAll('.collection-card').forEach((el) => el.classList.remove('drag-over'));
  });

  // Save
  document.getElementById('collections-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    (window as any).setButtonLoading(btn, true);

    const items = [...list.querySelectorAll('.collection-card')];
    const value = items.map((el, i) => {
      const handle = (el as HTMLElement).dataset.handle!;
      const navLabel = ((el as HTMLElement).querySelector('.collection-nav-input') as HTMLInputElement)?.value.trim() || '';
      return {
        handle,
        enabled: ((el as HTMLElement).querySelector(`input[name="enabled-${handle}"]`) as HTMLInputElement).checked,
        order: i,
        showInNav: ((el as HTMLElement).querySelector('.collection-nav-check') as HTMLInputElement).checked,
        navLabel: navLabel || undefined,
      };
    });

    // Snapshot for undo
    const prevChecked = items.map(el => {
      const handle = (el as HTMLElement).dataset.handle!;
      return (el.querySelector(`input[name="enabled-${handle}"]`) as HTMLInputElement).checked;
    });
    const prevOrder = [...items];

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'settings:collections', value }),
      });
      if (!res.ok) throw new Error('Save failed');
      const data = await res.json();
      if (data.warning) {
        (window as any).showToast(`Saved, but site won't update: ${data.warning}`, true);
      } else {
        (window as any).showToast('Collections saved — site will rebuild shortly', false, () => {
          // Undo: restore previous order and checked states
          list.innerHTML = '';
          prevOrder.forEach((el, i) => {
            const handle = (el as HTMLElement).dataset.handle!;
            (el.querySelector(`input[name="enabled-${handle}"]`) as HTMLInputElement).checked = prevChecked[i];
            list.appendChild(el);
          });
          updateCount();
        });
      }
    } catch {
      (window as any).showToast('Failed to save', true);
    } finally {
      (window as any).setButtonLoading(btn, false);
    }
  });
</script>
