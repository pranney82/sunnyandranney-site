---
export const prerender = false;

import AdminBase from '@/layouts/AdminBase.astro';
import { listPurchaseOrders } from '@/lib/po-db';

const statusFilter = Astro.url.searchParams.get('status') as any || undefined;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10));
const { orders, total } = await listPurchaseOrders(statusFilter, page);
const totalPages = Math.ceil(total / 25);
---

<AdminBase title="Purchase Orders">
  <div class="page-header">
    <h1>Purchase Orders</h1>
    <a href="/admin/po/new/" class="btn btn-primary">Upload PO</a>
  </div>

  <div class="filters">
    <a href="/admin/" class:list={[{ active: !statusFilter }]}>All</a>
    <a href="/admin/?status=reviewing" class:list={[{ active: statusFilter === 'reviewing' }]}>Reviewing</a>
    <a href="/admin/?status=approved" class:list={[{ active: statusFilter === 'approved' }]}>Approved</a>
    <a href="/admin/?status=completed" class:list={[{ active: statusFilter === 'completed' }]}>Completed</a>
    <a href="/admin/?status=failed" class:list={[{ active: statusFilter === 'failed' }]}>Failed</a>
  </div>

  {orders.length === 0 ? (
    <div class="empty-state">
      <p>No purchase orders{statusFilter ? ` with status "${statusFilter}"` : ''} yet.</p>
      <a href="/admin/po/new/" class="btn" style="margin-top: 1rem;">Upload your first PO</a>
    </div>
  ) : (
    <div class="card">
      <table class="po-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Supplier</th>
            <th>PO #</th>
            <th>File</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {orders.map(po => (
            <tr>
              <td class="cell-date">{new Date(po.created_at).toLocaleDateString()}</td>
              <td>{po.supplier_name || '—'}</td>
              <td>{po.po_number || '—'}</td>
              <td class="cell-file">{po.pdf_filename || '—'}</td>
              <td>
                <span class={`badge badge-${po.status}`}>{po.status}</span>
              </td>
              <td>
                <a href={`/admin/po/${po.id}/`} class="btn">Review</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {totalPages > 1 && (
    <div class="pagination">
      {page > 1 && (
        <a href={`/admin/?page=${page - 1}${statusFilter ? `&status=${statusFilter}` : ''}`} class="btn">Previous</a>
      )}
      <span class="page-info">Page {page} of {totalPages}</span>
      {page < totalPages && (
        <a href={`/admin/?page=${page + 1}${statusFilter ? `&status=${statusFilter}` : ''}`} class="btn">Next</a>
      )}
    </div>
  )}
</AdminBase>

<style>
  .filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .filters a {
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    transition: all 0.15s;
  }

  .filters a:hover { border-color: var(--accent); color: var(--accent); }
  .filters a.active { background: var(--accent); color: #fff; border-color: var(--accent); }

  .po-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .po-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--border);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .po-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .po-table tr:last-child td { border-bottom: none; }
  .po-table tr:hover { background: rgba(139, 111, 71, 0.03); }

  .cell-date { white-space: nowrap; color: var(--text-muted); }
  .cell-file {
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 0.8125rem;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .page-info { font-size: 0.875rem; color: var(--text-muted); }

  @media (max-width: 640px) {
    .po-table th:nth-child(4),
    .po-table td:nth-child(4) { display: none; }
  }
</style>
