---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';
import { env } from 'cloudflare:workers';
import type { TrendingSetting, HeroSetting, CollectionSetting, StoreSpecials, EmailSignupConfig, KidsSetting } from '@/lib/settings';

export const prerender = false;

const settingKeys = [
  'settings:hours',
  'settings:collections',
  'settings:specials',
  'settings:contact',
  'settings:email-signup',
  'settings:trending',
  'settings:hero',
  'settings:kids',
] as const;

const [hours, collections, specials, contact, emailSignup, trending, hero, kids] = await Promise.all([
  getSetting('settings:hours'),
  getSetting<CollectionSetting[]>('settings:collections'),
  getSetting<StoreSpecials>('settings:specials'),
  getSetting('settings:contact'),
  getSetting<EmailSignupConfig>('settings:email-signup'),
  getSetting<TrendingSetting>('settings:trending'),
  getSetting<HeroSetting>('settings:hero'),
  getSetting<KidsSetting>('settings:kids'),
]);

// Fetch updated_at timestamps
const timestampRows = await env.DB
  .prepare('SELECT key, updated_at FROM settings WHERE key IN (?, ?, ?, ?, ?, ?, ?, ?)')
  .bind(...settingKeys)
  .all<{ key: string; updated_at: string }>();

const timestamps: Record<string, string | null> = {};
for (const row of timestampRows.results) {
  timestamps[row.key] = row.updated_at;
}

// Relative time formatting
function timeAgo(dateStr: string | null | undefined): string {
  if (!dateStr) return 'Never';
  const now = new Date();
  const then = new Date(dateStr + 'Z');
  const diffMs = now.getTime() - then.getTime();
  const diffSec = Math.floor(diffMs / 1000);
  const diffMin = Math.floor(diffSec / 60);
  const diffHr = Math.floor(diffMin / 60);
  const diffDay = Math.floor(diffHr / 24);
  const diffWeek = Math.floor(diffDay / 7);

  if (diffSec < 60) return 'Just now';
  if (diffMin < 60) return `${diffMin} minute${diffMin !== 1 ? 's' : ''} ago`;
  if (diffHr < 24) return `${diffHr} hour${diffHr !== 1 ? 's' : ''} ago`;
  if (diffDay < 7) return `${diffDay} day${diffDay !== 1 ? 's' : ''} ago`;
  if (diffWeek < 5) return `${diffWeek} week${diffWeek !== 1 ? 's' : ''} ago`;
  return then.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Stat card data
const activeCollections = collections ? collections.filter(c => c.enabled).length : 0;
const totalCollections = collections ? collections.length : 0;
const activeSpecials = specials?.announcements?.filter(a => a.active).length ?? 0;
const totalSpecials = specials?.announcements?.length ?? 0;

const stats = [
  {
    label: 'Store Hours',
    desc: 'Opening times, holidays & special hours',
    value: hours ? 'Configured' : 'Not Set',
    status: hours ? 'admin-status--success' : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:hours']),
    href: '/admin/hours',
  },
  {
    label: 'Collections',
    desc: 'Which product collections appear on the shop',
    value: collections ? `${activeCollections} of ${totalCollections} shown` : 'All shown',
    status: collections
      ? (activeCollections === totalCollections ? 'admin-status--success' : 'admin-status--warning')
      : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:collections']),
    href: '/admin/collections',
  },
  {
    label: 'Specials',
    desc: 'Promos, banners & featured items',
    value: activeSpecials > 0 ? `${activeSpecials} active` : 'None',
    status: activeSpecials > 0
      ? 'admin-status--success'
      : (totalSpecials > 0 ? 'admin-status--warning' : 'admin-status--neutral'),
    updated: timeAgo(timestamps['settings:specials']),
    href: '/admin/specials',
  },
  {
    label: 'Trending Now',
    desc: 'Products featured in the Trending Now section',
    value: trending && trending.handles.length > 0 ? `${trending.handles.length} products` : 'Auto',
    status: trending && trending.handles.length > 0 ? 'admin-status--success' : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:trending']),
    href: '/admin/trending',
  },
  {
    label: 'Hero Section',
    desc: 'Hero image & featured product on the home page',
    value: hero?.productHandle ? 'Configured' : 'Default',
    status: hero?.productHandle ? 'admin-status--success' : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:hero']),
    href: '/admin/hero',
  },
  {
    label: 'Kids Section',
    desc: '"Their Stories" cards on the About page',
    value: kids?.kids?.length ? `${kids.kids.length} stories` : 'Default',
    status: kids?.kids?.length ? 'admin-status--success' : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:kids']),
    href: '/admin/kids',
  },
  {
    label: 'Contact Info',
    desc: 'Address, phone, email & social links',
    value: contact ? 'Configured' : 'Not Set',
    status: contact ? 'admin-status--success' : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:contact']),
    href: '/admin/contact',
  },
  {
    label: 'Email Signup',
    desc: 'Constant Contact list integration',
    value: emailSignup?.constantContactListId ? 'Connected' : 'Not Set',
    status: emailSignup?.constantContactListId ? 'admin-status--success' : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:email-signup']),
    href: '/admin/email-signup',
  },
];

const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

---

<Admin title="Dashboard">
  <div class="admin-header">
    <div>
      <h2>Dashboard</h2>
      <p>{today}</p>
    </div>
  </div>

  <div class="admin-nav-cards">
    {stats.map((stat) => (
      <a href={stat.href} class="admin-nav-card">
        <div class="admin-nav-card-header">
          <span class="admin-nav-card-label">{stat.label}</span>
          <span class={`admin-status ${stat.status}`}>{stat.value}</span>
        </div>
        <div class="admin-nav-card-desc">{stat.desc}</div>
        <div class="admin-nav-card-footer">Updated {stat.updated}</div>
      </a>
    ))}
  </div>
</Admin>

<style>
  /* ─── Nav cards grid ──────────────────── */
  .admin-nav-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }

  .admin-nav-card {
    display: flex;
    flex-direction: column;
    padding: 1.1rem 1.25rem;
    background: var(--admin-card);
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    text-decoration: none;
    color: var(--admin-text);
    transition: all 0.15s ease;
    box-shadow: var(--admin-shadow-sm);
    gap: 0.35rem;
  }

  .admin-nav-card:hover {
    border-color: var(--admin-accent);
    box-shadow: 0 2px 12px rgba(255, 212, 0, 0.12);
    transform: translateY(-1px);
  }

  .admin-nav-card:active {
    transform: translateY(0);
  }

  .admin-nav-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .admin-nav-card-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--admin-text);
  }

  .admin-nav-card-desc {
    font-size: 0.8rem;
    color: var(--admin-text-light);
    line-height: 1.4;
  }

  .admin-nav-card-footer {
    font-size: 0.7rem;
    color: var(--admin-text-light);
    opacity: 0.6;
    margin-top: 0.25rem;
  }

  @media (max-width: 600px) {
    .admin-nav-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
