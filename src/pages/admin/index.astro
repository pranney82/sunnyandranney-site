---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';
import { env } from 'cloudflare:workers';

export const prerender = false;

const settingKeys = [
  'settings:hours',
  'settings:collections',
  'settings:specials',
  'settings:contact',
  'settings:email-signup',
] as const;

const [hours, collections, specials, contact, emailSignup] = await Promise.all([
  getSetting('settings:hours'),
  getSetting<Array<{ handle: string; enabled: boolean; order: number }>>('settings:collections'),
  getSetting<{ announcements?: Array<{ active: boolean }> }>('settings:specials'),
  getSetting('settings:contact'),
  getSetting<{ constantContactListId?: string }>('settings:email-signup'),
]);

// Fetch updated_at timestamps
const timestampRows = await env.DB
  .prepare('SELECT key, updated_at FROM settings WHERE key IN (?, ?, ?, ?, ?)')
  .bind(...settingKeys)
  .all<{ key: string; updated_at: string }>();

const timestamps: Record<string, string | null> = {};
for (const row of timestampRows.results) {
  timestamps[row.key] = row.updated_at;
}

// Relative time formatting
function timeAgo(dateStr: string | null | undefined): string {
  if (!dateStr) return 'Never';
  const now = new Date();
  const then = new Date(dateStr + 'Z');
  const diffMs = now.getTime() - then.getTime();
  const diffSec = Math.floor(diffMs / 1000);
  const diffMin = Math.floor(diffSec / 60);
  const diffHr = Math.floor(diffMin / 60);
  const diffDay = Math.floor(diffHr / 24);
  const diffWeek = Math.floor(diffDay / 7);

  if (diffSec < 60) return 'Just now';
  if (diffMin < 60) return `${diffMin} minute${diffMin !== 1 ? 's' : ''} ago`;
  if (diffHr < 24) return `${diffHr} hour${diffHr !== 1 ? 's' : ''} ago`;
  if (diffDay < 7) return `${diffDay} day${diffDay !== 1 ? 's' : ''} ago`;
  if (diffWeek < 5) return `${diffWeek} week${diffWeek !== 1 ? 's' : ''} ago`;
  return then.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Stat card data
const activeCollections = collections ? (collections as any).filter((c: any) => c.enabled).length : 0;
const totalCollections = collections ? (collections as any).length : 0;
const activeSpecials = specials && (specials as any).announcements?.length
  ? (specials as any).announcements.filter((a: any) => a.active).length
  : 0;
const totalSpecials = specials && (specials as any).announcements?.length
  ? (specials as any).announcements.length
  : 0;

const stats = [
  {
    label: 'Store Hours',
    value: hours ? 'Configured' : 'Not Set',
    status: hours ? 'admin-status--success' : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:hours']),
  },
  {
    label: 'Collections',
    value: collections ? `${activeCollections} of ${totalCollections}` : 'All shown',
    status: collections
      ? (activeCollections === totalCollections ? 'admin-status--success' : 'admin-status--warning')
      : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:collections']),
  },
  {
    label: 'Specials',
    value: activeSpecials > 0 ? `${activeSpecials} active` : 'None',
    status: activeSpecials > 0
      ? 'admin-status--success'
      : (totalSpecials > 0 ? 'admin-status--warning' : 'admin-status--neutral'),
    updated: timeAgo(timestamps['settings:specials']),
  },
  {
    label: 'Contact Info',
    value: contact ? 'Configured' : 'Not Set',
    status: contact ? 'admin-status--success' : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:contact']),
  },
  {
    label: 'Email Signup',
    value: emailSignup && (emailSignup as any).constantContactListId ? 'Connected' : 'Not Set',
    status: emailSignup && (emailSignup as any).constantContactListId
      ? 'admin-status--success'
      : 'admin-status--neutral',
    updated: timeAgo(timestamps['settings:email-signup']),
  },
];

const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const storeLinks = [
  {
    href: '/admin/hours',
    title: 'Store Hours',
    description: 'Set opening and closing times, holidays, and special hours',
    icon: 'clock',
  },
  {
    href: '/admin/collections',
    title: 'Collections',
    description: 'Choose which product collections appear on the shop',
    icon: 'shopping-bag',
  },
  {
    href: '/admin/specials',
    title: 'Specials & Announcements',
    description: 'Manage promos, banners, and featured items',
    icon: 'star',
  },
];

const settingsLinks = [
  {
    href: '/admin/contact',
    title: 'Contact Info',
    description: 'Update address, phone, email, and social links',
    icon: 'map-pin',
  },
  {
    href: '/admin/email-signup',
    title: 'Email Signup',
    description: 'Constant Contact integration and list settings',
    icon: 'mail',
  },
];
---

<Admin title="Dashboard">
  <div class="admin-header">
    <div>
      <h2>Dashboard</h2>
      <p>{today}</p>
    </div>
  </div>

  <div class="admin-stat-grid">
    {stats.map((stat) => (
      <div class="admin-stat">
        <div class="admin-stat-label">{stat.label}</div>
        <div class="admin-stat-value">
          <span class={`admin-status ${stat.status}`}>{stat.value}</span>
        </div>
        <div class="admin-stat-updated">Last updated {stat.updated}</div>
      </div>
    ))}
  </div>

  <div class="dashboard-section">
    <h3 class="dashboard-section-title">Store</h3>
    <div class="dashboard-links">
      {storeLinks.map((link) => (
        <a href={link.href} class="dashboard-link">
          <div class="dashboard-link-icon">
            {link.icon === 'clock' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            )}
            {link.icon === 'shopping-bag' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
              </svg>
            )}
            {link.icon === 'star' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            )}
          </div>
          <div class="dashboard-link-text">
            <strong>{link.title}</strong>
            <span>{link.description}</span>
          </div>
          <svg class="dashboard-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </a>
      ))}
    </div>
  </div>

  <div class="dashboard-section">
    <h3 class="dashboard-section-title">Settings</h3>
    <div class="dashboard-links">
      {settingsLinks.map((link) => (
        <a href={link.href} class="dashboard-link">
          <div class="dashboard-link-icon">
            {link.icon === 'map-pin' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            )}
            {link.icon === 'mail' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            )}
          </div>
          <div class="dashboard-link-text">
            <strong>{link.title}</strong>
            <span>{link.description}</span>
          </div>
          <svg class="dashboard-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</Admin>

<style>
  /* ─── Stat updated timestamp ──────────── */
  .admin-stat-updated {
    font-size: 0.7rem;
    color: var(--admin-text-light);
    margin-top: 0.5rem;
    opacity: 0.7;
  }

  /* ─── Dashboard sections ──────────────── */
  .dashboard-section {
    margin-bottom: 1.75rem;
  }

  .dashboard-section-title {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--admin-text-light);
    margin-bottom: 0.6rem;
    padding-left: 0.1rem;
  }

  /* ─── Dashboard links ─────────────────── */
  .dashboard-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dashboard-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--admin-card);
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    text-decoration: none;
    color: var(--admin-text);
    transition: all 0.15s ease;
    box-shadow: var(--admin-shadow-sm);
  }

  .dashboard-link:hover {
    border-color: var(--admin-accent);
    box-shadow: 0 2px 12px rgba(255, 212, 0, 0.12);
    transform: translateY(-1px);
  }

  .dashboard-link:active {
    transform: translateY(0);
  }

  .dashboard-link-icon {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    border-radius: 10px;
    flex-shrink: 0;
    transition: background 0.15s;
  }

  .dashboard-link:hover .dashboard-link-icon {
    background: #fff8e1;
  }

  .dashboard-link-icon svg {
    width: 20px;
    height: 20px;
    color: var(--admin-text);
    opacity: 0.65;
  }

  .dashboard-link:hover .dashboard-link-icon svg {
    opacity: 0.85;
  }

  .dashboard-link-text {
    flex: 1;
    min-width: 0;
  }

  .dashboard-link-text strong {
    display: block;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .dashboard-link-text span {
    display: block;
    font-size: 0.8rem;
    color: var(--admin-text-light);
    margin-top: 0.15rem;
    line-height: 1.4;
  }

  .dashboard-link-arrow {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--admin-text-light);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.15s ease;
  }

  .dashboard-link:hover .dashboard-link-arrow {
    opacity: 0.6;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .dashboard-link {
      padding: 0.9rem 1rem;
      gap: 0.75rem;
    }

    .dashboard-link-icon {
      width: 38px;
      height: 38px;
    }

    .dashboard-link-icon svg {
      width: 18px;
      height: 18px;
    }

    .dashboard-link-arrow {
      display: none;
    }
  }
</style>
