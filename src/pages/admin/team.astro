---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';
import type { TeamSetting } from '@/lib/settings';

export const prerender = false;

const saved = await getSetting<TeamSetting>('settings:team');

const DEFAULT_MEMBERS = [
  { name: 'Staci', role: 'Store Manager', desc: 'Keeps the showroom running like clockwork and ensures every visitor feels at home from the moment they walk in.', imageUrl: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team-staci', initials: '' },
  { name: 'BJ', role: 'Team Member', desc: 'A valued member of the Sunny & Ranney family, helping create beautiful spaces and brighter futures every day.', imageUrl: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/team-bj', initials: '' },
  { name: 'Staci', role: 'AI Shopping Assistant', desc: 'Our tireless digital team member — always ready to help you find the perfect piece, 24/7.', imageUrl: '', initials: 'ST' },
];

const members = saved?.members?.length ? saved.members : DEFAULT_MEMBERS;
---

<Admin title="Team Photos">
  <div class="admin-header">
    <div>
      <h2>Team Photos</h2>
      <p>Edit the crew section on the About page — add, remove, or update team members</p>
    </div>
    <div class="admin-unsaved-badge" aria-live="polite">
      <span class="admin-unsaved-dot"></span>
      Unsaved changes
    </div>
  </div>

  <form id="team-form">

    <div id="members-container">
      {members.map((member, i) => (
        <div class="admin-card member-card" data-index={String(i)}>
          <div class="member-card__header">
            <h3 class="section-title">Team Member {i + 1}</h3>
            <button type="button" class="remove-member-btn" title="Remove this member" aria-label={`Remove ${member.name || 'team member'}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>

          <div class="member-fields">
            <div class="member-preview-col">
              <div class="member-img-preview" id={`member-preview-${i}`}>
                {member.imageUrl ? (
                  <img
                    src={`${member.imageUrl.trim().replace(/\/$/, '')}/w=200,h=250,fit=cover,gravity=face,q=75,format=auto`}
                    alt={member.name || 'Preview'}
                    width="160" height="200"
                  />
                ) : member.initials ? (
                  <div class="member-initials-preview"><span>{member.initials}</span></div>
                ) : (
                  <div class="member-img-placeholder">No image</div>
                )}
              </div>
            </div>

            <div class="member-text-col">
              <div class="field-group">
                <label class="field-label" for={`member-name-${i}`}>Name</label>
                <input id={`member-name-${i}`} name={`members[${i}][name]`} type="text" class="admin-input" value={member.name} placeholder="e.g. Staci" />
              </div>

              <div class="field-group">
                <label class="field-label" for={`member-role-${i}`}>Role</label>
                <input id={`member-role-${i}`} name={`members[${i}][role]`} type="text" class="admin-input" value={member.role} placeholder="e.g. Store Manager" />
              </div>

              <div class="field-group">
                <label class="field-label" for={`member-desc-${i}`}>Description</label>
                <textarea id={`member-desc-${i}`} name={`members[${i}][desc]`} class="admin-input admin-textarea" rows="3" placeholder="Short bio…">{member.desc}</textarea>
              </div>

              <div class="field-group">
                <label class="field-label" for={`member-image-${i}`}>Photo (Cloudflare Images base URL)</label>
                <p class="field-hint">Leave empty and set initials below for text-only avatar</p>
                <input
                  id={`member-image-${i}`}
                  name={`members[${i}][imageUrl]`}
                  type="url"
                  class="admin-input member-image-input"
                  data-index={String(i)}
                  value={member.imageUrl}
                  placeholder="https://imagedelivery.net/…/team-name"
                />
              </div>

              <div class="field-group">
                <label class="field-label" for={`member-initials-${i}`}>Initials (fallback when no photo)</label>
                <input id={`member-initials-${i}`} name={`members[${i}][initials]`} type="text" class="admin-input" value={member.initials} placeholder="e.g. ST" maxlength="3" style="max-width: 100px;" />
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <button type="button" id="add-member-btn" class="add-member-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Team Member
    </button>

    <div class="admin-save-bar">
      <button type="submit" class="admin-btn admin-btn--primary" id="save-btn">
        <span class="btn-spinner"></span>
        <span class="btn-label">Save Team</span>
      </button>
      <span class="admin-save-hint">
        <kbd class="admin-kbd">⌘S</kbd> to save
      </span>
    </div>

  </form>
</Admin>

<style>
  .section-title {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--admin-text-light);
    margin: 0;
  }

  .member-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .remove-member-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 6px;
    background: none;
    color: var(--admin-text-light);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .remove-member-btn:hover {
    background: rgba(220, 53, 69, 0.1);
    color: #dc3545;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }
  .field-group:last-child { margin-bottom: 0; }

  .field-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--admin-text);
  }

  .field-hint {
    font-size: 0.78rem;
    color: var(--admin-text-light);
    margin: 0;
    line-height: 1.5;
  }

  .member-card { padding-bottom: 1.5rem; }

  .member-fields {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 680px) {
    .member-fields { grid-template-columns: 1fr; }
  }

  .member-img-preview {
    border-radius: var(--admin-radius);
    overflow: hidden;
    border: 1px solid var(--admin-border);
    background: #f0f0f0;
    aspect-ratio: 4 / 5;
    width: 100%;
  }

  .member-img-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .member-img-placeholder,
  .member-initials-preview {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .member-img-placeholder {
    font-size: 0.78rem;
    color: var(--admin-text-light);
  }

  .member-initials-preview {
    background: var(--admin-accent, #4aa8c4);
  }
  .member-initials-preview span {
    font-size: 2rem;
    font-weight: 600;
    color: white;
    opacity: 0.6;
  }

  .add-member-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.85rem 1rem;
    background: none;
    border: 2px dashed var(--admin-border);
    border-radius: var(--admin-radius);
    color: var(--admin-text-light);
    font-size: 0.88rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    margin-bottom: 1.5rem;
    justify-content: center;
  }
  .add-member-btn:hover {
    border-color: var(--admin-accent);
    color: var(--admin-accent);
  }
</style>

<script>
  const form = document.getElementById('team-form') as HTMLFormElement;
  const container = document.getElementById('members-container')!;
  let memberCount = container.querySelectorAll('.member-card').length;

  // ─── Live image preview on URL input ───
  function attachImagePreview(input: HTMLInputElement) {
    let timer: ReturnType<typeof setTimeout>;
    input.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => {
        const idx = input.dataset.index!;
        const previewEl = document.getElementById(`member-preview-${idx}`)!;
        const base = input.value.trim().replace(/\/$/, '');
        if (!base) {
          // Check if there are initials
          const initialsInput = document.getElementById(`member-initials-${idx}`) as HTMLInputElement;
          if (initialsInput?.value.trim()) {
            previewEl.innerHTML = `<div class="member-initials-preview"><span>${initialsInput.value.trim()}</span></div>`;
          } else {
            previewEl.innerHTML = '<div class="member-img-placeholder">No image</div>';
          }
          return;
        }
        let img = previewEl.querySelector<HTMLImageElement>('img');
        if (!img) {
          previewEl.innerHTML = '';
          img = document.createElement('img');
          img.width = 160;
          img.height = 200;
          previewEl.appendChild(img);
        }
        img.src = `${base}/w=200,h=250,fit=cover,gravity=face,q=75,format=auto`;
        img.alt = 'Preview';
      }, 600);
    });
  }

  document.querySelectorAll<HTMLInputElement>('.member-image-input').forEach(attachImagePreview);

  // ─── Remove member ───
  function attachRemoveBtn(btn: HTMLElement) {
    btn.addEventListener('click', () => {
      btn.closest('.member-card')?.remove();
      renumberMembers();
      document.querySelector('.admin-unsaved-badge')?.classList.add('visible');
    });
  }

  document.querySelectorAll<HTMLElement>('.remove-member-btn').forEach(attachRemoveBtn);

  // ─── Add member ───
  document.getElementById('add-member-btn')?.addEventListener('click', () => {
    const i = memberCount++;
    const card = document.createElement('div');
    card.className = 'admin-card member-card';
    card.dataset.index = String(i);
    card.innerHTML = `
      <div class="member-card__header">
        <h3 class="section-title">Team Member ${i + 1}</h3>
        <button type="button" class="remove-member-btn" title="Remove this member" aria-label="Remove team member">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="member-fields">
        <div class="member-preview-col">
          <div class="member-img-preview" id="member-preview-${i}">
            <div class="member-img-placeholder">No image</div>
          </div>
        </div>
        <div class="member-text-col">
          <div class="field-group">
            <label class="field-label" for="member-name-${i}">Name</label>
            <input id="member-name-${i}" name="members[${i}][name]" type="text" class="admin-input" placeholder="e.g. Staci" />
          </div>
          <div class="field-group">
            <label class="field-label" for="member-role-${i}">Role</label>
            <input id="member-role-${i}" name="members[${i}][role]" type="text" class="admin-input" placeholder="e.g. Store Manager" />
          </div>
          <div class="field-group">
            <label class="field-label" for="member-desc-${i}">Description</label>
            <textarea id="member-desc-${i}" name="members[${i}][desc]" class="admin-input admin-textarea" rows="3" placeholder="Short bio…"></textarea>
          </div>
          <div class="field-group">
            <label class="field-label" for="member-image-${i}">Photo (Cloudflare Images base URL)</label>
            <p class="field-hint">Leave empty and set initials below for text-only avatar</p>
            <input id="member-image-${i}" name="members[${i}][imageUrl]" type="url" class="admin-input member-image-input" data-index="${i}" placeholder="https://imagedelivery.net/…/team-name" />
          </div>
          <div class="field-group">
            <label class="field-label" for="member-initials-${i}">Initials (fallback when no photo)</label>
            <input id="member-initials-${i}" name="members[${i}][initials]" type="text" class="admin-input" placeholder="e.g. ST" maxlength="3" style="max-width: 100px;" />
          </div>
        </div>
      </div>
    `;
    container.appendChild(card);

    // Wire up the new card
    const removeBtn = card.querySelector<HTMLElement>('.remove-member-btn')!;
    attachRemoveBtn(removeBtn);
    const imageInput = card.querySelector<HTMLInputElement>('.member-image-input')!;
    attachImagePreview(imageInput);

    document.querySelector('.admin-unsaved-badge')?.classList.add('visible');
    card.querySelector<HTMLInputElement>(`#member-name-${i}`)?.focus();
  });

  function renumberMembers() {
    container.querySelectorAll<HTMLElement>('.member-card').forEach((card, idx) => {
      card.dataset.index = String(idx);
      const title = card.querySelector('.section-title');
      if (title) title.textContent = `Team Member ${idx + 1}`;
    });
  }

  // ─── Unsaved badge ───
  form.addEventListener('input', () => {
    document.querySelector('.admin-unsaved-badge')?.classList.add('visible');
  });

  // ─── Save ───
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    (window as any).setButtonLoading(btn, true);

    const cards = container.querySelectorAll<HTMLElement>('.member-card');
    const membersData: Array<{ name: string; role: string; desc: string; imageUrl: string; initials: string }> = [];

    cards.forEach((card) => {
      const idx = card.dataset.index!;
      const name = (document.getElementById(`member-name-${idx}`) as HTMLInputElement)?.value.trim() ?? '';
      const role = (document.getElementById(`member-role-${idx}`) as HTMLInputElement)?.value.trim() ?? '';
      const desc = (document.getElementById(`member-desc-${idx}`) as HTMLTextAreaElement)?.value.trim() ?? '';
      const imageUrl = (document.getElementById(`member-image-${idx}`) as HTMLInputElement)?.value.trim().replace(/\/$/, '') ?? '';
      const initials = (document.getElementById(`member-initials-${idx}`) as HTMLInputElement)?.value.trim() ?? '';
      if (name) membersData.push({ name, role, desc, imageUrl, initials });
    });

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'settings:team', value: { members: membersData } }),
      });
      if (!res.ok) throw new Error('Save failed');
      const data = await res.json();
      document.querySelector('.admin-unsaved-badge')?.classList.remove('visible');
      if (data.warning) {
        (window as any).showToast(`Saved, but site won't update: ${data.warning}`, true);
      } else {
        (window as any).showToast('Team saved — site will rebuild shortly');
      }
    } catch {
      (window as any).showToast('Failed to save', true);
    } finally {
      (window as any).setButtonLoading(btn, false);
    }
  });

</script>
