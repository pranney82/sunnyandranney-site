---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';
import type { KidsSetting } from '@/lib/settings';

export const prerender = false;

const saved = await getSetting<KidsSetting>('settings:kids');

const DEFAULT_HEADING = 'The Kids Who Inspire Us';
const DEFAULT_SUBHEADING = 'Every room starts with a dream. These are the children who remind us why we do what we do.';
const DEFAULT_KIDS = [
  { name: 'Mathew', tag: 'Where It All Began', blurb: 'Our very first makeover — 11-year-old Mathew wanted a military-themed bunker bedroom, and bringing it to life changed everything for us and for him.', imageUrl: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/mathew/hero' },
  { name: 'Adrian', tag: 'Room #247', blurb: 'Adrian dreamed of a space-themed bedroom where he could imagine exploring the stars. His new room gave him a launchpad for his biggest adventures.', imageUrl: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/adrian/hero' },
  { name: 'Tripp', tag: '1.6 Million Watched', blurb: "Tripp's whole-home makeover drew 1.6 million viewers on WSB-TV and showed the world what a little sunshine can do.", imageUrl: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/kids/tripp/hero' },
];

const heading = saved?.heading ?? DEFAULT_HEADING;
const subheading = saved?.subheading ?? DEFAULT_SUBHEADING;
const kids = saved?.kids?.length ? saved.kids : DEFAULT_KIDS;
// Pad to 3 slots
while (kids.length < 3) kids.push({ name: '', tag: '', blurb: '', imageUrl: '' });

// Load SOARD kids for the picker
type SoardKid = { name: string; slug: string; year: number | null; diagnosis: string | null; roomTypes: string[]; imageUrl: string; blurb: string };
let soardKids: SoardKid[] = [];
try {
  const res = await fetch('https://soard-site.pages.dev/api/kids.json');
  if (res.ok) soardKids = await res.json();
} catch { /* silently skip if SOARD is unreachable */ }
---

<Admin title="Kids Section">
  <div class="admin-header">
    <div>
      <h2>Kids Section</h2>
      <p>Edit the "The Kids Who Inspire Us" section on the About page</p>
    </div>
    <div class="admin-unsaved-badge" aria-live="polite">
      <span class="admin-unsaved-dot"></span>
      Unsaved changes
    </div>
  </div>

  <form id="kids-form">

    <!-- ─── Section Header ─── -->
    <div class="admin-card">
      <h3 class="section-title">Section Header</h3>

      <div class="field-group">
        <label class="field-label" for="kids-heading">Heading</label>
        <p class="field-hint">Use "Inspire" to apply the italic gold style — e.g. "The Kids Who Inspire Us"</p>
        <input id="kids-heading" name="heading" type="text" class="admin-input" value={heading} />
      </div>

      <div class="field-group">
        <label class="field-label" for="kids-subheading">Subheading</label>
        <textarea id="kids-subheading" name="subheading" class="admin-input admin-textarea" rows="2">{subheading}</textarea>
      </div>
    </div>

    <!-- ─── Kid Cards ─── -->
    {kids.slice(0, 3).map((kid, i) => (
      <div class="admin-card kid-card">
        <h3 class="section-title">Story {i + 1}</h3>

        {soardKids.length > 0 && (
          <div class="field-group soard-picker-group">
            <label class="field-label" for={`soard-pick-${i}`}>Pick from SOARD</label>
            <p class="field-hint">Selecting a kid auto-fills their name, image, and blurb — you can still edit below.</p>
            <select id={`soard-pick-${i}`} class="admin-input soard-picker" data-slot={i}>
              <option value="">— Choose a kid —</option>
              {soardKids.map(sk => (
                <option
                  value={sk.slug}
                  data-name={sk.name}
                  data-image={sk.imageUrl}
                  data-blurb={sk.blurb}
                  selected={sk.name === kid.name}
                >
                  {sk.name}{sk.year ? ` (${sk.year})` : ''}{sk.diagnosis ? ` — ${sk.diagnosis}` : ''}
                </option>
              ))}
            </select>
          </div>
        )}

        <div class="kid-fields">
          <div class="kid-preview-col">
            <div class="kid-img-preview" id={`kid-preview-${i}`}>
              {kid.imageUrl ? (
                <img
                  src={`${kid.imageUrl.trim().replace(/\/$/, '')}/w=240,h=180,fit=cover,q=75,format=auto`}
                  alt={kid.name || 'Preview'}
                  width="240" height="180"
                />
              ) : (
                <div class="kid-img-placeholder">No image</div>
              )}
            </div>
          </div>

          <div class="kid-text-col">
            <div class="field-group">
              <label class="field-label" for={`kid-name-${i}`}>Name</label>
              <input id={`kid-name-${i}`} name={`kids[${i}][name]`} type="text" class="admin-input" value={kid.name} placeholder="e.g. Mathew" />
            </div>

            <div class="field-group">
              <label class="field-label" for={`kid-tag-${i}`}>Badge Tag</label>
              <p class="field-hint">Short label shown above the name — e.g. "Room #247"</p>
              <input id={`kid-tag-${i}`} name={`kids[${i}][tag]`} type="text" class="admin-input" value={kid.tag} placeholder="e.g. Where It All Began" />
            </div>

            <div class="field-group">
              <label class="field-label" for={`kid-blurb-${i}`}>Blurb</label>
              <textarea id={`kid-blurb-${i}`} name={`kids[${i}][blurb]`} class="admin-input admin-textarea" rows="3" placeholder="2–3 sentence story...">{kid.blurb}</textarea>
            </div>

            <div class="field-group">
              <label class="field-label" for={`kid-image-${i}`}>Image (Cloudflare Images base URL)</label>
              <p class="field-hint">Auto-filled from SOARD, or paste manually — e.g. <code>https://imagedelivery.net/…/kids/mathew/hero</code></p>
              <input
                id={`kid-image-${i}`}
                name={`kids[${i}][imageUrl]`}
                type="url"
                class="admin-input kid-image-input"
                data-preview={`kid-preview-${i}`}
                value={kid.imageUrl}
                placeholder="https://imagedelivery.net/…/kids/name/hero"
              />
            </div>
          </div>
        </div>
      </div>
    ))}

    <div class="admin-save-bar">
      <button type="submit" class="admin-btn admin-btn--primary" id="save-btn">
        <span class="btn-spinner"></span>
        <span class="btn-label">Save Kids Section</span>
      </button>
      <span class="admin-save-hint">
        <kbd class="admin-kbd">⌘S</kbd> to save
      </span>
    </div>

  </form>
</Admin>

<style>
  .section-title {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--admin-text-light);
    margin: 0 0 1.25rem;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }
  .field-group:last-child { margin-bottom: 0; }

  .field-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--admin-text);
  }

  .field-hint {
    font-size: 0.78rem;
    color: var(--admin-text-light);
    margin: 0;
    line-height: 1.5;
  }

  .field-hint code {
    background: rgba(0,0,0,0.06);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-size: 0.76rem;
  }

  .admin-input {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    font-size: 0.88rem;
    color: var(--admin-text);
    background: var(--admin-bg);
    box-sizing: border-box;
    transition: border-color 0.15s;
    font-family: inherit;
  }
  .admin-input:focus {
    outline: none;
    border-color: var(--admin-accent);
  }
  .admin-textarea {
    resize: vertical;
    line-height: 1.55;
  }

  /* SOARD picker */
  .soard-picker-group {
    background: rgba(74, 168, 196, 0.06);
    border: 1px solid rgba(74, 168, 196, 0.2);
    border-radius: var(--admin-radius);
    padding: 0.9rem 1rem;
    margin-bottom: 1.25rem;
  }
  .soard-picker-group .field-label { color: var(--admin-accent, #4aa8c4); }

  /* Kid card layout */
  .kid-card { padding-bottom: 1.5rem; }

  .kid-fields {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 680px) {
    .kid-fields { grid-template-columns: 1fr; }
  }

  .kid-img-preview {
    border-radius: var(--admin-radius);
    overflow: hidden;
    border: 1px solid var(--admin-border);
    background: #f0f0f0;
    aspect-ratio: 4 / 3;
    width: 100%;
  }

  .kid-img-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kid-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    color: var(--admin-text-light);
  }
</style>

<script>
  const form = document.getElementById('kids-form') as HTMLFormElement;

  // SOARD picker — auto-fill name, imageUrl, blurb on selection
  document.querySelectorAll<HTMLSelectElement>('.soard-picker').forEach(select => {
    select.addEventListener('change', () => {
      const opt = select.options[select.selectedIndex];
      if (!opt.value) return;
      const i = select.dataset.slot!;
      const name = opt.dataset.name || '';
      const imageUrl = opt.dataset.image || '';
      const blurb = opt.dataset.blurb || '';

      (document.getElementById(`kid-name-${i}`) as HTMLInputElement).value = name;
      (document.getElementById(`kid-blurb-${i}`) as HTMLTextAreaElement).value = blurb;
      const imageInput = document.getElementById(`kid-image-${i}`) as HTMLInputElement;
      imageInput.value = imageUrl;

      // Update preview
      if (imageUrl) {
        const container = document.getElementById(`kid-preview-${i}`)!;
        let img = container.querySelector<HTMLImageElement>('img');
        if (!img) {
          container.innerHTML = '';
          img = document.createElement('img');
          img.width = 240; img.height = 180;
          container.appendChild(img);
        }
        img.src = `${imageUrl}/w=240,h=180,fit=cover,q=75,format=auto`;
        img.alt = name;
      }

      document.querySelector('.admin-unsaved-badge')?.classList.add('visible');
    });
  });

  // Live image preview on URL input
  document.querySelectorAll<HTMLInputElement>('.kid-image-input').forEach(input => {
    let timer: ReturnType<typeof setTimeout>;
    input.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => {
        const previewId = input.dataset.preview!;
        const container = document.getElementById(previewId)!;
        const base = input.value.trim().replace(/\/$/, '');
        if (!base) return;
        let img = container.querySelector<HTMLImageElement>('img');
        if (!img) {
          container.innerHTML = '';
          img = document.createElement('img');
          img.width = 240;
          img.height = 180;
          container.appendChild(img);
        }
        img.src = `${base}/w=240,h=180,fit=cover,q=75,format=auto`;
        img.alt = 'Preview';
      }, 600);
    });
  });

  // Unsaved badge
  form.addEventListener('input', () => {
    document.querySelector('.admin-unsaved-badge')?.classList.add('visible');
  });

  // Save
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    (window as any).setButtonLoading(btn, true);

    const heading = (form.querySelector('#kids-heading') as HTMLInputElement).value.trim();
    const subheading = (form.querySelector('#kids-subheading') as HTMLTextAreaElement).value.trim();

    const kidsData: Array<{ name: string; tag: string; blurb: string; imageUrl: string }> = [];
    for (let i = 0; i < 3; i++) {
      const name = (form.querySelector(`#kid-name-${i}`) as HTMLInputElement).value.trim();
      const tag = (form.querySelector(`#kid-tag-${i}`) as HTMLInputElement).value.trim();
      const blurb = (form.querySelector(`#kid-blurb-${i}`) as HTMLTextAreaElement).value.trim();
      const imageUrl = (form.querySelector(`#kid-image-${i}`) as HTMLInputElement).value.trim().replace(/\/$/, '');
      if (name) kidsData.push({ name, tag, blurb, imageUrl });
    }

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'settings:kids', value: { heading, subheading, kids: kidsData } }),
      });
      if (!res.ok) throw new Error('Save failed');
      const data = await res.json();
      document.querySelector('.admin-unsaved-badge')?.classList.remove('visible');
      if (data.warning) {
        (window as any).showToast(`Saved, but site won't update: ${data.warning}`, true);
      } else {
        (window as any).showToast('Kids section saved — site will rebuild shortly');
      }
    } catch {
      (window as any).showToast('Failed to save', true);
    } finally {
      (window as any).setButtonLoading(btn, false);
    }
  });

  // ⌘S save
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 's') {
      e.preventDefault();
      form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
    }
  });
</script>
