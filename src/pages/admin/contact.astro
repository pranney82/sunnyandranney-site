---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';

export const prerender = false;

const contact: any = await getSetting('settings:contact');

const defaults = {
  address: '109A Oak Street',
  city: 'Roswell',
  state: 'GA',
  zip: '30075',
  phone: '678.888.5140',
  email: 'info@sunnyandranney.com',
  instagramUrl: 'https://www.instagram.com/sunnyandranney/',
  facebookUrl: 'https://www.facebook.com/sunnyandranney/',
};

const data = contact || defaults;
---

<Admin title="Contact Info">
  <div class="admin-header">
    <div>
      <h2>Contact Info</h2>
      <p>Update your store address, phone, email, and social links</p>
    </div>
    <div class="admin-unsaved-badge" aria-live="polite">
      <span class="admin-unsaved-dot"></span>
      Unsaved changes
    </div>
  </div>

  <form id="contact-form">
    <div class="admin-card">
      <h3>Store Address</h3>
      <div class="admin-field">
        <label class="admin-label">Street Address</label>
        <input type="text" class="admin-input" name="address" value={data.address} placeholder="e.g. 109A Oak Street" required />
      </div>
      <div class="address-row">
        <div class="admin-field" style="flex: 2;">
          <label class="admin-label">City</label>
          <input type="text" class="admin-input" name="city" value={data.city} placeholder="e.g. Roswell" required />
        </div>
        <div class="admin-field" style="flex: 0.75;">
          <label class="admin-label">State</label>
          <input type="text" class="admin-input" name="state" value={data.state} placeholder="e.g. GA" maxlength="2" required />
        </div>
        <div class="admin-field" style="flex: 1;">
          <label class="admin-label">ZIP</label>
          <input type="text" class="admin-input" name="zip" value={data.zip} placeholder="e.g. 30075" required />
        </div>
      </div>
    </div>

    <div class="admin-card">
      <h3>Contact Details</h3>
      <div class="admin-field">
        <label class="admin-label">Phone Number</label>
        <input type="text" class="admin-input" name="phone" value={data.phone} placeholder="e.g. 678.888.5140" required />
      </div>
      <div class="admin-field">
        <label class="admin-label">Email Address</label>
        <input type="email" class="admin-input" name="email" value={data.email} placeholder="e.g. info@sunnyandranney.com" required />
      </div>
    </div>

    <div class="admin-card">
      <h3>Social Media</h3>
      <div class="admin-field">
        <label class="admin-label">Instagram URL</label>
        <input type="url" class="admin-input" name="instagramUrl" value={data.instagramUrl} placeholder="https://www.instagram.com/..." />
      </div>
      <div class="admin-field">
        <label class="admin-label">Facebook URL</label>
        <input type="url" class="admin-input" name="facebookUrl" value={data.facebookUrl} placeholder="https://www.facebook.com/..." />
      </div>
    </div>

    <div class="admin-save-bar">
      <button type="submit" class="admin-btn admin-btn--primary" id="save-btn">Save Contact Info</button>
      <span class="admin-save-hint">
        <kbd class="admin-kbd">⌘S</kbd> to save
      </span>
    </div>
  </form>
</Admin>

<style>
  .address-row {
    display: flex;
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .address-row {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Saving...';

    const value = {
      address: (form.querySelector('[name="address"]') as HTMLInputElement).value,
      city: (form.querySelector('[name="city"]') as HTMLInputElement).value,
      state: (form.querySelector('[name="state"]') as HTMLInputElement).value,
      zip: (form.querySelector('[name="zip"]') as HTMLInputElement).value,
      phone: (form.querySelector('[name="phone"]') as HTMLInputElement).value,
      email: (form.querySelector('[name="email"]') as HTMLInputElement).value,
      instagramUrl: (form.querySelector('[name="instagramUrl"]') as HTMLInputElement).value,
      facebookUrl: (form.querySelector('[name="facebookUrl"]') as HTMLInputElement).value,
    };

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'settings:contact', value }),
      });
      if (!res.ok) throw new Error('Save failed');
      const data = await res.json();
      if (data.warning) {
        (window as any).showToast(`Saved, but site won't update: ${data.warning}`, true);
      } else {
        (window as any).showToast('Contact info saved — site will rebuild shortly');
      }
    } catch {
      (window as any).showToast('Failed to save', true);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Save Contact Info';
    }
  });
</script>
