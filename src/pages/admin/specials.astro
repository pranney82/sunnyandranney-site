---
import Admin from '@/layouts/Admin.astro';
import { getSetting } from '@/lib/db';

export const prerender = false;

const specials: any = await getSetting('settings:specials');

const defaults = {
  announcements: [] as Array<{
    id: string;
    text: string;
    link: string;
    active: boolean;
    type: 'banner' | 'promo' | 'info';
  }>,
  featuredHandle: '',
  promoCode: '',
  promoDescription: '',
};

const data = specials || defaults;
---

<Admin title="Specials & Announcements">
  <div class="admin-header">
    <div>
      <h2>Specials & Announcements</h2>
      <p>Manage banners, promos, and featured items</p>
    </div>
    <div class="admin-unsaved-badge" aria-live="polite">
      <span class="admin-unsaved-dot"></span>
      Unsaved changes
    </div>
  </div>

  <form id="specials-form">
    <div class="admin-card">
      <h3>Promo Details</h3>
      <div class="admin-field">
        <label class="admin-label">Promo Code</label>
        <input type="text" class="admin-input" name="promoCode" value={data.promoCode} placeholder="e.g. SUMMER20" />
      </div>
      <div class="admin-field">
        <label class="admin-label">Promo Description</label>
        <input type="text" class="admin-input" name="promoDescription" value={data.promoDescription} placeholder="e.g. 20% off all summer styles" />
      </div>
      <div class="admin-field">
        <label class="admin-label">Featured Product Handle</label>
        <input type="text" class="admin-input" name="featuredHandle" value={data.featuredHandle} placeholder="e.g. sunny-tee-gold" />
        <span style="font-size: 0.75rem; color: var(--admin-text-light); margin-top: 0.25rem; display: block;">
          The Shopify product handle to feature. Leave blank for none.
        </span>
      </div>
    </div>

    <div class="admin-card">
      <h3>Banner Announcements</h3>
      <p style="font-size: 0.85rem; color: var(--admin-text-light); margin-bottom: 1rem;">
        These appear in the rotating banner at the top of the site.
      </p>
      <div id="announcements-container">
        {data.announcements.map((a: any, i: number) => (
          <div class="announcement-card" data-index={i}>
            <div class="announcement-card-header">
              <select class="admin-input ann-type">
                <option value="banner" selected={a.type === 'banner'}>Banner</option>
                <option value="promo" selected={a.type === 'promo'}>Promo</option>
                <option value="info" selected={a.type === 'info'}>Info</option>
              </select>
              <label class="ann-toggle-wrap">
                <label class="admin-toggle">
                  <input type="checkbox" checked={a.active} class="ann-active" />
                  <span class="admin-toggle-slider"></span>
                </label>
                <span class="ann-active-label">{a.active ? 'Active' : 'Inactive'}</span>
              </label>
              <button type="button" class="admin-btn admin-btn--danger remove-ann">Remove</button>
            </div>
            <div class="announcement-card-body">
              <div class="admin-field" style="margin-bottom: 0.5rem">
                <label class="admin-label">Announcement Text</label>
                <input type="text" class="admin-input ann-text" value={a.text} placeholder="e.g. Free shipping on orders over $50" />
              </div>
              <div class="admin-field" style="margin-bottom: 0">
                <label class="admin-label">Link (optional)</label>
                <input type="text" class="admin-input ann-link" value={a.link || ''} placeholder="https://..." />
              </div>
            </div>
          </div>
        ))}
      </div>
      <button type="button" class="admin-btn admin-btn--outline" id="add-announcement" style="margin-top: 0.75rem">+ Add Announcement</button>
    </div>

    <div class="admin-save-bar">
      <button type="submit" class="admin-btn admin-btn--primary" id="save-btn">
        <span class="btn-spinner"></span>
        <span class="btn-label">Save Specials</span>
      </button>
      <span class="admin-save-hint">
        <kbd class="admin-kbd">⌘S</kbd> to save
      </span>
    </div>
  </form>
</Admin>

<style>
  .announcement-card {
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    margin-bottom: 0.75rem;
    overflow: hidden;
    background: white;
  }

  .announcement-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--admin-bg);
    border-bottom: 1px solid var(--admin-border);
    flex-wrap: wrap;
  }

  .announcement-card-header .ann-type {
    width: auto;
    flex-shrink: 0;
    font-size: 0.82rem;
    padding: 0.35rem 0.65rem;
  }

  .ann-toggle-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
  }

  .ann-active-label {
    font-size: 0.8rem;
    color: var(--admin-text-light);
    font-weight: 500;
  }

  .announcement-card-body {
    padding: 0.75rem 1rem;
  }

  @media (max-width: 600px) {
    .announcement-card-header {
      gap: 0.5rem;
    }

    .announcement-card-header .admin-btn {
      margin-left: auto;
    }
  }
</style>

<script>
  const form = document.getElementById('specials-form') as HTMLFormElement;
  const container = document.getElementById('announcements-container')!;

  // Update active label text when toggle changes
  function initAnnToggles() {
    document.querySelectorAll('.ann-active').forEach((cb) => {
      cb.addEventListener('change', (e) => {
        const input = e.target as HTMLInputElement;
        const label = input.closest('.ann-toggle-wrap')?.querySelector('.ann-active-label');
        if (label) label.textContent = input.checked ? 'Active' : 'Inactive';
      });
    });
  }
  initAnnToggles();

  // Add announcement
  document.getElementById('add-announcement')?.addEventListener('click', () => {
    const card = document.createElement('div');
    card.className = 'announcement-card';
    card.innerHTML = `
      <div class="announcement-card-header">
        <select class="admin-input ann-type">
          <option value="banner">Banner</option>
          <option value="promo">Promo</option>
          <option value="info">Info</option>
        </select>
        <label class="ann-toggle-wrap">
          <label class="admin-toggle">
            <input type="checkbox" checked class="ann-active" />
            <span class="admin-toggle-slider"></span>
          </label>
          <span class="ann-active-label">Active</span>
        </label>
        <button type="button" class="admin-btn admin-btn--danger remove-ann">Remove</button>
      </div>
      <div class="announcement-card-body">
        <div class="admin-field" style="margin-bottom: 0.5rem">
          <label class="admin-label">Announcement Text</label>
          <input type="text" class="admin-input ann-text" placeholder="e.g. Free shipping on orders over $50" />
        </div>
        <div class="admin-field" style="margin-bottom: 0">
          <label class="admin-label">Link (optional)</label>
          <input type="text" class="admin-input ann-link" placeholder="https://..." />
        </div>
      </div>
    `;
    container.appendChild(card);
    initAnnToggles();
  });

  // Remove announcement
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.remove-ann');
    if (btn) btn.closest('.announcement-card')?.remove();
  });

  // Save
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    (window as any).setButtonLoading(btn, true);

    const announcements = [...container.querySelectorAll('.announcement-card')].map((card, i) => ({
      id: `ann-${i}`,
      text: (card.querySelector('.ann-text') as HTMLInputElement).value,
      link: (card.querySelector('.ann-link') as HTMLInputElement).value,
      active: (card.querySelector('.ann-active') as HTMLInputElement).checked,
      type: (card.querySelector('.ann-type') as HTMLSelectElement).value,
    }));

    const value = {
      announcements,
      promoCode: (form.querySelector('[name="promoCode"]') as HTMLInputElement).value,
      promoDescription: (form.querySelector('[name="promoDescription"]') as HTMLInputElement).value,
      featuredHandle: (form.querySelector('[name="featuredHandle"]') as HTMLInputElement).value,
    };

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: 'settings:specials', value }),
      });
      if (!res.ok) throw new Error('Save failed');
      const data = await res.json();
      if (data.warning) {
        (window as any).showToast(`Saved, but site won't update: ${data.warning}`, true);
      } else {
        (window as any).showToast('Specials saved — site will rebuild shortly');
      }
    } catch {
      (window as any).showToast('Failed to save', true);
    } finally {
      (window as any).setButtonLoading(btn, false);
    }
  });
</script>
