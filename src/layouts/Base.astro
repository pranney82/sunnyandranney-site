---
import { ClientRouter } from 'astro:transitions';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import VisitStrip from '@/components/VisitStrip.astro';
import EmailCapture from '@/components/EmailCapture.astro';
import CartDrawer from '@/components/CartDrawer.astro';

import StaciChat from '@/components/StaciChat.astro';
import SEO from '@/components/SEO.astro';
import { getHoursStatic, getSpecialsStatic, getContactStatic, getReviewsStatic, formatHoursShort, type StoreHours } from '@/lib/settings';
import { fetchGooglePlaceData } from '@/lib/google-places';
import '@/styles/global.css';

// Load admin settings at build time (committed JSON files)
const [hours, specials, contact, reviewsSetting, liveReviews] = await Promise.all([
  getHoursStatic(), getSpecialsStatic(), getContactStatic(), getReviewsStatic(), fetchGooglePlaceData(),
]);
const footerHours = hours ? formatHoursShort(hours) : null;
const holidays = hours?.holidays ?? [];
const announcements = specials?.announcements?.filter(a => a.active) ?? [];

// AggregateRating: prefer live Google data, fall back to saved reviews
const ratingValue = liveReviews?.rating ?? reviewsSetting?.googleRating;
const ratingCount = liveReviews?.reviewCount ?? reviewsSetting?.reviewCount;
const rating = ratingValue && ratingCount ? { value: ratingValue, count: ratingCount } : undefined;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  lcpImage?: string;
  lcpImageSrcset?: string;
  lcpImageSizes?: string;
  product?: {
    name: string;
    price: string;
    currency: string;
    image: string;
    availability: boolean;
  };
}

const props = Astro.props;
const isShopPage = Astro.url.pathname.startsWith('/shop') || Astro.url.pathname.startsWith('/products');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <!-- Favicon: full browser + device coverage -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#FAF7F2" />
    <SEO {...props} rating={rating} />

    <!-- Critical CSS — renders LCP banner text before external CSS loads -->
    <style is:inline>
      .nav{position:fixed;top:0;left:0;right:0;z-index:100;background:#FAF7F2}
      .nav__banner{background:#2C2C2C;color:#FAF7F2;font-size:.72rem;text-align:center;padding:.4rem 0;letter-spacing:.02em;max-height:40px;overflow:hidden}
      .nav__banner-slider{position:relative;height:1.3em;overflow:hidden}
      .nav__banner-slide{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0;white-space:nowrap}
      .nav__banner-slide--active{opacity:1;transform:translateY(0)}
      @media(max-width:767px){.nav__banner{font-size:.6rem}.nav__banner-slider{height:2.4em}.nav__banner-slide{white-space:normal;text-align:center;line-height:1.2;padding:0 .25rem}}
    </style>

    <!-- Preconnect to external CDNs — as early as possible for LCP -->
    <link rel="preconnect" href="https://imagedelivery.net" />
    <link rel="dns-prefetch" href="https://imagedelivery.net" />
    {isShopPage && <link rel="preconnect" href="https://cdn.shopify.com" />}
    {isShopPage && <link rel="dns-prefetch" href="https://cdn.shopify.com" />}

    {/* Preload LCP image FIRST — before fonts so it wins the bandwidth race on slow connections */}
    {props.lcpImage && (
      <Fragment set:html={`<link rel="preload" href="${props.lcpImage}" as="image" fetchpriority="high"${props.lcpImageSrcset ? ` imagesrcset="${props.lcpImageSrcset}"` : ''}${props.lcpImageSizes ? ` imagesizes="${props.lcpImageSizes}"` : ''} />`} />
    )}

    <!-- Preload body font only — display fonts use font-display:optional and gracefully degrade on slow connections -->
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- View Transitions for SPA-like navigation -->
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <Nav announcements={announcements} />
    <main id="main-content" style={`margin-top: var(--nav-height);`} transition:animate="fade">
      <slot />
    </main>
    <VisitStrip contact={contact} hours={footerHours} holidays={holidays} />
    <EmailCapture />
    <Footer contact={contact} />
    <CartDrawer transition:persist />

    <StaciChat transition:persist />

    <!-- Expose public Shopify config for client-side search typeahead -->
    <script is:inline define:vars={{
      shopifyDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN || 'sunnyandranney.myshopify.com',
      shopifyToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN || '',
    }}>
      window.__SHOPIFY_DOMAIN = shopifyDomain;
      window.__SHOPIFY_TOKEN = shopifyToken;
    </script>

    <!-- Scroll reveal observer — re-runs after View Transitions -->
    <script>
      function initReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );

        document.querySelectorAll('.reveal:not(.visible)').forEach((el) => observer.observe(el));
      }

      // Run on initial load
      initReveal();

      // Re-run after View Transitions navigate
      document.addEventListener('astro:after-swap', initReveal);
    </script>
  </body>
</html>
