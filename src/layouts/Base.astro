---
import { ClientRouter } from 'astro:transitions';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import VisitStrip from '@/components/VisitStrip.astro';
import EmailCapture from '@/components/EmailCapture.astro';
import CartDrawer from '@/components/CartDrawer.astro';

import StaciChat from '@/components/StaciChat.astro';
import BackToTop from '@/components/BackToTop.astro';
import SEO from '@/components/SEO.astro';
import { getHoursStatic, getSpecialsStatic, formatHoursShort } from '@/lib/settings';
import '@/styles/global.css';

// Load admin settings at build time (committed JSON files)
const [hours, specials] = await Promise.all([getHoursStatic(), getSpecialsStatic()]);
const footerHours = hours ? formatHoursShort(hours) : null;
const announcements = specials?.announcements?.filter(a => a.active) ?? [];

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  lcpImage?: string;
  product?: {
    name: string;
    price: string;
    currency: string;
    image: string;
    availability: boolean;
  };
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <!-- Favicon: full browser + device coverage -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#FAF7F2" />
    <SEO {...props} />

    <!-- View Transitions for SPA-like navigation -->
    <ClientRouter />

    <!-- Preconnect to external CDNs for faster images -->
    <link rel="preconnect" href="https://cdn.shopify.com" />
    <link rel="dns-prefetch" href="https://cdn.shopify.com" />
    <link rel="preconnect" href="https://imagedelivery.net" />
    <link rel="dns-prefetch" href="https://imagedelivery.net" />
    <!-- Preload critical fonts (eliminates FOIT, avoids render-blocking chain) -->
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/TheSeasons-Regular.woff2" as="font" type="font/woff2" crossorigin />

    {/* Preload LCP image when provided by page */}
    {props.lcpImage && (
      <link rel="preload" href={props.lcpImage} as="image" fetchpriority="high" />
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <Nav announcements={announcements} />
    <main id="main-content" style={`margin-top: var(--nav-height);`} transition:animate="fade">
      <slot />
    </main>
    <VisitStrip />
    <EmailCapture />
    <Footer hours={footerHours} />
    <CartDrawer transition:persist />
    <BackToTop />

    <StaciChat transition:persist />

    <!-- Expose public Shopify config for client-side search typeahead -->
    <script is:inline define:vars={{
      shopifyDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN || 'sunnyandranney.myshopify.com',
      shopifyToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN || '',
    }}>
      window.__SHOPIFY_DOMAIN = shopifyDomain;
      window.__SHOPIFY_TOKEN = shopifyToken;
    </script>

    <!-- Scroll reveal observer — re-runs after View Transitions -->
    <script>
      function initReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );

        document.querySelectorAll('.reveal:not(.visible)').forEach((el) => observer.observe(el));
      }

      // Run on initial load
      initReveal();

      // Re-run after View Transitions navigate
      document.addEventListener('astro:after-swap', initReveal);
    </script>
  </body>
</html>
