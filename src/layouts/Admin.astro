---
interface Props {
  title?: string;
}

const { title = 'Admin' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: 'grid' },
  { href: '/admin/hours', label: 'Store Hours', icon: 'clock' },
  { href: '/admin/collections', label: 'Collections', icon: 'shopping-bag' },
  { href: '/admin/specials', label: 'Specials', icon: 'star' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | Sunny & Ranney Admin</title>
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <style>
      @font-face {
        font-family: 'DM Sans';
        src: url('/fonts/DMSans-Variable.woff2') format('woff2');
        font-weight: 300 600;
        font-style: normal;
        font-display: swap;
      }

      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --admin-bg: #f8f9fa;
        --admin-sidebar: #1a1a2e;
        --admin-sidebar-hover: #16213e;
        --admin-accent: #FFD400;
        --admin-text: #2C2C2C;
        --admin-text-light: #6c757d;
        --admin-card: #ffffff;
        --admin-border: #e9ecef;
        --admin-success: #28a745;
        --admin-danger: #dc3545;
        --admin-radius: 8px;
      }

      html { font-size: 16px; -webkit-font-smoothing: antialiased; }

      body {
        font-family: 'DM Sans', system-ui, sans-serif;
        background: var(--admin-bg);
        color: var(--admin-text);
        line-height: 1.6;
        display: flex;
        min-height: 100vh;
      }

      /* Sidebar */
      .admin-sidebar {
        width: 240px;
        background: var(--admin-sidebar);
        color: white;
        padding: 1.5rem 0;
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 100;
        transition: transform 0.3s ease;
      }

      .admin-logo {
        padding: 0 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 0.5rem;
      }

      .admin-logo h1 {
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .admin-logo span {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--admin-accent);
        display: block;
        margin-top: 0.15rem;
      }

      .admin-nav { flex: 1; padding: 0.5rem 0; }

      .admin-nav a {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.7rem 1.25rem;
        color: rgba(255, 255, 255, 0.65);
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        transition: all 0.2s;
        border-left: 3px solid transparent;
      }

      .admin-nav a:hover {
        color: white;
        background: var(--admin-sidebar-hover);
      }

      .admin-nav a.active {
        color: var(--admin-accent);
        background: var(--admin-sidebar-hover);
        border-left-color: var(--admin-accent);
      }

      .admin-nav-icon {
        width: 18px;
        height: 18px;
        opacity: 0.7;
      }

      .admin-nav a.active .admin-nav-icon,
      .admin-nav a:hover .admin-nav-icon {
        opacity: 1;
      }

      .admin-sidebar-footer {
        padding: 1rem 1.25rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
      }

      .admin-sidebar-footer a {
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        font-size: 0.8rem;
        transition: color 0.2s;
      }

      .admin-sidebar-footer a:hover { color: white; }

      /* Main content */
      .admin-main {
        flex: 1;
        margin-left: 240px;
        padding: 2rem;
        max-width: 1040px;
      }

      .admin-header {
        margin-bottom: 2rem;
      }

      .admin-header h2 {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--admin-text);
      }

      .admin-header p {
        color: var(--admin-text-light);
        font-size: 0.9rem;
        margin-top: 0.25rem;
      }

      /* Mobile toggle */
      .admin-mobile-toggle {
        display: none;
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 101;
        width: 40px;
        height: 40px;
        background: var(--admin-sidebar);
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
      }

      .admin-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 99;
      }

      @media (max-width: 768px) {
        .admin-sidebar {
          transform: translateX(-100%);
        }

        .admin-sidebar.open {
          transform: translateX(0);
        }

        .admin-overlay.open {
          display: block;
        }

        .admin-mobile-toggle {
          display: flex;
        }

        .admin-main {
          margin-left: 0;
          padding: 1rem;
          padding-top: 4rem;
        }
      }

      /* Shared admin component styles */
      .admin-card {
        background: var(--admin-card);
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
      }

      .admin-card h3 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--admin-text);
      }

      .admin-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.55rem 1.25rem;
        font-family: inherit;
        font-size: 0.85rem;
        font-weight: 600;
        border: 2px solid transparent;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s;
      }

      .admin-btn--primary {
        background: var(--admin-accent);
        color: var(--admin-text);
        border-color: var(--admin-accent);
      }

      .admin-btn--primary:hover {
        background: #e6bf00;
        border-color: #e6bf00;
      }

      .admin-btn--primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .admin-btn--outline {
        background: transparent;
        color: var(--admin-text);
        border-color: var(--admin-border);
      }

      .admin-btn--outline:hover {
        border-color: var(--admin-text);
      }

      .admin-btn--danger {
        background: transparent;
        color: var(--admin-danger);
        border-color: var(--admin-danger);
      }

      .admin-btn--danger:hover {
        background: var(--admin-danger);
        color: white;
      }

      .admin-input {
        width: 100%;
        padding: 0.55rem 0.75rem;
        font-family: inherit;
        font-size: 0.9rem;
        border: 1px solid var(--admin-border);
        border-radius: 6px;
        background: white;
        color: var(--admin-text);
        transition: border-color 0.2s;
      }

      .admin-input:focus {
        outline: none;
        border-color: var(--admin-accent);
        box-shadow: 0 0 0 3px rgba(255, 212, 0, 0.15);
      }

      .admin-textarea {
        resize: vertical;
        min-height: 80px;
      }

      .admin-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--admin-text-light);
        margin-bottom: 0.35rem;
      }

      .admin-field {
        margin-bottom: 1rem;
      }

      .admin-toggle {
        position: relative;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
      }

      .admin-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
        position: absolute;
      }

      .admin-toggle-slider {
        position: absolute;
        inset: 0;
        background: var(--admin-border);
        border-radius: 24px;
        cursor: pointer;
        transition: background 0.2s;
      }

      .admin-toggle-slider::before {
        content: '';
        position: absolute;
        width: 18px;
        height: 18px;
        left: 3px;
        bottom: 3px;
        background: white;
        border-radius: 50%;
        transition: transform 0.2s;
      }

      .admin-toggle input:checked + .admin-toggle-slider {
        background: var(--admin-success);
      }

      .admin-toggle input:checked + .admin-toggle-slider::before {
        transform: translateX(20px);
      }

      .admin-toast {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        padding: 0.75rem 1.25rem;
        background: var(--admin-text);
        color: white;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        z-index: 200;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.3s;
        pointer-events: none;
      }

      .admin-toast.show {
        opacity: 1;
        transform: translateY(0);
      }

      .admin-toast.error {
        background: var(--admin-danger);
      }

      .admin-stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
      }

      .admin-stat {
        background: var(--admin-card);
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius);
        padding: 1.25rem;
      }

      .admin-stat-label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--admin-text-light);
        margin-bottom: 0.35rem;
      }

      .admin-stat-value {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--admin-text);
      }
    </style>
  </head>
  <body>
    <button class="admin-mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
      &#9776;
    </button>
    <div class="admin-overlay" id="admin-overlay"></div>

    <aside class="admin-sidebar" id="admin-sidebar">
      <div class="admin-logo">
        <h1>Sunny & Ranney</h1>
        <span>Admin Panel</span>
      </div>
      <nav class="admin-nav">
        {navItems.map((item) => (
          <a href={item.href} class:list={[{ active: currentPath === item.href || (item.href !== '/admin' && currentPath.startsWith(item.href)) }]}>
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              {item.icon === 'grid' && <><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></>}
              {item.icon === 'clock' && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
              {item.icon === 'shopping-bag' && <><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></>}
              {item.icon === 'star' && <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>}
            </svg>
            {item.label}
          </a>
        ))}
      </nav>
      <div class="admin-sidebar-footer">
        <a href="/">&#8592; Back to site</a>
      </div>
    </aside>

    <main class="admin-main">
      <slot />
    </main>

    <div class="admin-toast" id="admin-toast"></div>

    <script>
      // Mobile sidebar toggle
      const toggle = document.getElementById('mobile-toggle');
      const sidebar = document.getElementById('admin-sidebar');
      const overlay = document.getElementById('admin-overlay');

      toggle?.addEventListener('click', () => {
        sidebar?.classList.toggle('open');
        overlay?.classList.toggle('open');
      });

      overlay?.addEventListener('click', () => {
        sidebar?.classList.remove('open');
        overlay?.classList.remove('open');
      });

      // Toast helper — available globally
      window.showToast = function(message, isError = false) {
        const toast = document.getElementById('admin-toast');
        if (!toast) return;
        toast.textContent = message;
        toast.className = 'admin-toast show' + (isError ? ' error' : '');
        setTimeout(() => { toast.className = 'admin-toast'; }, 3000);
      };
    </script>
  </body>
</html>
