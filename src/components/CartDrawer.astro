---
// Cart Drawer — rendered on every page via Base layout
---

<div id="cart-system" transition:persist="cart-system">
<!-- Cart Overlay -->
<div class="cart-overlay" id="cart-overlay" aria-hidden="true"></div>

<!-- Cart Drawer -->
<aside class="cart-drawer" id="cart-drawer" aria-hidden="true" inert aria-label="Shopping cart">
  <div class="cart-drawer__header">
    <h3>Your Cart <span class="cart-drawer__count" id="cart-drawer-count"></span></h3>
    <button class="cart-drawer__close" id="cart-close" aria-label="Close cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Local pickup notice -->
  <div class="cart-drawer__shipping" id="cart-shipping">
    <p class="shipping-bar__text" id="shipping-text" style="text-align:center;">Local pickup only — no shipping available</p>
  </div>

  <!-- Cart items -->
  <div class="cart-drawer__items" id="cart-items">
    <!-- Populated by JS -->
  </div>

  <!-- Empty state -->
  <div class="cart-drawer__empty" id="cart-empty" style="display:none;">
    <svg class="cart-empty__icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.35;"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
    <p>Your cart is empty</p>
    <a href="/shop/" class="btn btn--primary" style="margin-top: 1rem;">Start Shopping</a>
  </div>

  <!-- Cart footer -->
  <div class="cart-drawer__footer" id="cart-footer" style="display:none;">
    <div class="cart-footer__row">
      <span>Subtotal</span>
      <span class="cart-footer__total" id="cart-total">$0.00</span>
    </div>
    <p class="cart-footer__note">Taxes calculated at checkout · Local pickup only</p>
    <div class="cart-footer__rewards">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <span>Earn 1 point for every $1 spent</span>
    </div>
    <div class="cart-footer__alert" id="cart-alert" style="display:none;" role="alert"></div>
    <button class="btn btn--gold cart-footer__checkout" id="cart-checkout" style="width:100%; justify-content:center;">
      Proceed to Checkout
    </button>
    <div class="cart-footer__trust">
      <span>Secure checkout</span>
      <span class="cart-footer__trust-dot">·</span>
      <span>100% to charity</span>
    </div>
  </div>
</aside>

<!-- Toast notification -->
<div class="cart-toast" id="cart-toast" role="status" aria-live="polite">
  <svg class="cart-toast__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  <div class="cart-toast__text">
    <span class="cart-toast__title" id="cart-toast-title"></span>
    <span class="cart-toast__sub">Added to cart</span>
  </div>
</div>
</div>

<style is:global>
  /* ─── Overlay ─────────────────────────── */
  .cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 200;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
    backdrop-filter: blur(2px);
  }
  .cart-overlay[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  /* ─── Drawer ──────────────────────────── */
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 420px;
    max-width: 92vw;
    background: var(--color-cream);
    z-index: 201;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.08);
  }
  .cart-drawer[aria-hidden="false"] {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .cart-drawer__header h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cart-drawer__count {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--color-gold);
    color: var(--color-charcoal);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer__close {
    padding: 0.5rem;
    min-width: 48px;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-stone);
    transition: color 0.2s;
  }
  .cart-drawer__close:hover { color: var(--color-charcoal); }

  /* ─── Shipping Progress ───────────────── */
  .cart-drawer__shipping {
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .shipping-bar {
    width: 100%;
    height: 4px;
    background: var(--color-cream-dark);
    border-radius: 2px;
    overflow: hidden;
  }

  .shipping-bar__fill {
    height: 100%;
    background: var(--color-gold);
    border-radius: 2px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .shipping-bar__text {
    font-size: 0.78rem;
    color: var(--color-slate);
    margin-top: 0.4rem;
    text-align: center;
    max-width: none;
  }

  .shipping-bar__text strong {
    color: var(--color-charcoal);
    font-weight: 600;
  }

  /* ─── Cart Items ──────────────────────── */
  .cart-drawer__items {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.5rem;
  }

  .cart-item {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-cream-dark);
    animation: fadeInUp 0.3s ease both;
    transition: opacity 0.3s ease, max-height 0.35s ease, padding 0.35s ease, margin 0.35s ease;
    max-height: 200px;
    overflow: hidden;
  }

  .cart-item--removing {
    opacity: 0;
    max-height: 0;
    padding: 0;
    border-bottom-color: transparent;
  }

  .cart-item__image {
    width: 80px;
    height: 80px;
    background: var(--color-cream-dark);
    flex-shrink: 0;
    overflow: hidden;
    display: block;
    border-radius: 4px;
    transition: opacity 0.2s;
  }

  .cart-item__image:hover { opacity: 0.8; }

  .cart-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__details {
    flex: 1;
    min-width: 0;
  }

  .cart-item__title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-charcoal);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    text-decoration: none;
    transition: color 0.2s;
  }

  a.cart-item__title:hover { color: var(--color-gold); }

  .cart-item__variant {
    font-size: 0.78rem;
    color: var(--color-stone);
    margin-top: 0.15rem;
  }

  .cart-item__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
  }

  .cart-item__qty {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--color-cream-dark);
    border-radius: 4px;
    overflow: hidden;
  }

  .cart-item__qty button {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    color: var(--color-slate);
    transition: background 0.2s;
  }
  .cart-item__qty button:hover:not(:disabled) { background: var(--color-cream-dark); }
  .cart-item__qty button:disabled { cursor: not-allowed; }

  .cart-item__qty span {
    width: 28px;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
  }

  @media (max-width: 767px) {
    .cart-item__qty button { width: 36px; height: 36px; font-size: 1rem; }
    .cart-item__qty span { width: 32px; font-size: 0.9rem; }
  }

  .cart-item__price {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .cart-item__remove {
    font-size: 0.72rem;
    color: var(--color-stone);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-top: 0.35rem;
    display: inline-block;
    transition: color 0.2s;
  }
  .cart-item__remove:hover { color: #c0392b; }

  /* ─── Empty state ─────────────────────── */
  .cart-drawer__empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .cart-empty__icon {
    margin-bottom: 0.75rem;
  }

  .cart-drawer__empty p {
    color: var(--color-stone);
    font-size: 0.95rem;
  }

  /* ─── Footer ──────────────────────────── */
  .cart-drawer__footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--color-cream-dark);
    background: var(--color-warm-white);
  }

  .cart-footer__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.25rem;
  }

  .cart-footer__row span:first-child {
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  .cart-footer__total {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .cart-footer__note {
    font-size: 0.75rem;
    color: var(--color-stone);
    margin-bottom: 1rem;
  }

  .cart-footer__rewards {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.72rem;
    font-weight: 500;
    color: #7a5a06;
    background: color-mix(in srgb, var(--color-gold, #b8860b) 12%, transparent);
    border-radius: 6px;
    letter-spacing: 0.02em;
  }
  .cart-footer__rewards svg {
    flex-shrink: 0;
    stroke: #7a5a06;
  }

  .cart-footer__mission {
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-slate);
    margin-top: 0.75rem;
    max-width: none;
  }


  /* ─── Cart Footer Trust ─────────────── */
  .cart-footer__trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-stone);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cart-footer__trust-dot { color: var(--color-cream-dark); }

  /* Cart badge bounce on add */
  @keyframes cartBadgeBounce {
    0% { transform: scale(1); }
    30% { transform: scale(1.5); }
    50% { transform: scale(0.9); }
    70% { transform: scale(1.2); }
    100% { transform: scale(1); }
  }

  .nav__cart-count.bounce {
    animation: cartBadgeBounce 0.5s var(--ease-out);
  }

  #mobile-cart-count.bounce {
    animation: cartBadgeBounce 0.5s var(--ease-out);
  }

  /* ─── Unit price ────────────────────────── */
  .cart-item__unit-price {
    font-size: 0.7rem;
    color: var(--color-stone);
    margin-top: 0.1rem;
  }

  /* ─── Checkout alert ──────────────────────── */
  .cart-footer__alert {
    background: #FEF2F2;
    border: 1px solid #FECACA;
    color: #991B1B;
    font-size: 0.8rem;
    line-height: 1.4;
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    margin-bottom: 0.75rem;
    animation: fadeInUp 0.25s ease both;
  }

  /* ─── Checkout loading state ────────────── */
  .cart-footer__checkout--loading {
    opacity: 0.6;
    pointer-events: none;
    position: relative;
  }

  /* ─── Toast notification ────────────────── */
  .cart-toast {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 300;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
    font-size: 0.85rem;
    font-weight: 500;
    opacity: 0;
    transform: translateY(-12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    max-width: 340px;
  }

  .cart-toast--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .cart-toast__img {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .cart-toast__text {
    flex: 1;
    min-width: 0;
    line-height: 1.3;
  }

  .cart-toast__title {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cart-toast__sub {
    display: block;
    font-size: 0.72rem;
    color: var(--color-gold);
    font-weight: 400;
  }

  .cart-toast__check {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .cart-toast {
      top: auto;
      bottom: 100px;
      right: 0.75rem;
      left: 0.75rem;
      max-width: none;
    }
  }
</style>

<script>
  import { cart } from '@/lib/cart-store.js';

  // No shipping — local pickup only

  // DOM refs — elements inside CartDrawer (transition:persist, never replaced)
  const overlay = document.getElementById('cart-overlay');
  const drawer = document.getElementById('cart-drawer');
  const closeBtn = document.getElementById('cart-close');
  const itemsEl = document.getElementById('cart-items');
  const emptyEl = document.getElementById('cart-empty');
  const footerEl = document.getElementById('cart-footer');
  const countEl = document.getElementById('cart-drawer-count');
  const totalEl = document.getElementById('cart-total');
  const shippingText = document.getElementById('shipping-text');
  const checkoutBtn = document.getElementById('cart-checkout');
  const alertEl = document.getElementById('cart-alert');
  const shippingEl = document.getElementById('cart-shipping');
  // Nav badge lives OUTSIDE CartDrawer (inside Nav, which is replaced on
  // each View Transition). Must query fresh each time — never cache the ref.

  // ─── Focus Trap ─────────────────────────
  function trapFocus(container, e) {
    const focusable = container.querySelectorAll(
      'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
    );
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  // ─── Open / Close ────────────────────────
  let previousFocus = null;

  function openCart() {
    previousFocus = document.activeElement;
    drawer?.setAttribute('aria-hidden', 'false');
    drawer?.removeAttribute('inert');
    overlay?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    // Focus the close button
    setTimeout(() => closeBtn?.focus(), 50);
  }

  function closeCart() {
    drawer?.setAttribute('aria-hidden', 'true');
    drawer?.setAttribute('inert', '');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Restore focus
    if (previousFocus && typeof previousFocus.focus === 'function') {
      previousFocus.focus();
    }
    previousFocus = null;
  }

  overlay?.addEventListener('click', closeCart);
  closeBtn?.addEventListener('click', closeCart);

  // Escape key and focus trap
  document.addEventListener('keydown', (e) => {
    if (drawer?.getAttribute('aria-hidden') === 'false') {
      if (e.key === 'Escape') closeCart();
      if (e.key === 'Tab') trapFocus(drawer, e);
    }
  });

  // Expose globally for nav cart button
  window.openCart = openCart;
  window.closeCart = closeCart;

  // ─── Badge bounce + toast on add ─────────
  const toastEl = document.getElementById('cart-toast');
  const toastTitle = document.getElementById('cart-toast-title');
  let toastTimer: ReturnType<typeof setTimeout> | undefined;

  window.showCartToast = function(title?: string) {
    // Badge bounce (fresh query — Nav elements replaced on View Transitions)
    [document.getElementById('cart-count'), document.getElementById('mobile-cart-count')].forEach(el => {
      if (!el) return;
      el.classList.remove('bounce');
      void el.offsetWidth;
      el.classList.add('bounce');
    });

    // Toast notification
    if (toastEl && toastTitle && title) {
      clearTimeout(toastTimer);
      toastTitle.textContent = title;
      toastEl.classList.add('cart-toast--visible');
      toastTimer = setTimeout(() => {
        toastEl.classList.remove('cart-toast--visible');
      }, 2500);
    }
  };

  function createCartItem(item) {
    const el = document.createElement('div');
    el.className = 'cart-item';
    el.dataset.id = item.variantId;

    const safeHandle = encodeURIComponent(item.handle || '');
    const link = `/shop/${safeHandle}/`;

    // Image
    const imgLink = document.createElement('a');
    imgLink.href = link;
    imgLink.className = 'cart-item__image';
    imgLink.addEventListener('click', () => window.closeCart?.());
    if (item.image) {
      const img = document.createElement('img');
      if (item.image.includes('cdn.shopify.com')) {
        const sep = item.image.includes('?') ? '&' : '?';
        img.src = `${item.image}${sep}width=160&crop=center`;
      } else {
        img.src = item.image;
      }
      img.alt = item.title || '';
      img.loading = 'lazy';
      imgLink.appendChild(img);
    }
    el.appendChild(imgLink);

    // Details
    const details = document.createElement('div');
    details.className = 'cart-item__details';

    const titleLink = document.createElement('a');
    titleLink.href = link;
    titleLink.className = 'cart-item__title';
    titleLink.textContent = item.title;
    titleLink.addEventListener('click', () => window.closeCart?.());
    details.appendChild(titleLink);

    if (item.variantTitle && item.variantTitle !== 'Default Title') {
      const variant = document.createElement('div');
      variant.className = 'cart-item__variant';
      variant.textContent = item.variantTitle;
      details.appendChild(variant);
    }

    const bottom = document.createElement('div');
    bottom.className = 'cart-item__bottom';

    const qtyWrap = document.createElement('div');
    qtyWrap.className = 'cart-item__qty';

    const minusBtn = document.createElement('button');
    minusBtn.textContent = '−';
    minusBtn.setAttribute('aria-label', 'Decrease quantity');
    if (item.qty <= 1) { minusBtn.disabled = true; minusBtn.style.opacity = '0.3'; }
    minusBtn.addEventListener('click', () => {
      const current = cart.getItems().find(i => i.variantId === item.variantId);
      if (current && current.qty > 1) cart.updateQty(item.variantId, current.qty - 1);
    });

    const qtySpan = document.createElement('span');
    qtySpan.textContent = String(item.qty);

    const plusBtn = document.createElement('button');
    plusBtn.textContent = '+';
    plusBtn.setAttribute('aria-label', 'Increase quantity');
    plusBtn.addEventListener('click', () => {
      const current = cart.getItems().find(i => i.variantId === item.variantId);
      if (current) cart.updateQty(item.variantId, current.qty + 1);
    });

    qtyWrap.append(minusBtn, qtySpan, plusBtn);

    const priceWrap = document.createElement('div');
    const priceSpan = document.createElement('span');
    priceSpan.className = 'cart-item__price';
    priceSpan.textContent = cart.formatMoney(item.price * item.qty);
    priceWrap.appendChild(priceSpan);

    if (item.qty > 1) {
      const unitPrice = document.createElement('div');
      unitPrice.className = 'cart-item__unit-price';
      unitPrice.textContent = `${cart.formatMoney(item.price)} each`;
      priceWrap.appendChild(unitPrice);
    }

    bottom.append(qtyWrap, priceWrap);
    details.appendChild(bottom);

    let removed = false;
    function animateRemove() {
      if (removed) return;
      el.classList.add('cart-item--removing');
      function doRemove() {
        if (removed) return;
        removed = true;
        cart.remove(item.variantId);
      }
      el.addEventListener('transitionend', doRemove, { once: true });
      // Fallback if transitionend doesn't fire
      setTimeout(doRemove, 400);
    }

    const removeBtn = document.createElement('button');
    removeBtn.className = 'cart-item__remove';
    removeBtn.textContent = 'Remove';
    removeBtn.addEventListener('click', animateRemove);
    details.appendChild(removeBtn);

    el.appendChild(details);
    return el;
  }

  // ─── Render ──────────────────────────────
  function renderCart(items) {
    const count = items.reduce((n, i) => n + i.qty, 0);
    const total = items.reduce((s, i) => s + i.price * i.qty, 0);

    // Nav badge (fresh query — Nav is replaced on each View Transition)
    const navCount = document.getElementById('cart-count');
    if (navCount) {
      navCount.textContent = String(count);
      navCount.style.display = count > 0 ? 'flex' : 'none';
    }

    // Drawer count badge
    if (countEl) {
      countEl.textContent = String(count);
      countEl.style.display = count > 0 ? 'inline-flex' : 'none';
    }

    // Show/hide empty vs items
    if (items.length === 0) {
      if (itemsEl) itemsEl.style.display = 'none';
      if (emptyEl) emptyEl.style.display = 'flex';
      if (footerEl) footerEl.style.display = 'none';
      if (shippingEl) shippingEl.style.display = 'none';
      if (alertEl) alertEl.style.display = 'none';
    } else {
      if (itemsEl) itemsEl.style.display = 'block';
      if (emptyEl) emptyEl.style.display = 'none';
      if (footerEl) footerEl.style.display = 'block';
      if (shippingEl) shippingEl.style.display = 'block';
    }

    // Local pickup notice (static)
    if (shippingText) {
      shippingText.textContent = 'Local pickup only — no shipping available';
    }

    // Total
    if (totalEl) totalEl.textContent = cart.formatMoney(total);

    // Items — smart DOM reconciliation (preserves remove animations)
    if (itemsEl) {
      const currentIds = new Set(items.map(i => i.variantId));
      const existingEls = itemsEl.querySelectorAll('.cart-item');

      // Remove DOM nodes for items no longer in cart (skip if already animating)
      existingEls.forEach(el => {
        if (!currentIds.has(el.dataset.id) && !el.classList.contains('cart-item--removing')) {
          el.remove();
        }
      });

      // Update existing or add new items
      items.forEach((item, idx) => {
        const existing = itemsEl.querySelector(`.cart-item[data-id="${CSS.escape(item.variantId)}"]`);
        if (existing && !existing.classList.contains('cart-item--removing')) {
          // Update qty and price in-place instead of replacing
          const qtySpan = existing.querySelector('.cart-item__qty span');
          if (qtySpan) qtySpan.textContent = String(item.qty);
          const priceSpan = existing.querySelector('.cart-item__price');
          if (priceSpan) priceSpan.textContent = cart.formatMoney(item.price * item.qty);
          // Update unit price
          let unitEl = existing.querySelector('.cart-item__unit-price');
          if (item.qty > 1) {
            if (!unitEl) {
              unitEl = document.createElement('div');
              unitEl.className = 'cart-item__unit-price';
              priceSpan?.parentElement?.appendChild(unitEl);
            }
            unitEl.textContent = `${cart.formatMoney(item.price)} each`;
          } else if (unitEl) {
            unitEl.remove();
          }
          // Disable minus at qty 1
          const minusBtn = existing.querySelector('.cart-item__qty button:first-child');
          if (minusBtn) {
            minusBtn.disabled = item.qty <= 1;
            minusBtn.style.opacity = item.qty <= 1 ? '0.3' : '1';
          }
        } else if (!existing) {
          // New item — create and insert at correct position
          const newEl = createCartItem(item);
          const children = itemsEl.querySelectorAll('.cart-item:not(.cart-item--removing)');
          if (children[idx]) {
            itemsEl.insertBefore(newEl, children[idx]);
          } else {
            itemsEl.appendChild(newEl);
          }
        }
      });
    }

  }

  // Subscribe to cart changes
  cart.subscribe(renderCart);

  // Surface Shopify errors in cart drawer
  cart.onError((error) => {
    if (alertEl && drawer?.getAttribute('aria-hidden') === 'false') {
      alertEl.textContent = error.message;
      alertEl.style.display = 'block';
      setTimeout(() => { alertEl.style.display = 'none'; }, 6000);
    }
  });

  // Checkout — uses Shopify Cart API checkoutUrl (server-validated)
  let checkoutInFlight = false;

  checkoutBtn?.addEventListener('click', async () => {
    if (checkoutInFlight) return;
    const items = cart.getItems();
    if (!items.length) return;

    checkoutInFlight = true;
    if (alertEl) alertEl.style.display = 'none';
    checkoutBtn.classList.add('cart-footer__checkout--loading');
    checkoutBtn.textContent = 'Preparing checkout…';

    // Ensure Shopify cart is synced and we have a valid checkoutUrl
    try {
      await cart.sync();
    } catch {
      // sync failed — try with whatever we have
    }

    const url = cart.getCheckoutUrl();
    if (url) {
      checkoutBtn.textContent = 'Redirecting…';
      window.location.href = url;
    } else {
      // No checkout URL — cart may have been emptied by Shopify (all items unavailable)
      checkoutBtn.classList.remove('cart-footer__checkout--loading');
      checkoutBtn.textContent = 'Proceed to Checkout';
      checkoutInFlight = false;
      const currentItems = cart.getItems();
      if (currentItems.length === 0 && items.length > 0) {
        // Shopify pruned everything — items were unavailable
        if (alertEl) {
          alertEl.textContent = 'Sorry, those items are no longer available.';
          alertEl.style.display = 'block';
        }
      } else if (alertEl) {
        alertEl.textContent = 'Unable to start checkout. Please try again.';
        alertEl.style.display = 'block';
      }
    }
  });

  // ─── Global: Add to cart from anywhere ───
  window.addToCart = function(product, qty = 1) {
    cart.add(product, qty);
    window.showCartToast(product.title);
    openCart();
  };

  // Reset checkout button if user navigates back
  window.addEventListener('pageshow', () => {
    checkoutInFlight = false;
    if (checkoutBtn) {
      checkoutBtn.classList.remove('cart-footer__checkout--loading');
      checkoutBtn.textContent = 'Proceed to Checkout';
    }
    if (alertEl) alertEl.style.display = 'none';
  });

</script>
