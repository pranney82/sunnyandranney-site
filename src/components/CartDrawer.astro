---
// Cart Drawer — rendered on every page via Base layout
---

<!-- Cart Overlay -->
<div class="cart-overlay" id="cart-overlay" aria-hidden="true"></div>

<!-- Cart Drawer -->
<aside class="cart-drawer" id="cart-drawer" aria-hidden="true" inert aria-label="Shopping cart">
  <div class="cart-drawer__header">
    <h3>Your Cart <span class="cart-drawer__count" id="cart-drawer-count"></span></h3>
    <button class="cart-drawer__close" id="cart-close" aria-label="Close cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Local pickup notice -->
  <div class="cart-drawer__shipping" id="cart-shipping">
    <p class="shipping-bar__text" id="shipping-text" style="text-align:center;">Local pickup only — no shipping available</p>
  </div>

  <!-- Cart items -->
  <div class="cart-drawer__items" id="cart-items">
    <!-- Populated by JS -->
  </div>

  <!-- You might also like -->
  <div class="cart-upsell" id="cart-upsell" style="display:none;" aria-label="You might also like">
    <p class="cart-upsell__label">You might also like</p>
    <div class="cart-upsell__products" id="cart-upsell-products"></div>
  </div>

  <!-- Empty state -->
  <div class="cart-drawer__empty" id="cart-empty" style="display:none;">
    <div class="cart-empty__icon"></div>
    <p>Your cart is empty</p>
    <a href="/shop" class="btn btn--primary" style="margin-top: 1rem;">Start Shopping</a>
  </div>

  <!-- Cart footer -->
  <div class="cart-drawer__footer" id="cart-footer" style="display:none;">
    <div class="cart-footer__row">
      <span>Subtotal</span>
      <span class="cart-footer__total" id="cart-total">$0.00</span>
    </div>
    <p class="cart-footer__note">Taxes calculated at checkout · Local pickup only</p>
    <button class="btn btn--gold cart-footer__checkout" id="cart-checkout" style="width:100%; justify-content:center;">
      Proceed to Checkout
    </button>
    <div class="cart-footer__trust">
      <span>Secure checkout</span>
      <span class="cart-footer__trust-dot">·</span>
      <span>100% to charity</span>
    </div>
  </div>
</aside>

<!-- Toast notification -->

<style>
  /* ─── Overlay ─────────────────────────── */
  .cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 200;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
    backdrop-filter: blur(2px);
  }
  .cart-overlay[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  /* ─── Drawer ──────────────────────────── */
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 420px;
    max-width: 92vw;
    background: var(--color-cream);
    z-index: 201;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.08);
  }
  .cart-drawer[aria-hidden="false"] {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .cart-drawer__header h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cart-drawer__count {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--color-gold);
    color: var(--color-charcoal);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer__close {
    padding: 0.5rem;
    color: var(--color-stone);
    transition: color 0.2s;
  }
  .cart-drawer__close:hover { color: var(--color-charcoal); }

  /* ─── Shipping Progress ───────────────── */
  .cart-drawer__shipping {
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .shipping-bar {
    width: 100%;
    height: 4px;
    background: var(--color-cream-dark);
    border-radius: 2px;
    overflow: hidden;
  }

  .shipping-bar__fill {
    height: 100%;
    background: var(--color-gold);
    border-radius: 2px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .shipping-bar__text {
    font-size: 0.78rem;
    color: var(--color-slate);
    margin-top: 0.4rem;
    text-align: center;
    max-width: none;
  }

  .shipping-bar__text strong {
    color: var(--color-charcoal);
    font-weight: 600;
  }

  /* ─── Cart Items ──────────────────────── */
  .cart-drawer__items {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.5rem;
  }

  .cart-item {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-cream-dark);
    animation: fadeInUp 0.3s ease both;
  }

  .cart-item__image {
    width: 80px;
    height: 80px;
    background: var(--color-cream-dark);
    flex-shrink: 0;
    overflow: hidden;
    display: block;
    border-radius: 4px;
    transition: opacity 0.2s;
  }

  .cart-item__image:hover { opacity: 0.8; }

  .cart-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__details {
    flex: 1;
    min-width: 0;
  }

  .cart-item__title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-charcoal);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    text-decoration: none;
    transition: color 0.2s;
  }

  a.cart-item__title:hover { color: var(--color-gold); }

  .cart-item__variant {
    font-size: 0.78rem;
    color: var(--color-stone);
    margin-top: 0.15rem;
  }

  .cart-item__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
  }

  .cart-item__qty {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--color-cream-dark);
    border-radius: 4px;
    overflow: hidden;
  }

  .cart-item__qty button {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    color: var(--color-slate);
    transition: background 0.2s;
  }
  .cart-item__qty button:hover { background: var(--color-cream-dark); }

  .cart-item__qty span {
    width: 28px;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .cart-item__price {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .cart-item__remove {
    font-size: 0.72rem;
    color: var(--color-stone);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-top: 0.35rem;
    display: inline-block;
    transition: color 0.2s;
  }
  .cart-item__remove:hover { color: #c0392b; }

  /* ─── Empty state ─────────────────────── */
  .cart-drawer__empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .cart-empty__icon {
    font-size: 3rem;
    margin-bottom: 0.75rem;
    opacity: 0.5;
  }

  .cart-drawer__empty p {
    color: var(--color-stone);
    font-size: 0.95rem;
  }

  /* ─── Footer ──────────────────────────── */
  .cart-drawer__footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--color-cream-dark);
    background: var(--color-warm-white);
  }

  .cart-footer__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.25rem;
  }

  .cart-footer__row span:first-child {
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  .cart-footer__total {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }

  .cart-footer__note {
    font-size: 0.75rem;
    color: var(--color-stone);
    margin-bottom: 1rem;
  }

  .cart-footer__mission {
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-slate);
    margin-top: 0.75rem;
    max-width: none;
  }


  /* ─── Cart Footer Trust ─────────────── */
  .cart-footer__trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-stone);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cart-footer__trust-dot { color: var(--color-cream-dark); }

  /* Cart badge bounce on add */
  @keyframes cartBadgeBounce {
    0% { transform: scale(1); }
    30% { transform: scale(1.5); }
    50% { transform: scale(0.9); }
    70% { transform: scale(1.2); }
    100% { transform: scale(1); }
  }

  :global(.nav__cart-count.bounce) {
    animation: cartBadgeBounce 0.5s var(--ease-out);
  }

  :global(#mobile-cart-count.bounce) {
    animation: cartBadgeBounce 0.5s var(--ease-out);
  }

  /* ─── Cart Upsell ──────────────────────── */
  .cart-upsell {
    border-top: 1px solid var(--color-cream-dark);
    padding: 0.875rem 1rem;
    flex-shrink: 0;
  }

  .cart-upsell__label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-stone);
    margin-bottom: 0.65rem;
  }

  .cart-upsell__products {
    display: flex;
    gap: 0.625rem;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .cart-upsell__products::-webkit-scrollbar { display: none; }

  .cart-upsell-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 0 0 100px;
    text-decoration: none;
    color: var(--color-charcoal);
    transition: opacity 0.15s;
  }

  .cart-upsell-card:hover { opacity: 0.75; }

  .cart-upsell-card__img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 4px;
    background: var(--color-cream-dark);
    display: block;
  }

  .cart-upsell-card__title {
    font-size: 0.68rem;
    font-weight: 500;
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .cart-upsell-card__price {
    font-size: 0.65rem;
    color: var(--color-slate);
  }

  .cart-upsell-card__add {
    margin-top: 0.2rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--color-gold);
    color: var(--color-charcoal);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.15s;
    width: 100%;
  }

  .cart-upsell-card__add:hover { background: var(--color-gold-light, #ffe033); }
</style>

<script>
  import { cart } from '@/lib/cart-store.js';

  // No shipping — local pickup only

  // DOM refs
  const overlay = document.getElementById('cart-overlay');
  const drawer = document.getElementById('cart-drawer');
  const closeBtn = document.getElementById('cart-close');
  const itemsEl = document.getElementById('cart-items');
  const emptyEl = document.getElementById('cart-empty');
  const footerEl = document.getElementById('cart-footer');
  const countEl = document.getElementById('cart-drawer-count');
  const totalEl = document.getElementById('cart-total');
  const navCount = document.getElementById('cart-count');
  const shippingText = document.getElementById('shipping-text');
  const checkoutBtn = document.getElementById('cart-checkout');
  const upsellEl = document.getElementById('cart-upsell');
  const upsellProductsEl = document.getElementById('cart-upsell-products');

  // ─── Focus Trap ─────────────────────────
  function trapFocus(container, e) {
    const focusable = container.querySelectorAll(
      'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
    );
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  // ─── Open / Close ────────────────────────
  let previousFocus = null;

  function openCart() {
    previousFocus = document.activeElement;
    drawer?.setAttribute('aria-hidden', 'false');
    drawer?.removeAttribute('inert');
    overlay?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    // Focus the close button
    setTimeout(() => closeBtn?.focus(), 50);
  }

  function closeCart() {
    drawer?.setAttribute('aria-hidden', 'true');
    drawer?.setAttribute('inert', '');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Restore focus
    if (previousFocus && typeof previousFocus.focus === 'function') {
      previousFocus.focus();
    }
    previousFocus = null;
  }

  overlay?.addEventListener('click', closeCart);
  closeBtn?.addEventListener('click', closeCart);

  // Escape key and focus trap
  document.addEventListener('keydown', (e) => {
    if (drawer?.getAttribute('aria-hidden') === 'false') {
      if (e.key === 'Escape') closeCart();
      if (e.key === 'Tab') trapFocus(drawer, e);
    }
  });

  // Expose globally for nav cart button
  window.openCart = openCart;
  window.closeCart = closeCart;

  // ─── Badge bounce on add ────────────────
  window.showCartToast = function() {
    [navCount, document.getElementById('mobile-cart-count')].forEach(el => {
      if (!el) return;
      el.classList.remove('bounce');
      void el.offsetWidth;
      el.classList.add('bounce');
    });
  };

  function createCartItem(item) {
    const el = document.createElement('div');
    el.className = 'cart-item';
    el.dataset.id = item.variantId;

    const safeHandle = encodeURIComponent(item.handle || '');
    const link = `/shop/${safeHandle}`;

    // Image
    const imgLink = document.createElement('a');
    imgLink.href = link;
    imgLink.className = 'cart-item__image';
    imgLink.addEventListener('click', () => window.closeCart?.());
    if (item.image) {
      const img = document.createElement('img');
      if (item.image.includes('cdn.shopify.com')) {
        const sep = item.image.includes('?') ? '&' : '?';
        img.src = `${item.image}${sep}width=160&crop=center`;
      } else {
        img.src = item.image;
      }
      img.alt = item.title || '';
      img.loading = 'lazy';
      imgLink.appendChild(img);
    }
    el.appendChild(imgLink);

    // Details
    const details = document.createElement('div');
    details.className = 'cart-item__details';

    const titleLink = document.createElement('a');
    titleLink.href = link;
    titleLink.className = 'cart-item__title';
    titleLink.textContent = item.title;
    titleLink.addEventListener('click', () => window.closeCart?.());
    details.appendChild(titleLink);

    if (item.variantTitle && item.variantTitle !== 'Default Title') {
      const variant = document.createElement('div');
      variant.className = 'cart-item__variant';
      variant.textContent = item.variantTitle;
      details.appendChild(variant);
    }

    const bottom = document.createElement('div');
    bottom.className = 'cart-item__bottom';

    const qtyWrap = document.createElement('div');
    qtyWrap.className = 'cart-item__qty';

    const minusBtn = document.createElement('button');
    minusBtn.textContent = '−';
    minusBtn.setAttribute('aria-label', 'Decrease quantity');
    minusBtn.addEventListener('click', () => {
      const current = cart.getItems().find(i => i.variantId === item.variantId);
      if (current && current.qty > 1) cart.updateQty(item.variantId, current.qty - 1);
      else cart.remove(item.variantId);
    });

    const qtySpan = document.createElement('span');
    qtySpan.textContent = String(item.qty);

    const plusBtn = document.createElement('button');
    plusBtn.textContent = '+';
    plusBtn.setAttribute('aria-label', 'Increase quantity');
    plusBtn.addEventListener('click', () => {
      const current = cart.getItems().find(i => i.variantId === item.variantId);
      if (current) cart.updateQty(item.variantId, current.qty + 1);
    });

    qtyWrap.append(minusBtn, qtySpan, plusBtn);

    const priceSpan = document.createElement('span');
    priceSpan.className = 'cart-item__price';
    priceSpan.textContent = `$${(item.price * item.qty).toFixed(2)}`;

    bottom.append(qtyWrap, priceSpan);
    details.appendChild(bottom);

    const removeBtn = document.createElement('button');
    removeBtn.className = 'cart-item__remove';
    removeBtn.textContent = 'Remove';
    removeBtn.addEventListener('click', () => cart.remove(item.variantId));
    details.appendChild(removeBtn);

    el.appendChild(details);
    return el;
  }

  // ─── Render ──────────────────────────────
  function renderCart(items) {
    const count = items.reduce((n, i) => n + i.qty, 0);
    const total = items.reduce((s, i) => s + i.price * i.qty, 0);

    // Nav badge
    if (navCount) {
      navCount.textContent = String(count);
      navCount.style.display = count > 0 ? 'flex' : 'none';
    }

    // Drawer count badge
    if (countEl) {
      countEl.textContent = String(count);
      countEl.style.display = count > 0 ? 'inline-flex' : 'none';
    }

    // Show/hide empty vs items
    if (items.length === 0) {
      if (itemsEl) itemsEl.style.display = 'none';
      if (emptyEl) emptyEl.style.display = 'flex';
      if (footerEl) footerEl.style.display = 'none';
    } else {
      if (itemsEl) itemsEl.style.display = 'block';
      if (emptyEl) emptyEl.style.display = 'none';
      if (footerEl) footerEl.style.display = 'block';
    }

    // Local pickup notice (static)
    if (shippingText) {
      shippingText.textContent = 'Local pickup only — no shipping available';
    }

    // Total
    if (totalEl) totalEl.textContent = '$' + total.toFixed(2);

    // Items — DOM-based rendering (no innerHTML with user data)
    if (itemsEl) {
      itemsEl.replaceChildren(...items.map(createCartItem));
    }

    // Upsell: show when cart has items
    if (items.length > 0) {
      loadUpsells(items.map(i => i.handle));
    } else if (upsellEl) {
      upsellEl.style.display = 'none';
    }
  }

  // ─── Cart upsells ─────────────────────────────
  let upsellCache: any[] | null = null;

  async function loadUpsells(cartHandles: string[]) {
    if (!upsellEl || !upsellProductsEl) return;

    if (!upsellCache) {
      const domain = (window as any).__SHOPIFY_DOMAIN || 'sunnyandranney.myshopify.com';
      const token = (window as any).__SHOPIFY_TOKEN || '';
      if (!token) return;

      try {
        const res = await fetch(`https://${domain}/api/2025-01/graphql.json`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Shopify-Storefront-Access-Token': token },
          body: JSON.stringify({ query: `{
            products(first: 12, sortKey: BEST_SELLING) {
              edges { node {
                title handle availableForSale
                priceRange { minVariantPrice { amount } }
                variants(first: 1) { edges { node { id } } }
                images(first: 1) { edges { node { url } } }
              } }
            }
          }` }),
        });
        const json = await res.json();
        upsellCache = (json.data?.products?.edges ?? []).map((e: any) => ({
          title: e.node.title,
          handle: e.node.handle,
          price: e.node.priceRange.minVariantPrice.amount,
          image: e.node.images.edges[0]?.node?.url || '',
          variantId: e.node.variants.edges[0]?.node?.id || '',
          available: e.node.availableForSale,
        }));
      } catch {
        return;
      }
    }

    const suggestions = (upsellCache ?? [])
      .filter(p => !cartHandles.includes(p.handle) && p.available)
      .slice(0, 4);

    if (!suggestions.length) { upsellEl.style.display = 'none'; return; }

    upsellProductsEl.replaceChildren();
    suggestions.forEach(p => {
      const card = document.createElement('a');
      card.href = `/shop/${p.handle}`;
      card.className = 'cart-upsell-card';
      card.addEventListener('click', closeCart);

      if (p.image) {
        const img = document.createElement('img');
        img.src = p.image.includes('cdn.shopify.com') ? `${p.image}?width=200` : p.image;
        img.alt = p.title;
        img.className = 'cart-upsell-card__img';
        img.loading = 'lazy';
        img.width = 100;
        img.height = 100;
        card.appendChild(img);
      }

      const title = document.createElement('span');
      title.className = 'cart-upsell-card__title';
      title.textContent = p.title;
      card.appendChild(title);

      const price = document.createElement('span');
      price.className = 'cart-upsell-card__price';
      price.textContent = `$${parseFloat(p.price).toFixed(2)}`;
      card.appendChild(price);

      const addBtn = document.createElement('button');
      addBtn.className = 'cart-upsell-card__add';
      addBtn.textContent = 'Add';
      addBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        window.addToCart?.({ variantId: p.variantId, handle: p.handle, title: p.title, price: parseFloat(p.price), image: p.image, variantTitle: '' });
      });
      card.appendChild(addBtn);

      upsellProductsEl.appendChild(card);
    });

    upsellEl.style.display = 'block';
  }

  // Subscribe to cart changes
  cart.subscribe(renderCart);

  // Checkout
  checkoutBtn?.addEventListener('click', () => {
    const url = cart.getCheckoutUrl();
    if (url) window.location.href = url;
  });

  // ─── Global: Add to cart from anywhere ───
  window.addToCart = function(product, qty = 1) {
    cart.add(product, qty);
    window.showCartToast(`${product.title} added to cart`);
  };

</script>
