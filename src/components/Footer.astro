---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__main container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/logo-tagline-dark-bg/w=500,h=200,fit=scale-down"
          alt="Sunny & Ranney"
          class="footer__logo-img"
          width="500"
          height="200"
          loading="lazy"
          decoding="async"
        />
        <p class="footer__description">
          Curated furniture & home decor in Roswell, GA.
          100% of profits fund <a href="/mission" class="footer__mission-link">Sunshine on a Ranney Day</a> — bedroom makeovers for children with special needs.
        </p>
        <div class="footer__social">
          <a href="https://www.instagram.com/sunnyandranney/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/sunnyandranney/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Shop -->
      <div class="footer__col">
        <h3 class="footer__heading">Shop</h3>
        <nav aria-label="Shop links">
          <ul class="footer__nav">
            <li><a href="/shop">All Products</a></li>
            <li><a href="/collections/new-arrivals">New Arrivals</a></li>
            <li><a href="/shop?category=furniture">Furniture</a></li>
            <li><a href="/shop?category=decor">Home Decor</a></li>
            <li><a href="/shop?category=lighting">Lighting</a></li>
            <li><a href="/shop?category=kitchenware">Kitchenware</a></li>
            <li><a href="/shop?category=gifts">Gifts</a></li>
            <li><a href="/collections/sale">Sale</a></li>
          </ul>
        </nav>
      </div>

      <!-- Company -->
      <div class="footer__col">
        <h3 class="footer__heading">Company</h3>
        <nav aria-label="Company links">
          <ul class="footer__nav">
            <li><a href="/mission">Our Mission</a></li>
            <li><a href="/team">Our Team</a></li>
            <li><a href="https://sunshineonaranneyday.com" target="_blank" rel="noopener noreferrer">
              Sunshine on a Ranney Day
              <svg class="footer__external-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a></li>
          </ul>
        </nav>
      </div>

      <!-- Visit Us -->
      <div class="footer__col">
        <h3 class="footer__heading">Visit Us</h3>
        <address class="footer__address">
          <p>109A Oak Street<br />Roswell, GA 30075</p>
          <p class="footer__hours">Tue&ndash;Thu 10&ndash;5 &middot; Fri&ndash;Sat 10&ndash;6</p>
          <p>
            <a href="tel:6788885140">678.888.5140</a><br />
            <a href="mailto:info@sunnyandranney.com">info@sunnyandranney.com</a>
          </p>
        </address>
      </div>
    </div>
  </div>

  <!-- ─── Bottom Bar ─── -->
  <div class="footer__bottom container">
    <p>&copy; {currentYear} Sunny & Ranney. All rights reserved.</p>
    <nav class="footer__legal" aria-label="Legal">
      <a href="https://sunnyandranney.myshopify.com/policies/privacy-policy" target="_blank" rel="noopener noreferrer">Privacy</a>
      <a href="https://sunnyandranney.myshopify.com/policies/terms-of-service" target="_blank" rel="noopener noreferrer">Terms</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-charcoal);
    color: var(--color-cream);
  }

  /* ─── Footer Main ─────────────────────── */
  .footer__main {
    padding: var(--space-xl) var(--space-md) var(--space-lg);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.8fr 1fr 1fr 1fr;
      gap: var(--space-xl);
    }
  }

  /* Brand column */
  .footer__logo-img {
    height: 56px;
    width: auto;
    object-fit: contain;
    display: block;
    margin-bottom: var(--space-sm);
    aspect-ratio: 5 / 2;
  }

  .footer__description {
    color: var(--color-stone);
    font-size: 0.85rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
    max-width: 34ch;
  }

  .footer__mission-link {
    color: var(--color-gold);
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .footer__mission-link:hover {
    opacity: 0.8;
  }

  .footer__mission-link:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .footer__social {
    display: flex;
    gap: 0.5rem;
  }

  .footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: var(--color-stone);
    background: rgba(255, 255, 255, 0.05);
    transition: color 0.3s, background 0.3s;
  }

  .footer__social a:hover {
    color: var(--color-charcoal);
    background: var(--color-gold);
  }

  .footer__social a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
    border-radius: 50%;
  }

  /* Nav columns */
  .footer__heading {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
  }

  .footer__nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__nav a {
    color: var(--color-stone);
    font-size: 0.85rem;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
  }

  .footer__nav a:hover {
    color: var(--color-cream);
  }

  .footer__nav a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .footer__external-icon {
    opacity: 0.4;
    flex-shrink: 0;
  }

  /* Address */
  .footer__address {
    color: var(--color-stone);
    font-size: 0.85rem;
    font-style: normal;
    line-height: 1.6;
  }

  .footer__address p {
    margin: 0 0 0.5rem;
    max-width: none;
  }

  .footer__hours {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.35);
  }

  .footer__address a {
    color: var(--color-stone);
    transition: color 0.2s;
  }

  .footer__address a:hover {
    color: var(--color-cream);
  }

  .footer__address a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ─── Bottom Bar ───────────────────────── */
  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: var(--space-sm) var(--space-md);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .footer__bottom p {
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.75rem;
  }

  .footer__legal {
    display: flex;
    gap: 1.25rem;
  }

  .footer__legal a {
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.75rem;
    transition: color 0.2s;
  }

  .footer__legal a:hover {
    color: var(--color-cream);
  }

  .footer__legal a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
