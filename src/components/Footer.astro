---
import type { ContactInfo, StoreHours } from '@/lib/settings';

interface Props {
  hours?: string | null;
  contact?: ContactInfo | null;
  holidays?: StoreHours['holidays'];
}

const { hours, contact, holidays = [] } = Astro.props;
const currentYear = new Date().getFullYear();
const displayHours = hours || 'Tue\u2013Thu 10\u20135 \u00b7 Fri\u2013Sat 10\u20136';

const address = contact?.address || '109A Oak Street';
const city = contact?.city || 'Roswell';
const state = contact?.state || 'GA';
const zip = contact?.zip || '30075';
const phone = contact?.phone || '678.888.5140';
const email = contact?.email || 'info@sunnyandranney.com';
const instagramUrl = contact?.instagramUrl || 'https://www.instagram.com/sunnyandranney/';
const facebookUrl = contact?.facebookUrl || 'https://www.facebook.com/sunnyandranney/';
const phoneDigits = phone.replace(/\D/g, '');
---

<footer class="footer">
  <div class="footer__main container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/logo-tagline-dark-bg/w=500,h=200,fit=scale-down"
          alt="Sunny & Ranney"
          class="footer__logo-img"
          width="500"
          height="200"
          loading="lazy"
          decoding="async"
        />
        <p class="footer__description">
          Curated furniture & home decor in Roswell, GA.
          100% of profits fund <a href="/about" class="footer__mission-link">Sunshine on a Ranney Day</a> — bedroom makeovers for children with special needs.
        </p>
        <div class="footer__social">
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href={facebookUrl} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Shop -->
      <details class="footer__col" open>
        <summary class="footer__heading">
          Shop
          <svg class="footer__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <nav aria-label="Shop links">
          <ul class="footer__nav">
            <li><a href="/shop">All Products</a></li>
            <li><a href="/shop?sort=newest">New Arrivals</a></li>
            <li><a href="/shop?category=furniture">Furniture</a></li>
            <li><a href="/shop?category=decor">Home Decor</a></li>
            <li><a href="/shop?category=lighting">Lighting</a></li>
            <li><a href="/shop?category=kitchenware">Kitchenware</a></li>
            <li><a href="/shop?category=gifts">Gifts</a></li>
            <li><a href="/shop?sale=true">Sale</a></li>
          </ul>
        </nav>
      </details>

      <!-- Company -->
      <details class="footer__col" open>
        <summary class="footer__heading">
          Company
          <svg class="footer__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <nav aria-label="Company links">
          <ul class="footer__nav">
            <li><a href="/about">About Us</a></li>
            <li><a href="https://sunshineonaranneyday.com" target="_blank" rel="noopener noreferrer">
              Sunshine on a Ranney Day
              <svg class="footer__external-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a></li>
          </ul>
        </nav>
      </details>

      <!-- Visit Us -->
      <details class="footer__col" open>
        <summary class="footer__heading">
          Visit Us
          <svg class="footer__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <address class="footer__address">
          <p>{address}<br />{city}, {state} {zip}</p>
          <p class="footer__hours">{displayHours}</p>
          {holidays.length > 0 && (
            <div class="footer__holiday-hours" data-holidays={JSON.stringify(holidays)}></div>
          )}
          <p>
            <a href={`tel:${phoneDigits}`}>{phone}</a><br />
            <a href={`mailto:${email}`}>{email}</a>
          </p>
        </address>
      </details>
    </div>
  </div>

  <!-- ─── Bottom Bar ─── -->
  <div class="footer__bottom container">
    <p>&copy; {currentYear} Sunny & Ranney. All rights reserved.</p>
    <div class="footer__payment" aria-label="Accepted payment methods">
      <!-- Visa -->
      <svg width="38" height="24" viewBox="0 0 38 24" fill="none" aria-label="Visa"><rect width="38" height="24" rx="3" fill="rgba(255,255,255,0.08)"/><path d="M15.8 15.5h-2.2l1.4-8.5h2.2l-1.4 8.5zm9.1-8.3c-.4-.2-1.1-.3-2-.3-2.2 0-3.7 1.2-3.7 2.8 0 1.2 1.1 1.9 2 2.3.9.4 1.2.7 1.2 1.1 0 .6-.7.9-1.4.9-.9 0-1.4-.1-2.2-.5l-.3-.1-.3 2c.5.3 1.5.5 2.5.5 2.3 0 3.8-1.1 3.8-2.9 0-1-.6-1.7-1.9-2.3-.8-.4-1.3-.7-1.3-1.1 0-.4.4-.8 1.3-.8.7 0 1.3.2 1.7.3l.2.1.4-2zm5.6-.2h-1.7c-.5 0-.9.1-1.1.7l-3.2 7.8h2.3l.5-1.3h2.8l.3 1.3h2l-1.9-8.5zm-2.7 5.5l1.2-3.2.3 1.5.5 1.7h-2zm-14-5.5l-2 5.8-.2-1.1-.8-3.8c-.1-.5-.5-.7-1-.7H7l-.1.3c.7.2 1.5.4 2 .7l1.9 7.3h2.3l3.5-8.5h-2.8z" fill="rgba(255,255,255,0.5)"/></svg>
      <!-- Mastercard -->
      <svg width="38" height="24" viewBox="0 0 38 24" fill="none" aria-label="Mastercard"><rect width="38" height="24" rx="3" fill="rgba(255,255,255,0.08)"/><circle cx="15" cy="12" r="6" fill="rgba(255,255,255,0.15)"/><circle cx="23" cy="12" r="6" fill="rgba(255,255,255,0.12)"/></svg>
      <!-- Amex -->
      <svg width="38" height="24" viewBox="0 0 38 24" fill="none" aria-label="American Express"><rect width="38" height="24" rx="3" fill="rgba(255,255,255,0.08)"/><text x="19" y="14" text-anchor="middle" font-size="7" font-weight="700" fill="rgba(255,255,255,0.4)" font-family="sans-serif">AMEX</text></svg>
      <!-- Apple Pay -->
      <svg width="38" height="24" viewBox="0 0 38 24" fill="none" aria-label="Apple Pay"><rect width="38" height="24" rx="3" fill="rgba(255,255,255,0.08)"/><text x="19" y="14" text-anchor="middle" font-size="6.5" font-weight="600" fill="rgba(255,255,255,0.4)" font-family="sans-serif">Pay</text></svg>
      <!-- PayPal -->
      <svg width="38" height="24" viewBox="0 0 38 24" fill="none" aria-label="PayPal"><rect width="38" height="24" rx="3" fill="rgba(255,255,255,0.08)"/><text x="19" y="14" text-anchor="middle" font-size="6" font-weight="600" fill="rgba(255,255,255,0.4)" font-family="sans-serif">PayPal</text></svg>
    </div>
    <nav class="footer__legal" aria-label="Legal">
      <a href="https://sunnyandranney.myshopify.com/policies/privacy-policy" target="_blank" rel="noopener noreferrer">Privacy</a>
      <a href="https://sunnyandranney.myshopify.com/policies/terms-of-service" target="_blank" rel="noopener noreferrer">Terms</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-charcoal);
    color: var(--color-cream);
    margin-top: -1px;
  }

  /* ─── Footer Main ─────────────────────── */
  .footer__main {
    padding: var(--space-xl) var(--space-md) var(--space-lg);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.8fr 1fr 1fr 1fr;
      gap: var(--space-xl);
    }
  }

  /* ─── Brand column ──────────────────────── */
  .footer__logo-img {
    height: 56px;
    width: auto;
    object-fit: contain;
    display: block;
    margin-bottom: var(--space-sm);
    aspect-ratio: 5 / 2;
  }

  .footer__description {
    color: #A0A09D;
    font-size: 0.85rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
    max-width: 34ch;
  }

  .footer__mission-link {
    color: var(--color-gold);
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .footer__mission-link:hover {
    opacity: 0.8;
  }

  .footer__mission-link:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .footer__social {
    display: flex;
    gap: 0.5rem;
  }

  .footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: var(--color-stone);
    background: rgba(255, 255, 255, 0.05);
    transition: color 0.3s, background 0.3s;
  }

  .footer__social a:first-child:hover {
    color: white;
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
  }

  .footer__social a:last-child:hover {
    color: white;
    background: var(--color-cyan);
  }

  .footer__social a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
    border-radius: 50%;
  }

  /* ─── Nav columns (details/summary accordion) ─── */
  .footer__col {
    border: none;
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Hide native marker */
  .footer__heading::-webkit-details-marker {
    display: none;
  }
  .footer__heading::marker {
    content: '';
  }

  .footer__chevron {
    display: none;
  }

  /* Desktop: always open, no interaction */
  @media (min-width: 768px) {
    .footer__col {
      pointer-events: none;
    }
    .footer__col a,
    .footer__col nav {
      pointer-events: auto;
    }
    .footer__heading {
      cursor: default;
    }
  }

  /* Mobile: accordion behavior */
  @media (max-width: 767px) {
    .footer__chevron {
      display: block;
      transition: transform 0.3s;
      color: var(--color-stone);
      flex-shrink: 0;
    }
    .footer__col[open] > .footer__heading .footer__chevron {
      transform: rotate(180deg);
    }
    .footer__heading {
      cursor: pointer;
      padding: 0.75rem 0;
      margin-bottom: 0;
      -webkit-tap-highlight-color: transparent;
    }
    .footer__col > nav,
    .footer__col > address {
      padding-bottom: var(--space-xs);
    }
  }

  .footer__nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__nav a {
    color: #A0A09D;
    font-size: 0.85rem;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    min-height: 44px;
    padding: 0.25rem 0;
  }

  @media (min-width: 768px) {
    .footer__nav a {
      min-height: unset;
      padding: 0;
    }
  }

  .footer__nav a:hover {
    color: var(--color-cream);
  }

  .footer__nav a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .footer__external-icon {
    opacity: 0.4;
    flex-shrink: 0;
  }

  /* ─── Address ──────────────────────────── */
  .footer__address {
    color: #A0A09D;
    font-size: 0.85rem;
    font-style: normal;
    line-height: 1.6;
  }

  .footer__address p {
    margin: 0 0 0.5rem;
    max-width: none;
  }

  .footer__hours {
    font-size: 0.78rem;
    color: var(--color-cyan);
    opacity: 0.6;
  }

  .footer__holiday-hours {
    font-size: 0.75rem;
    color: var(--color-gold);
    opacity: 0.7;
    margin-top: 0.15rem;
    line-height: 1.5;
  }

  .footer__address a {
    color: #A0A09D;
    transition: color 0.2s;
  }

  .footer__address a:hover {
    color: var(--color-cream);
  }

  .footer__address a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ─── Bottom Bar ───────────────────────── */
  .footer__bottom {
    padding: var(--space-sm) var(--space-md);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .footer__bottom p {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.75rem;
  }

  .footer__payment {
    display: flex;
    gap: 0.35rem;
    align-items: center;
  }

  .footer__legal {
    display: flex;
    gap: 1.25rem;
  }

  .footer__legal a {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.75rem;
    transition: color 0.2s;
  }

  .footer__legal a:hover {
    color: var(--color-cream);
  }

  .footer__legal a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ─── Mobile overrides ─────────────────── */
  @media (max-width: 767px) {
    .footer__main {
      padding: var(--space-lg) var(--space-md) var(--space-sm);
    }
    .footer__grid {
      gap: 0;
    }
    .footer__brand {
      margin-bottom: var(--space-sm);
    }
    .footer__brand .footer__description {
      max-width: none;
    }
    .footer__logo-img {
      height: 48px;
    }
    .footer__address a {
      word-break: break-all;
    }
    .footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.5rem;
      padding: var(--space-md) var(--space-md);
    }
    .footer__payment {
      order: -1;
    }
  }
</style>

<script>
  function initFooterAccordion() {
    if (window.innerWidth >= 768) return;
    document.querySelectorAll<HTMLDetailsElement>('.footer__col').forEach(d => {
      d.removeAttribute('open');
    });
  }

  function formatTime(time: string): string {
    const [h, m] = time.split(':').map(Number);
    const suffix = h >= 12 ? 'pm' : 'am';
    const hour = h > 12 ? h - 12 : h === 0 ? 12 : h;
    return m === 0 ? `${hour}${suffix}` : `${hour}:${m.toString().padStart(2, '0')}${suffix}`;
  }

  function initHolidayDisplay() {
    const el = document.querySelector('.footer__holiday-hours') as HTMLElement | null;
    if (!el) return;
    const holidays = JSON.parse(el.dataset.holidays || '[]');
    if (!holidays.length) return;

    const today = new Date().toISOString().split('T')[0];
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() + 30);
    const cutoffStr = cutoff.toISOString().split('T')[0];

    // Show today's holiday or upcoming ones
    const todayHoliday = holidays.find((h: any) => h.date === today);
    const upcoming = holidays
      .filter((h: any) => h.date > today && h.date <= cutoffStr)
      .sort((a: any, b: any) => a.date.localeCompare(b.date))
      .slice(0, 2);

    const lines: string[] = [];
    if (todayHoliday) {
      if (todayHoliday.closed) {
        lines.push(`Today: Closed for ${todayHoliday.label}`);
      } else {
        lines.push(`Today: ${todayHoliday.label} ${formatTime(todayHoliday.open)}\u2013${formatTime(todayHoliday.close)}`);
      }
    }
    for (const h of upcoming) {
      const d = new Date(h.date + 'T12:00:00');
      const label = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      if (h.closed) {
        lines.push(`${label}: Closed (${h.label})`);
      } else {
        lines.push(`${label}: ${h.label} ${formatTime(h.open)}\u2013${formatTime(h.close)}`);
      }
    }

    if (lines.length) {
      el.innerHTML = lines.map(l => `<p style="margin:0">${l}</p>`).join('');
    }
  }

  initFooterAccordion();
  initHolidayDisplay();
  document.addEventListener('astro:after-swap', () => {
    initFooterAccordion();
    initHolidayDisplay();
  });
</script>
