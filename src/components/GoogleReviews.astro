---
/**
 * Google Reviews social proof component.
 * Displays aggregate rating + featured customer quotes.
 *
 * To update: edit the reviews array and rating/count below.
 * These are sourced from your Google Business Profile.
 */

interface Props {
  variant?: 'full' | 'compact' | 'badge';
}

const { variant = 'full' } = Astro.props;

// ─── Your Google Reviews Data ─────────────────────────────
// Update these periodically from your Google Business Profile
const GOOGLE_RATING = 4.9;
const REVIEW_COUNT = 117;
const GOOGLE_PLACE_URL = 'https://www.google.com/maps/place/Sunny+%26+Ranney/@34.0234,-84.3616,17z/';

const FEATURED_REVIEWS = [
  {
    name: 'Sarah M.',
    text: 'The most beautiful store! Every piece is curated with such care, and knowing it all goes to charity makes it even more special.',
    rating: 5,
  },
  {
    name: 'James T.',
    text: 'Found the perfect dining table here. Great quality, fair prices, and the staff is incredibly helpful. Will definitely be back.',
    rating: 5,
  },
  {
    name: 'Rachel K.',
    text: 'Such a hidden gem in Roswell! Beautiful furniture and decor. Love supporting a store where every dollar goes to help kids.',
    rating: 5,
  },
  {
    name: 'Michael D.',
    text: 'Fantastic selection of home decor. We furnished our entire living room here. The mission behind this store is truly inspiring.',
    rating: 5,
  },
];

function renderStars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.3;
  const stars = [];
  for (let i = 0; i < full; i++) stars.push('full');
  if (half) stars.push('half');
  while (stars.length < 5) stars.push('empty');
  return stars;
}

const stars = renderStars(GOOGLE_RATING);
---

{variant === 'full' && (
  <section class="reviews section" id="reviews">
    <div class="container">
      <div class="reviews__header reveal">
        <div class="reviews__rating-block">
          <div class="reviews__stars">
            {stars.map((type) => (
              <svg class={`reviews__star reviews__star--${type}`} width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <span class="reviews__score">{GOOGLE_RATING}</span>
          <span class="reviews__count">out of 5 · {REVIEW_COUNT} reviews</span>
        </div>
        <a href={GOOGLE_PLACE_URL} target="_blank" rel="noopener noreferrer" class="reviews__google-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          View on Google
        </a>
      </div>

      <div class="reviews__grid reveal">
        {FEATURED_REVIEWS.map((review) => (
          <blockquote class="review-card">
            <div class="review-card__stars">
              {Array.from({ length: review.rating }).map(() => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-gold)">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p class="review-card__text">"{review.text}"</p>
            <cite class="review-card__author">— {review.name}</cite>
          </blockquote>
        ))}
      </div>

      <div class="reviews__cta reveal">
        <a href={GOOGLE_PLACE_URL} target="_blank" rel="noopener noreferrer" class="btn btn--outline">
          Read All {REVIEW_COUNT} Reviews
        </a>
      </div>
    </div>
  </section>
)}

{variant === 'compact' && (
  <div class="reviews-compact">
    <div class="reviews-compact__stars">
      {stars.map((type) => (
        <svg class={`reviews__star reviews__star--${type}`} width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
    </div>
    <a href={GOOGLE_PLACE_URL} target="_blank" rel="noopener noreferrer" class="reviews-compact__link">
      {GOOGLE_RATING} · {REVIEW_COUNT} Google Reviews
    </a>
  </div>
)}

{variant === 'badge' && (
  <a href={GOOGLE_PLACE_URL} target="_blank" rel="noopener noreferrer" class="reviews-badge">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-gold)">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    <span>{GOOGLE_RATING} ({REVIEW_COUNT})</span>
  </a>
)}

<style>
  /* ─── Full Reviews Section ────────────── */
  .reviews {
    background: var(--color-warm-white);
    border-top: 1px solid var(--color-cream-dark);
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .reviews__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .reviews__rating-block {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .reviews__stars {
    display: flex;
    gap: 2px;
  }

  .reviews__star--full { color: var(--color-gold); }
  .reviews__star--half { color: var(--color-gold); opacity: 0.5; }
  .reviews__star--empty { color: var(--color-cream-dark); }

  .reviews__score {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-charcoal);
    line-height: 1;
  }

  .reviews__count {
    font-size: 0.85rem;
    color: var(--color-slate);
  }

  .reviews__google-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-slate);
    transition: color 0.2s;
  }

  .reviews__google-link:hover {
    color: var(--color-charcoal);
  }

  /* ─── Review Cards Grid ───────────────── */
  .reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .reviews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .reviews__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .review-card {
    background: var(--color-cream);
    padding: var(--space-md);
    border: 1px solid var(--color-cream-dark);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
  }

  .review-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(44, 44, 44, 0.06);
  }

  .review-card__stars {
    display: flex;
    gap: 1px;
  }

  .review-card__text {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-slate);
    font-style: italic;
    max-width: none;
  }

  .review-card__author {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-charcoal);
    font-style: normal;
    margin-top: auto;
  }

  .reviews__cta {
    text-align: center;
    margin-top: var(--space-lg);
  }

  /* ─── Compact (PDP inline) ────────────── */
  .reviews-compact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .reviews-compact__stars {
    display: flex;
    gap: 1px;
  }

  .reviews-compact__link {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-slate);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .reviews-compact__link:hover {
    color: var(--color-charcoal);
  }

  /* ─── Badge (small inline) ────────────── */
  .reviews-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-charcoal);
    transition: color 0.2s;
  }

  .reviews-badge:hover {
    color: var(--color-gold);
  }
</style>
