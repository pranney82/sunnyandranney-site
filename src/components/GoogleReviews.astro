---
/**
 * Google Reviews social proof component.
 * Fetches live data from Google Places API at build time.
 * Falls back to admin-saved data if the API isn't configured or fails.
 */
import { getReviewsStatic } from '@/lib/settings';
import { fetchGooglePlaceData } from '@/lib/google-places';

interface Props {
  variant?: 'full' | 'compact' | 'badge';
}

const { variant = 'full' } = Astro.props;

// Live API data (auto-updated each deploy) → admin overrides → defaults
const liveData = await fetchGooglePlaceData();
const savedData = getReviewsStatic();

const GOOGLE_RATING = liveData?.rating ?? savedData?.googleRating ?? 5.0;
const REVIEW_COUNT = liveData?.reviewCount ?? savedData?.reviewCount ?? 117;
const GOOGLE_PLACE_URL = 'https://maps.app.goo.gl/QXwgPyiX93HkwjwDA';

const AVATAR_COLORS = ['#4285F4', '#EA4335', '#34A853', '#FBBC05', '#8E44AD', '#E67E22'];

// Prefer live reviews from Google, fall back to admin-curated ones
const FEATURED_REVIEWS = (liveData?.reviews?.length ? liveData.reviews : savedData?.featured) ?? [];

function renderStars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.3;
  const stars = [];
  for (let i = 0; i < full; i++) stars.push('full');
  if (half) stars.push('half');
  while (stars.length < 5) stars.push('empty');
  return stars;
}

const stars = renderStars(GOOGLE_RATING);
---

{variant === 'full' && (
  <section class="reviews section" id="reviews">
    <div class="container">
      <div class="reviews__header reveal">
        <a href={GOOGLE_PLACE_URL} target="_blank" rel="noopener noreferrer" class="reviews__google-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Google Reviews
        </a>
        <div class="reviews__rating-block">
          <span class="reviews__score">{GOOGLE_RATING}</span>
          <div class="reviews__score-detail">
            <div class="reviews__stars">
              {stars.map((type) => (
                <svg class={`reviews__star reviews__star--${type}`} width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <span class="reviews__count">Based on {REVIEW_COUNT} reviews</span>
          </div>
        </div>
      </div>

      <div class="reviews__grid reveal">
        {FEATURED_REVIEWS.map((review, i) => (
          <blockquote class="review-card">
            <div class="review-card__header">
              {'photoUrl' in review && review.photoUrl ? (
                <img
                  class="review-card__avatar"
                  src={review.photoUrl}
                  alt=""
                  width="40"
                  height="40"
                  loading="lazy"
                  data-initial={review.name.charAt(0)}
                  data-color={AVATAR_COLORS[i % AVATAR_COLORS.length]}
                  onerror="const d=document.createElement('div');d.className='review-card__avatar review-card__avatar--initials';d.style.backgroundColor=this.dataset.color;d.textContent=this.dataset.initial;this.replaceWith(d);"
                />
              ) : (
                <div class="review-card__avatar review-card__avatar--initials" style={`background-color: ${AVATAR_COLORS[i % AVATAR_COLORS.length]}`}>
                  {review.name.charAt(0)}
                </div>
              )}
              <div class="review-card__meta">
                <cite class="review-card__author">{review.name}</cite>
                {'timeAgo' in review && review.timeAgo && (
                  <span class="review-card__time">{review.timeAgo}</span>
                )}
              </div>
            </div>
            <div class="review-card__stars">
              {Array.from({ length: review.rating }).map(() => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-gold)" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p class="review-card__text">{review.text}</p>
          </blockquote>
        ))}
      </div>

      <div class="reviews__cta reveal">
        <a href={GOOGLE_PLACE_URL} target="_blank" rel="noopener noreferrer" class="reviews__cta-link">
          Read all {REVIEW_COUNT} reviews on Google <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>
)}

{variant === 'compact' && (
  <div class="reviews-compact">
    <div class="reviews-compact__stars">
      {stars.map((type) => (
        <svg class={`reviews__star reviews__star--${type}`} width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
    </div>
    <a href={GOOGLE_PLACE_URL} target="_blank" rel="noopener noreferrer" class="reviews-compact__link">
      {GOOGLE_RATING} · {REVIEW_COUNT} Google Reviews
    </a>
  </div>
)}

{variant === 'badge' && (
  <a href={GOOGLE_PLACE_URL} target="_blank" rel="noopener noreferrer" class="reviews-badge">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-gold)" aria-hidden="true">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    <span>{GOOGLE_RATING} ({REVIEW_COUNT})</span>
  </a>
)}

<style>
  /* ─── Full Reviews Section ────────────── */
  .reviews {
    background: var(--color-cream);
  }

  .reviews__header {
    text-align: center;
    margin-bottom: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .reviews__google-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-charcoal);
    text-decoration: none;
    transition: color 0.2s;
  }

  .reviews__google-badge:hover {
    color: #000;
  }

  .reviews__rating-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .reviews__score {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    color: var(--color-charcoal);
    line-height: 1;
  }

  .reviews__score-detail {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }

  .reviews__stars {
    display: flex;
    gap: 2px;
  }

  .reviews__star--full { color: var(--color-gold); }
  .reviews__star--half { color: var(--color-gold); opacity: 0.5; }
  .reviews__star--empty { color: var(--color-cream-dark); }

  .reviews__count {
    font-size: 0.82rem;
    color: var(--color-charcoal);
  }

  /* ─── Review Cards Grid ───────────────── */
  .reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .reviews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .reviews__grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .review-card {
    background: #fff;
    padding: 1.25rem;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s;
  }

  .review-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(44, 44, 44, 0.06);
  }

  /* ─── Card header (avatar + name) ─────── */
  .review-card__header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .review-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
  }

  .review-card__avatar--initials {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-display);
  }

  .review-card__meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .review-card__author {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-charcoal);
    font-style: normal;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-card__time {
    font-size: 0.72rem;
    color: var(--color-slate);
  }

  .review-card__stars {
    display: flex;
    gap: 1px;
  }

  .review-card__text {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-charcoal);
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: none;
  }

  .reviews__cta {
    text-align: center;
    margin-top: var(--space-lg);
  }

  .reviews__cta-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-slate);
    text-decoration: none;
    transition: color 0.2s;
  }

  .reviews__cta-link:hover {
    color: var(--color-charcoal);
  }

  .reviews__cta-link span {
    display: inline-block;
    transition: transform 0.2s;
  }

  .reviews__cta-link:hover span {
    transform: translateX(3px);
  }

  /* ─── Compact (PDP inline) ────────────── */
  .reviews-compact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .reviews-compact__stars {
    display: flex;
    gap: 1px;
  }

  .reviews-compact__link {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-slate);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .reviews-compact__link:hover {
    color: var(--color-charcoal);
  }

  /* ─── Badge (small inline) ────────────── */
  .reviews-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-charcoal);
    transition: color 0.2s;
  }

  .reviews-badge:hover {
    color: var(--color-gold);
  }
</style>
