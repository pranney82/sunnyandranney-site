<script>
  /* Lazy bootstrap — defers the 16 KB chat bundle download until after LCP.
     Returning users with an open panel get it immediately; everyone else waits for idle. */
  const _load = () => import('../lib/staci-chat-init');
  if (localStorage.getItem('staci_panel_open') === 'true') {
    _load();
  } else {
    ('requestIdleCallback' in window)
      ? requestIdleCallback(() => _load(), { timeout: 3000 })
      : setTimeout(_load, 50);
  }
</script>

