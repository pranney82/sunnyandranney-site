---
/* Staci — AI shopping assistant chat widget (Cloudflare Workers AI) */
---

<!-- Chat toggle button -->
<button id="staci-toggle" aria-label="Chat with Staci" title="Chat with Staci">
  <img id="staci-icon-chat" class="staci-toggle__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" alt="Ask Staci" width="40" height="40" loading="lazy" />
  <svg id="staci-icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
  </svg>
  <span class="staci-toggle__label" id="staci-toggle-label">Ask Staci</span>
</button>

<!-- Chat panel -->
<div id="staci-panel" aria-hidden="true">
  <div class="staci-header">
    <div class="staci-header__info">
      <img class="staci-avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Staci" />
      <div>
        <strong>Staci</strong>
        <span class="staci-status">AI Shopping Assistant</span>
      </div>
    </div>
  </div>

  <div id="staci-messages" class="staci-messages">
    <div class="staci-msg staci-msg--bot">
      <img class="staci-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Staci" />
      <div class="staci-msg__bubble">Hi! I'm Staci, your shopping assistant. How can I help you today?</div>
    </div>
  </div>

  <form id="staci-form" class="staci-input">
    <input
      id="staci-input"
      type="text"
      placeholder="Ask Staci anything…"
      autocomplete="off"
      aria-label="Type a message"
    />
    <button type="submit" aria-label="Send message">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </form>
</div>

<style>
  /* ─── Toggle Button ──────────────────────────────────────── */
  #staci-toggle {
    position: fixed;
    bottom: 6rem;
    right: 1.5rem;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1rem 0.5rem 0.5rem;
    border-radius: 100px;
    background: var(--color-charcoal);
    color: var(--color-gold);
    box-shadow: 0 4px 20px rgba(44, 44, 44, 0.3);
    transition: transform 0.3s var(--ease-out), background 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
    cursor: pointer;
    border: none;
  }

  #staci-toggle:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 28px rgba(44, 44, 44, 0.4);
  }

  .staci-toggle__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-gold);
    flex-shrink: 0;
  }

  .staci-toggle__label {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-cream);
    white-space: nowrap;
  }

  /* ─── Chat Panel ─────────────────────────────────────────── */
  #staci-panel {
    position: fixed;
    bottom: 10.5rem;
    right: 1.5rem;
    z-index: 9998;
    width: 380px;
    max-height: 520px;
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    box-shadow: 0 12px 40px rgba(44, 44, 44, 0.15);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out);
  }

  #staci-panel[aria-hidden="false"] {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ─── Header ─────────────────────────────────────────────── */
  .staci-header {
    padding: 1rem 1.25rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .staci-header__info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .staci-header__info strong {
    font-family: var(--font-display);
    font-size: 1.1rem;
    display: block;
    line-height: 1.2;
  }

  .staci-status {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
  }

  .staci-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  /* ─── Messages ───────────────────────────────────────────── */
  .staci-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-height: 350px;
    min-height: 200px;
  }

  .staci-msg {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }

  .staci-msg--user {
    flex-direction: row-reverse;
  }

  .staci-msg__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  span.staci-msg__avatar {
    background: var(--color-cyan);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
  }

  .staci-msg__bubble {
    padding: 0.65rem 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
    max-width: 80%;
    color: var(--color-charcoal);
  }

  .staci-msg--bot .staci-msg__bubble {
    background: var(--color-cream);
    border-radius: 2px 12px 12px 12px;
  }

  .staci-msg--user .staci-msg__bubble {
    background: var(--color-charcoal);
    color: var(--color-cream);
    border-radius: 12px 2px 12px 12px;
  }

  /* Typing indicator */
  .staci-typing .staci-msg__bubble {
    display: flex;
    gap: 0.3rem;
    align-items: center;
    padding: 0.8rem 1.2rem;
  }

  .staci-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-stone);
    animation: staciBounce 1.4s infinite ease-in-out both;
  }

  .staci-dot:nth-child(2) { animation-delay: 0.16s; }
  .staci-dot:nth-child(3) { animation-delay: 0.32s; }

  @keyframes staciBounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  /* ─── Input ──────────────────────────────────────────────── */
  .staci-input {
    display: flex;
    border-top: 1px solid var(--color-cream-dark);
    padding: 0;
  }

  .staci-input input {
    flex: 1;
    padding: 0.9rem 1.25rem;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    background: transparent;
    color: var(--color-charcoal);
  }

  .staci-input input::placeholder {
    color: var(--color-stone);
  }

  .staci-input button {
    padding: 0.9rem 1.25rem;
    color: var(--color-gold);
    transition: color 0.2s;
    cursor: pointer;
    border: none;
    background: none;
  }

  .staci-input button:hover {
    color: var(--color-charcoal);
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 480px) {
    #staci-panel {
      width: calc(100vw - 2rem);
      right: 1rem;
      bottom: 10rem;
      max-height: 70vh;
    }

    #staci-toggle {
      padding: 0.35rem;
      bottom: 5.5rem;
      right: 1rem;
    }

    .staci-toggle__label {
      display: none;
    }

    .staci-toggle__avatar {
      width: 44px;
      height: 44px;
    }
  }
</style>

<script>
  let conversationHistory: { role: string; content: string }[] = [];
  let staciInitialized = false;

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function addMessage(text: string, isUser: boolean) {
    const messagesEl = document.getElementById('staci-messages');
    if (!messagesEl) return;
    const msg = document.createElement('div');
    msg.className = `staci-msg staci-msg--${isUser ? 'user' : 'bot'}`;
    msg.innerHTML = `
      ${isUser ? '<span class="staci-msg__avatar">Y</span>' : '<img class="staci-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Staci" />'}
      <div class="staci-msg__bubble">${escapeHtml(text)}</div>
    `;
    messagesEl.appendChild(msg);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function showTyping() {
    const messagesEl = document.getElementById('staci-messages');
    if (!messagesEl) return;
    const typing = document.createElement('div');
    typing.className = 'staci-msg staci-msg--bot staci-typing';
    typing.id = 'staci-typing';
    typing.innerHTML = `
      <img class="staci-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Staci" />
      <div class="staci-msg__bubble">
        <span class="staci-dot"></span>
        <span class="staci-dot"></span>
        <span class="staci-dot"></span>
      </div>
    `;
    messagesEl.appendChild(typing);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('staci-typing')?.remove();
  }

  async function handleSubmit(e: Event) {
    e.preventDefault();
    const input = document.getElementById('staci-input') as HTMLInputElement | null;
    if (!input) return;
    const text = input.value.trim();
    if (!text) return;

    addMessage(text, true);
    input.value = '';
    conversationHistory.push({ role: 'user', content: text });

    showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conversationHistory }),
      });

      removeTyping();

      if (!res.ok) throw new Error('Request failed');

      const data = await res.json();
      const reply = data.reply || "Sorry, I couldn't process that. Please try again.";

      conversationHistory.push({ role: 'assistant', content: reply });
      addMessage(reply, false);
    } catch {
      removeTyping();
      addMessage("Oops — I'm having trouble connecting. Please try again in a moment.", false);
    }
  }

  // Use event delegation so clicks work even if DOM is swapped by View Transitions
  document.addEventListener('click', (e) => {
    const toggle = (e.target as Element).closest('#staci-toggle');
    if (!toggle) return;

    const panel = document.getElementById('staci-panel');
    const iconChat = document.getElementById('staci-icon-chat');
    const iconClose = document.getElementById('staci-icon-close');
    const label = document.getElementById('staci-toggle-label');
    const input = document.getElementById('staci-input') as HTMLInputElement | null;
    if (!panel) return;

    const isOpen = panel.getAttribute('aria-hidden') === 'false';
    panel.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
    if (iconChat) iconChat.style.display = isOpen ? 'none' : 'block';
    if (iconClose) iconClose.style.display = isOpen ? 'none' : 'block';
    if (label) label.style.display = isOpen ? 'block' : 'none';
    if (!isOpen && input) input.focus();
  });

  function initStaciForm() {
    if (staciInitialized) return;
    const form = document.getElementById('staci-form');
    if (!form) return;
    staciInitialized = true;
    form.addEventListener('submit', handleSubmit);
  }

  // Init form on load and after View Transition navigations
  initStaciForm();
  document.addEventListener('astro:page-load', initStaciForm);
</script>
