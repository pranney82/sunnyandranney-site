---
/* Staci — AI shopping assistant chat widget (Cloudflare Workers AI) */
---

<!-- Chat toggle button -->
<button id="staci-toggle" aria-label="Chat with Staci" title="Chat with Staci">
  <img id="staci-icon-chat" class="staci-toggle__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" alt="Ask Staci" width="40" height="40" loading="lazy" />
  <svg id="staci-icon-close" class="staci-toggle__close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
  </svg>
  <span class="staci-toggle__label" id="staci-toggle-label">Ask Staci</span>
</button>

<!-- Chat panel -->
<div id="staci-panel" aria-hidden="true">
  <div class="staci-header">
    <div class="staci-header__info">
      <div class="staci-header__avatar-wrap">
        <img class="staci-avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Staci" />
        <span class="staci-header__online"></span>
      </div>
      <div>
        <strong>Staci</strong>
        <span class="staci-status">AI Shopping Assistant</span>
      </div>
    </div>
    <button class="staci-header__close" id="staci-header-close" aria-label="Close chat">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div id="staci-messages" class="staci-messages">
    <div class="staci-msg staci-msg--bot staci-msg--entrance">
      <img class="staci-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Staci" />
      <div class="staci-msg__bubble">Hi! I'm Staci, your shopping assistant. How can I help you today?</div>
    </div>
  </div>

  <!-- Quick reply chips -->
  <div class="staci-chips" id="staci-chips">
    <button class="staci-chip" data-msg="What's new in the shop?">What's new?</button>
    <button class="staci-chip" data-msg="What are your store hours and location?">Store hours</button>
    <button class="staci-chip" data-msg="What is your return policy?">Returns</button>
    <button class="staci-chip" data-msg="Tell me about Sunny & Ranney's mission">Your mission</button>
  </div>

  <form id="staci-form" class="staci-input">
    <input
      id="staci-input"
      type="text"
      placeholder="Ask Staci anything..."
      autocomplete="off"
      aria-label="Type a message"
    />
    <button type="submit" class="staci-input__send" aria-label="Send message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </form>

  <div class="staci-footer">
    Powered by AI &middot; Responses may not always be accurate
  </div>
</div>

<style>
  /* ─── Toggle Button ──────────────────────────────────────── */
  #staci-toggle {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 1rem 0.4rem 0.4rem;
    border-radius: 100px;
    background: var(--color-charcoal);
    color: var(--color-gold);
    box-shadow: 0 4px 24px rgba(44, 44, 44, 0.35);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
    cursor: pointer;
    border: none;
  }

  #staci-toggle:hover {
    transform: scale(1.04);
    box-shadow: 0 6px 32px rgba(44, 44, 44, 0.45);
  }

  .staci-toggle__avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-gold);
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .staci-toggle__close {
    flex-shrink: 0;
  }

  .staci-toggle__label {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-cream);
    white-space: nowrap;
  }

  /* ─── Chat Panel ─────────────────────────────────────────── */
  #staci-panel {
    position: fixed;
    bottom: 5.5rem;
    right: 1.5rem;
    z-index: 9998;
    width: 400px;
    max-height: 580px;
    background: var(--color-warm-white);
    border-radius: 16px;
    border: 1px solid var(--color-cream-dark);
    box-shadow: 0 16px 60px rgba(44, 44, 44, 0.18), 0 2px 8px rgba(44, 44, 44, 0.06);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(12px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out);
    overflow: hidden;
  }

  #staci-panel[aria-hidden="false"] {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ─── Header ─────────────────────────────────────────────── */
  .staci-header {
    padding: 0.85rem 1rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: 16px 16px 0 0;
  }

  .staci-header__info {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .staci-header__avatar-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .staci-header__online {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 10px;
    height: 10px;
    background: #34D399;
    border-radius: 50%;
    border: 2px solid var(--color-charcoal);
  }

  .staci-header__info strong {
    font-family: var(--font-display);
    font-size: 1.05rem;
    display: block;
    line-height: 1.2;
  }

  .staci-status {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
  }

  .staci-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .staci-header__close {
    padding: 0.4rem;
    color: var(--color-stone);
    transition: color 0.2s;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: 50%;
  }

  .staci-header__close:hover {
    color: var(--color-cream);
  }

  /* ─── Messages ───────────────────────────────────────────── */
  .staci-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-height: 340px;
    min-height: 120px;
    scroll-behavior: smooth;
  }

  .staci-messages::-webkit-scrollbar {
    width: 4px;
  }

  .staci-messages::-webkit-scrollbar-thumb {
    background: var(--color-cream-dark);
    border-radius: 4px;
  }

  .staci-msg {
    display: flex;
    gap: 0.5rem;
    align-items: flex-end;
    animation: staciMsgIn 0.3s var(--ease-out) both;
  }

  .staci-msg--user {
    flex-direction: row-reverse;
  }

  .staci-msg__avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  span.staci-msg__avatar {
    background: var(--color-charcoal);
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.65rem;
  }

  .staci-msg__bubble {
    padding: 0.6rem 0.9rem;
    font-size: 0.88rem;
    line-height: 1.55;
    max-width: 82%;
    color: var(--color-charcoal);
  }

  /* Rich text in bot bubbles */
  .staci-msg--bot .staci-msg__bubble :global(strong) { font-weight: 600; }
  .staci-msg--bot .staci-msg__bubble :global(a) {
    color: var(--color-cyan);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .staci-msg--bot .staci-msg__bubble :global(ul),
  .staci-msg--bot .staci-msg__bubble :global(ol) {
    margin: 0.3rem 0;
    padding-left: 1.2rem;
  }
  .staci-msg--bot .staci-msg__bubble :global(li) {
    margin: 0.15rem 0;
  }

  .staci-msg--bot .staci-msg__bubble {
    background: var(--color-cream);
    border-radius: 2px 14px 14px 14px;
  }

  .staci-msg--user .staci-msg__bubble {
    background: var(--color-charcoal);
    color: var(--color-cream);
    border-radius: 14px 2px 14px 14px;
  }

  /* Typing indicator */
  .staci-typing .staci-msg__bubble {
    display: flex;
    gap: 0.3rem;
    align-items: center;
    padding: 0.8rem 1.1rem;
  }

  .staci-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-stone);
    animation: staciBounce 1.4s infinite ease-in-out both;
  }

  .staci-dot:nth-child(2) { animation-delay: 0.16s; }
  .staci-dot:nth-child(3) { animation-delay: 0.32s; }

  @keyframes staciBounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  @keyframes staciMsgIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Error message with retry */
  .staci-msg--error .staci-msg__bubble {
    background: #FEF2F2;
    border: 1px solid #FECACA;
    color: #991B1B;
  }

  .staci-retry {
    display: inline-block;
    margin-top: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-cyan);
    cursor: pointer;
    border: none;
    background: none;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .staci-retry:hover {
    color: var(--color-charcoal);
  }

  /* ─── Quick Reply Chips ────────────────────────────────────── */
  .staci-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.5rem 1rem 0.75rem;
  }

  .staci-chip {
    padding: 0.4rem 0.85rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-charcoal);
    background: var(--color-cream);
    border: 1px solid var(--color-cream-dark);
    border-radius: 100px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
    white-space: nowrap;
  }

  .staci-chip:hover {
    background: var(--color-gold-soft);
    border-color: var(--color-gold);
    transform: translateY(-1px);
  }

  .staci-chip:active {
    transform: scale(0.97);
  }

  /* ─── Input ──────────────────────────────────────────────── */
  .staci-input {
    display: flex;
    align-items: center;
    border-top: 1px solid var(--color-cream-dark);
    padding: 0;
    gap: 0;
  }

  .staci-input input {
    flex: 1;
    padding: 0.85rem 1rem;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.88rem;
    background: transparent;
    color: var(--color-charcoal);
  }

  .staci-input input::placeholder {
    color: var(--color-stone);
  }

  .staci-input__send {
    padding: 0.6rem;
    margin-right: 0.5rem;
    color: var(--color-cream);
    background: var(--color-gold);
    border-radius: 50%;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.15s;
    cursor: pointer;
    border: none;
    flex-shrink: 0;
  }

  .staci-input__send:hover {
    background: var(--color-charcoal);
    transform: scale(1.06);
  }

  .staci-input__send svg {
    stroke: currentColor;
  }

  /* ─── Footer ─────────────────────────────────────────────── */
  .staci-footer {
    padding: 0.4rem 1rem;
    font-size: 0.62rem;
    color: var(--color-stone);
    text-align: center;
    border-top: 1px solid var(--color-cream-dark);
    background: var(--color-cream);
    border-radius: 0 0 16px 16px;
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 480px) {
    #staci-panel {
      width: calc(100vw - 1rem);
      right: 0.5rem;
      bottom: 4.5rem;
      max-height: 80vh;
      border-radius: 16px;
    }

    .staci-messages {
      max-height: 50vh;
    }

    #staci-toggle {
      padding: 0.3rem;
      bottom: 1rem;
      right: 1rem;
    }

    .staci-toggle__label {
      display: none;
    }

    .staci-toggle__avatar {
      width: 48px;
      height: 48px;
    }

    .staci-chips {
      padding: 0.4rem 0.75rem 0.6rem;
    }

    .staci-chip {
      font-size: 0.74rem;
      padding: 0.35rem 0.7rem;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'staci_chat_history';
  const MAX_STORED_MESSAGES = 50;

  let conversationHistory: { role: string; content: string }[] = [];
  let staciInitialized = false;

  // ─── Helpers ─────────────────────────────────────────────

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  /** Simple markdown → HTML (bold, italic, links, lists) */
  function renderMarkdown(text: string): string {
    let html = escapeHtml(text);
    // Bold: **text**
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    // Italic: *text*
    html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
    // Links: [text](url)
    html = html.replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
    // Line breaks
    html = html.replace(/\n/g, '<br>');
    return html;
  }

  // ─── Session Storage ───────────────────────────────────────

  function saveSession() {
    try {
      const data = conversationHistory.slice(-MAX_STORED_MESSAGES);
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch { /* quota exceeded — ignore */ }
  }

  function loadSession(): { role: string; content: string }[] {
    try {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return [];
      return JSON.parse(raw);
    } catch {
      return [];
    }
  }

  function restoreSession() {
    const saved = loadSession();
    if (!saved.length) return;

    conversationHistory = saved;
    const messagesEl = document.getElementById('staci-messages');
    if (!messagesEl) return;

    // Clear default welcome message
    messagesEl.innerHTML = '';

    // Re-render welcome + all saved messages
    addBotBubble('Hi! I\'m Staci, your shopping assistant. How can I help you today?', false);
    saved.forEach(msg => {
      if (msg.role === 'user') {
        addUserBubble(msg.content, false);
      } else {
        addBotBubble(msg.content, false);
      }
    });

    // Hide chips if conversation has started
    if (saved.length > 0) hideChips();
  }

  // ─── DOM Manipulation ─────────────────────────────────────

  function addUserBubble(text: string, animate = true) {
    const messagesEl = document.getElementById('staci-messages');
    if (!messagesEl) return;
    const msg = document.createElement('div');
    msg.className = `staci-msg staci-msg--user`;
    if (!animate) msg.style.animation = 'none';
    msg.innerHTML = `
      <span class="staci-msg__avatar">You</span>
      <div class="staci-msg__bubble">${escapeHtml(text)}</div>
    `;
    messagesEl.appendChild(msg);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function addBotBubble(text: string, animate = true) {
    const messagesEl = document.getElementById('staci-messages');
    if (!messagesEl) return;
    const msg = document.createElement('div');
    msg.className = `staci-msg staci-msg--bot`;
    if (!animate) msg.style.animation = 'none';
    msg.innerHTML = `
      <img class="staci-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Staci" />
      <div class="staci-msg__bubble">${renderMarkdown(text)}</div>
    `;
    messagesEl.appendChild(msg);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function addErrorBubble(retryFn: () => void) {
    const messagesEl = document.getElementById('staci-messages');
    if (!messagesEl) return;
    const msg = document.createElement('div');
    msg.className = 'staci-msg staci-msg--bot staci-msg--error';
    msg.id = 'staci-error';

    const avatar = document.createElement('img');
    avatar.className = 'staci-msg__avatar';
    avatar.src = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav';
    avatar.alt = 'Staci';
    avatar.loading = 'lazy';
    msg.appendChild(avatar);

    const bubble = document.createElement('div');
    bubble.className = 'staci-msg__bubble';
    bubble.textContent = "Sorry, I couldn't connect. ";
    const retry = document.createElement('button');
    retry.className = 'staci-retry';
    retry.textContent = 'Try again';
    retry.addEventListener('click', () => {
      msg.remove();
      retryFn();
    });
    bubble.appendChild(retry);
    msg.appendChild(bubble);

    messagesEl.appendChild(msg);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function showTyping() {
    const messagesEl = document.getElementById('staci-messages');
    if (!messagesEl) return;
    const typing = document.createElement('div');
    typing.className = 'staci-msg staci-msg--bot staci-typing';
    typing.id = 'staci-typing';
    typing.innerHTML = `
      <img class="staci-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Staci" />
      <div class="staci-msg__bubble">
        <span class="staci-dot"></span>
        <span class="staci-dot"></span>
        <span class="staci-dot"></span>
      </div>
    `;
    messagesEl.appendChild(typing);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('staci-typing')?.remove();
  }

  function hideChips() {
    const chips = document.getElementById('staci-chips');
    if (chips) chips.style.display = 'none';
  }

  // ─── Chat Toggle ──────────────────────────────────────────

  function openPanel() {
    const panel = document.getElementById('staci-panel');
    const iconChat = document.getElementById('staci-icon-chat');
    const iconClose = document.getElementById('staci-icon-close');
    const label = document.getElementById('staci-toggle-label');
    const input = document.getElementById('staci-input') as HTMLInputElement | null;
    if (!panel) return;

    panel.setAttribute('aria-hidden', 'false');
    if (iconChat) iconChat.style.display = 'none';
    if (iconClose) iconClose.style.display = 'block';
    if (label) label.style.display = 'none';
    if (input) input.focus();
  }

  function closePanel() {
    const panel = document.getElementById('staci-panel');
    const iconChat = document.getElementById('staci-icon-chat');
    const iconClose = document.getElementById('staci-icon-close');
    const label = document.getElementById('staci-toggle-label');
    if (!panel) return;

    panel.setAttribute('aria-hidden', 'true');
    if (iconChat) iconChat.style.display = 'block';
    if (iconClose) iconClose.style.display = 'none';
    if (label) label.style.display = '';
  }

  function isPanelOpen() {
    return document.getElementById('staci-panel')?.getAttribute('aria-hidden') === 'false';
  }

  // ─── Send Message ─────────────────────────────────────────

  async function sendMessage(text: string) {
    hideChips();
    addUserBubble(text);
    conversationHistory.push({ role: 'user', content: text });
    saveSession();

    showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conversationHistory }),
      });

      removeTyping();

      if (!res.ok) throw new Error('Request failed');

      const data = await res.json();
      const reply = data.reply || "Sorry, I couldn't process that. Please try again.";

      conversationHistory.push({ role: 'assistant', content: reply });
      saveSession();
      addBotBubble(reply);
    } catch {
      removeTyping();
      // Remove the failed user message from history so retry works cleanly
      const lastMsg = conversationHistory[conversationHistory.length - 1];
      addErrorBubble(() => {
        sendMessage(lastMsg?.content || text);
        // Remove the duplicate user entry since sendMessage adds it again
        conversationHistory.pop();
      });
    }
  }

  // ─── Event Listeners (delegation for View Transitions) ────

  // Toggle button
  document.addEventListener('click', (e) => {
    const toggle = (e.target as Element).closest('#staci-toggle');
    if (!toggle) return;
    if (isPanelOpen()) closePanel();
    else openPanel();
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!isPanelOpen()) return;
    const target = e.target as Element;
    if (target.closest('#staci-panel') || target.closest('#staci-toggle')) return;
    closePanel();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isPanelOpen()) closePanel();
  });

  // Header close button
  document.addEventListener('click', (e) => {
    if ((e.target as Element).closest('#staci-header-close')) {
      closePanel();
    }
  });

  // Quick reply chips
  document.addEventListener('click', (e) => {
    const chip = (e.target as Element).closest('.staci-chip') as HTMLElement | null;
    if (!chip) return;
    const msg = chip.dataset.msg;
    if (msg) sendMessage(msg);
  });

  // Form submit
  function initStaciForm() {
    if (staciInitialized) return;
    const form = document.getElementById('staci-form');
    if (!form) return;
    staciInitialized = true;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = document.getElementById('staci-input') as HTMLInputElement | null;
      if (!input) return;
      const text = input.value.trim();
      if (!text) return;
      input.value = '';
      sendMessage(text);
    });
  }

  // ─── Init ─────────────────────────────────────────────────

  initStaciForm();
  restoreSession();
  document.addEventListener('astro:page-load', () => {
    initStaciForm();
    restoreSession();
  });
</script>
