---
/* Staci — AI shopping assistant chat widget (Cloudflare Workers AI, streaming) */
---

<!-- Chat toggle button -->
<button id="staci-toggle" aria-label="Chat with Staci" title="Chat with Staci">
  <span class="staci-badge" id="staci-badge" style="display:none;"></span>
  <img id="staci-icon-chat" class="staci-toggle__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/w=96,h=96,fit=cover,format=auto" alt="" width="40" height="40" loading="lazy" />
  <svg id="staci-icon-close" class="staci-toggle__close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
  </svg>
  <span class="staci-toggle__label" id="staci-toggle-label">Ask Staci</span>
</button>

<!-- Chat panel -->
<div id="staci-panel" aria-hidden="true" inert>
  <div class="staci-header">
    <div class="staci-header__info">
      <div class="staci-header__avatar-wrap">
        <img class="staci-avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/w=96,h=96,fit=cover,format=auto" loading="lazy" alt="Staci" width="32" height="32" />
        <span class="staci-header__online"></span>
      </div>
      <div>
        <strong>Staci</strong>
        <span class="staci-status">AI Shopping Assistant</span>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:0.25rem;">
      <button class="staci-header__reset" id="staci-header-reset" aria-label="Clear conversation" title="Clear conversation">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/>
        </svg>
      </button>
      <button class="staci-header__close" id="staci-header-close" aria-label="Close chat">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="staci-messages" class="staci-messages" role="log" aria-live="polite">
    <div class="staci-welcome" id="staci-welcome">
      <img class="staci-welcome__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/w=128,h=128,fit=cover,format=auto" alt="Staci" width="52" height="52" />
      <p class="staci-welcome__name">Hi, I'm Staci</p>
      <p class="staci-welcome__sub">Your personal shopping assistant at Sunny&nbsp;&amp;&nbsp;Ranney. Ask me about products, hours, or anything else!</p>
      <div class="staci-welcome__chips">
        <button class="staci-chip" data-msg="What's new in the shop?">What's new?</button>
        <button class="staci-chip" data-msg="What are your store hours and location?">Store hours</button>
        <button class="staci-chip" data-msg="What is your return policy?">Returns</button>
        <button class="staci-chip" data-msg="Tell me about Sunny & Ranney's mission">Your mission</button>
      </div>
    </div>
  </div>

  <!-- Quick reply chips (hidden when welcome card is visible, shown after first exchange) -->
  <div class="staci-chips" id="staci-chips" style="display:none;">
  </div>

  <form id="staci-form" class="staci-input">
    <div class="staci-input__wrap">
      <textarea
        id="staci-input"
        placeholder="Ask Staci anything..."
        autocomplete="off"
        maxlength="500"
        aria-label="Type a message"
        rows="1"
      ></textarea>
      <span class="staci-char-count" id="staci-char-count"></span>
    </div>
    <button type="submit" id="staci-send" class="staci-input__send" aria-label="Send message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </form>

  <div class="staci-footer">
    Staci knows a lot, but feel free to <a href="tel:6788885140">call</a> or <a href="mailto:info@sunnyandranney.com">email</a> us anytime.
  </div>
</div>

<style>
  /* ─── Toggle Button ──────────────────────────────────────── */
  #staci-toggle {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 1rem 0.4rem 0.4rem;
    border-radius: 100px;
    background: var(--color-charcoal);
    color: var(--color-gold);
    box-shadow:
      0 4px 24px rgba(44, 44, 44, 0.28),
      0 1px 4px rgba(44, 44, 44, 0.12);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
    cursor: pointer;
    border: none;
  }

  #staci-toggle:hover {
    transform: scale(1.04);
    box-shadow:
      0 8px 36px rgba(44, 44, 44, 0.35),
      0 2px 8px rgba(44, 44, 44, 0.15);
  }

  .staci-toggle__avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-gold);
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .staci-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 11px;
    height: 11px;
    background: #EF4444;
    border-radius: 50%;
    border: 2px solid var(--color-charcoal);
    pointer-events: none;
    animation: staciBadgePulse 2s ease-in-out infinite;
  }

  @keyframes staciBadgePulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }

  .staci-toggle__close {
    flex-shrink: 0;
  }

  .staci-toggle__label {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-cream);
    white-space: nowrap;
  }

  /* ─── Chat Panel ─────────────────────────────────────────── */
  #staci-panel {
    position: fixed;
    bottom: 5.5rem;
    right: 1.5rem;
    z-index: 9998;
    width: 400px;
    max-height: 600px;
    background: var(--color-warm-white);
    border-radius: 20px;
    border: 1px solid var(--color-cream-dark);
    box-shadow:
      0 24px 80px rgba(44, 44, 44, 0.14),
      0 8px 24px rgba(44, 44, 44, 0.08),
      0 2px 6px rgba(44, 44, 44, 0.04);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    pointer-events: none;
    transition:
      opacity 0.25s ease-out,
      transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1); /* spring overshoot */
    overflow: hidden;
  }

  #staci-panel[aria-hidden="false"] {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* Closing uses a faster, no-overshoot curve */
  #staci-panel[aria-hidden="true"] {
    transition:
      opacity 0.2s ease-in,
      transform 0.25s var(--ease-out);
  }

  /* ─── Header ─────────────────────────────────────────────── */
  .staci-header {
    padding: 0.9rem 1rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: 20px 20px 0 0;
    flex-shrink: 0;
  }

  .staci-header__info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .staci-header__avatar-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .staci-header__online {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 10px;
    height: 10px;
    background: #34D399;
    border-radius: 50%;
    border: 2px solid var(--color-charcoal);
  }

  .staci-header__info strong {
    font-family: var(--font-display);
    font-size: 1.05rem;
    display: block;
    line-height: 1.2;
  }

  .staci-status {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
  }

  .staci-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 1.5px solid rgba(255, 212, 0, 0.4);
  }

  .staci-header__reset {
    padding: 0.4rem;
    color: var(--color-stone);
    transition: color 0.2s, background 0.2s;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: 50%;
    min-width: 36px;
    min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .staci-header__reset:hover {
    color: #FCA5A5;
    background: rgba(255, 255, 255, 0.08);
  }

  .staci-header__close {
    padding: 0.4rem;
    color: var(--color-stone);
    transition: color 0.2s, background 0.2s;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: 50%;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .staci-header__close:hover {
    color: var(--color-cream);
    background: rgba(255, 255, 255, 0.08);
  }

  /* ─── Welcome Card ────────────────────────────────────────── */
  .staci-welcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 1rem 0.5rem;
    animation: staciWelcomeIn 0.5s var(--ease-out) both;
  }

  @keyframes staciWelcomeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .staci-welcome__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2.5px solid var(--color-gold-soft);
    box-shadow: 0 2px 12px rgba(255, 212, 0, 0.15), 0 1px 4px rgba(44, 44, 44, 0.08);
    margin-bottom: 0.7rem;
    animation: staciAvatarGlow 3s ease-in-out infinite;
  }

  @keyframes staciAvatarGlow {
    0%, 100% { box-shadow: 0 2px 12px rgba(255, 212, 0, 0.12), 0 1px 4px rgba(44, 44, 44, 0.06); }
    50% { box-shadow: 0 2px 20px rgba(255, 212, 0, 0.28), 0 1px 4px rgba(44, 44, 44, 0.06); }
  }

  .staci-welcome__name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-charcoal);
    margin-bottom: 0.25rem;
  }

  .staci-welcome__sub {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-stone);
    max-width: 280px;
    margin-bottom: 1rem;
  }

  .staci-welcome__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
  }

  .staci-welcome__chips .staci-chip {
    animation: staciPillIn 0.3s var(--ease-out) both;
    min-height: 36px;
    font-size: 0.76rem;
  }

  .staci-welcome__chips .staci-chip:nth-child(1) { animation-delay: 0.1s; }
  .staci-welcome__chips .staci-chip:nth-child(2) { animation-delay: 0.16s; }
  .staci-welcome__chips .staci-chip:nth-child(3) { animation-delay: 0.22s; }
  .staci-welcome__chips .staci-chip:nth-child(4) { animation-delay: 0.28s; }

  /* ─── Messages ───────────────────────────────────────────── */
  .staci-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.1rem 1rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    max-height: 360px;
    min-height: 120px;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
  }

  .staci-messages:hover {
    scrollbar-color: var(--color-cream-dark) transparent;
  }

  .staci-messages::-webkit-scrollbar {
    width: 4px;
  }

  .staci-messages::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .staci-messages:hover::-webkit-scrollbar-thumb {
    background: var(--color-cream-dark);
  }

  .staci-msg {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    animation: staciMsgIn 0.35s var(--ease-out) both;
  }

  .staci-msg--user {
    flex-direction: row-reverse;
    animation: staciUserMsgIn 0.3s var(--ease-out) both;
  }

  .staci-msg__avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .staci-msg--bot > .staci-msg__avatar {
    border: 1.5px solid var(--color-gold-soft);
    box-shadow: 0 1px 4px rgba(44, 44, 44, 0.1);
  }

  span.staci-msg__avatar {
    background: var(--color-charcoal);
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.6rem;
  }

  .staci-msg__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    max-width: 80%;
    min-width: 0;
  }

  .staci-msg__bubble {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    line-height: 1.65;
    letter-spacing: 0.005em;
    color: var(--color-charcoal);
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  /* Rich text in bot bubbles */
  .staci-msg--bot .staci-msg__bubble :global(strong) { font-weight: 600; }
  .staci-msg--bot .staci-msg__bubble :global(a) {
    color: var(--color-cyan);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    font-weight: 500;
    transition: color 0.15s;
  }
  .staci-msg--bot .staci-msg__bubble :global(a:hover) {
    color: var(--color-charcoal);
  }
  .staci-msg--bot .staci-msg__bubble :global(a:active) {
    opacity: 0.7;
  }
  .staci-msg--bot .staci-msg__bubble :global(ul),
  .staci-msg--bot .staci-msg__bubble :global(ol) {
    margin: 0.5rem 0 0.6rem;
    padding-left: 1.2rem;
  }
  .staci-msg--bot .staci-msg__bubble :global(li) {
    margin: 0.35rem 0;
    line-height: 1.55;
  }
  .staci-msg--bot .staci-msg__bubble :global(li::marker) {
    color: var(--color-stone);
  }
  .staci-msg--bot .staci-msg__bubble :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82em;
    background: rgba(44, 44, 44, 0.06);
    padding: 0.15em 0.35em;
    border-radius: 4px;
  }
  .staci-msg--bot .staci-msg__bubble :global(p) {
    margin: 0;
  }
  .staci-msg--bot .staci-msg__bubble :global(p + p) {
    margin-top: 0.55rem;
  }

  .staci-msg--bot .staci-msg__bubble {
    background: var(--color-cream);
    border-radius: 6px 16px 16px 16px;
    box-shadow: 0 1px 4px rgba(44, 44, 44, 0.06);
  }

  .staci-msg--user .staci-msg__bubble {
    background: var(--color-charcoal);
    color: var(--color-cream);
    border-radius: 16px 6px 16px 16px;
    box-shadow: 0 1px 4px rgba(44, 44, 44, 0.1);
  }

  /* Typing indicator — shimmer bar */
  .staci-typing .staci-msg__bubble {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    padding: 0.75rem 1rem;
  }

  .staci-shimmer {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .staci-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-stone);
    animation: staciBounce 1.2s infinite ease-in-out both;
  }

  .staci-dot:nth-child(2) { animation-delay: 0.15s; }
  .staci-dot:nth-child(3) { animation-delay: 0.3s; }

  @keyframes staciBounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.3; }
    40% { transform: translateY(-4px); opacity: 1; }
  }

  .staci-typing__label {
    font-size: 0.68rem;
    color: var(--color-stone);
    letter-spacing: 0.02em;
    animation: staciTypingFade 2s ease-in-out infinite;
  }

  @keyframes staciTypingFade {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.8; }
  }

  @keyframes staciMsgIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes staciUserMsgIn {
    from { opacity: 0; transform: translateX(12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* Streaming bubble replaces typing — no slide, just crossfade */
  .staci-msg--bot.staci-msg--stream-start {
    animation: staciBotFadeIn 0.25s ease-out both;
  }

  @keyframes staciBotFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes staciPillIn {
    from { opacity: 0; transform: translateY(4px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes staciCursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.15; }
  }

  .staci-streaming::after {
    content: '▎';
    display: inline-block;
    animation: staciCursor 0.8s steps(1) infinite;
    color: var(--color-gold);
    margin-left: 2px;
    font-size: 0.95em;
    vertical-align: text-bottom;
    line-height: 1;
    transition: opacity 0.3s ease-out;
  }

  /* Fade out cursor when stream ends */
  .staci-streaming--done::after {
    opacity: 0;
    animation: none;
  }

  /* Error message with retry */
  .staci-msg--error .staci-msg__bubble {
    background: #FEF2F2;
    border: 1px solid #FECACA;
    color: #991B1B;
  }

  .staci-retry {
    display: inline-flex;
    align-items: center;
    margin-top: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-cyan);
    cursor: pointer;
    border: none;
    background: none;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
    min-height: 44px;
    transition: color 0.15s;
  }

  .staci-retry:hover {
    color: var(--color-charcoal);
  }

  .staci-msg__time {
    font-size: 0.6rem;
    color: var(--color-stone);
    opacity: 0;
    padding: 0 0.3rem;
    line-height: 1;
    transition: opacity 0.2s;
  }

  .staci-msg:hover .staci-msg__time {
    opacity: 0.55;
  }

  .staci-msg--user .staci-msg__time {
    text-align: right;
  }

  /* Delivered indicator on user messages */
  .staci-msg--user .staci-msg__delivered {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.2rem;
    font-size: 0.58rem;
    color: var(--color-stone);
    padding-right: 0.3rem;
    opacity: 0;
    animation: staciFadeIn 0.3s 0.4s ease-out forwards;
  }

  .staci-msg--user .staci-msg__delivered svg {
    width: 10px;
    height: 10px;
    stroke: var(--color-stone);
    flex-shrink: 0;
  }

  @keyframes staciFadeIn {
    to { opacity: 0.5; }
  }

  /* Time separator between message groups */
  .staci-time-sep {
    text-align: center;
    font-size: 0.6rem;
    color: var(--color-stone);
    opacity: 0.6;
    padding: 0.3rem 0;
    letter-spacing: 0.03em;
  }

  /* ─── Product Cards ───────────────────────────────────────── */
  .staci-products {
    display: flex;
    gap: 0.6rem;
    padding: 0.15rem 1rem 0.5rem 2.35rem;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    animation: staciMsgIn 0.35s var(--ease-out) both;
    scroll-snap-type: x proximity;
    scroll-padding-left: 2.35rem;
  }

  .staci-products::-webkit-scrollbar {
    display: none;
  }

  .staci-product-card {
    flex: 0 0 140px;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-charcoal);
    border: 1px solid var(--color-cream-dark);
    box-shadow: 0 1px 3px rgba(44, 44, 44, 0.04);
    transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
    display: flex;
    flex-direction: column;
    scroll-snap-align: start;
    position: relative;
    animation: staciCardIn 0.35s var(--ease-out) both;
  }

  .staci-product-card:nth-child(2) { animation-delay: 0.07s; }
  .staci-product-card:nth-child(3) { animation-delay: 0.14s; }
  .staci-product-card:nth-child(4) { animation-delay: 0.21s; }

  @keyframes staciCardIn {
    from { opacity: 0; transform: translateY(8px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .staci-product-card__badge {
    position: absolute;
    top: 6px;
    left: 6px;
    background: #EF4444;
    color: white;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.15rem 0.4rem;
