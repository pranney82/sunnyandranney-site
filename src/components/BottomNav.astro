---
const currentPath = Astro.url.pathname;
---

<nav class="bottom-nav" id="bottom-nav" aria-label="Mobile navigation">
  <a href="/" class:list={['bottom-nav__tab', { 'bottom-nav__tab--active': currentPath === '/' }]}>
    <svg class="bottom-nav__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>
    <span class="bottom-nav__label">Home</span>
  </a>

  <a href="/shop" class:list={['bottom-nav__tab', { 'bottom-nav__tab--active': currentPath.startsWith('/shop') }]}>
    <svg class="bottom-nav__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="7"/>
      <rect x="14" y="3" width="7" height="7"/>
      <rect x="3" y="14" width="7" height="7"/>
      <rect x="14" y="14" width="7" height="7"/>
    </svg>
    <span class="bottom-nav__label">Shop</span>
  </a>

  <a href="/#mission" class="bottom-nav__tab" id="bottom-nav-mission">
    <svg class="bottom-nav__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
    </svg>
    <span class="bottom-nav__label">Mission</span>
  </a>

  <button class="bottom-nav__tab" id="bottom-nav-cart" aria-label="Cart">
    <svg class="bottom-nav__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
      <line x1="3" y1="6" x2="21" y2="6"/>
      <path d="M16 10a4 4 0 01-8 0"/>
    </svg>
    <span class="bottom-nav__label">Cart</span>
    <span class="bottom-nav__badge" id="bottom-nav-cart-count" style="display:none;">0</span>
  </button>
</nav>

<style>
  .bottom-nav {
    display: flex;
    position: fixed;
    bottom: 0;
    z-index: 200;
    height: calc(64px + env(safe-area-inset-bottom, 0px));
    padding-bottom: env(safe-area-inset-bottom, 0px);

    /* Floating pill shape */
    margin: 0 10px 8px;
    left: 0;
    right: 0;
    border-radius: 20px;

    /* Frosted glass — Wayfair-style */
    background: rgba(255, 255, 255, 0.55);
    -webkit-backdrop-filter: saturate(180%) blur(24px);
    backdrop-filter: saturate(180%) blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.45);
    box-shadow:
      0 4px 30px rgba(0, 0, 0, 0.08),
      0 1px 3px rgba(0, 0, 0, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  .bottom-nav__tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    color: var(--color-stone);
    transition: color 0.2s;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    text-decoration: none;
    padding: 0;
  }

  .bottom-nav__tab:hover,
  .bottom-nav__tab--active {
    color: var(--color-charcoal);
  }

  .bottom-nav__tab--active .bottom-nav__icon {
    stroke: var(--color-gold);
    stroke-width: 2;
  }

  .bottom-nav__tab--active .bottom-nav__label {
    color: var(--color-charcoal);
    font-weight: 600;
  }

  .bottom-nav__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .bottom-nav__label {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .bottom-nav__badge {
    position: absolute;
    top: 6px;
    right: 50%;
    transform: translateX(14px);
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-size: 0.6rem;
    font-weight: 700;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* Only visible on mobile */
  @media (min-width: 768px) {
    .bottom-nav {
      display: none;
    }
  }
</style>

<script>
  // Cart button → open cart drawer
  document.getElementById('bottom-nav-cart')?.addEventListener('click', () => {
    window.openCart?.();
  });

  // Sync cart count badge with the header badge
  function syncBottomNavCart() {
    const headerCount = document.getElementById('cart-count');
    const bottomCount = document.getElementById('bottom-nav-cart-count');
    if (!headerCount || !bottomCount) return;

    const observer = new MutationObserver(() => {
      const count = headerCount.textContent || '0';
      const visible = headerCount.style.display !== 'none';
      bottomCount.textContent = count;
      bottomCount.style.display = visible ? 'flex' : 'none';
    });

    observer.observe(headerCount, {
      childList: true,
      attributes: true,
      attributeFilter: ['style'],
    });

    // Initial sync
    const count = headerCount.textContent || '0';
    const visible = headerCount.style.display !== 'none';
    bottomCount.textContent = count;
    bottomCount.style.display = visible ? 'flex' : 'none';
  }

  syncBottomNavCart();
  document.addEventListener('astro:after-swap', syncBottomNavCart);
</script>
