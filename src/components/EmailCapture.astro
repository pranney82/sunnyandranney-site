---
/**
 * Email capture — visually integrated as the top zone of the footer.
 * Same dark background so it reads as one unified footer section.
 */
---

<section class="email-capture" id="email-capture">
  <div class="container">
    <div class="email-capture__card">
      <div class="email-capture__text">
        <span class="email-capture__kicker">Be the First to Know</span>
        <h2>Early access to new arrivals, exclusive in-store events & mission&nbsp;updates.</h2>
      </div>
      <form class="email-capture__form" id="email-form">
        <div class="email-capture__input-wrap">
          <input
            type="email"
            id="email-input"
            placeholder="Your email address"
            required
            autocomplete="email"
            aria-label="Email address"
          />
          <button type="submit" class="email-capture__btn">
            Subscribe
          </button>
        </div>
        <p class="email-capture__privacy">
          No spam, ever. Unsubscribe anytime. <span>Your email supports our mission.</span>
        </p>
        <p class="email-capture__success" id="email-success" style="display:none;">
          You're in! We'll keep you posted on new arrivals and mission updates.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .email-capture {
    background: var(--color-charcoal);
    padding: clamp(2.5rem, 5vh, 3.5rem) 0 0;
    margin-top: -1px;
  }

  .email-capture__card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
    padding: clamp(2rem, 4vh, 3rem) clamp(1.5rem, 3vw, 2.5rem);
    background: linear-gradient(135deg, rgba(75, 149, 180, 0.08) 0%, rgba(255, 212, 0, 0.05) 100%);
    border: 1px solid rgba(75, 149, 180, 0.15);
    border-radius: 12px;
  }

  @media (min-width: 768px) {
    .email-capture__card {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--space-2xl);
    }
  }

  @media (max-width: 767px) {
    .email-capture {
      padding: clamp(1.5rem, 4vh, 2.5rem) 0 0;
    }
    .email-capture__card {
      gap: var(--space-sm);
      padding: 1.5rem 1.25rem;
    }
    .email-capture__text h2 {
      font-size: 1.15rem;
      line-height: 1.35;
    }
    .email-capture__input-wrap {
      flex-direction: column;
    }
    .email-capture__btn {
      padding: 0.9rem 1.5rem;
    }
    .email-capture__privacy {
      font-size: 0.68rem;
    }
  }

  .email-capture__kicker {
    display: block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-xs);
  }

  .email-capture__text h2 {
    font-family: var(--font-display);
    color: white;
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    line-height: 1.3;
    font-weight: 400;
  }

  .email-capture__input-wrap {
    display: flex;
    background: rgba(255, 255, 255, 0.08);
    border: 1.5px solid rgba(75, 149, 180, 0.25);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .email-capture__input-wrap:focus-within {
    border-color: var(--color-cyan);
    box-shadow: 0 0 0 3px rgba(75, 149, 180, 0.15);
  }

  .email-capture__form input[type="email"] {
    flex: 1;
    padding: 0.85rem 1.25rem;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: white;
    min-width: 0;
  }

  .email-capture__form input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .email-capture__btn {
    padding: 0.85rem 1.75rem;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .email-capture__btn:hover {
    background: var(--color-gold-light);
  }

  .email-capture__btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .email-capture__privacy {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 0.5rem;
    max-width: none;
  }

  .email-capture__privacy span {
    color: var(--color-cyan);
    opacity: 0.8;
  }

  .email-capture__success {
    font-size: 0.88rem;
    color: var(--color-gold);
    font-weight: 500;
    margin-top: 0.5rem;
    max-width: none;
  }
</style>

<script>
  function initEmailCapture() {
    const form = document.getElementById('email-form') as HTMLFormElement;
    if (!form || form.dataset.bound) return;
    form.dataset.bound = 'true';

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('#email-input') as HTMLInputElement;
      const success = form.querySelector('#email-success') as HTMLElement;
      const email = input?.value.trim();
      if (!email) return;

      // TODO: Replace with your email service endpoint (Klaviyo, Mailchimp, etc.)
      const subs = JSON.parse(localStorage.getItem('sr_email_subs') || '[]');
      if (!subs.includes(email)) subs.push(email);
      localStorage.setItem('sr_email_subs', JSON.stringify(subs));

      const inputWrap = form.querySelector('.email-capture__input-wrap') as HTMLElement;
      const privacy = form.querySelector('.email-capture__privacy') as HTMLElement;
      if (inputWrap) inputWrap.style.display = 'none';
      if (privacy) privacy.style.display = 'none';
      if (success) success.style.display = 'block';
    });
  }

  initEmailCapture();
  document.addEventListener('astro:after-swap', initEmailCapture);
</script>
