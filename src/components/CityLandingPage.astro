---
/**
 * Reusable service-area city landing page for local SEO.
 * Each city page passes unique prose + data; shared layout, schema, and reviews.
 */
import Base from '@/layouts/Base.astro';
import { getContactStatic, getHoursStatic, getReviewsStatic, formatHoursShort } from '@/lib/settings';
import { fetchGooglePlaceData } from '@/lib/google-places';
import { cfImage, cfSrcset } from '@/lib/images';

interface FAQ { q: string; a: string; }

export interface Props {
  slug: string;               // e.g. 'furniture-store-alpharetta-ga'
  cityName: string;           // 'Alpharetta'
  cityStateShort: string;     // 'Alpharetta, GA'
  distanceLine: string;       // '15 minutes · 6 miles south of our Roswell showroom'
  h1: string;                 // 'Furniture Store Serving Alpharetta, GA'
  title: string;              // Full <title>
  description: string;        // meta description
  intro: string;              // 1-2 paragraph HTML-safe prose
  designStyle: string;        // 1-2 sentences about local design sensibility
  directions: string;         // prose directions FROM that city
  landmarks: string[];        // 4-6 landmarks
  neighborhoods: string[];    // 5-8 neighborhoods within the city
  faqs: FAQ[];                // 5-6 FAQ entries
  cityLat: number;
  cityLng: number;
  otherCities: Array<{ name: string; slug: string }>; // for internal linking
}

const p = Astro.props;

const [contact, hours, reviewsSetting, livePlace] = await Promise.all([
  getContactStatic(),
  getHoursStatic(),
  getReviewsStatic(),
  fetchGooglePlaceData(),
]);

const address = contact?.address || '109A Oak Street';
const storeCity = contact?.city || 'Roswell';
const storeState = contact?.state || 'GA';
const zip = contact?.zip || '30075';
const phone = contact?.phone || '678.888.5140';
const phoneDigits = phone.replace(/\D/g, '');
const hoursLine = hours ? formatHoursShort(hours) : 'Tue–Thu 10am–5pm · Fri–Sat 10am–6pm';

const rating = livePlace?.rating ?? reviewsSetting?.googleRating ?? 5.0;
const reviewCount = livePlace?.reviewCount ?? reviewsSetting?.reviewCount ?? 75;
const reviews = (livePlace?.reviews ?? []).slice(0, 6);

const pageUrl = `https://sunnyandranney.com/${p.slug}/`;

// Hero image preload
const heroImageBase = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/sunny-ranney-storefront';
const heroImageSrc = cfImage(heroImageBase, { width: 880, quality: 80 });
const heroImageSrcset = cfSrcset(heroImageBase, [480, 720, 880, 1200], 80);
const heroImageSizes = '(max-width: 767px) 100vw, 50vw';

// Schema: FurnitureStore with city-specific areaServed
const localSchema = {
  '@context': 'https://schema.org',
  '@type': 'FurnitureStore',
  '@id': `${pageUrl}#furniturestore`,
  name: `Sunny & Ranney — Furniture Store Serving ${p.cityName}, GA`,
  alternateName: 'Sunny and Ranney',
  description: p.description,
  url: pageUrl,
  mainEntityOfPage: pageUrl,
  image: [
    'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/sunny-ranney-storefront/og',
    'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/og',
  ],
  logo: 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/logo-tagline-light-bg/full',
  telephone: '+16788885140',
  priceRange: '$$',
  currenciesAccepted: 'USD',
  paymentAccepted: 'Cash, Credit Card, Apple Pay, PayPal',
  address: {
    '@type': 'PostalAddress',
    streetAddress: address,
    addressLocality: storeCity,
    addressRegion: storeState,
    postalCode: zip,
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 34.0234, longitude: -84.3616 },
  hasMap: 'https://maps.app.goo.gl/QXwgPyiX93HkwjwDA',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday'], opens: '10:00', closes: '17:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Friday', 'Saturday'], opens: '10:00', closes: '18:00' },
  ],
  areaServed: {
    '@type': 'City',
    name: `${p.cityName}, GA`,
    geo: { '@type': 'GeoCoordinates', latitude: p.cityLat, longitude: p.cityLng },
    containedInPlace: { '@type': 'AdministrativeArea', name: 'Metro Atlanta' },
  },
  sameAs: [
    'https://www.instagram.com/sunnyandranney/',
    'https://www.facebook.com/sunnyandranney/',
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: rating,
    bestRating: 5,
    ratingCount: reviewCount,
  },
  ...(reviews.length > 0 && {
    review: reviews.map(r => ({
      '@type': 'Review',
      author: { '@type': 'Person', name: r.name },
      reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
      reviewBody: r.text,
      itemReviewed: { '@id': `${pageUrl}#furniturestore` },
    })),
  }),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://sunnyandranney.com/' },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: 'https://sunnyandranney.com/furniture-store-roswell-ga/' },
    { '@type': 'ListItem', position: 3, name: `${p.cityName}, GA`, item: pageUrl },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: p.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const deliveryService = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${pageUrl}#service-delivery`,
  name: `White-Glove Furniture Delivery to ${p.cityName}, GA`,
  serviceType: 'Furniture Delivery',
  description: `Professional white-glove delivery, assembly and placement for furniture orders throughout ${p.cityName}, Georgia and surrounding neighborhoods.`,
  provider: { '@id': `${pageUrl}#furniturestore` },
  areaServed: {
    '@type': 'City',
    name: `${p.cityName}, GA`,
    geo: { '@type': 'GeoCoordinates', latitude: p.cityLat, longitude: p.cityLng },
  },
  availableChannel: { '@type': 'ServiceChannel', servicePhone: '+16788885140', serviceUrl: pageUrl },
};
---

<Base
  title={p.title}
  description={p.description}
  lcpImage={heroImageSrc}
  lcpImageSrcset={heroImageSrcset}
  lcpImageSizes={heroImageSizes}
>
  <script type="application/ld+json" set:html={JSON.stringify(localSchema)}/>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}/>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}/>
  <script type="application/ld+json" set:html={JSON.stringify(deliveryService)}/>

  <article class="city">
    <!-- ─── Hero ─── -->
    <section class="city__hero">
      <div class="container city__hero-grid">
        <div>
          <nav class="city__crumbs" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">›</span>
            <a href="/furniture-store-roswell-ga/">Service Areas</a>
            <span aria-hidden="true">›</span>
            <span>{p.cityName}, GA</span>
          </nav>
          <span class="city__kicker">{p.distanceLine}</span>
          <h1 class="city__h1">{p.h1}</h1>
          <div class="city__lede" set:html={p.intro} />

          <div class="city__meta">
            <div class="city__meta-item">
              <span class="city__meta-label">Showroom</span>
              <span>{address}, {storeCity}, {storeState} {zip}</span>
            </div>
            <div class="city__meta-item">
              <span class="city__meta-label">Hours</span>
              <span>{hoursLine}</span>
            </div>
            <div class="city__meta-item">
              <span class="city__meta-label">Phone</span>
              <a href={`tel:${phoneDigits}`}>{phone}</a>
            </div>
            <div class="city__meta-item">
              <span class="city__meta-label">Rating</span>
              <span>★ {rating.toFixed(1)} · {reviewCount}+ Google reviews</span>
            </div>
          </div>

          <div class="city__ctas">
            <a class="city__btn city__btn--primary" href="https://maps.app.goo.gl/QXwgPyiX93HkwjwDA" target="_blank" rel="noopener noreferrer">Get Directions</a>
            <a class="city__btn city__btn--ghost" href="/shop/">Shop the Showroom</a>
            <a class="city__btn city__btn--ghost" href={`tel:${phoneDigits}`}>Call {phone}</a>
          </div>
        </div>
        <div class="city__hero-image">
          <img
            src={heroImageSrc}
            srcset={heroImageSrcset}
            sizes={heroImageSizes}
            alt={`Sunny & Ranney designer furniture showroom serving ${p.cityName}, GA — located on Oak Street in Historic Roswell`}
            width="880"
            height="660"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <!-- ─── Design Sensibility + Landmarks ─── -->
    <section class="city__section">
      <div class="container city__grid">
        <div>
          <h2>How We Serve {p.cityName} Homes</h2>
          <p>{p.designStyle}</p>
          <p>
            Our Historic Roswell showroom is a short drive from {p.cityName}, and our white-glove delivery team
            makes regular runs throughout your neighborhood. Bring your floor plan, your designer, or just your
            questions — we'll help you find pieces that fit your home and your taste.
          </p>
          <p>
            And every dollar of profit funds <a href="/about/">Sunshine on a Ranney Day</a>, building dream bedrooms
            for children with special needs. When you shop with us from {p.cityName}, you're furnishing your home
            <em>and</em> transforming a kid's life.
          </p>
        </div>
        <aside class="city__landmarks">
          <h3>Close To</h3>
          <ul>
            {p.landmarks.map(l => <li>{l}</li>)}
          </ul>
        </aside>
      </div>
    </section>

    <!-- ─── Neighborhoods Served ─── -->
    <section class="city__section city__section--alt">
      <div class="container">
        <h2>Neighborhoods We Serve in {p.cityName}</h2>
        <p class="city__sub">
          We deliver throughout {p.cityName} and work with clients in these neighborhoods and communities:
        </p>
        <ul class="city__neighborhoods">
          {p.neighborhoods.map(n => <li>{n}</li>)}
        </ul>
      </div>
    </section>

    <!-- ─── Directions ─── -->
    <section class="city__section">
      <div class="container city__grid">
        <div>
          <h2>Directions from {p.cityName} to Our Roswell Showroom</h2>
          <p class="city__directions" set:html={p.directions} />
          <p>
            <strong>Address:</strong> {address}, {storeCity}, {storeState} {zip}<br />
            <strong>Phone:</strong> <a href={`tel:${phoneDigits}`}>{phone}</a><br />
            <strong>Hours:</strong> {hoursLine}
          </p>
          <a class="city__btn city__btn--primary" href="https://maps.app.goo.gl/QXwgPyiX93HkwjwDA" target="_blank" rel="noopener noreferrer">Open in Google Maps</a>
        </div>
        <div class="city__map">
          <iframe
            src="https://www.google.com/maps?q=109A+Oak+Street+Roswell+GA+30075&output=embed"
            width="100%"
            height="420"
            style="border:0;border-radius:12px;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Map of Sunny & Ranney furniture store near ${p.cityName}, GA`}
          ></iframe>
        </div>
      </div>
    </section>

    <!-- ─── Shop Categories ─── -->
    <section class="city__section city__section--alt">
      <div class="container">
        <h2>What You'll Find in Our Showroom</h2>
        <div class="city__cats">
          <a href="/shop/?collection=living"><span>Living Room</span><small>Sofas, sectionals, chairs</small></a>
          <a href="/shop/?collection=dining"><span>Dining</span><small>Tables, chairs, buffets</small></a>
          <a href="/shop/?collection=bedroom"><span>Bedroom</span><small>Beds, nightstands, dressers</small></a>
          <a href="/shop/?collection=rugs"><span>Rugs</span><small>Hand-knotted &amp; area rugs</small></a>
          <a href="/shop/?collection=art-mirrors"><span>Art &amp; Mirrors</span><small>Original art, mirrors</small></a>
          <a href="/shop/?collection=outdoor"><span>Outdoor</span><small>Patio &amp; garden</small></a>
        </div>
      </div>
    </section>

    <!-- ─── Reviews ─── -->
    {reviews.length > 0 && (
      <section class="city__section">
        <div class="container">
          <h2>What Customers Are Saying</h2>
          <p class="city__sub">★ {rating.toFixed(1)} average from {reviewCount}+ Google reviews.</p>
          <div class="city__reviews">
            {reviews.map(r => (
              <figure class="city__review">
                <div class="city__review-head">
                  {r.photoUrl ? (
                    <img src={r.photoUrl} alt={`${r.name} review avatar`} width="48" height="48" loading="lazy" decoding="async" />
                  ) : (
                    <div class="city__review-initial" aria-hidden="true">{r.name.charAt(0)}</div>
                  )}
                  <div>
                    <figcaption>{r.name}</figcaption>
                    <div class="city__review-stars" aria-label={`${r.rating} out of 5 stars`}>
                      {'★'.repeat(r.rating)}<span class="city__review-empty">{'★'.repeat(5 - r.rating)}</span>
                    </div>
                    {r.timeAgo && <small>{r.timeAgo}</small>}
                  </div>
                </div>
                <blockquote>{r.text.length > 260 ? r.text.slice(0, 260).trim() + '…' : r.text}</blockquote>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ─── FAQ ─── -->
    <section class="city__section city__section--alt">
      <div class="container">
        <h2>Frequently Asked Questions</h2>
        <div class="city__faq">
          {p.faqs.map(f => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Other Service Areas ─── -->
    <section class="city__section">
      <div class="container">
        <h2>Also Serving North Atlanta</h2>
        <p class="city__sub">Shoppers from these nearby cities also trust us for designer furniture:</p>
        <ul class="city__other">
          <li><a href="/furniture-store-roswell-ga/">Roswell, GA</a></li>
          {p.otherCities.map(c => <li><a href={`/${c.slug}/`}>{c.name}, GA</a></li>)}
        </ul>
      </div>
    </section>
  </article>
</Base>

<style>
  .city { color: var(--color-charcoal); }
  .city h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.15;
    margin: 0 0 var(--space-md);
  }
  .city h3 {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-cyan);
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .city p { line-height: 1.7; font-size: 1rem; margin: 0 0 var(--space-sm); max-width: 68ch; color: #3a3a3a; }
  .city a { color: var(--color-cyan); }

  /* Hero */
  .city__hero {
    padding: clamp(3rem, 9vh, 6rem) 0 clamp(2.5rem, 6vh, 4rem);
    background: linear-gradient(180deg, #FAF7F2 0%, #F3EEE5 100%);
  }
  .city__hero-grid {
    display: grid; grid-template-columns: 1fr; gap: var(--space-lg); align-items: center;
  }
  @media (min-width: 860px) {
    .city__hero-grid { grid-template-columns: 1.15fr 1fr; gap: var(--space-2xl); }
  }
  .city__hero-image img {
    width: 100%; height: auto; display: block;
    border-radius: 14px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.18);
    aspect-ratio: 4/3; object-fit: cover;
  }
  .city__crumbs { font-size: 0.78rem; color: #6b6b6b; margin-bottom: var(--space-sm); display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
  .city__kicker {
    display: inline-block; font-size: 0.72rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--color-cyan); font-weight: 600;
    margin-bottom: var(--space-xs);
  }
  .city__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.08;
    margin: 0 0 var(--space-sm);
    color: var(--color-charcoal);
  }
  .city__lede { font-size: 1.05rem; max-width: 62ch; color: #3a3a3a; margin-bottom: var(--space-md); }
  .city__lede :global(strong) { color: var(--color-charcoal); }

  .city__meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-sm);
    margin: var(--space-md) 0;
    padding: var(--space-sm) 0;
    border-top: 1px solid rgba(0,0,0,0.1);
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .city__meta-item { display: flex; flex-direction: column; gap: 0.15rem; font-size: 0.88rem; }
  .city__meta-label { font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: #6b6b6b; font-weight: 600; }

  .city__ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: var(--space-sm); }
  .city__btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0.85rem 1.6rem;
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    border-radius: 8px; transition: all 0.3s; min-height: 48px;
  }
  .city__btn--primary { background: var(--color-cyan); color: white; }
  .city__btn--primary:hover { background: var(--color-cyan-light, #5BA7C4); }
  .city__btn--ghost { background: transparent; color: var(--color-charcoal); border: 1.5px solid var(--color-charcoal); }
  .city__btn--ghost:hover { background: var(--color-charcoal); color: white; }

  /* Sections */
  .city__section { padding: clamp(2.5rem, 6vh, 4.5rem) 0; }
  .city__section--alt { background: #FAF7F2; }
  .city__sub { color: #4a4a4a; max-width: 68ch; margin-bottom: var(--space-md); }

  .city__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-xl); }
  @media (min-width: 860px) {
    .city__grid { grid-template-columns: 1.15fr 1fr; align-items: start; gap: var(--space-2xl); }
  }

  .city__landmarks {
    padding: var(--space-md);
    background: white;
    border-left: 3px solid var(--color-gold);
    border-radius: 4px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
  }
  .city__landmarks ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .city__landmarks li { font-size: 0.92rem; color: #3a3a3a; }
  .city__landmarks li::before { content: '◆ '; color: var(--color-cyan); font-size: 0.7rem; }

  /* Neighborhoods */
  .city__neighborhoods {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem;
  }
  .city__neighborhoods li {
    padding: 0.5rem 0.9rem; background: white;
    border: 1px solid rgba(0,0,0,0.1); border-radius: 999px;
    font-size: 0.85rem; color: #3a3a3a;
  }

  /* Categories */
  .city__cats {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-sm); margin-top: var(--space-md);
  }
  .city__cats a {
    display: flex; flex-direction: column; gap: 0.25rem;
    padding: var(--space-md); background: white; border-radius: 10px;
    border: 1px solid rgba(0,0,0,0.08);
    transition: all 0.3s; color: var(--color-charcoal);
  }
  .city__cats a:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.08); border-color: var(--color-cyan); }
  .city__cats span { font-family: var(--font-display); font-size: 1.25rem; }
  .city__cats small { font-size: 0.82rem; color: #6b6b6b; }

  /* Directions */
  .city__directions { font-size: 0.94rem; color: #3a3a3a; max-width: 62ch; }
  .city__directions :global(strong) { color: var(--color-charcoal); }
  .city__map iframe { display: block; width: 100%; box-shadow: 0 12px 40px rgba(0,0,0,0.1); }

  /* Reviews */
  .city__reviews {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md); margin-top: var(--space-md);
  }
  .city__review {
    margin: 0; padding: var(--space-md);
    background: white; border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 8px 24px rgba(0,0,0,0.05);
  }
  .city__review-head { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 0.6rem; }
  .city__review-head img { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
  .city__review-initial {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--color-cyan); color: white;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 1.2rem;
  }
  .city__review figcaption { font-weight: 600; color: var(--color-charcoal); font-size: 0.95rem; }
  .city__review-stars { color: var(--color-gold); letter-spacing: 1px; font-size: 0.85rem; line-height: 1; }
  .city__review-empty { color: rgba(0,0,0,0.15); }
  .city__review small { color: #6b6b6b; font-size: 0.75rem; }
  .city__review blockquote { margin: 0; padding: 0; font-size: 0.92rem; line-height: 1.6; color: #3a3a3a; }

  /* FAQ */
  .city__faq { display: flex; flex-direction: column; gap: 0.5rem; max-width: 820px; }
  .city__faq details {
    background: white; border: 1px solid rgba(0,0,0,0.08); border-radius: 10px;
    padding: 0.25rem 1.1rem; transition: border-color 0.3s;
  }
  .city__faq details[open] { border-color: var(--color-cyan); }
  .city__faq summary {
    cursor: pointer; padding: 0.9rem 0;
    font-weight: 600; font-size: 0.98rem;
    color: var(--color-charcoal);
    list-style: none;
    display: flex; justify-content: space-between; align-items: center;
  }
  .city__faq summary::-webkit-details-marker { display: none; }
  .city__faq summary::after {
    content: '+'; font-size: 1.3rem; color: var(--color-cyan);
    transition: transform 0.3s; font-weight: 400;
  }
  .city__faq details[open] summary::after { transform: rotate(45deg); }
  .city__faq p { padding: 0 0 0.9rem; color: #4a4a4a; font-size: 0.94rem; max-width: 70ch; }

  /* Other cities */
  .city__other { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .city__other li a {
