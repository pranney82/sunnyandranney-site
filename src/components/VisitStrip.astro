---
/**
 * Visit our showroom strip — appears on every page above the footer.
 * Lazy-loads a static Google Maps image (zero JS overhead vs embed iframe).
 */
import type { ContactInfo, StoreHours } from '@/lib/settings';

interface Props {
  contact?: ContactInfo | null;
  hours?: string | null;
  holidays?: StoreHours['holidays'];
}

const { contact, hours, holidays = [] } = Astro.props;

const address = contact?.address || '109A Oak Street';
const city = contact?.city || 'Roswell';
const state = contact?.state || 'GA';
const zip = contact?.zip || '30075';
const phone = contact?.phone || '678.888.5140';
const email = contact?.email || 'info@sunnyandranney.com';
const phoneDigits = phone.replace(/\D/g, '');
const mapQuery = `${address}+${city}+${state}+${zip}`.replace(/\s+/g, '+');
---

<section class="visit-strip">
  <div class="container visit-strip__inner">

    <!-- Left: Photos -->
    <div class="visit-strip__gallery">
      <div class="visit-strip__photo visit-strip__photo--main">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=600,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=400,q=75,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=600,q=80,format=auto 600w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/sunny-ranney-interior/w=900,q=80,format=auto 900w"
          sizes="(max-width: 767px) 85vw, 40vw"
          alt="Inside the Sunny & Ranney showroom"
          width="600"
          height="450"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="visit-strip__photo visit-strip__photo--inset">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/sunny-ranney-storefront/w=400,q=80,format=auto"
          srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/sunny-ranney-storefront/w=250,q=75,format=auto 250w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/sunny-ranney-storefront/w=400,q=80,format=auto 400w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/about/sunny-ranney-storefront/w=600,q=80,format=auto 600w"
          sizes="(max-width: 767px) 40vw, 20vw"
          alt="Sunny & Ranney storefront in Roswell, Georgia"
          width="400"
          height="300"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- Right: Info -->
    <div class="visit-strip__content">
      <span class="visit-strip__kicker">Shop with a Purpose</span>
      <h2 class="visit-strip__title">Every Purchase Transforms a Child's&nbsp;Bedroom</h2>
      <p class="visit-strip__tagline">100% of profits fund bedroom makeovers for children with special needs through <a href="/about/">Sunshine on a Ranney Day</a>.</p>

      <div class="visit-strip__details">
        <div class="visit-strip__detail">
          <svg class="visit-strip__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div>
            <p>{address}</p>
            <p>{city}, {state} {zip}</p>
          </div>
        </div>

        <div class="visit-strip__detail">
          <svg class="visit-strip__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div>
            {hours ? (
              <p>{hours}</p>
            ) : (
              <>
                <p>Tue &ndash; Thu: 10am &ndash; 5pm</p>
                <p>Fri &ndash; Sat: 10am &ndash; 6pm</p>
              </>
            )}
            {holidays.length > 0 && (
              <div class="visit-strip__holidays" data-holidays={JSON.stringify(holidays)}></div>
            )}
          </div>
        </div>

        <div class="visit-strip__detail">
          <svg class="visit-strip__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div>
            <a href={`tel:${phoneDigits}`}>{phone}</a>
            <a href={`mailto:${email}`}>{email}</a>
          </div>
        </div>
      </div>

      <a href="https://maps.app.goo.gl/QXwgPyiX93HkwjwDA" target="_blank" rel="noopener noreferrer" class="visit-strip__btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Get Directions
      </a>
    </div>
  </div>
</section>

<style>
  .visit-strip {
    background: var(--color-charcoal);
    padding: clamp(3rem, 8vh, 5rem) 0;
    position: relative;
    overflow: hidden;
  }

  /* Subtle warm glow */
  .visit-strip::before {
    content: '';
    position: absolute;
    top: -40%;
    left: -10%;
    width: 50%;
    height: 180%;
    background: radial-gradient(circle, rgba(255, 212, 0, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .visit-strip::after {
    content: '';
    position: absolute;
    bottom: -30%;
    right: -5%;
    width: 40%;
    height: 160%;
    background: radial-gradient(circle, rgba(75, 149, 180, 0.06) 0%, transparent 55%);
    pointer-events: none;
  }

  .visit-strip__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .visit-strip__inner {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: var(--space-2xl);
    }
  }

  /* ─── Gallery ──────────────────────────── */
  .visit-strip__gallery {
    position: relative;
    padding-bottom: 2.5rem;
    padding-right: 2.5rem;
  }

  .visit-strip__photo img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .visit-strip__photo--main {
    position: relative;
    z-index: 1;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }

  .visit-strip__photo--main img {
    transition: transform 0.8s var(--ease-out);
  }

  .visit-strip__photo--main:hover img {
    transform: scale(1.03);
  }

  .visit-strip__photo--inset {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 48%;
    z-index: 2;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    border: 3px solid var(--color-cyan);
  }

  .visit-strip__photo--inset img {
    transition: transform 0.8s var(--ease-out);
  }

  .visit-strip__photo--inset:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 767px) {
    .visit-strip {
      padding: clamp(2rem, 5vh, 2.5rem) 0;
    }
    .visit-strip__inner {
      gap: var(--space-md);
    }
    .visit-strip__gallery {
      padding-bottom: 1.25rem;
      padding-right: 1.25rem;
    }
    .visit-strip__photo--main {
      border-radius: 10px;
    }
    .visit-strip__photo--inset {
      width: 42%;
      border-radius: 8px;
    }
    .visit-strip__title {
      font-size: 1.3rem;
      margin-bottom: var(--space-xs);
    }
    .visit-strip__tagline {
      font-size: 0.82rem;
      margin-bottom: var(--space-sm);
      max-width: none;
    }
    .visit-strip__details {
      display: none;
    }
    .visit-strip__btn {
      width: 100%;
      justify-content: center;
      padding: 0.85rem 1.5rem;
    }
  }

  /* ─── Content ─────────────────────────── */
  .visit-strip__content {
    display: flex;
    flex-direction: column;
  }

  .visit-strip__kicker {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-cyan);
    margin-bottom: var(--space-xs);
  }

  .visit-strip__title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: white;
    margin: 0 0 var(--space-sm);
    line-height: 1.15;
  }

  .visit-strip__tagline {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin: 0 0 var(--space-lg);
    max-width: 36ch;
  }

  .visit-strip__tagline a {
    color: var(--color-gold);
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .visit-strip__tagline a:hover {
    opacity: 0.8;
  }

  /* ─── Details with icons ──────────────── */
  .visit-strip__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .visit-strip__detail {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .visit-strip__icon {
    color: var(--color-cyan);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .visit-strip__detail div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .visit-strip__detail p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    line-height: 1.5;
    max-width: none;
  }

  .visit-strip__detail a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s;
    line-height: 1.5;
  }

  .visit-strip__detail a:hover {
    color: var(--color-cyan);
  }

  .visit-strip__detail a:focus-visible {
    outline: 2px solid var(--color-cyan);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .visit-strip__holidays {
    margin-top: 0.35rem;
    font-size: 0.82rem;
    color: var(--color-gold);
    opacity: 0.85;
    line-height: 1.5;
  }

  .visit-strip__holidays p {
    color: var(--color-gold);
    font-size: 0.82rem;
  }

  /* ─── Button ──────────────────────────── */
  .visit-strip__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: white;
    background: var(--color-cyan);
    border-radius: 4px;
    transition: background 0.3s, transform 0.3s;
    align-self: flex-start;
  }

  .visit-strip__btn:hover {
    background: var(--color-cyan-light);
    transform: translateY(-1px);
  }

  .visit-strip__btn:focus-visible {
    outline: 2px solid var(--color-cyan);
    outline-offset: 4px;
    border-radius: 4px;
  }
</style>

<script>
  function formatTime(time: string): string {
    const [h, m] = time.split(':').map(Number);
    const suffix = h >= 12 ? 'pm' : 'am';
    const hour = h > 12 ? h - 12 : h === 0 ? 12 : h;
    return m === 0 ? `${hour}${suffix}` : `${hour}:${m.toString().padStart(2, '0')}${suffix}`;
  }

  function initVisitStripHolidays() {
    const el = document.querySelector('.visit-strip__holidays') as HTMLElement | null;
    if (!el) return;
    const holidays = JSON.parse(el.dataset.holidays || '[]');
    if (!holidays.length) return;

    const today = new Date().toISOString().split('T')[0];
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() + 14);
    const cutoffStr = cutoff.toISOString().split('T')[0];

    const todayHoliday = holidays.find((h: any) => h.date === today);
    const upcoming = holidays
      .filter((h: any) => h.date > today && h.date <= cutoffStr)
      .sort((a: any, b: any) => a.date.localeCompare(b.date))
      .slice(0, 2);

    const lines: string[] = [];
    if (todayHoliday) {
      if (todayHoliday.closed) {
        lines.push(`Today: Closed for ${todayHoliday.label}`);
      } else {
        lines.push(`Today: ${todayHoliday.label} ${formatTime(todayHoliday.open)}\u2013${formatTime(todayHoliday.close)}`);
      }
    }
    for (const h of upcoming) {
      const d = new Date(h.date + 'T12:00:00');
      const label = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      if (h.closed) {
        lines.push(`${label}: Closed (${h.label})`);
      } else {
        lines.push(`${label}: ${h.label} ${formatTime(h.open)}\u2013${formatTime(h.close)}`);
      }
    }

    if (lines.length) {
      el.innerHTML = lines.map(l => `<p style="margin:0">${l}</p>`).join('');
    }
  }

  initVisitStripHolidays();
  document.addEventListener('astro:after-swap', initVisitStripHolidays);
</script>
