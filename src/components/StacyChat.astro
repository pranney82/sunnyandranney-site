---
/* Stacy — AI shopping assistant chat widget (Cloudflare Workers AI) */
---

<!-- Chat toggle button -->
<button id="stacy-toggle" aria-label="Chat with Stacy" title="Chat with Stacy">
  <svg id="stacy-icon-chat" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </svg>
  <svg id="stacy-icon-close" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
  </svg>
</button>

<!-- Chat panel -->
<div id="stacy-panel" aria-hidden="true">
  <div class="stacy-header">
    <div class="stacy-header__info">
      <img class="stacy-avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Stacy" />
      <div>
        <strong>Stacy</strong>
        <span class="stacy-status">AI Shopping Assistant</span>
      </div>
    </div>
  </div>

  <div id="stacy-messages" class="stacy-messages">
    <div class="stacy-msg stacy-msg--bot">
      <img class="stacy-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Stacy" />
      <div class="stacy-msg__bubble">Hi! I'm Stacy, your shopping assistant. How can I help you today?</div>
    </div>
  </div>

  <form id="stacy-form" class="stacy-input">
    <input
      id="stacy-input"
      type="text"
      placeholder="Ask Stacy anything…"
      autocomplete="off"
      aria-label="Type a message"
    />
    <button type="submit" aria-label="Send message">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </form>
</div>

<style>
  /* ─── Toggle Button ──────────────────────────────────────── */
  #stacy-toggle {
    position: fixed;
    bottom: 6rem;
    right: 1.5rem;
    z-index: 9999;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--color-charcoal);
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(44, 44, 44, 0.3);
    transition: transform 0.3s var(--ease-out), background 0.3s var(--ease-out);
    cursor: pointer;
    border: none;
  }

  #stacy-toggle:hover {
    transform: scale(1.08);
    background: var(--color-gold);
    color: var(--color-charcoal);
  }

  /* ─── Chat Panel ─────────────────────────────────────────── */
  #stacy-panel {
    position: fixed;
    bottom: 10.5rem;
    right: 1.5rem;
    z-index: 9998;
    width: 380px;
    max-height: 520px;
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    box-shadow: 0 12px 40px rgba(44, 44, 44, 0.15);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out);
  }

  #stacy-panel[aria-hidden="false"] {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ─── Header ─────────────────────────────────────────────── */
  .stacy-header {
    padding: 1rem 1.25rem;
    background: var(--color-charcoal);
    color: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .stacy-header__info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .stacy-header__info strong {
    font-family: var(--font-display);
    font-size: 1.1rem;
    display: block;
    line-height: 1.2;
  }

  .stacy-status {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
  }

  .stacy-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  /* ─── Messages ───────────────────────────────────────────── */
  .stacy-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-height: 350px;
    min-height: 200px;
  }

  .stacy-msg {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }

  .stacy-msg--user {
    flex-direction: row-reverse;
  }

  .stacy-msg__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  span.stacy-msg__avatar {
    background: var(--color-cyan);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
  }

  .stacy-msg__bubble {
    padding: 0.65rem 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
    max-width: 80%;
    color: var(--color-charcoal);
  }

  .stacy-msg--bot .stacy-msg__bubble {
    background: var(--color-cream);
    border-radius: 2px 12px 12px 12px;
  }

  .stacy-msg--user .stacy-msg__bubble {
    background: var(--color-charcoal);
    color: var(--color-cream);
    border-radius: 12px 2px 12px 12px;
  }

  /* Typing indicator */
  .stacy-typing .stacy-msg__bubble {
    display: flex;
    gap: 0.3rem;
    align-items: center;
    padding: 0.8rem 1.2rem;
  }

  .stacy-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-stone);
    animation: stacyBounce 1.4s infinite ease-in-out both;
  }

  .stacy-dot:nth-child(2) { animation-delay: 0.16s; }
  .stacy-dot:nth-child(3) { animation-delay: 0.32s; }

  @keyframes stacyBounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  /* ─── Input ──────────────────────────────────────────────── */
  .stacy-input {
    display: flex;
    border-top: 1px solid var(--color-cream-dark);
    padding: 0;
  }

  .stacy-input input {
    flex: 1;
    padding: 0.9rem 1.25rem;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    background: transparent;
    color: var(--color-charcoal);
  }

  .stacy-input input::placeholder {
    color: var(--color-stone);
  }

  .stacy-input button {
    padding: 0.9rem 1.25rem;
    color: var(--color-gold);
    transition: color 0.2s;
    cursor: pointer;
    border: none;
    background: none;
  }

  .stacy-input button:hover {
    color: var(--color-charcoal);
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 480px) {
    #stacy-panel {
      width: calc(100vw - 2rem);
      right: 1rem;
      bottom: 10rem;
      max-height: 70vh;
    }

    #stacy-toggle {
      width: 52px;
      height: 52px;
      bottom: 5.5rem;
      right: 1rem;
    }
  }
</style>

<script>
  function initStacy() {
    const toggle = document.getElementById('stacy-toggle')!;
    const panel = document.getElementById('stacy-panel')!;
    const form = document.getElementById('stacy-form')! as HTMLFormElement;
    const input = document.getElementById('stacy-input')! as HTMLInputElement;
    const messagesEl = document.getElementById('stacy-messages')!;
    const iconChat = document.getElementById('stacy-icon-chat')!;
    const iconClose = document.getElementById('stacy-icon-close')!;

    let conversationHistory: { role: string; content: string }[] = [];

    toggle.addEventListener('click', () => {
      const isOpen = panel.getAttribute('aria-hidden') === 'false';
      panel.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
      iconChat.style.display = isOpen ? 'block' : 'none';
      iconClose.style.display = isOpen ? 'none' : 'block';
      if (!isOpen) input.focus();
    });

    function addMessage(text: string, isUser: boolean) {
      const msg = document.createElement('div');
      msg.className = `stacy-msg stacy-msg--${isUser ? 'user' : 'bot'}`;
      msg.innerHTML = `
        ${isUser ? '<span class="stacy-msg__avatar">Y</span>' : '<img class="stacy-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Stacy" />'}
        <div class="stacy-msg__bubble">${escapeHtml(text)}</div>
      `;
      messagesEl.appendChild(msg);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function showTyping() {
      const typing = document.createElement('div');
      typing.className = 'stacy-msg stacy-msg--bot stacy-typing';
      typing.id = 'stacy-typing';
      typing.innerHTML = `
        <img class="stacy-msg__avatar" src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/ai-chat-avatar/nav" loading="lazy" alt="Stacy" />
        <div class="stacy-msg__bubble">
          <span class="stacy-dot"></span>
          <span class="stacy-dot"></span>
          <span class="stacy-dot"></span>
        </div>
      `;
      messagesEl.appendChild(typing);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function removeTyping() {
      document.getElementById('stacy-typing')?.remove();
    }

    function escapeHtml(str: string) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text) return;

      addMessage(text, true);
      input.value = '';
      conversationHistory.push({ role: 'user', content: text });

      showTyping();

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: conversationHistory }),
        });

        removeTyping();

        if (!res.ok) throw new Error('Request failed');

        const data = await res.json();
        const reply = data.reply || "Sorry, I couldn't process that. Please try again.";

        conversationHistory.push({ role: 'assistant', content: reply });
        addMessage(reply, false);
      } catch {
        removeTyping();
        addMessage("Oops — I'm having trouble connecting. Please try again in a moment.", false);
      }
    });
  }

  // Run once — component uses transition:persist so DOM + listeners survive navigations.
  // Do NOT re-init on astro:after-swap or listeners will duplicate.
  initStacy();
</script>
