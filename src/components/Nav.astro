---
import { getCollectionsStatic } from '@/lib/settings';

interface Props {
  announcements?: Array<{ text: string; link?: string; type: string }>;
}

const { announcements = [] } = Astro.props;
const currentPath = Astro.url.pathname;

const collectionSettings = await getCollectionsStatic();
const enabledCollectionHandles = (collectionSettings ?? [])
  .filter(c => c.enabled)
  .map(c => c.handle);

// Fetch subcategory taxonomy at build time — zero client-side API calls
const roomCollections = [
  { handle: 'living', label: 'Living' },
  { handle: 'dining', label: 'Dining' },
  { handle: 'bedroom', label: 'Bedroom' },
  { handle: 'art-mirrors', label: 'Art & Mirrors' },
  { handle: 'rugs-collection', label: 'Rugs' },
];

// Default slides + any admin-configured announcements
const defaultSlides = [
  { text: '100% of profits support&nbsp;<strong>Sunshine on a Ranney Day</strong>&nbsp;—&nbsp;Our Story', link: '/about/' },
  { text: 'LOCAL PICKUP ONLY — Shop Now', link: '/shop/' },
  { text: 'Visit our Roswell showroom — Tue–Sat, 10am–6pm', link: '/about/' },
];
const adminSlides = announcements.map(a =>
  ({ text: a.link ? `${a.text} — Learn More` : a.text, link: a.link || '' })
);
const allSlides = [...adminSlides, ...defaultSlides];
---

<header class:list={['nav', { 'nav--shop-active': currentPath.startsWith('/shop') }]} id="main-nav" transition:persist="main-nav" transition:animate="none">
  <!-- Top banner -->
  <div class="nav__banner" role="status" aria-live="polite">
    <div class="container nav__banner-inner">
      <div class="nav__banner-slider" id="banner-slider">
        {allSlides.map((slide, i) => (
          slide.link
            ? <a href={slide.link} class:list={['nav__banner-slide', { 'nav__banner-slide--active': i === 0 }]} set:html={slide.text} />
            : <span class:list={['nav__banner-slide', { 'nav__banner-slide--active': i === 0 }]} set:html={slide.text} />
        ))}
      </div>
    </div>
  </div>

  <!-- Mobile header: logo + cart -->
  <div class="nav__mobile-header">
    <a href="/" class="nav__logo" aria-label="Sunny & Ranney Home">
      <img
        src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/logo-tagline-light-bg/w=160,h=64,fit=scale-down,format=auto"
        alt="Sunny & Ranney"
        class="nav__logo-img"
        width="160"
        height="64"
        decoding="async"
      />
    </a>
    <div class="nav__mobile-actions">
      <a href="/about/" class:list={['nav__mission-link nav__mission-link--mobile', { 'nav__mission-link--active': currentPath === '/about' || currentPath === '/about/' }]}>
        Mission
        <img src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/soard-favicon/w=40,h=40,fit=cover,q=80,format=auto" alt="" class="nav__mission-pig" width="20" height="20" loading="lazy" aria-hidden="true" />
      </a>
      <button class="nav__icon-btn nav__search-toggle" aria-label="Search products" id="mobile-search-toggle">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <button class="nav__icon-btn nav__cart" aria-label="Shopping cart" id="mobile-cart-trigger">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="nav__cart-count" id="mobile-cart-count" style="display:none;">0</span>
      </button>
    </div>
  </div>

  <!-- Mobile search bar -->
  <div class="nav__mobile-topbar">
    <div class="nav__mobile-search-wrap">
      <div class="nav__mobile-topbar-inner">
        <svg class="nav__mobile-topbar-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <label for="mobile-topbar-search" class="sr-only">Search products</label>
        <input
          type="search"
          id="mobile-topbar-search"
          placeholder="Search furniture, decor, accessories, gifts..."
          autocomplete="off"
          role="combobox"
          aria-expanded="false"
          aria-controls="mobile-search-suggest"
          aria-autocomplete="list"
        />
      </div>
      <div class="search-suggest search-suggest--mobile" id="mobile-search-suggest" role="listbox" aria-label="Search suggestions" style="display:none;"></div>
    </div>
  </div>

  <!-- Desktop nav row -->
  <div class="nav__main">
    <div class="container nav__main-inner">
      <a href="/" class="nav__logo" aria-label="Sunny & Ranney Home">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/logo-tagline-light-bg/w=260,h=104,fit=scale-down,format=auto"
          alt="Sunny & Ranney"
          class="nav__logo-img"
          width="260"
          height="104"
          decoding="async"
        />
      </a>

      <!-- Search bar -->
      <div class="nav__search-bar" id="nav-search-bar">
        <svg class="nav__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <label for="nav-search-input" class="sr-only">Search products</label>
        <input
          type="search"
          id="nav-search-input"
          placeholder="Search furniture, decor, accessories, gifts..."
          autocomplete="off"
          role="combobox"
          aria-expanded="false"
          aria-controls="search-suggest"
          aria-autocomplete="list"
        />
        <button class="nav__search-submit" id="nav-search-submit" aria-label="Search">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <div class="search-suggest" id="search-suggest" role="listbox" aria-label="Search suggestions" style="display:none;"></div>
      </div>

      <div class="nav__actions">
        <a href="/about/" data-astro-prefetch class:list={['nav__mission-link', { 'nav__mission-link--active': currentPath === '/about' || currentPath === '/about/' }]}>
          Mission
          <img src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/soard-favicon/w=40,h=40,fit=cover,q=80,format=auto" alt="" class="nav__mission-pig" width="20" height="20" loading="lazy" aria-hidden="true" />
        </a>
        <button class="nav__icon-btn nav__cart" aria-label="Shopping cart" id="cart-trigger">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span class="nav__cart-count" id="cart-count" style="display:none;">0</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Category bar -->
  <nav class="nav__categories" aria-label="Product categories">
    <div class="container nav__categories-inner">
      <span class="nav__cat-indicator" id="cat-indicator" aria-hidden="true"></span>
      <a href="/shop/" data-astro-prefetch="hover" class:list={['nav__cat-link', { 'nav__cat-link--active': currentPath === '/shop' || currentPath === '/shop/' }]}>
        All
      </a>
      <a href="/shop/?collection=new-arrivals" data-astro-prefetch="hover" class="nav__cat-link nav__cat-link--new">
        New
      </a>
      {roomCollections.map(col => (
        <a href={`/shop/?collection=${col.handle}`} data-astro-prefetch="hover" class="nav__cat-link">
          {col.label}
        </a>
      ))}
      <a href="/shop/?sale=true" data-astro-prefetch="hover" class="nav__cat-link nav__cat-link--sale">Sale</a>
    </div>
  </nav>

</header>

<style>
  /* ─── Screen-reader only ────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── Banner ───────────────────────────── */
  .nav__banner {
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-size: 0.72rem;
    text-align: center;
    padding: 0.4rem 0;
    letter-spacing: 0.02em;
  }

  .nav__banner strong { color: var(--color-gold); }

  a.nav__banner-slide {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  a.nav__banner-slide:hover {
    text-decoration: underline;
    text-decoration-color: var(--color-gold);
  }

  /* Smooth banner collapse on scroll — composited properties only */
  .nav__banner {
    transform-origin: top;
    transition: transform 0.3s ease, opacity 0.2s ease;
    max-height: 40px;
    overflow: hidden;
  }
  .nav--scrolled .nav__banner {
    transform: scaleY(0);
    opacity: 0;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .nav__banner {
      font-size: 0.82rem;
      padding: 0.5rem 0;
    }
  }

  .nav__banner-slider { position: relative; height: 1.3em; overflow: hidden; }

  .nav__banner-slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.5s, transform 0.5s;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .nav__banner {
      font-size: 0.6rem;
      max-height: 56px; /* taller than desktop — accommodates 2-line mobile text */
    }
    .nav__banner-slider { height: 2.4em; }
    .nav__banner-slide {
      white-space: normal;
      text-align: center;
      line-height: 1.2;
      padding: 0 0.25rem;
    }
  }

  .nav__banner-slide--active {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Main Nav ─────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-cream);
  }

  /* Composited shadow via pseudo-element with opacity transition */
  .nav::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: 0 4px 12px rgba(44, 44, 44, 0.08), 0 1px 3px rgba(44, 44, 44, 0.04);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: -1;
  }

  .nav--scrolled::after {
    opacity: 1;
  }

  .nav--scrolled .nav__categories {
    box-shadow: none;
  }

  .nav--scrolled .nav__mobile-header {
    border-bottom-color: transparent;
  }

  /* ─── Mobile Header (logo + cart) ──────── */
  .nav__mobile-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px;
    height: 48px;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .nav__mobile-header .nav__logo-img {
    height: 38px;
    width: auto;
  }

  .nav__mobile-actions {
    display: flex;
    align-items: center;
    gap: 0;
  }

  /* 44px minimum touch target for mobile icons */
  .nav__mobile-header .nav__cart,
  .nav__mobile-header .nav__search-toggle {
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav__search-toggle {
    color: var(--color-charcoal);
    transition: color 0.2s;
  }
  .nav__search-toggle:hover { color: var(--color-gold); }

  @media (min-width: 768px) {
    .nav__mobile-header { display: none; }
  }

  /* ─── Mobile Search Bar ──────────────────── */
  .nav__mobile-topbar {
    display: block;
    background: var(--color-cream);
    transition: opacity 0.25s ease;
    /* Hidden by default — revealed when user taps search icon */
    max-height: 0;
    padding: 0 12px;
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Hide search (scroll down or default) */
  .nav__mobile-topbar.is-hidden {
    max-height: 0;
    padding: 0 12px;
    opacity: 0;
    pointer-events: none;
  }

  /* Show when user taps search icon */
  .nav__mobile-topbar.is-forced-open {
    max-height: 60px;
    padding: 6px 12px;
    opacity: 1;
    pointer-events: auto;
  }

  .nav__mobile-topbar-inner {
    display: flex;
    align-items: center;
    background: var(--color-warm-white);
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 100px;
    padding: 0 14px;
    height: 38px;
    gap: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .nav__mobile-topbar-inner:focus-within {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(255, 212, 0, 0.1);
  }

  .nav__mobile-topbar-icon {
    color: var(--color-stone);
    flex-shrink: 0;
  }

  .nav__mobile-topbar-inner input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 1rem; /* ≥16px prevents iOS Safari auto-zoom on focus */
    color: var(--color-charcoal);
    padding: 0;
  }

  .nav__mobile-topbar-inner input::placeholder {
    color: var(--color-stone);
  }

  .nav__mobile-search-wrap {
    position: relative;
  }

  .search-suggest--mobile {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 4px;
    border-radius: 8px;
    z-index: 60;
  }

  @media (min-width: 768px) {
    .nav__mobile-topbar { display: none; }
  }

  /* ─── Desktop Nav Row ───────────────────── */
  .nav__main {
    border-bottom: 1px solid var(--color-cream-dark);
    display: none;
  }

  @media (min-width: 768px) {
    .nav__main { display: block; }
  }

  .nav__main-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 1.5rem;
  }

  .nav__logo-img {
    height: 44px;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
    aspect-ratio: 5 / 2;
  }

  @media (min-width: 768px) {
    .nav__main { border-bottom: none; }
    .nav__main-inner { height: 72px; }
    .nav__logo-img { height: 52px; }
  }

  /* ─── Search Bar (desktop) ─────────────── */
  .nav__search-bar {
    flex: 1;
    max-width: 560px;
    display: flex;
    align-items: center;
    background: var(--color-warm-white);
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 6px;
    padding: 0 0 0 0.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
    position: relative;
  }

  .nav__search-bar:focus-within {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(255, 212, 0, 0.1);
  }

  @media (min-width: 768px) {
    .nav__search-bar {
      max-width: 480px;
      border-radius: 100px;
      background: var(--color-cream);
      border-color: var(--color-cream-dark);
    }
    .nav__search-submit {
      border-radius: 0 100px 100px 0;
    }
  }

  .nav__search-icon {
    color: var(--color-stone);
    flex-shrink: 0;
  }

  .nav__search-bar input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-charcoal);
    padding: 0.55rem 0.6rem;
  }

  .nav__search-bar input::placeholder { color: var(--color-stone); }

  .nav__search-submit {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--color-stone);
    border: none;
    cursor: pointer;
    transition: color 0.2s;
    flex-shrink: 0;
    border-radius: 0 100px 100px 0;
    margin: 1px;
  }

  .nav__search-submit:hover { color: var(--color-charcoal); }

  /* ─── Search Suggestions ────────────────── */
  .search-suggest {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    border-top: none;
    border-radius: 0 0 6px 6px;
    box-shadow: 0 8px 24px rgba(44, 44, 44, 0.1);
    z-index: 50;
    max-height: 360px;
    overflow-y: auto;
  }

  .search-suggest__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    text-decoration: none;
    color: var(--color-charcoal);
    transition: background 0.15s;
  }

  .search-suggest__item:hover,
  .search-suggest__item[aria-selected="true"] {
    background: var(--color-cream-dark);
  }

  .search-suggest__img {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-cream-dark);
    flex-shrink: 0;
  }

  .search-suggest__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-suggest__info {
    flex: 1;
    min-width: 0;
  }

  .search-suggest__title {
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  .search-suggest__price {
    font-size: 0.75rem;
    color: var(--color-slate);
  }

  .search-suggest__all {
    display: block;
    padding: 0.6rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-gold);
    text-align: center;
    border-top: 1px solid var(--color-cream-dark);
    transition: background 0.15s;
  }

  .search-suggest__all:hover {
    background: var(--color-cream-dark);
    color: var(--color-charcoal);
  }


  /* ─── Our Mission link (both mobile header + desktop nav row) ── */
  .nav__mission-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-charcoal, #373A36);
    background: transparent;
    border: 1.5px solid var(--color-charcoal, #373A36);
    padding: 0.45rem 0.9rem;
    border-radius: 2rem;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    text-decoration: none;
  }

  .nav__mission-pig {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    object-fit: cover;
    opacity: 1;
    transform: translateY(0) scale(1);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .nav__mission-link:hover .nav__mission-pig {
    transform: translateY(-3px) scale(1.15) rotate(-8deg);
    animation: pig-wiggle 0.5s ease 0.15s 1;
  }

  @keyframes pig-wiggle {
    0%   { transform: translateY(-3px) scale(1.15) rotate(-8deg); }
    25%  { transform: translateY(-3px) scale(1.15) rotate(6deg); }
    50%  { transform: translateY(-3px) scale(1.15) rotate(-4deg); }
    75%  { transform: translateY(-3px) scale(1.15) rotate(2deg); }
    100% { transform: translateY(-3px) scale(1.15) rotate(0deg); }
  }

  .nav__mission-link:hover {
    background: var(--color-gold, #d4a843);
    border-color: var(--color-gold, #d4a843);
    color: var(--color-charcoal);
    box-shadow: 0 0 12px rgba(255, 212, 0, 0.45), 0 0 24px rgba(255, 212, 0, 0.2);
  }

  .nav__mission-link:active {
    transform: scale(0.95);
    box-shadow: 0 0 6px rgba(255, 212, 0, 0.3);
  }

  .nav__mission-link--active {
    background: var(--color-charcoal, #373A36);
    color: #fff;
  }

  @media (min-width: 768px) {
    .nav__mission-link {
      font-size: 0.78rem;
      padding: 0.4rem 1.1rem;
    }
  }

  /* ─── Actions ──────────────────────────── */
  .nav__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .nav__icon-btn {
    padding: 0.5rem;
    color: var(--color-charcoal);
    transition: color 0.3s;
    position: relative;
  }
  .nav__icon-btn:hover { color: var(--color-gold); }

  .nav__cart { position: relative; padding: 0.5rem; color: var(--color-charcoal); transition: color 0.3s; }
  .nav__cart:hover { color: var(--color-gold); }

  .nav__cart-count {
    position: absolute;
    top: 0;
    right: -2px;
    width: 18px;
    height: 18px;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Category Bar ─────────────────────── */
  .nav__categories {
    border-bottom: none;
    background: var(--color-cream);
    box-shadow: inset 0 1px 0 var(--color-cream-dark);
    display: block;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .nav__categories::-webkit-scrollbar { display: none; }

  .nav__categories-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    white-space: nowrap;
    position: relative;
  }

  /* ─── Sliding active indicator ──────────────── */
  .nav__cat-indicator {
    position: absolute;
    bottom: 0;
    height: 2.5px;
    background: var(--color-gold);
    border-radius: 2px 2px 0 0;
    pointer-events: none;
    opacity: 0;
    /* Spring-like easing for premium feel */
    transition: left 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                width 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.15s ease;
  }

  @media (max-width: 767px) {
    .nav__cat-indicator {
      /* Mobile: solid pill behind active tab */
      top: 50%;
      bottom: auto;
      transform: translateY(-50%);
      height: 36px;
      border-radius: 100px;
      background: var(--color-cream-dark);
    }
  }

  @media (max-width: 767px) {
    .nav__categories {
      padding: 0;
      scroll-snap-type: x proximity;
    }

    .nav__categories-inner {
      justify-content: flex-start;
      padding: 0 10px;
      padding-right: 32px;
    }
  }

  /* ─── Category Links ─────────────────────── */
  .nav__cat-link {
    padding: 0.85rem 1.15rem;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-slate);
    transition: color 0.2s;
    flex-shrink: 0;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  @media (max-width: 767px) {
    .nav__cat-link {
      padding: 1.1rem 0.85rem;
      font-size: 0.85rem;
      min-height: 56px;
      scroll-snap-align: start;
      z-index: 1; /* text above pill indicator */
    }
  }

  @media (min-width: 768px) {
    .nav__cat-link {
      padding: 1.05rem 1.35rem;
      min-height: 48px;
    }
  }

  .nav__cat-link:hover {
    color: var(--color-charcoal);
  }

  .nav__cat-link:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: -2px;
    border-radius: 3px;
  }

  .nav__cat-link--active {
    color: var(--color-charcoal);
    font-weight: 600;
  }

  /* ─── "New Arrivals" accent dot ──────────── */
  .nav__cat-link--new::after {
    content: '';
    width: 3.5px;
    height: 3.5px;
    border-radius: 50%;
    background: var(--color-gold);
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 2px;
    margin-left: -1px;
  }

  /* ─── Sale treatment ─────────────────────── */
  .nav__cat-link--sale {
    color: #1a6580;
    font-weight: 600;
  }

  .nav__cat-link--sale:hover {
    color: #124a5e;
  }

  /* ─── Dividers between groups ────────────── */
  .nav__cat-divider {
    width: 1px;
    height: 14px;
    background: var(--color-cream-dark);
    flex-shrink: 0;
    margin: 0 0.35rem;
    opacity: 0.7;
  }

  @media (max-width: 767px) {
    .nav__cat-divider {
      margin: 0 0.15rem;
    }
  }

</style>

<script is:inline define:vars={{ enabledCollectionHandles }}>
  window.__ENABLED_COLLECTIONS = enabledCollectionHandles;
</script>

<script>
  // ═══════════════════════════════════════════════════════════════
  //  Nav script — View Transitions safe
  //  Uses AbortController so every listener, observer, and timer
  //  is torn down cleanly before re-init on astro:after-swap.
  // ═══════════════════════════════════════════════════════════════

  // ─── Module-level (persists across navigations) ─────────────

  type Product = { title: string; handle: string; price: string; image: string; type: string };
  let productIndex: Product[] | null = null;
  const SEARCH_CACHE_KEY = 'sr_search_idx';
  const SEARCH_CACHE_TTL = 5 * 60 * 1000; // 5 minutes

  async function loadProductIndex(): Promise<Product[]> {
    if (productIndex) return productIndex;

    // Check sessionStorage cache first (survives View Transitions)
    try {
      const cached = sessionStorage.getItem(SEARCH_CACHE_KEY);
      if (cached) {
        const { data, ts } = JSON.parse(cached);
        if (Date.now() - ts < SEARCH_CACHE_TTL) {
          productIndex = data;
          return productIndex!;
        }
      }
    } catch { /* sessionStorage unavailable */ }

    try {
      const domain = (window as any).__SHOPIFY_DOMAIN || 'sunnyandranney.myshopify.com';
      const token = (window as any).__SHOPIFY_TOKEN || '';
      if (!token) return [];

      const enabledHandles: string[] = (window as any).__ENABLED_COLLECTIONS || [];

      const productFragment = `{ title handle productType priceRange { minVariantPrice { amount } } images(first: 1) { edges { node { url } } } }`;
      let gqlQuery: string;
      if (enabledHandles.length > 0) {
        const aliases = enabledHandles
          .map((h, i) => `c${i}: collection(handle: ${JSON.stringify(h)}) { products(first: 50, sortKey: BEST_SELLING) { edges { node ${productFragment} } } }`)
          .join(' ');
        gqlQuery = `{ ${aliases} }`;
      } else {
        gqlQuery = `{ products(first: 50, sortKey: BEST_SELLING) { edges { node ${productFragment} } } }`;
      }

      const res = await fetch(`https://${domain}/api/2025-01/graphql.json`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Shopify-Storefront-Access-Token': token,
        },
        body: JSON.stringify({ query: gqlQuery }),
      });
      const json = await res.json();

      const seen = new Set<string>();
      const allEdges: any[] = [];
      if (enabledHandles.length > 0) {
        for (let i = 0; i < enabledHandles.length; i++) {
          const edges = json.data?.[`c${i}`]?.products?.edges || [];
          for (const e of edges) {
            if (!seen.has(e.node.handle)) {
              seen.add(e.node.handle);
              allEdges.push(e);
            }
          }
        }
      } else {
        allEdges.push(...(json.data?.products?.edges || []));
      }

      productIndex = allEdges.map((e: any) => ({
        title: e.node.title,
        handle: e.node.handle,
        price: e.node.priceRange.minVariantPrice.amount,
        image: e.node.images.edges[0]?.node?.url || '',
        type: (e.node.productType || '').toLowerCase(),
      }));

      try {
        sessionStorage.setItem(SEARCH_CACHE_KEY, JSON.stringify({ data: productIndex, ts: Date.now() }));
      } catch { /* quota exceeded */ }

      return productIndex!;
    } catch {
      return [];
    }
  }

  function renderSuggestions(suggestEl: HTMLElement, query: string, items: Product[]) {
    const q = query.toLowerCase();
    const matches = items.filter(p =>
      p.title.toLowerCase().includes(q) || p.type.includes(q)
    ).slice(0, 5);

    if (matches.length === 0) {
      suggestEl.style.display = 'none';
      return;
    }

    const frag = document.createDocumentFragment();
    matches.forEach((p) => {
      const link = document.createElement('a');
      link.href = `/shop/${p.handle}/`;
      link.className = 'search-suggest__item';
      link.setAttribute('role', 'option');

      if (p.image) {
        const imgWrap = document.createElement('div');
        imgWrap.className = 'search-suggest__img';
        const img = document.createElement('img');
        img.src = p.image.includes('cdn.shopify.com') ? `${p.image}?width=80` : p.image;
        img.alt = p.title;
        img.loading = 'lazy';
        imgWrap.appendChild(img);
        link.appendChild(imgWrap);
      }

      const info = document.createElement('div');
      info.className = 'search-suggest__info';
      const title = document.createElement('span');
      title.className = 'search-suggest__title';
      title.textContent = p.title;
      info.appendChild(title);
      const price = document.createElement('span');
      price.className = 'search-suggest__price';
      price.textContent = `$${parseFloat(p.price).toFixed(2)}`;
      info.appendChild(price);
      link.appendChild(info);
      frag.appendChild(link);
    });

    const allLink = document.createElement('a');
    allLink.href = `/shop?q=${encodeURIComponent(query)}`;
    allLink.className = 'search-suggest__all';
    allLink.textContent = `View all results for "${query}"`;
    frag.appendChild(allLink);

    suggestEl.replaceChildren(frag);
    suggestEl.style.display = 'block';
  }

  function doSearch(input: HTMLInputElement) {
    const q = input.value.trim();
    if (q) window.location.href = `/shop?q=${encodeURIComponent(q)}`;
  }

  function setupTypeahead(input: HTMLInputElement, suggestEl: HTMLElement, signal: AbortSignal) {
    let timer: ReturnType<typeof setTimeout>;

    input.addEventListener('input', () => {
      const q = input.value.trim();
      clearTimeout(timer);
      if (!q || q.length < 2) {
        suggestEl.style.display = 'none';
        input.setAttribute('aria-expanded', 'false');
        return;
      }
      timer = setTimeout(async () => {
        const items = await loadProductIndex();
        renderSuggestions(suggestEl, q, items);
        input.setAttribute('aria-expanded', suggestEl.style.display !== 'none' ? 'true' : 'false');
      }, 300);
    }, { signal });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        suggestEl.style.display = 'none';
        input.setAttribute('aria-expanded', 'false');
        return;
      }
      if (suggestEl.style.display === 'none') return;
      const items = suggestEl.querySelectorAll('.search-suggest__item');
      if (!items.length) return;
      const active = suggestEl.querySelector('[aria-selected="true"]') as HTMLElement;
      let idx = active ? Array.from(items).indexOf(active) : -1;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (active) active.removeAttribute('aria-selected');
        idx = (idx + 1) % items.length;
        items[idx].setAttribute('aria-selected', 'true');
        (items[idx] as HTMLElement).scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (active) active.removeAttribute('aria-selected');
        idx = idx <= 0 ? items.length - 1 : idx - 1;
        items[idx].setAttribute('aria-selected', 'true');
        (items[idx] as HTMLElement).scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'Enter' && active) {
        e.preventDefault();
        (active as HTMLAnchorElement).click();
      }
    }, { signal });

    document.addEventListener('click', (e) => {
      if (!suggestEl.contains(e.target as Node) && e.target !== input) {
        suggestEl.style.display = 'none';
        input.setAttribute('aria-expanded', 'false');
      }
    }, { signal });
  }

  // ─── Pure helpers (query fresh DOM each call) ───────────────

  function updateActiveTab() {
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    const search = window.location.search;
    const links = document.querySelectorAll('.nav__cat-link');

    links.forEach((link) => {
      const href = link.getAttribute('href') || '';
      const [linkPath, linkSearch] = href.split('?');
      const normalizedLinkPath = linkPath.replace(/\/$/, '') || '/';

      let isActive = false;
      if (linkSearch) {
        isActive = normalizedLinkPath === path && search.includes(linkSearch);
      } else {
        isActive = normalizedLinkPath === path && !search;
      }

      link.classList.toggle('nav__cat-link--active', isActive);
      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  function setupCatIndicator() {
    const indicator = document.getElementById('cat-indicator');
    const container = document.querySelector<HTMLElement>('.nav__categories-inner');
    const catLinks = document.querySelectorAll<HTMLElement>('.nav__cat-link');
    if (!indicator || !container || !catLinks.length) return;

    function moveToLink(link: HTMLElement) {
      const containerRect = container!.getBoundingClientRect();
      const linkRect = link.getBoundingClientRect();
      // getBoundingClientRect already accounts for scroll position,
      // so no need to add scrollLeft — that would double-count
      const isMobile = window.innerWidth < 768;
      const inset = isMobile ? 4 : 0;
      indicator!.style.left = `${linkRect.left - containerRect.left + inset}px`;
      indicator!.style.width = `${linkRect.width - inset * 2}px`;
      indicator!.style.opacity = '1';
    }

    function moveToActive() {
      const active = document.querySelector<HTMLElement>('.nav__cat-link--active');
      if (active) {
        moveToLink(active);
      } else {
        indicator!.style.opacity = '0';
      }
    }

    catLinks.forEach((link) => {
      link.addEventListener('click', () => moveToLink(link));
    });

    moveToActive();
  }

  function scrollActiveTabIntoView() {
    const activeLink = document.querySelector('.nav__cat-link--active') as HTMLElement;
    if (!activeLink) return;
    const container = activeLink.closest('.nav__categories') as HTMLElement;
    if (!container) return;
    const inner = container.querySelector('.nav__categories-inner') as HTMLElement;
    if (!inner) return;

    const innerRect = inner.getBoundingClientRect();
    const linkRect = activeLink.getBoundingClientRect();
    const linkOffsetInInner = linkRect.left - innerRect.left + container.scrollLeft;
    const scrollLeft = linkOffsetInInner - (container.clientWidth / 2) + (linkRect.width / 2);
    container.scrollTo({ left: Math.max(0, scrollLeft), behavior: 'smooth' });

    setTimeout(() => setupCatIndicator(), 350);
  }

  // ─── Per-navigation init ────────────────────────────────────
  //  Re-queries all DOM refs, attaches listeners via AbortController
  //  signal so everything is auto-cleaned on the next navigation.

  let _ac: AbortController | null = null;

  function init() {
    // Tear down previous lifecycle
    _ac?.abort();
    _ac = new AbortController();
    const { signal } = _ac;

    // ── Fresh DOM refs ──────────────────────────
    const nav = document.getElementById('main-nav');
    const mobileSearch = nav?.querySelector('.nav__mobile-topbar') as HTMLElement | null;
    const searchToggle = document.getElementById('mobile-search-toggle');
    const mobileSearchInput = document.getElementById('mobile-topbar-search') as HTMLInputElement | null;
    const searchInput = document.getElementById('nav-search-input') as HTMLInputElement | null;
    const searchSubmit = document.getElementById('nav-search-submit');
    const mobileTopbarSearch = document.getElementById('mobile-topbar-search') as HTMLInputElement | null;
    const suggestEl = document.getElementById('search-suggest');
    const mobileSuggestEl = document.getElementById('mobile-search-suggest');

    // ── Nav height → CSS variable (debounced to avoid CLS) ───────────────
    if (nav) {
      let lastH = 0;
      const syncHeight = () => {
        const h = Math.round(nav.getBoundingClientRect().height);
        if (h === lastH) return; // skip no-change updates
        lastH = h;
        document.documentElement.style.setProperty('--nav-height', `${h}px`);
      };
      const ro = new ResizeObserver(syncHeight);
      ro.observe(nav);
      syncHeight();
      signal.addEventListener('abort', () => ro.disconnect());

      // Pre-swap: toggle shop-active so height is correct before new content paints
      document.addEventListener('astro:before-swap', (e) => {
        const going = new URL((e as any).to).pathname;
        nav.classList.toggle('nav--shop-active', going.startsWith('/shop'));
      }, { signal });
    }

    // ── Scroll behavior ─────────────────────────
    let lastScrollY = 0;
    let scrollTicking = false;

    window.addEventListener('scroll', () => {
      if (!scrollTicking) {
        scrollTicking = true;
        requestAnimationFrame(() => {
          const y = window.scrollY;
          nav?.classList.toggle('nav--scrolled', y > 20);

          if (mobileSearch?.classList.contains('is-forced-open') && y > 60 && y > lastScrollY) {
            mobileSearch.classList.remove('is-forced-open');
            mobileSearch.classList.add('is-hidden');
          }
          lastScrollY = y;
          scrollTicking = false;
        });
      }
    }, { passive: true, signal });

    // ── Mobile search toggle ────────────────────
    searchToggle?.addEventListener('click', () => {
      if (!mobileSearch) return;
      const isOpen = mobileSearch.classList.contains('is-forced-open');
      if (isOpen) {
        mobileSearch.classList.remove('is-forced-open');
        mobileSearch.classList.add('is-hidden');
      } else {
        mobileSearch.classList.remove('is-hidden');
        mobileSearch.classList.add('is-forced-open');
        setTimeout(() => mobileSearchInput?.focus(), 260);
      }
    }, { signal });

    mobileSearchInput?.addEventListener('blur', () => {
      setTimeout(() => {
        if (mobileSearch && window.scrollY > 60) {
          mobileSearch.classList.remove('is-forced-open');
        }
      }, 300);
    }, { signal });

    // ── Cart buttons ────────────────────────────
    document.getElementById('cart-trigger')?.addEventListener('click', () => window.openCart?.(), { signal });
    document.getElementById('mobile-cart-trigger')?.addEventListener('click', () => window.openCart?.(), { signal });

    // ── Search submit ───────────────────────────
    searchInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(searchInput); }, { signal });
    searchSubmit?.addEventListener('click', () => { if (searchInput) doSearch(searchInput); }, { signal });
    mobileTopbarSearch?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(mobileTopbarSearch); }, { signal });

    // ── Typeahead ───────────────────────────────
    if (searchInput && suggestEl) setupTypeahead(searchInput, suggestEl, signal);
    if (mobileTopbarSearch && mobileSuggestEl) setupTypeahead(mobileTopbarSearch, mobileSuggestEl, signal);

    // ── Banner rotation ─────────────────────────
    let bannerInterval: ReturnType<typeof setInterval> | undefined;
    function startBanner() {
      const bannerSlider = document.getElementById('banner-slider');
      if (!bannerSlider) return;
      const slides = bannerSlider.querySelectorAll('.nav__banner-slide');
      let currentSlide = 0;
      if (slides.length > 1) {
        bannerInterval = setInterval(() => {
          slides[currentSlide].classList.remove('nav__banner-slide--active');
          currentSlide = (currentSlide + 1) % slides.length;
          slides[currentSlide].classList.add('nav__banner-slide--active');
        }, 8000);
      }
    }
    const scheduleIdle = window.requestIdleCallback || ((cb: () => void) => setTimeout(cb, 200));
    scheduleIdle(startBanner);
    signal.addEventListener('abort', () => { if (bannerInterval) clearInterval(bannerInterval); });

    // ── Sync mobile cart badge ──────────────────
    function syncMobileCartBadge() {
      const headerCount = document.getElementById('cart-count');
      const mobileCount = document.getElementById('mobile-cart-count');
      if (!headerCount || !mobileCount) return;

      const update = () => {
        const count = headerCount.textContent || '0';
        const visible = headerCount.style.display !== 'none';
        mobileCount.textContent = count;
        mobileCount.style.display = visible ? 'flex' : 'none';
      };

      const mo = new MutationObserver(update);
      mo.observe(headerCount, { childList: true, attributes: true, attributeFilter: ['style'] });
      signal.addEventListener('abort', () => mo.disconnect());

      update();
    }
    scheduleIdle(syncMobileCartBadge);

    // ── Active tab + indicator + scroll-into-view ──
    updateActiveTab();
    setupCatIndicator();
    requestAnimationFrame(scrollActiveTabIntoView);
  }

  // ─── Boot ───────────────────────────────────────────────────
  init();
  document.addEventListener('astro:after-swap', init);

</script>
