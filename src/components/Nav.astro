---
const currentPath = Astro.url.pathname;

const categories = [
  { href: '/shop?sort=newest', label: 'New Arrivals', highlight: false },
  { href: '/shop?category=furniture', label: 'Furniture', highlight: false },
  { href: '/shop?category=decor', label: 'Decor', highlight: false },
  { href: '/shop?category=lighting', label: 'Lighting', highlight: false },
  { href: '/shop?category=gifts', label: 'Gifts', highlight: false },
  { href: '/shop?category=kitchenware', label: 'Kitchenware', highlight: false },
  { href: '/shop?sale=true', label: 'Sale', highlight: true },
];
---

<header class="nav" id="main-nav">
  <!-- Top banner -->
  <div class="nav__banner">
    <div class="container nav__banner-inner">
      <div class="nav__banner-slider" id="banner-slider">
        <span class="nav__banner-slide nav__banner-slide--active">100% of profits support <strong>Sunshine on a Ranney Day</strong> — home makeovers for kids with special needs</span>
        <span class="nav__banner-slide">FREE SHIPPING on orders over $200 — <a href="/shop" style="color:var(--color-gold);text-decoration:underline;">Shop Now</a></span>
        <span class="nav__banner-slide">Visit our Roswell showroom — Tue–Sat, 10am–6pm</span>
      </div>
    </div>
  </div>

  <!-- Mobile search bar (always visible, Wayfair-style) -->
  <div class="nav__mobile-topbar">
    <div class="nav__mobile-search-wrap">
      <div class="nav__mobile-topbar-inner">
        <svg class="nav__mobile-topbar-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="mobile-topbar-search" placeholder="Search Sunny & Ranney" autocomplete="off" />
      </div>
      <!-- Mobile typeahead suggestions -->
      <div class="search-suggest search-suggest--mobile" id="mobile-search-suggest" role="listbox" aria-label="Search suggestions" style="display:none;"></div>
    </div>
  </div>

  <!-- Desktop nav row -->
  <div class="nav__main">
    <div class="container nav__main-inner">
      <a href="/" class="nav__logo" aria-label="Sunny & Ranney Home">
        <img src="/images/logos/logo-light-bg.png" alt="Sunny & Ranney" class="nav__logo-img" />
      </a>

      <!-- Search bar — prominent, center (desktop) -->
      <div class="nav__search-bar" id="nav-search-bar">
        <svg class="nav__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="nav-search-input" placeholder="Search furniture, decor, lighting, gifts..." autocomplete="off" />
        <button class="nav__search-submit" id="nav-search-submit" aria-label="Search">
          Search
        </button>
        <!-- Typeahead suggestions dropdown -->
        <div class="search-suggest" id="search-suggest" role="listbox" aria-label="Search suggestions" style="display:none;"></div>
      </div>

      <div class="nav__actions">
        <!-- Cart (desktop only — mobile uses bottom nav) -->
        <button class="nav__icon-btn nav__cart" aria-label="Shopping cart" id="cart-trigger" onclick="window.openCart?.()">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span class="nav__cart-count" id="cart-count" style="display:none;">0</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Category bar (desktop) -->
  <div class="nav__categories">
    <div class="container nav__categories-inner">
      <a href="/shop" class:list={['nav__cat-link', { 'nav__cat-link--active': currentPath === '/shop' || currentPath === '/shop/' }]}>
        All Products
      </a>
      {categories.map((cat) => (
        <a href={cat.href} class:list={['nav__cat-link', { 'nav__cat-link--sale': cat.highlight }]}>{cat.label}</a>
      ))}
      <span class="nav__cat-divider"></span>
      <a href="/mission" class:list={['nav__cat-link', { 'nav__cat-link--active': currentPath === '/mission' || currentPath === '/mission/' }]}>Mission</a>
      <a href="/team" class:list={['nav__cat-link', { 'nav__cat-link--active': currentPath === '/team' || currentPath === '/team/' }]}>Our Team</a>
    </div>
  </div>
</header>

<style>
  /* ─── Banner ───────────────────────────── */
  .nav__banner {
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-size: 0.72rem;
    text-align: center;
    padding: 0.4rem 0;
    letter-spacing: 0.02em;
  }

  .nav__banner strong { color: var(--color-gold); }

  .nav__banner-slider { position: relative; height: 1.1em; overflow: hidden; }

  .nav__banner-slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.5s, transform 0.5s;
    white-space: nowrap;
  }

  .nav__banner-slide--active {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Main Nav ─────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-cream);
    transition: box-shadow 0.3s ease;
  }

  .nav--scrolled {
    box-shadow: 0 2px 20px rgba(44, 44, 44, 0.06);
  }

  /* ─── Mobile Top Search Bar ─────────────── */
  .nav__mobile-topbar {
    display: block;
    padding: 8px 12px;
    background: var(--color-charcoal);
  }

  .nav__mobile-topbar-inner {
    display: flex;
    align-items: center;
    background: var(--color-warm-white);
    border-radius: 28px;
    padding: 0 14px;
    height: 40px;
    gap: 8px;
  }

  .nav__mobile-topbar-icon {
    color: var(--color-stone);
    flex-shrink: 0;
  }

  .nav__mobile-topbar-inner input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-charcoal);
    padding: 0;
  }

  .nav__mobile-topbar-inner input::placeholder {
    color: var(--color-stone);
  }

  .nav__mobile-search-wrap {
    position: relative;
  }

  .search-suggest--mobile {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 4px;
    border-radius: 8px;
    z-index: 60;
  }

  @media (min-width: 768px) {
    .nav__mobile-topbar { display: none; }
  }

  /* ─── Desktop Nav Row ───────────────────── */
  .nav__main {
    border-bottom: 1px solid var(--color-cream-dark);
    display: none;
  }

  @media (min-width: 768px) {
    .nav__main { display: block; }
  }

  .nav__main-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 1.5rem;
  }

  .nav__logo-img {
    height: 36px;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* ─── Search Bar (desktop) ─────────────── */
  .nav__search-bar {
    flex: 1;
    max-width: 560px;
    display: flex;
    align-items: center;
    background: var(--color-warm-white);
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 6px;
    padding: 0 0 0 0.75rem;
    transition: border-color 0.2s;
    overflow: hidden;
  }

  .nav__search-bar:focus-within {
    border-color: var(--color-gold);
  }

  .nav__search-icon {
    color: var(--color-stone);
    flex-shrink: 0;
  }

  .nav__search-bar input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-charcoal);
    padding: 0.55rem 0.6rem;
  }

  .nav__search-bar input::placeholder { color: var(--color-stone); }

  .nav__search-submit {
    padding: 0.55rem 1.25rem;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .nav__search-submit:hover { background: var(--color-gold-light); }

  /* ─── Search Suggestions ────────────────── */
  .search-suggest {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    border-top: none;
    border-radius: 0 0 6px 6px;
    box-shadow: 0 8px 24px rgba(44, 44, 44, 0.1);
    z-index: 50;
    max-height: 360px;
    overflow-y: auto;
  }

  .search-suggest__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    text-decoration: none;
    color: var(--color-charcoal);
    transition: background 0.15s;
  }

  .search-suggest__item:hover,
  .search-suggest__item[aria-selected="true"] {
    background: var(--color-cream-dark);
  }

  .search-suggest__img {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-cream-dark);
    flex-shrink: 0;
  }

  .search-suggest__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-suggest__info {
    flex: 1;
    min-width: 0;
  }

  .search-suggest__title {
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  .search-suggest__price {
    font-size: 0.75rem;
    color: var(--color-slate);
  }

  .search-suggest__all {
    display: block;
    padding: 0.6rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-gold);
    text-align: center;
    border-top: 1px solid var(--color-cream-dark);
    transition: background 0.15s;
  }

  .search-suggest__all:hover {
    background: var(--color-cream-dark);
    color: var(--color-charcoal);
  }

  .nav__search-bar {
    position: relative;
  }

  /* ─── Actions ──────────────────────────── */
  .nav__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .nav__icon-btn {
    padding: 0.5rem;
    color: var(--color-charcoal);
    transition: color 0.3s;
    position: relative;
  }
  .nav__icon-btn:hover { color: var(--color-gold); }

  .nav__cart { position: relative; padding: 0.5rem; color: var(--color-charcoal); transition: color 0.3s; }
  .nav__cart:hover { color: var(--color-gold); }

  .nav__cart-count {
    position: absolute;
    top: 0;
    right: -2px;
    width: 18px;
    height: 18px;
    background: var(--color-gold);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Category Bar ─────────────────────── */
  .nav__categories {
    border-bottom: 1px solid var(--color-cream-dark);
    display: none;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav__categories::-webkit-scrollbar { display: none; }

  @media (min-width: 768px) {
    .nav__categories { display: block; }
  }

  .nav__categories-inner {
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
  }

  .nav__cat-link {
    padding: 0.6rem 1.25rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-slate);
    transition: color 0.2s, background 0.2s;
    flex-shrink: 0;
  }

  .nav__cat-link:hover {
    color: var(--color-charcoal);
    background: var(--color-cream-dark);
  }

  .nav__cat-link--active {
    color: var(--color-charcoal);
    border-bottom: 2px solid var(--color-gold);
  }

  .nav__cat-link--sale {
    color: #e74c3c;
    font-weight: 600;
  }

  .nav__cat-link--sale:hover {
    color: #c0392b;
    background: #fdf2f2;
  }

  .nav__cat-divider {
    width: 1px;
    height: 16px;
    background: var(--color-cream-dark);
    flex-shrink: 0;
    margin: 0 0.25rem;
  }
</style>

<script>
  // Scroll behavior — rAF-throttled for perf
  const nav = document.getElementById('main-nav');
  let scrollTicking = false;

  window.addEventListener('scroll', () => {
    if (!scrollTicking) {
      scrollTicking = true;
      requestAnimationFrame(() => {
        nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
        scrollTicking = false;
      });
    }
  }, { passive: true });

  // Desktop search
  const searchInput = document.getElementById('nav-search-input') as HTMLInputElement;
  const searchSubmit = document.getElementById('nav-search-submit');

  function doSearch(input: HTMLInputElement) {
    const q = input.value.trim();
    if (q) {
      window.location.href = `/shop?q=${encodeURIComponent(q)}`;
    }
  }

  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doSearch(searchInput);
  });
  searchSubmit?.addEventListener('click', () => { if (searchInput) doSearch(searchInput); });

  // Mobile top search bar
  const mobileTopbarSearch = document.getElementById('mobile-topbar-search') as HTMLInputElement;
  mobileTopbarSearch?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doSearch(mobileTopbarSearch);
  });

  // ─── Typeahead / Autocomplete ──────────────
  const suggestEl = document.getElementById('search-suggest');
  let debounceTimer: ReturnType<typeof setTimeout>;
  let productIndex: Array<{ title: string; handle: string; price: string; image: string; type: string }> | null = null;

  // Fetch the product index once (lightweight — just titles, handles, images, prices)
  async function loadProductIndex() {
    if (productIndex) return productIndex;
    try {
      const domain = (window as any).__SHOPIFY_DOMAIN || 'sunnyandranney.myshopify.com';
      const token = (window as any).__SHOPIFY_TOKEN || '';
      if (!token) return [];
      const res = await fetch(`https://${domain}/api/2025-01/graphql.json`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Shopify-Storefront-Access-Token': token,
        },
        body: JSON.stringify({
          query: `{ products(first: 100, sortKey: BEST_SELLING) { edges { node { title handle productType priceRange { minVariantPrice { amount } } images(first: 1) { edges { node { url } } } } } } }`
        }),
      });
      const json = await res.json();
      productIndex = (json.data?.products?.edges || []).map((e: any) => ({
        title: e.node.title,
        handle: e.node.handle,
        price: e.node.priceRange.minVariantPrice.amount,
        image: e.node.images.edges[0]?.node?.url || '',
        type: (e.node.productType || '').toLowerCase(),
      }));
      return productIndex;
    } catch {
      return [];
    }
  }

  function showSuggestions(query: string, items: typeof productIndex) {
    if (!suggestEl || !items || !query) {
      if (suggestEl) suggestEl.style.display = 'none';
      return;
    }

    const q = query.toLowerCase();
    const matches = items.filter(p =>
      p.title.toLowerCase().includes(q) ||
      p.type.includes(q)
    ).slice(0, 5);

    if (matches.length === 0) {
      suggestEl.style.display = 'none';
      return;
    }

    const frag = document.createDocumentFragment();
    matches.forEach((p) => {
      const link = document.createElement('a');
      link.href = `/shop/${p.handle}`;
      link.className = 'search-suggest__item';
      link.setAttribute('role', 'option');

      if (p.image) {
        const imgWrap = document.createElement('div');
        imgWrap.className = 'search-suggest__img';
        const img = document.createElement('img');
        // Use small Shopify CDN image
        img.src = p.image.includes('cdn.shopify.com') ? `${p.image}?width=80` : p.image;
        img.alt = p.title;
        img.loading = 'lazy';
        imgWrap.appendChild(img);
        link.appendChild(imgWrap);
      }

      const info = document.createElement('div');
      info.className = 'search-suggest__info';
      const title = document.createElement('span');
      title.className = 'search-suggest__title';
      title.textContent = p.title;
      info.appendChild(title);
      const price = document.createElement('span');
      price.className = 'search-suggest__price';
      price.textContent = `$${parseFloat(p.price).toFixed(2)}`;
      info.appendChild(price);
      link.appendChild(info);

      frag.appendChild(link);
    });

    // "View all results" link
    const allLink = document.createElement('a');
    allLink.href = `/shop?q=${encodeURIComponent(query)}`;
    allLink.className = 'search-suggest__all';
    allLink.textContent = `View all results for "${query}"`;
    frag.appendChild(allLink);

    suggestEl.replaceChildren(frag);
    suggestEl.style.display = 'block';
  }

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.trim();
    clearTimeout(debounceTimer);
    if (!q || q.length < 2) {
      if (suggestEl) suggestEl.style.display = 'none';
      return;
    }
    debounceTimer = setTimeout(async () => {
      const items = await loadProductIndex();
      showSuggestions(q, items);
    }, 200);
  });

  // Hide suggestions on click outside
  document.addEventListener('click', (e) => {
    if (suggestEl && !suggestEl.contains(e.target as Node) && e.target !== searchInput) {
      suggestEl.style.display = 'none';
    }
  });

  // Keyboard navigation in suggestions
  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && suggestEl) { suggestEl.style.display = 'none'; return; }
    if (!suggestEl || suggestEl.style.display === 'none') return;
    const items = suggestEl.querySelectorAll('.search-suggest__item');
    if (!items.length) return;
    const active = suggestEl.querySelector('[aria-selected="true"]') as HTMLElement;
    let idx = active ? Array.from(items).indexOf(active) : -1;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (active) active.removeAttribute('aria-selected');
      idx = (idx + 1) % items.length;
      items[idx].setAttribute('aria-selected', 'true');
      (items[idx] as HTMLElement).scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (active) active.removeAttribute('aria-selected');
      idx = idx <= 0 ? items.length - 1 : idx - 1;
      items[idx].setAttribute('aria-selected', 'true');
      (items[idx] as HTMLElement).scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'Enter' && active) {
      e.preventDefault();
      (active as HTMLAnchorElement).click();
    }
  });

  // ─── Mobile typeahead ──────────────────────────
  const mobileSuggestEl = document.getElementById('mobile-search-suggest');
  let mobileDebounceTimer: ReturnType<typeof setTimeout>;

  mobileTopbarSearch?.addEventListener('input', () => {
    const q = mobileTopbarSearch.value.trim();
    clearTimeout(mobileDebounceTimer);
    if (!q || q.length < 2) {
      if (mobileSuggestEl) mobileSuggestEl.style.display = 'none';
      return;
    }
    mobileDebounceTimer = setTimeout(async () => {
      const items = await loadProductIndex();
      if (!mobileSuggestEl || !items || !q) return;

      const lq = q.toLowerCase();
      const matches = items.filter(p =>
        p.title.toLowerCase().includes(lq) || p.type.includes(lq)
      ).slice(0, 5);

      if (matches.length === 0) {
        mobileSuggestEl.style.display = 'none';
        return;
      }

      const frag = document.createDocumentFragment();
      matches.forEach((p) => {
        const link = document.createElement('a');
        link.href = `/shop/${p.handle}`;
        link.className = 'search-suggest__item';
        link.setAttribute('role', 'option');
        if (p.image) {
          const imgWrap = document.createElement('div');
          imgWrap.className = 'search-suggest__img';
          const img = document.createElement('img');
          img.src = p.image.includes('cdn.shopify.com') ? `${p.image}?width=80` : p.image;
          img.alt = p.title;
          img.loading = 'lazy';
          imgWrap.appendChild(img);
          link.appendChild(imgWrap);
        }
        const info = document.createElement('div');
        info.className = 'search-suggest__info';
        const title = document.createElement('span');
        title.className = 'search-suggest__title';
        title.textContent = p.title;
        info.appendChild(title);
        const price = document.createElement('span');
        price.className = 'search-suggest__price';
        price.textContent = `$${parseFloat(p.price).toFixed(2)}`;
        info.appendChild(price);
        link.appendChild(info);
        frag.appendChild(link);
      });

      const allLink = document.createElement('a');
      allLink.href = `/shop?q=${encodeURIComponent(q)}`;
      allLink.className = 'search-suggest__all';
      allLink.textContent = `View all results for "${q}"`;
      frag.appendChild(allLink);

      mobileSuggestEl.replaceChildren(frag);
      mobileSuggestEl.style.display = 'block';
    }, 200);
  });

  // Mobile keyboard navigation in suggestions
  mobileTopbarSearch?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileSuggestEl) { mobileSuggestEl.style.display = 'none'; return; }
    if (!mobileSuggestEl || mobileSuggestEl.style.display === 'none') return;
    const items = mobileSuggestEl.querySelectorAll('.search-suggest__item');
    if (!items.length) return;
    const active = mobileSuggestEl.querySelector('[aria-selected="true"]') as HTMLElement;
    let idx = active ? Array.from(items).indexOf(active) : -1;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (active) active.removeAttribute('aria-selected');
      idx = (idx + 1) % items.length;
      items[idx].setAttribute('aria-selected', 'true');
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (active) active.removeAttribute('aria-selected');
      idx = idx <= 0 ? items.length - 1 : idx - 1;
      items[idx].setAttribute('aria-selected', 'true');
    } else if (e.key === 'Enter' && active) {
      e.preventDefault();
      (active as HTMLAnchorElement).click();
    }
  });

  // Hide mobile suggestions on click outside
  document.addEventListener('click', (e) => {
    if (mobileSuggestEl && !mobileSuggestEl.contains(e.target as Node) && e.target !== mobileTopbarSearch) {
      mobileSuggestEl.style.display = 'none';
    }
  });

  // ─── Rotating banner ────────────────────────
  const bannerSlider = document.getElementById('banner-slider');
  if (bannerSlider) {
    const slides = bannerSlider.querySelectorAll('.nav__banner-slide');
    let currentSlide = 0;
    if (slides.length > 1) {
      setInterval(() => {
        slides[currentSlide].classList.remove('nav__banner-slide--active');
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add('nav__banner-slide--active');
      }, 4000);
    }
  }
</script>
