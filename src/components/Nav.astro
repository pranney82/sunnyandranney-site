---
interface Props {
  announcements?: Array<{ text: string; link?: string; type: string }>;
}

const { announcements = [] } = Astro.props;
const currentPath = Astro.url.pathname;

const categories = [
  { href: '/shop?sort=newest', label: 'New Arrivals', highlight: false },
  { href: '/shop?category=furniture', label: 'Furniture', highlight: false },
  { href: '/shop?category=decor', label: 'Decor', highlight: false },
  { href: '/shop?category=lighting', label: 'Lighting', highlight: false },
  { href: '/shop?category=gifts', label: 'Gifts', highlight: false },
  { href: '/shop?category=kitchenware', label: 'Kitchenware', highlight: false },
  { href: '/shop?sale=true', label: 'Sale', highlight: true },
];

// Default slides + any admin-configured announcements
const defaultSlides = [
  { html: '100% of profits support <strong>Sunshine on a Ranney Day</strong> — home makeovers for kids with special needs' },
  { html: 'LOCAL PICKUP ONLY — <a href="/shop" class="nav__banner-link">Shop Now</a>' },
  { html: 'Visit our Roswell showroom — Tue–Sat, 10am–6pm' },
];
const adminSlides = announcements.map(a =>
  ({ html: a.link ? `${a.text} — <a href="${a.link}" class="nav__banner-link">Learn More</a>` : a.text })
);
const allSlides = [...adminSlides, ...defaultSlides];
---

<header class="nav" id="main-nav" transition:persist="main-nav" transition:animate="none">
  <!-- Top banner -->
  <div class="nav__banner" role="status" aria-live="polite">
    <div class="container nav__banner-inner">
      <div class="nav__banner-slider" id="banner-slider">
        {allSlides.map((slide, i) => (
          <span class:list={['nav__banner-slide', { 'nav__banner-slide--active': i === 0 }]} set:html={slide.html} />
        ))}
      </div>
    </div>
  </div>

  <!-- Mobile header: logo + cart -->
  <div class="nav__mobile-header">
    <a href="/" class="nav__logo" aria-label="Sunny & Ranney Home">
      <img
        src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/logo-tagline-light-bg/w=160,h=64,fit=scale-down,format=auto"
        alt="Sunny & Ranney"
        class="nav__logo-img"
        width="160"
        height="64"
        fetchpriority="high"
        decoding="async"
      />
    </a>
    <div class="nav__mobile-actions">
      <button class="nav__icon-btn nav__search-toggle" aria-label="Search products" id="mobile-search-toggle">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <button class="nav__icon-btn nav__cart" aria-label="Shopping cart" id="mobile-cart-trigger">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="nav__cart-count" id="mobile-cart-count" style="display:none;">0</span>
      </button>
    </div>
  </div>

  <!-- Mobile search bar -->
  <div class="nav__mobile-topbar">
    <div class="nav__mobile-search-wrap">
      <div class="nav__mobile-topbar-inner">
        <svg class="nav__mobile-topbar-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <label for="mobile-topbar-search" class="sr-only">Search products</label>
        <input
          type="search"
          id="mobile-topbar-search"
          placeholder="Search furniture, decor, lighting, gifts..."
          autocomplete="off"
          role="combobox"
          aria-expanded="false"
          aria-controls="mobile-search-suggest"
          aria-autocomplete="list"
        />
      </div>
      <div class="search-suggest search-suggest--mobile" id="mobile-search-suggest" role="listbox" aria-label="Search suggestions" style="display:none;"></div>
    </div>
  </div>

  <!-- Desktop nav row -->
  <div class="nav__main">
    <div class="container nav__main-inner">
      <a href="/" class="nav__logo" aria-label="Sunny & Ranney Home">
        <img
          src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/logo-tagline-light-bg/w=500,h=200,fit=scale-down,format=auto"
          alt="Sunny & Ranney"
          class="nav__logo-img"
          width="500"
          height="200"
          decoding="async"
        />
      </a>

      <!-- Search bar -->
      <div class="nav__search-bar" id="nav-search-bar">
        <svg class="nav__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <label for="nav-search-input" class="sr-only">Search products</label>
        <input
          type="search"
          id="nav-search-input"
          placeholder="Search furniture, decor, lighting, gifts..."
          autocomplete="off"
          role="combobox"
          aria-expanded="false"
          aria-controls="search-suggest"
          aria-autocomplete="list"
        />
        <button class="nav__search-submit" id="nav-search-submit" aria-label="Search">
          Search
        </button>
        <div class="search-suggest" id="search-suggest" role="listbox" aria-label="Search suggestions" style="display:none;"></div>
      </div>

      <div class="nav__actions">
        <button class="nav__icon-btn nav__cart" aria-label="Shopping cart" id="cart-trigger">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span class="nav__cart-count" id="cart-count" style="display:none;">0</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Category bar -->
  <nav class="nav__categories" aria-label="Product categories">
    <div class="container nav__categories-inner">
      <a href="/shop" data-astro-prefetch class:list={['nav__cat-link', { 'nav__cat-link--active': currentPath === '/shop' || currentPath === '/shop/' }]}>
        All Products
      </a>
      {categories.map((cat) => (
        <a href={cat.href} data-astro-prefetch class:list={['nav__cat-link', { 'nav__cat-link--sale': cat.highlight }]}>{cat.label}</a>
      ))}
      <span class="nav__cat-divider" role="separator"></span>
      <a href="/about" data-astro-prefetch class:list={['nav__cat-link', { 'nav__cat-link--active': currentPath === '/about' || currentPath === '/about/' || currentPath === '/about' || currentPath === '/about/' }]}>About Us</a>
    </div>
  </nav>
</header>

<style>
  /* ─── Screen-reader only ────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── Banner ───────────────────────────── */
  .nav__banner {
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-size: 0.72rem;
    text-align: center;
    padding: 0.4rem 0;
    letter-spacing: 0.02em;
  }

  .nav__banner strong { color: var(--color-gold); }

  .nav__banner-link {
    color: var(--color-gold);
    text-decoration: underline;
  }

  /* Smooth banner collapse on scroll — no position:absolute jump */
  .nav__banner {
    transition: max-height 0.3s ease, padding 0.3s ease, opacity 0.2s ease;
    max-height: 40px;
    overflow: hidden;
  }
  .nav--scrolled .nav__banner {
    max-height: 0;
    padding: 0;
    opacity: 0;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .nav__banner {
      font-size: 0.82rem;
      padding: 0.5rem 0;
    }
  }

  .nav__banner-slider { position: relative; height: 1.3em; overflow: hidden; }

  .nav__banner-slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.5s, transform 0.5s;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .nav__banner { font-size: 0.6rem; }
    .nav__banner-slider { height: 2.4em; }
    .nav__banner-slide {
      white-space: normal;
      text-align: center;
      line-height: 1.2;
      padding: 0 0.25rem;
    }
  }

  .nav__banner-slide--active {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Main Nav ─────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-cream);
    transition: box-shadow 0.3s ease;
  }

  .nav--scrolled {
    box-shadow: 0 2px 20px rgba(44, 44, 44, 0.06);
  }

  /* ─── Mobile Header (logo + cart) ──────── */
  .nav__mobile-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px;
    height: 48px;
    border-bottom: 1px solid var(--color-cream-dark);
  }

  .nav__mobile-header .nav__logo-img {
    height: 32px;
    width: auto;
  }

  .nav__mobile-actions {
    display: flex;
    align-items: center;
    gap: 0;
  }

  /* 44px minimum touch target for mobile icons */
  .nav__mobile-header .nav__cart,
  .nav__mobile-header .nav__search-toggle {
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav__search-toggle {
    color: var(--color-charcoal);
    transition: color 0.2s;
  }
  .nav__search-toggle:hover { color: var(--color-gold); }

  @media (min-width: 768px) {
    .nav__mobile-header { display: none; }
  }

  /* ─── Mobile Search Bar ──────────────────── */
  .nav__mobile-topbar {
    display: block;
    background: var(--color-cream);
    transition: max-height 0.25s ease, padding 0.25s ease, opacity 0.25s ease;
    will-change: opacity, max-height;
    /* Hidden by default — revealed when user taps search icon */
    max-height: 0;
    padding: 0 12px;
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Hide search (scroll down or default) */
  .nav__mobile-topbar.is-hidden {
    max-height: 0;
    padding: 0 12px;
    opacity: 0;
    pointer-events: none;
  }

  /* Show when user taps search icon */
  .nav__mobile-topbar.is-forced-open {
    max-height: 60px;
    padding: 6px 12px;
    opacity: 1;
    pointer-events: auto;
  }

  .nav__mobile-topbar-inner {
    display: flex;
    align-items: center;
    background: var(--color-warm-white);
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 100px;
    padding: 0 14px;
    height: 38px;
    gap: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .nav__mobile-topbar-inner:focus-within {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(255, 212, 0, 0.1);
  }

  .nav__mobile-topbar-icon {
    color: var(--color-stone);
    flex-shrink: 0;
  }

  .nav__mobile-topbar-inner input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-charcoal);
    padding: 0;
  }

  .nav__mobile-topbar-inner input::placeholder {
    color: var(--color-stone);
  }

  .nav__mobile-search-wrap {
    position: relative;
  }

  .search-suggest--mobile {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 4px;
    border-radius: 8px;
    z-index: 60;
  }

  @media (min-width: 768px) {
    .nav__mobile-topbar { display: none; }
  }

  /* ─── Desktop Nav Row ───────────────────── */
  .nav__main {
    border-bottom: 1px solid var(--color-cream-dark);
    display: none;
  }

  @media (min-width: 768px) {
    .nav__main { display: block; }
  }

  .nav__main-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 1.5rem;
  }

  .nav__logo-img {
    height: 44px;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
    aspect-ratio: 5 / 2;
  }

  @media (min-width: 768px) {
    .nav__main { border-bottom: none; }
    .nav__main-inner { height: 72px; }
    .nav__logo-img { height: 52px; }
  }

  /* ─── Search Bar (desktop) ─────────────── */
  .nav__search-bar {
    flex: 1;
    max-width: 560px;
    display: flex;
    align-items: center;
    background: var(--color-warm-white);
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 6px;
    padding: 0 0 0 0.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
    position: relative;
  }

  .nav__search-bar:focus-within {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(255, 212, 0, 0.1);
  }

  @media (min-width: 768px) {
    .nav__search-bar {
      max-width: 480px;
      border-radius: 100px;
      background: var(--color-cream);
      border-color: var(--color-cream-dark);
    }
    .nav__search-submit {
      border-radius: 0 100px 100px 0;
    }
  }

  .nav__search-icon {
    color: var(--color-stone);
    flex-shrink: 0;
  }

  .nav__search-bar input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-charcoal);
    padding: 0.55rem 0.6rem;
  }

  .nav__search-bar input::placeholder { color: var(--color-stone); }

  .nav__search-submit {
    padding: 0.55rem 1.25rem;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .nav__search-submit:hover { background: var(--color-gold-light); }

  /* ─── Search Suggestions ────────────────── */
  .search-suggest {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-warm-white);
    border: 1px solid var(--color-cream-dark);
    border-top: none;
    border-radius: 0 0 6px 6px;
    box-shadow: 0 8px 24px rgba(44, 44, 44, 0.1);
    z-index: 50;
    max-height: 360px;
    overflow-y: auto;
  }

  .search-suggest__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    text-decoration: none;
    color: var(--color-charcoal);
    transition: background 0.15s;
  }

  .search-suggest__item:hover,
  .search-suggest__item[aria-selected="true"] {
    background: var(--color-cream-dark);
  }

  .search-suggest__img {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-cream-dark);
    flex-shrink: 0;
  }

  .search-suggest__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-suggest__info {
    flex: 1;
    min-width: 0;
  }

  .search-suggest__title {
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  .search-suggest__price {
    font-size: 0.75rem;
    color: var(--color-slate);
  }

  .search-suggest__all {
    display: block;
    padding: 0.6rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-gold);
    text-align: center;
    border-top: 1px solid var(--color-cream-dark);
    transition: background 0.15s;
  }

  .search-suggest__all:hover {
    background: var(--color-cream-dark);
    color: var(--color-charcoal);
  }

  /* ─── Actions ──────────────────────────── */
  .nav__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .nav__icon-btn {
    padding: 0.5rem;
    color: var(--color-charcoal);
    transition: color 0.3s;
    position: relative;
  }
  .nav__icon-btn:hover { color: var(--color-gold); }

  .nav__cart { position: relative; padding: 0.5rem; color: var(--color-charcoal); transition: color 0.3s; }
  .nav__cart:hover { color: var(--color-gold); }

  .nav__cart-count {
    position: absolute;
    top: 0;
    right: -2px;
    width: 18px;
    height: 18px;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Category Bar ─────────────────────── */
  .nav__categories {
    border-bottom: 1px solid var(--color-cream-dark);
    display: block;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .nav__categories::-webkit-scrollbar { display: none; }

  .nav__categories-inner {
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .nav__categories {
      padding: 0 4px;
    }
    /* Hide nav categories on shop page — shop has its own filter pills */
    .nav--shop-active .nav__categories {
      display: none;
    }
  }

  .nav__cat-link {
    padding: 0.6rem 1.25rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-slate);
    transition: color 0.2s, background 0.2s;
    flex-shrink: 0;
    border-bottom: 2px solid transparent;
  }

  @media (max-width: 767px) {
    .nav__cat-link {
      padding: 0.75rem 0.85rem;
      font-size: 0.7rem;
      min-height: 44px;
      display: flex;
      align-items: center;
    }
  }

  .nav__cat-link:hover {
    color: var(--color-charcoal);
    background: var(--color-cream-dark);
  }

  .nav__cat-link--active {
    color: var(--color-charcoal);
    border-bottom-color: var(--color-gold);
  }

  .nav__cat-link--sale {
    color: var(--color-cyan);
    font-weight: 600;
  }

  .nav__cat-link--sale:hover {
    color: var(--color-charcoal);
    background: rgba(75, 149, 180, 0.08);
  }

  .nav__cat-divider {
    width: 1px;
    height: 16px;
    background: var(--color-cream-dark);
    flex-shrink: 0;
    margin: 0 0.25rem;
  }
</style>

<script>
  // ─── Dynamic nav height → CSS variable (drives main margin-top) ─────
  const nav = document.getElementById('main-nav');
  if (nav) {
    const syncHeight = () => {
      const h = nav.getBoundingClientRect().height;
      document.documentElement.style.setProperty('--nav-height', `${h}px`);
    };
    new ResizeObserver(syncHeight).observe(nav);
    syncHeight();
  }

  // ─── Scroll behavior ────────────────────────────────────────
  const mobileSearch = nav?.querySelector('.nav__mobile-topbar') as HTMLElement;
  let lastScrollY = 0;
  let scrollTicking = false;

  window.addEventListener('scroll', () => {
    if (!scrollTicking) {
      scrollTicking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        nav?.classList.toggle('nav--scrolled', y > 20);

        // Auto-close search bar on scroll down when user opened it
        if (mobileSearch?.classList.contains('is-forced-open') && y > 60 && y > lastScrollY) {
          mobileSearch.classList.remove('is-forced-open');
          mobileSearch.classList.add('is-hidden');
        }
        lastScrollY = y;
        scrollTicking = false;
      });
    }
  }, { passive: true });

  // ─── Mobile search toggle — tap icon to reveal/hide search ────────────
  const searchToggle = document.getElementById('mobile-search-toggle');
  const mobileSearchInput = document.getElementById('mobile-topbar-search') as HTMLInputElement;

  searchToggle?.addEventListener('click', () => {
    if (!mobileSearch) return;
    const isOpen = mobileSearch.classList.contains('is-forced-open');
    if (isOpen) {
      mobileSearch.classList.remove('is-forced-open');
      mobileSearch.classList.add('is-hidden');
    } else {
      mobileSearch.classList.remove('is-hidden');
      mobileSearch.classList.add('is-forced-open');
      setTimeout(() => mobileSearchInput?.focus(), 260);
    }
  });

  // Close search bar when input loses focus and user has scrolled
  mobileSearchInput?.addEventListener('blur', () => {
    setTimeout(() => {
      if (mobileSearch && window.scrollY > 60) {
        mobileSearch.classList.remove('is-forced-open');
      }
    }, 300);
  });

  // ─── Cart buttons (no inline onclick) ────────────
  document.getElementById('cart-trigger')?.addEventListener('click', () => window.openCart?.());
  document.getElementById('mobile-cart-trigger')?.addEventListener('click', () => window.openCart?.());

  // ─── Search submit ──────────────────────────────
  function doSearch(input: HTMLInputElement) {
    const q = input.value.trim();
    if (q) window.location.href = `/shop?q=${encodeURIComponent(q)}`;
  }

  const searchInput = document.getElementById('nav-search-input') as HTMLInputElement;
  const searchSubmit = document.getElementById('nav-search-submit');
  const mobileTopbarSearch = document.getElementById('mobile-topbar-search') as HTMLInputElement;

  searchInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(searchInput); });
  searchSubmit?.addEventListener('click', () => { if (searchInput) doSearch(searchInput); });
  mobileTopbarSearch?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(mobileTopbarSearch); });

  // ─── Shared typeahead engine ────────────────────
  type Product = { title: string; handle: string; price: string; image: string; type: string };
  let productIndex: Product[] | null = null;
  const SEARCH_CACHE_KEY = 'sr_search_idx';
  const SEARCH_CACHE_TTL = 5 * 60 * 1000; // 5 minutes

  async function loadProductIndex(): Promise<Product[]> {
    if (productIndex) return productIndex;

    // Check sessionStorage cache first (survives View Transitions)
    try {
      const cached = sessionStorage.getItem(SEARCH_CACHE_KEY);
      if (cached) {
        const { data, ts } = JSON.parse(cached);
        if (Date.now() - ts < SEARCH_CACHE_TTL) {
          productIndex = data;
          return productIndex!;
        }
      }
    } catch { /* sessionStorage unavailable */ }

    try {
      const domain = (window as any).__SHOPIFY_DOMAIN || 'sunnyandranney.myshopify.com';
      const token = (window as any).__SHOPIFY_TOKEN || '';
      if (!token) return [];
      const res = await fetch(`https://${domain}/api/2025-01/graphql.json`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Shopify-Storefront-Access-Token': token,
        },
        body: JSON.stringify({
          query: `{ products(first: 50, sortKey: BEST_SELLING) { edges { node { title handle productType priceRange { minVariantPrice { amount } } images(first: 1) { edges { node { url } } } } } } }`
        }),
      });
      const json = await res.json();
      productIndex = (json.data?.products?.edges || []).map((e: any) => ({
        title: e.node.title,
        handle: e.node.handle,
        price: e.node.priceRange.minVariantPrice.amount,
        image: e.node.images.edges[0]?.node?.url || '',
        type: (e.node.productType || '').toLowerCase(),
      }));

      // Cache in sessionStorage
      try {
        sessionStorage.setItem(SEARCH_CACHE_KEY, JSON.stringify({ data: productIndex, ts: Date.now() }));
      } catch { /* quota exceeded — fine, just skip */ }

      return productIndex!;
    } catch {
      return [];
    }
  }

  function renderSuggestions(suggestEl: HTMLElement, query: string, items: Product[]) {
    const q = query.toLowerCase();
    const matches = items.filter(p =>
      p.title.toLowerCase().includes(q) || p.type.includes(q)
    ).slice(0, 5);

    if (matches.length === 0) {
      suggestEl.style.display = 'none';
      return;
    }

    const frag = document.createDocumentFragment();
    matches.forEach((p) => {
      const link = document.createElement('a');
      link.href = `/shop/${p.handle}`;
      link.className = 'search-suggest__item';
      link.setAttribute('role', 'option');

      if (p.image) {
        const imgWrap = document.createElement('div');
        imgWrap.className = 'search-suggest__img';
        const img = document.createElement('img');
        img.src = p.image.includes('cdn.shopify.com') ? `${p.image}?width=80` : p.image;
        img.alt = p.title;
        img.loading = 'lazy';
        imgWrap.appendChild(img);
        link.appendChild(imgWrap);
      }

      const info = document.createElement('div');
      info.className = 'search-suggest__info';
      const title = document.createElement('span');
      title.className = 'search-suggest__title';
      title.textContent = p.title;
      info.appendChild(title);
      const price = document.createElement('span');
      price.className = 'search-suggest__price';
      price.textContent = `$${parseFloat(p.price).toFixed(2)}`;
      info.appendChild(price);
      link.appendChild(info);
      frag.appendChild(link);
    });

    const allLink = document.createElement('a');
    allLink.href = `/shop?q=${encodeURIComponent(query)}`;
    allLink.className = 'search-suggest__all';
    allLink.textContent = `View all results for "${query}"`;
    frag.appendChild(allLink);

    suggestEl.replaceChildren(frag);
    suggestEl.style.display = 'block';
  }

  function setupTypeahead(input: HTMLInputElement, suggestEl: HTMLElement) {
    let timer: ReturnType<typeof setTimeout>;

    input.addEventListener('input', () => {
      const q = input.value.trim();
      clearTimeout(timer);
      if (!q || q.length < 2) {
        suggestEl.style.display = 'none';
        input.setAttribute('aria-expanded', 'false');
        return;
      }
      timer = setTimeout(async () => {
        const items = await loadProductIndex();
        renderSuggestions(suggestEl, q, items);
        input.setAttribute('aria-expanded', suggestEl.style.display !== 'none' ? 'true' : 'false');
      }, 300);
    });

    // Keyboard navigation
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        suggestEl.style.display = 'none';
        input.setAttribute('aria-expanded', 'false');
        return;
      }
      if (suggestEl.style.display === 'none') return;
      const items = suggestEl.querySelectorAll('.search-suggest__item');
      if (!items.length) return;
      const active = suggestEl.querySelector('[aria-selected="true"]') as HTMLElement;
      let idx = active ? Array.from(items).indexOf(active) : -1;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (active) active.removeAttribute('aria-selected');
        idx = (idx + 1) % items.length;
        items[idx].setAttribute('aria-selected', 'true');
        (items[idx] as HTMLElement).scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (active) active.removeAttribute('aria-selected');
        idx = idx <= 0 ? items.length - 1 : idx - 1;
        items[idx].setAttribute('aria-selected', 'true');
        (items[idx] as HTMLElement).scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'Enter' && active) {
        e.preventDefault();
        (active as HTMLAnchorElement).click();
      }
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!suggestEl.contains(e.target as Node) && e.target !== input) {
        suggestEl.style.display = 'none';
        input.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // Wire up both search bars with shared logic
  const suggestEl = document.getElementById('search-suggest');
  const mobileSuggestEl = document.getElementById('mobile-search-suggest');
  if (searchInput && suggestEl) setupTypeahead(searchInput, suggestEl);
  if (mobileTopbarSearch && mobileSuggestEl) setupTypeahead(mobileTopbarSearch, mobileSuggestEl);

  // ─── Rotating banner (with cleanup for persist) ────
  let bannerInterval: ReturnType<typeof setInterval> | undefined;

  function startBanner() {
    if (bannerInterval) clearInterval(bannerInterval);
    const bannerSlider = document.getElementById('banner-slider');
    if (!bannerSlider) return;
    const slides = bannerSlider.querySelectorAll('.nav__banner-slide');
    let currentSlide = 0;
    if (slides.length > 1) {
      bannerInterval = setInterval(() => {
        slides[currentSlide].classList.remove('nav__banner-slide--active');
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add('nav__banner-slide--active');
      }, 4000);
    }
  }
  // Defer banner start — not critical for first paint
  const scheduleIdle = window.requestIdleCallback || ((cb: () => void) => setTimeout(cb, 200));
  scheduleIdle(startBanner);

  // ─── Sync mobile cart badge ────────────────────
  function syncMobileCartBadge() {
    const headerCount = document.getElementById('cart-count');
    const mobileCount = document.getElementById('mobile-cart-count');
    if (!headerCount || !mobileCount) return;

    const update = () => {
      const count = headerCount.textContent || '0';
      const visible = headerCount.style.display !== 'none';
      mobileCount.textContent = count;
      mobileCount.style.display = visible ? 'flex' : 'none';
    };

    new MutationObserver(update).observe(headerCount, {
      childList: true,
      attributes: true,
      attributeFilter: ['style'],
    });

    update();
  }

  scheduleIdle(syncMobileCartBadge);
  document.addEventListener('astro:after-swap', syncMobileCartBadge);

  // ─── Update active tab on client after persist ────
  function updateActiveTab() {
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    const search = window.location.search;
    const links = document.querySelectorAll('.nav__cat-link');

    links.forEach((link) => {
      const href = link.getAttribute('href') || '';
      const [linkPath, linkSearch] = href.split('?');
      const normalizedLinkPath = linkPath.replace(/\/$/, '') || '/';

      let isActive = false;
      if (linkSearch) {
        isActive = normalizedLinkPath === path && search.includes(linkSearch);
      } else {
        isActive = normalizedLinkPath === path && !search;
      }

      link.classList.toggle('nav__cat-link--active', isActive);
    });
  }

  updateActiveTab();
  document.addEventListener('astro:after-swap', updateActiveTab);

  // ─── Auto-scroll active category into view on mobile ────
  function scrollActiveTabIntoView() {
    const activeLink = document.querySelector('.nav__cat-link--active') as HTMLElement;
    if (!activeLink) return;
    const container = activeLink.closest('.nav__categories') as HTMLElement;
    if (!container) return;
    // Center the active tab in the scrollable area
    const scrollLeft = activeLink.offsetLeft - (container.clientWidth / 2) + (activeLink.offsetWidth / 2);
    container.scrollTo({ left: Math.max(0, scrollLeft), behavior: 'smooth' });
  }

  // Run after initial load and after navigation
  requestAnimationFrame(scrollActiveTabIntoView);
  document.addEventListener('astro:after-swap', () => requestAnimationFrame(scrollActiveTabIntoView));
</script>
