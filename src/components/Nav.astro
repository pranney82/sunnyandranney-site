---
const currentPath = Astro.url.pathname;

const categories = [
  { href: '/shop?category=furniture', label: 'Furniture' },
  { href: '/shop?category=decor', label: 'Decor' },
  { href: '/shop?category=lighting', label: 'Lighting' },
  { href: '/shop?category=gifts', label: 'Gifts' },
  { href: '/shop?category=kitchenware', label: 'Kitchenware' },
];
---

<header class="nav" id="main-nav">
  <!-- Top banner -->
  <div class="nav__banner">
    <div class="container nav__banner-inner">
      <span>☀️ 100% of profits support <strong>Sunshine on a Ranney Day</strong> — home makeovers for kids with special needs</span>
    </div>
  </div>

  <!-- Mobile search bar (always visible, Wayfair-style) -->
  <div class="nav__mobile-topbar">
    <div class="nav__mobile-topbar-inner">
      <svg class="nav__mobile-topbar-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" id="mobile-topbar-search" placeholder="Search Sunny & Ranney" autocomplete="off" />
    </div>
  </div>

  <!-- Desktop nav row -->
  <div class="nav__main">
    <div class="container nav__main-inner">
      <a href="/" class="nav__logo" aria-label="Sunny & Ranney Home">
        <img src="/images/logos/logo-light-bg.png" alt="Sunny & Ranney" class="nav__logo-img" />
      </a>

      <!-- Search bar — prominent, center (desktop) -->
      <div class="nav__search-bar" id="nav-search-bar">
        <svg class="nav__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="nav-search-input" placeholder="Search furniture, decor, lighting, gifts..." autocomplete="off" />
        <button class="nav__search-submit" id="nav-search-submit" aria-label="Search">
          Search
        </button>
      </div>

      <div class="nav__actions">
        <!-- Cart (desktop only — mobile uses bottom nav) -->
        <button class="nav__icon-btn nav__cart" aria-label="Shopping cart" id="cart-trigger" onclick="window.openCart?.()">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span class="nav__cart-count" id="cart-count" style="display:none;">0</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Category bar (desktop) -->
  <div class="nav__categories">
    <div class="container nav__categories-inner">
      <a href="/shop" class:list={['nav__cat-link', { 'nav__cat-link--active': currentPath === '/shop' || currentPath === '/shop/' }]}>
        All Products
      </a>
      {categories.map((cat) => (
        <a href={cat.href} class="nav__cat-link">{cat.label}</a>
      ))}
    </div>
  </div>
</header>

<style>
  /* ─── Banner ───────────────────────────── */
  .nav__banner {
    background: var(--color-charcoal);
    color: var(--color-cream);
    font-size: 0.72rem;
    text-align: center;
    padding: 0.4rem 0;
    letter-spacing: 0.02em;
  }

  .nav__banner strong { color: var(--color-gold); }

  /* ─── Main Nav ─────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-cream);
    transition: box-shadow 0.3s ease;
  }

  .nav--scrolled {
    box-shadow: 0 2px 20px rgba(44, 44, 44, 0.06);
  }

  /* ─── Mobile Top Search Bar ─────────────── */
  .nav__mobile-topbar {
    display: block;
    padding: 8px 12px;
    background: var(--color-charcoal);
  }

  .nav__mobile-topbar-inner {
    display: flex;
    align-items: center;
    background: var(--color-warm-white);
    border-radius: 28px;
    padding: 0 14px;
    height: 40px;
    gap: 8px;
  }

  .nav__mobile-topbar-icon {
    color: var(--color-stone);
    flex-shrink: 0;
  }

  .nav__mobile-topbar-inner input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-charcoal);
    padding: 0;
  }

  .nav__mobile-topbar-inner input::placeholder {
    color: var(--color-stone);
  }

  @media (min-width: 768px) {
    .nav__mobile-topbar { display: none; }
  }

  /* ─── Desktop Nav Row ───────────────────── */
  .nav__main {
    border-bottom: 1px solid var(--color-cream-dark);
    display: none;
  }

  @media (min-width: 768px) {
    .nav__main { display: block; }
  }

  .nav__main-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 1.5rem;
  }

  .nav__logo-img {
    height: 36px;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* ─── Search Bar (desktop) ─────────────── */
  .nav__search-bar {
    flex: 1;
    max-width: 560px;
    display: flex;
    align-items: center;
    background: var(--color-warm-white);
    border: 1.5px solid var(--color-cream-dark);
    border-radius: 6px;
    padding: 0 0 0 0.75rem;
    transition: border-color 0.2s;
    overflow: hidden;
  }

  .nav__search-bar:focus-within {
    border-color: var(--color-gold);
  }

  .nav__search-icon {
    color: var(--color-stone);
    flex-shrink: 0;
  }

  .nav__search-bar input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-charcoal);
    padding: 0.55rem 0.6rem;
  }

  .nav__search-bar input::placeholder { color: var(--color-stone); }

  .nav__search-submit {
    padding: 0.55rem 1.25rem;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .nav__search-submit:hover { background: var(--color-gold-light); }

  /* ─── Actions ──────────────────────────── */
  .nav__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .nav__icon-btn {
    padding: 0.5rem;
    color: var(--color-charcoal);
    transition: color 0.3s;
    position: relative;
  }
  .nav__icon-btn:hover { color: var(--color-gold); }

  .nav__cart { position: relative; padding: 0.5rem; color: var(--color-charcoal); transition: color 0.3s; }
  .nav__cart:hover { color: var(--color-gold); }

  .nav__cart-count {
    position: absolute;
    top: 0;
    right: -2px;
    width: 18px;
    height: 18px;
    background: var(--color-gold);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Category Bar ─────────────────────── */
  .nav__categories {
    border-bottom: 1px solid var(--color-cream-dark);
    display: none;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav__categories::-webkit-scrollbar { display: none; }

  @media (min-width: 768px) {
    .nav__categories { display: block; }
  }

  .nav__categories-inner {
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
  }

  .nav__cat-link {
    padding: 0.6rem 1.25rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-slate);
    transition: color 0.2s, background 0.2s;
    flex-shrink: 0;
  }

  .nav__cat-link:hover {
    color: var(--color-charcoal);
    background: var(--color-cream-dark);
  }

  .nav__cat-link--active {
    color: var(--color-charcoal);
    border-bottom: 2px solid var(--color-gold);
  }
</style>

<script>
  // Scroll behavior
  const nav = document.getElementById('main-nav');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('nav--scrolled');
    } else {
      nav?.classList.remove('nav--scrolled');
    }
  }, { passive: true });

  // Desktop search
  const searchInput = document.getElementById('nav-search-input') as HTMLInputElement;
  const searchSubmit = document.getElementById('nav-search-submit');

  function doSearch(input: HTMLInputElement) {
    const q = input.value.trim();
    if (q) {
      window.location.href = `/shop?q=${encodeURIComponent(q)}`;
    }
  }

  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doSearch(searchInput);
  });
  searchSubmit?.addEventListener('click', () => { if (searchInput) doSearch(searchInput); });

  // Mobile top search bar
  const mobileTopbarSearch = document.getElementById('mobile-topbar-search') as HTMLInputElement;
  mobileTopbarSearch?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doSearch(mobileTopbarSearch);
  });
</script>
