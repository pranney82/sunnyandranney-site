# Shopify Storefront API
# Get these from Shopify Admin > Settings > Apps > Develop apps > Create an app
# Give it Storefront API access, then copy the token
PUBLIC_SHOPIFY_STORE_DOMAIN=sunnyandranney.myshopify.com
PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token_here

# SOARD Stats API — JSON endpoint from the Sunshine on a Ranney Day site
# Used to pull live impact stats (room makeovers, children served, etc.)
SOARD_STATS_URL=https://your-soard-site.pages.dev/api/stats.json

# Google Maps JavaScript API
# Get from Google Cloud Console > APIs & Services > Credentials
# Restrict to: sunnyandranney.com/* and localhost:*
PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here
